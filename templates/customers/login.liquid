{{ 'accounts.css' | asset_url | stylesheet_tag }}

<div class="account-page">

  <div class="account-hero">
    <p class="account-hero__kicker">My Account</p>
    <h1 class="account-hero__heading">Welcome back</h1>
    <p class="account-hero__subhead">Sign in to view your orders, saved addresses, and account details.</p>
  </div>

  <div class="account-wrap account-wrap--narrow">

    {%- comment -%} ── Login panel ── {%- endcomment -%}
    <div class="account-card account-login-panel" id="login-panel">

      {%- form 'customer_login' -%}
        {%- if form.errors -%}
          <div class="account-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="account-form">

          <div class="account-field">
            <label for="CustomerEmail">Email address</label>
            <input
              type="email"
              name="customer[email]"
              id="CustomerEmail"
              autocomplete="email"
              autocapitalize="off"
              autocorrect="off"
              required
              {% if form.errors contains 'form' %}aria-invalid="true"{% endif %}
            >
          </div>

          <div class="account-field">
            <label for="CustomerPassword">
              Password
              <button
                type="button"
                class="account-form__link"
                style="float:right;border:none;background:none;cursor:pointer;padding:0;font-size:13px;color:#6e6e73"
                id="forgot-password-btn"
                aria-controls="recover-panel"
                aria-expanded="false"
              >Forgot password?</button>
            </label>
            <input
              type="password"
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
              required
            >
          </div>

          <div class="account-form__actions">
            <button type="submit" class="btn btn--primary btn--block">Sign in</button>
          </div>

        </div>
      {%- endform -%}

      <p class="account-form__link" style="margin-top:1.25rem">
        New to EZQuest? <a href="{{ routes.account_register_url }}">Create an account</a>
      </p>

    </div>

    {%- comment -%} ── Recover password panel ── {%- endcomment -%}
    <div class="account-card account-recover" id="recover-panel" aria-hidden="true">

      <h2 style="font-size:17px;font-weight:600;margin:0 0 0.25rem">Reset your password</h2>
      <p style="font-size:14px;color:#6e6e73;margin:0 0 1.5rem">We'll send a reset link to your email address.</p>

      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <div class="account-errors" style="background:#f0fdf4;border-color:#bbf7d0;color:#166534" role="status">
            We've sent a password reset email. Check your inbox.
          </div>
        {%- elsif form.errors -%}
          <div class="account-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="account-form">
          <div class="account-field">
            <label for="RecoverEmail">Email address</label>
            <input
              type="email"
              name="email"
              id="RecoverEmail"
              autocomplete="email"
              autocapitalize="off"
              required
            >
          </div>
          <div class="account-form__actions">
            <button type="submit" class="btn btn--primary btn--block">Send reset link</button>
            <button type="button" class="btn btn--secondary btn--block" id="cancel-recover-btn">Back to sign in</button>
          </div>
        </div>
      {%- endform -%}

    </div>

  </div>
</div>

<script>
(function () {
  var loginPanel  = document.getElementById('login-panel');
  var recoverPanel = document.getElementById('recover-panel');
  var forgotBtn   = document.getElementById('forgot-password-btn');
  var cancelBtn   = document.getElementById('cancel-recover-btn');

  function showRecover() {
    loginPanel.classList.add('is-hidden');
    recoverPanel.classList.add('is-active');
    recoverPanel.setAttribute('aria-hidden', 'false');
    forgotBtn && forgotBtn.setAttribute('aria-expanded', 'true');
    var input = recoverPanel.querySelector('input[type="email"]');
    if (input) input.focus();
  }

  function showLogin() {
    recoverPanel.classList.remove('is-active');
    recoverPanel.setAttribute('aria-hidden', 'true');
    loginPanel.classList.remove('is-hidden');
    forgotBtn && forgotBtn.setAttribute('aria-expanded', 'false');
  }

  if (forgotBtn) forgotBtn.addEventListener('click', showRecover);
  if (cancelBtn) cancelBtn.addEventListener('click', showLogin);

  // Auto-show recover panel if recover form was submitted
  {%- if form.posted_successfully? -%}
  showRecover();
  {%- endif -%}
}());
</script>
