{{ 'accounts.css' | asset_url | stylesheet_tag }}

<div class="account-page">

  <div class="account-hero">
    <p class="account-hero__kicker">My Account</p>
    <h1 class="account-hero__heading">Order {{ order.name }}</h1>
  </div>

  <div class="account-wrap account-wrap--wide">

    <a href="{{ routes.account_url }}" class="account-back">
      ← Back to account
    </a>

    {%- comment -%} ── Order meta + status ── {%- endcomment -%}
    <div class="account-card">

      <div class="order-meta">
        <span>Placed <strong>{{ order.created_at | date: '%B %d, %Y' }}</strong></span>
        <span>
          Payment:
          <span class="status-badge status-badge--{{ order.financial_status }}">
            {{ order.financial_status_label }}
          </span>
        </span>
        <span>
          Fulfillment:
          <span class="status-badge status-badge--{{ order.fulfillment_status }}">
            {{ order.fulfillment_status_label }}
          </span>
        </span>
      </div>

      {%- comment -%} ── Tracking ── {%- endcomment -%}
      {%- if order.fulfillments.size > 0 -%}
        {%- for fulfillment in order.fulfillments -%}
          {%- if fulfillment.tracking_number -%}
            <div class="order-tracking">
              <div class="order-tracking__label">Tracking</div>
              {%- if fulfillment.tracking_url -%}
                <a href="{{ fulfillment.tracking_url }}" target="_blank" rel="noopener">
                  {{ fulfillment.tracking_company | default: 'Carrier' }} — {{ fulfillment.tracking_number }}
                </a>
              {%- else -%}
                {{ fulfillment.tracking_company | default: 'Carrier' }} — {{ fulfillment.tracking_number }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} ── Line items ── {%- endcomment -%}
      <ul class="order-items">
        {%- for item in order.line_items -%}
          <li class="order-item">
            {%- if item.image -%}
              <img
                src="{{ item.image | image_url: width: 160, format: 'pjpg' }}"
                alt="{{ item.image.alt | default: item.title | escape }}"
                width="72"
                height="72"
                class="order-item__image"
                loading="lazy"
              >
            {%- else -%}
              <div class="order-item__image" style="display:flex;align-items:center;justify-content:center;color:#c0c0c0">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M3 16l5-5 4 4 3-3 6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
            {%- endif -%}
            <div class="order-item__details">
              <p class="order-item__title">{{ item.title }}</p>
              {%- unless item.product.has_only_default_variant -%}
                <p class="order-item__variant">{{ item.variant.title }}</p>
              {%- endunless -%}
              {%- if item.sku != blank -%}
                <p class="order-item__variant">SKU: {{ item.sku }}</p>
              {%- endif -%}
              <p class="order-item__qty">Qty: {{ item.quantity }}</p>
            </div>
            <div class="order-item__price">{{ item.final_line_price | money }}</div>
          </li>
        {%- endfor -%}
      </ul>

      {%- comment -%} ── Totals ── {%- endcomment -%}
      <div class="order-totals">
        <div class="order-totals__row">
          <span>Subtotal</span>
          <span>{{ order.subtotal_price | money }}</span>
        </div>
        {%- if order.total_discounts > 0 -%}
          <div class="order-totals__row" style="color:#166534">
            <span>Discount</span>
            <span>−{{ order.total_discounts | money }}</span>
          </div>
        {%- endif -%}
        <div class="order-totals__row">
          <span>Shipping</span>
          <span>
            {%- if order.total_shipping_price == 0 -%}Free
            {%- else -%}{{ order.total_shipping_price | money }}
            {%- endif -%}
          </span>
        </div>
        {%- if order.tax_price > 0 -%}
          <div class="order-totals__row">
            <span>Tax</span>
            <span>{{ order.tax_price | money }}</span>
          </div>
        {%- endif -%}
        <div class="order-totals__row order-totals__row--total">
          <span>Total</span>
          <span>{{ order.total_price | money }}</span>
        </div>
      </div>

    </div>

    {%- comment -%} ── Addresses ── {%- endcomment -%}
    <div class="account-card">
      <h2 class="account-card__heading">Shipping & billing</h2>
      <div class="order-addresses">
        <div>
          <div class="order-address__label">Ships to</div>
          <div class="order-address__body">
            {%- if order.shipping_address -%}
              {{ order.shipping_address.name }}<br>
              {{ order.shipping_address.address1 }}<br>
              {%- if order.shipping_address.address2 != blank -%}{{ order.shipping_address.address2 }}<br>{%- endif -%}
              {{ order.shipping_address.city }}, {{ order.shipping_address.province_code }} {{ order.shipping_address.zip }}<br>
              {{ order.shipping_address.country }}
            {%- else -%}
              N/A
            {%- endif -%}
          </div>
        </div>
        <div>
          <div class="order-address__label">Billed to</div>
          <div class="order-address__body">
            {%- if order.billing_address -%}
              {{ order.billing_address.name }}<br>
              {{ order.billing_address.address1 }}<br>
              {%- if order.billing_address.address2 != blank -%}{{ order.billing_address.address2 }}<br>{%- endif -%}
              {{ order.billing_address.city }}, {{ order.billing_address.province_code }} {{ order.billing_address.zip }}<br>
              {{ order.billing_address.country }}
            {%- else -%}
              Same as shipping
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} ── Actions ── {%- endcomment -%}
    <div class="account-actions">
      <a href="{{ order.order_status_url }}" class="btn btn--secondary btn--sm" target="_blank" rel="noopener">
        Order status page
      </a>
      <a href="/pages/contact" class="btn btn--secondary btn--sm">
        Contact support
      </a>
      <a href="/pages/shipping-returns" class="btn btn--secondary btn--sm">
        Start a return
      </a>
    </div>

  </div>
</div>
