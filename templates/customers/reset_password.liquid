{{ 'accounts.css' | asset_url | stylesheet_tag }}

<div class="account-page">

  <div class="account-hero">
    <p class="account-hero__kicker">My Account</p>
    <h1 class="account-hero__heading">Reset your password</h1>
    <p class="account-hero__subhead">Enter a new password for your account.</p>
  </div>

  <div class="account-wrap account-wrap--narrow">
    <div class="account-card">

      {%- form 'reset_customer_password' -%}
        {%- if form.errors -%}
          <div class="account-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="account-form">

          <div class="account-field">
            <label for="Password">New password <span style="color:#6e6e73;font-weight:400">(min. 5 characters)</span></label>
            <input
              type="password"
              name="customer[password]"
              id="Password"
              autocomplete="new-password"
              minlength="5"
              required
              {% if form.errors contains 'password' %}aria-invalid="true"{% endif %}
            >
          </div>

          <div class="account-field">
            <label for="PasswordConfirm">Confirm new password</label>
            <input
              type="password"
              name="customer[password_confirmation]"
              id="PasswordConfirm"
              autocomplete="new-password"
              minlength="5"
              required
            >
          </div>

          <div class="account-form__actions">
            <button type="submit" class="btn btn--primary btn--block">Set new password</button>
          </div>

        </div>
      {%- endform -%}

    </div>
  </div>
</div>
