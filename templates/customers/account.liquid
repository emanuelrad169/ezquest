{{ 'accounts.css' | asset_url | stylesheet_tag }}

<div class="account-page">

  <div class="account-hero">
    <p class="account-hero__kicker">My Account</p>
    <h1 class="account-hero__heading">Hi, {{ customer.first_name }}</h1>
    <p class="account-hero__subhead">{{ customer.email }}</p>
  </div>

  <div class="account-wrap account-wrap--wide">

    {%- comment -%} ── Quick stats ── {%- endcomment -%}
    <div class="account-stats">
      <div class="account-stat">
        <div class="account-stat__value">{{ customer.orders_count }}</div>
        <div class="account-stat__label">Total orders</div>
      </div>
      <div class="account-stat">
        <div class="account-stat__value">{{ customer.total_spent | money_without_trailing_zeros }}</div>
        <div class="account-stat__label">Total spent</div>
      </div>
      <div class="account-stat">
        <div class="account-stat__value">{{ customer.created_at | date: '%Y' }}</div>
        <div class="account-stat__label">Member since</div>
      </div>
    </div>

    {%- comment -%} ── Recent orders ── {%- endcomment -%}
    <div class="account-card">
      <h2 class="account-card__heading">Orders</h2>

      {%- if customer.orders_count == 0 -%}
        <p style="font-size:14px;color:#6e6e73;margin:0">
          You haven't placed any orders yet.
          <a href="{{ routes.all_products_collection_url }}" style="color:#1d1d1f;font-weight:500">Browse products →</a>
        </p>
      {%- else -%}
        {%- paginate customer.orders by 10 -%}
          <table class="orders-table">
            <thead>
              <tr>
                <th>Order</th>
                <th>Date</th>
                <th>Status</th>
                <th>Total</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                {%- assign fulfillment_status = order.fulfillment_status | downcase -%}
                <tr>
                  <td data-label="Order">
                    <a href="{{ order.customer_url }}">{{ order.name }}</a>
                  </td>
                  <td data-label="Date">
                    {{ order.created_at | date: '%b %d, %Y' }}
                  </td>
                  <td data-label="Status">
                    <span class="status-badge status-badge--{{ fulfillment_status }}">
                      {{ order.fulfillment_status_label }}
                    </span>
                  </td>
                  <td data-label="Total">{{ order.total_price | money }}</td>
                  <td>
                    <a href="{{ order.customer_url }}" class="btn btn--secondary btn--sm">
                      View
                    </a>
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>

          {%- if paginate.pages > 1 -%}
            <div style="margin-top:1.5rem;text-align:center">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    </div>

    {%- comment -%} ── Saved addresses ── {%- endcomment -%}
    <div class="account-card">
      <h2 class="account-card__heading">Addresses</h2>

      {%- if customer.addresses_count == 0 -%}
        <p style="font-size:14px;color:#6e6e73;margin:0 0 1rem">No saved addresses yet.</p>
      {%- else -%}
        <div class="addresses-grid" style="margin-bottom:1.25rem">
          {%- for address in customer.addresses -%}
            <div class="address-card{% if address == customer.default_address %} address-card--default{% endif %}">
              {%- if address == customer.default_address -%}
                <div class="address-card__default-badge">Default</div>
              {%- endif -%}
              <div class="address-card__body">
                {{ address.first_name }} {{ address.last_name }}<br>
                {{ address.address1 }}<br>
                {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
                {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                {{ address.country }}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <a href="{{ routes.account_addresses_url }}" class="btn btn--secondary btn--sm">
        Manage addresses
      </a>
    </div>

    {%- comment -%} ── Account actions ── {%- endcomment -%}
    <div class="account-actions">
      <a href="{{ routes.account_logout_url }}" class="btn btn--secondary btn--sm">
        Sign out
      </a>
    </div>

  </div>
</div>
