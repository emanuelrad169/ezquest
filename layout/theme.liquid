<!doctype html>
<!-- EZQuest v1.0 | Built: 2026-04-26 | Claude Code -->
<html lang="{{ request.locale.iso_code }}" dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
  <head>
    {% # theme-check-disable RemoteAsset %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
      window.EZRoutes = {
        root: {{ routes.root_url | json }},
        cart: {{ routes.cart_url | json }},
        cartAdd: {{ routes.cart_add_url | json }},
        cartChange: {{ routes.cart_change_url | json }},
        cartUpdate: {{ routes.cart_update_url | json }},
        locale: {{ request.locale.iso_code | json }}
      };
      window.EZMoney = {
        locale: {{ request.locale.iso_code | json }},
        currency: {{ cart.currency.iso_code | default: shop.currency | json }}
      };
    </script>
    <meta name="theme-color" content="#f8f9f5">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="dns-prefetch" href="https://monorail-edge.shopifysvc.com">
    <link rel="dns-prefetch" href="https://code.tidio.co">
{% if settings.ga4_measurement_id != blank %}
      <link rel="preconnect" href="https://www.googletagmanager.com">
      <link rel="dns-prefetch" href="https://www.google-analytics.com">
    {% endif %}
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% elsif template.name == 'index' %}
      <meta name="description" content="EZQuest makes premium USB-C hubs, GaN wall chargers, and DuraGuard cables — compatible with Mac, iPad, iPhone, and Windows. Free US shipping over $35.">
    {% endif %}
    {% if request.page_type == 'blog' and current_tags %}
      <link rel="canonical" href="{{ shop.url }}{{ request.path }}">
    {% else %}
      <link rel="canonical" href="{{ canonical_url }}">
    {% endif %}
    {% if settings.favicon %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
    {% else %}
      <link rel="icon" type="image/svg+xml" href="{{ 'ezquest-logo.svg' | asset_url }}">
    {% endif %}
    <title>{% if page_title %}{{ page_title }}{% endif %}{% if current_tags %} - {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} - Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}</title>

    <!-- Open Graph -->
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:type" content="{% if template == 'product' %}product{% elsif template == 'article' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
    <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
    {% if page_image %}
      <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    {% elsif settings.share_image %}
      <meta property="og:image" content="{{ settings.share_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    {% endif %}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | default: shop.name | escape }}">
    <meta name="twitter:description" content="{{ page_description | default: shop.description | escape }}">
    {% if page_image %}
      <meta name="twitter:image" content="{{ page_image | image_url: width: 1200 }}">
    {% elsif settings.share_image %}
      <meta name="twitter:image" content="{{ settings.share_image | image_url: width: 1200 }}">
    {% endif %}

    <!-- Structured data: Organization + WebSite -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "logo": "{{ settings.share_image | image_url: width: 400 }}"
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    {% render 'breadcrumb-jsonld' %}
    {% if request.page_type == 'article' %}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": {{ article.title | json }},
        "description": {{ article.excerpt | default: article.title | strip_html | truncate: 160 | json }},
        "author": {
          "@type": "Person",
          "name": {{ article.author | json }}
        },
        "publisher": {
          "@type": "Organization",
          "name": "EZQuest",
          "url": {{ shop.url | json }}
        },
        "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
        "dateModified": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
        {% if article.image %}
        "image": "{{ article.image | image_url: width: 1200 }}",
        {% endif %}
        "url": "{{ shop.url }}{{ article.url }}"
      }
      </script>
    {% endif %}

    {% if settings.ga4_measurement_id != blank %}
      <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id }}"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', {{ settings.ga4_measurement_id | json }}, {
          page_path: window.location.pathname,
          anonymize_ip: true,
          cookie_flags: 'SameSite=None;Secure'
        });
      </script>
      <script>
        document.addEventListener('DOMContentLoaded', function() {
          {% if template.name == 'cart' or request.page_type == 'cart' %}
            gtag('event', 'view_cart', {
              currency: {{ cart.currency.iso_code | default: shop.currency | json }},
              value: {{ cart.total_price | divided_by: 100.0 | json }},
              items: [
                {%- for item in cart.items -%}
                  {
                    item_id: {{ item.variant.sku | default: item.product_id | json }},
                    item_name: {{ item.product.title | json }},
                    item_category: {{ item.product.type | json }},
                    price: {{ item.final_price | divided_by: 100.0 | json }},
                    quantity: {{ item.quantity }}
                  }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              ]
            });
          {% endif %}
        });
      </script>
    {% endif %}
    <style id="ez-critical-css">
      :root{--page-max-width:100rem;--header-height:4.5rem;--ez-amber:#FED300;--ez-black:#1d1d1f;--ez-dark:#0a0a0a;--ez-grey:#6e6e73;--ez-light:#f5f5f7;--radius-pill:9999px;--radius-lg:1.75rem;--shadow-soft:0 12px 32px rgba(15,23,42,.04);--font-base:"Inter",-apple-system,BlinkMacSystemFont,sans-serif}
      *,:before,:after{box-sizing:border-box}html{background:#fff;color:#020617;font-family:var(--font-base);-webkit-text-size-adjust:100%}body{margin:0;min-height:100vh;-webkit-font-smoothing:antialiased}img,svg,video{display:block;max-width:100%;height:auto}[hidden]{display:none!important}.page-shell{min-height:100vh;background:#fff;color:#020617}.site-main{position:relative}.container-shell{width:100%;max-width:var(--page-max-width);margin-inline:auto;padding-inline:1.25rem}.section-shell{padding-block:2.5rem;scroll-margin-top:calc(var(--header-height) + 1.25rem)}.display-heading,.section-heading{font-weight:500;color:#020617;letter-spacing:-.04em;line-height:1.02}.section-heading{font-size:clamp(1.875rem,4vw,3rem)}.section-kicker{display:inline-flex;align-items:center;gap:.75rem;font-size:.7rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:#64748b}.button-primary,.button-secondary{display:inline-flex;min-height:3.2rem;align-items:center;justify-content:center;border-radius:var(--radius-pill);padding:.75rem 1.25rem;font-weight:500;text-decoration:none}.button-primary{background:#0f172a;color:#fff}.skip-link{position:absolute;left:1rem;top:1rem;z-index:9999;transform:translateY(-6rem);border-radius:999px;background:#020617;color:#fff;padding:.6rem 1rem}.skip-link:focus{transform:translateY(0)}.home-hero,.collection-showcase,.product-hero-grid{contain:layout paint}.home-hero-media-image,.collection-showcase-image{width:100%;height:100%;object-fit:cover}.product-buybox{background:#fff;border:1px solid rgba(226,232,240,.9);border-radius:var(--radius-lg);box-shadow:var(--shadow-soft)}
      @media (min-width:640px){.container-shell{padding-inline:1.5rem}}@media (min-width:1024px){.container-shell{padding-inline:2rem}.section-shell{padding-block:4rem}}
    </style>
    <style id="tidio-cls-fix">#tidio-chat-root,#tidio-chat-code{display:none!important}</style>
    {%- if settings.hide_chat_widget -%}
      <style>#tidio-chat-root,#tidio-chat-code,#tidio-chat,iframe[id*="tidio"]{display:none!important;visibility:hidden!important}</style>
    {%- endif -%}
    {%- comment -%}v2026-04-29-newsletter-popup{%- endcomment -%}
    {{ content_for_header }}
    <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ 'theme.css' | asset_url }}"></noscript>
    {% if request.path contains '/policies/' %}
      <link rel="stylesheet" href="{{ 'policy-page.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="{{ 'policy-page.css' | asset_url }}"></noscript>
      <script src="{{ 'policy-page.js' | asset_url }}" defer="defer"></script>
    {% endif %}
    {%- assign analytics_src = 'analytics.js' | asset_url | split: '?' | first -%}
    <script src="{{ analytics_src }}?ezv=20260428" defer="defer"></script>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'component-accordion.js' | asset_url }}" defer="defer"></script>
    {% # theme-check-enable RemoteAsset %}
  </head>
  <body class="page-shell template-{{ template | split: '.' | first | handle }}{% if request.design_mode %} design-mode{% endif %}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>
    {% sections 'header-group' %}
    <main id="MainContent" class="site-main" role="main">
      {{ content_for_layout }}
    </main>
    {% sections 'footer-group' %}
    {% render 'cart-drawer' %}
    {% render 'cookie-consent' %}
    <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'reveal.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'recently-viewed.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'notify.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'compare-share.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cart-gift.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cart-gift-note.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'fbt.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'free-shipping-bar.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'cookie-consent.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'mega-menu.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'scroll-animate.js' | asset_url }}" defer="defer"></script>
    <script>
    (function(){
      var s = document.getElementById('tidio-cls-fix');
      if (!s) return;
      var done = false;
      function show() {
        if (done) return;
        done = true;
        s.remove();
        ['scroll','click','touchstart','keydown'].forEach(function(e){
          window.removeEventListener(e, show);
        });
      }
      ['scroll','click','touchstart','keydown'].forEach(function(e){
        window.addEventListener(e, show, { passive: true, once: true });
      });
    })();
    </script>
    {% render 'newsletter-popup' %}
    {% render 'quick-view-modal' %}
  </body>
</html>
