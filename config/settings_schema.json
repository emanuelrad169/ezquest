[
  {
    "name": "theme_info",
    "theme_name": "EZQuest",
    "theme_version": "0.1.0",
    "theme_author": "OpenAI Codex",
    "theme_documentation_url": "https://shopify.dev/docs/storefronts/themes/architecture",
    "theme_support_url": "https://shopify.dev/"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "brand_logo",
        "label": "Brand logo"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Premium connectivity solutions"
      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default social sharing image",
        "info": "Used when a page has no featured image. Recommended: 1200\u00d7630px."
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "link_list",
        "id": "header_primary_menu",
        "label": "Primary menu"
      },
      {
        "type": "checkbox",
        "id": "header_show_search",
        "label": "Show search icon",
        "default": true
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "link_list",
        "id": "footer_menu_support",
        "label": "Support menu"
      },
      {
        "type": "link_list",
        "id": "footer_menu_company",
        "label": "Company menu"
      },
      {
        "type": "link_list",
        "id": "footer_menu_legal",
        "label": "Legal menu"
      },
      {
        "type": "text",
        "id": "footer_newsletter_heading",
        "label": "Newsletter heading",
        "default": "Stay connected"
      }
    ]
  },
  {
    "name": "Integrations",
    "settings": [
      {
        "type": "text",
        "id": "ga4_measurement_id",
        "label": "GA4 Measurement ID",
        "info": "Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.",
        "placeholder": "G-XXXXXXXXXX"
      },
      {
        "type": "select",
        "id": "reviews_app",
        "label": "Reviews app",
        "info": "Controls how review stars render on product cards. Set to Judge.me after installing the app.",
        "options": [
          {
            "value": "none",
            "label": "None"
          },
          {
            "value": "native",
            "label": "Shopify native metafields"
          },
          {
            "value": "judgeme",
            "label": "Judge.me"
          }
        ],
        "default": "native"
      }
    ]
  },
  {
    "name": "Support Center",
    "settings": [
      {
        "type": "text",
        "id": "support_contact_url",
        "label": "Support contact URL",
        "default": "/pages/contact"
      },
      {
        "type": "text",
        "id": "support_warranty_url",
        "label": "Warranty URL",
        "default": "/pages/warranty"
      }
    ]
  }
]