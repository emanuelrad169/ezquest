[
  {
    "name": "Theme Information",
    "theme_name": "EZQuest",
    "theme_version": "0.1.0",
    "theme_author": "OpenAI Codex",
    "theme_documentation_url": "https://shopify.dev/docs/storefronts/themes/architecture",
    "theme_support_url": "https://shopify.dev/"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "brand_logo",
        "label": "Brand logo"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Premium connectivity solutions"
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "link_list",
        "id": "header_primary_menu",
        "label": "Primary menu"
      },
      {
        "type": "checkbox",
        "id": "header_show_search",
        "label": "Show search icon",
        "default": true
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "link_list",
        "id": "footer_menu_support",
        "label": "Support menu"
      },
      {
        "type": "link_list",
        "id": "footer_menu_company",
        "label": "Company menu"
      },
      {
        "type": "text",
        "id": "footer_newsletter_heading",
        "label": "Newsletter heading",
        "default": "Stay connected"
      }
    ]
  },
  {
    "name": "Support Center",
    "settings": [
      {
        "type": "text",
        "id": "support_contact_url",
        "label": "Support contact URL",
        "default": "/pages/contact"
      },
      {
        "type": "text",
        "id": "support_warranty_url",
        "label": "Warranty URL",
        "default": "/pages/warranty"
      }
    ]
  }
]
