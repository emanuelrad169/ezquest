<section class="contact-panel">
  <div class="contact-panel__inner">

    <!-- Info column -->
    <div class="contact-panel__info">
      {% if section.settings.eyebrow != blank %}
        <span class="contact-kicker">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="contact-heading">{{ section.settings.heading }}</h2>
      {% if section.settings.copy != blank %}
        <p class="contact-subhead">{{ section.settings.copy }}</p>
      {% endif %}

      <div class="contact-channels">
        <!-- Phone -->
        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 10.5c-.83 0-1.63-.13-2.38-.37a.75.75 0 00-.77.18l-1.47 1.47A11.3 11.3 0 014.22 7.12l1.47-1.47a.75.75 0 00.18-.77A7.5 7.5 0 015.5 2.5a.75.75 0 00-.75-.75H2a.75.75 0 00-.75.75C1.25 9.63 6.37 14.75 13.5 14.75a.75.75 0 00.75-.75v-2.75a.75.75 0 00-.75-.75z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="contact-channel__info">
            <span class="contact-channel__label">Phone</span>
            <a href="tel:18008819305" class="contact-channel__link">1-800-881-9305</a>
            <span class="contact-channel__meta">Mon–Fri 9am–5pm PST</span>
          </div>
        </div>

        <!-- Email -->
        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1.75" y="3.75" width="12.5" height="8.5" rx="1.25" stroke="currentColor" stroke-width="1.25"/><path d="M1.75 5.5l6.25 4 6.25-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          </div>
          <div class="contact-channel__info">
            <span class="contact-channel__label">Email</span>
            <a href="mailto:support@ezquest.com" class="contact-channel__link">support@ezquest.com</a>
            <span class="contact-channel__meta">Response within 1 business day</span>
          </div>
        </div>

        <!-- Hours -->
        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.25" stroke="currentColor" stroke-width="1.25"/><path d="M8 5v3.25l2 2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="contact-channel__info">
            <span class="contact-channel__label">Support hours</span>
            <span class="contact-channel__value">Mon–Fri, 9am–5pm PST</span>
            <span class="contact-channel__meta">Closed weekends and US holidays</span>
          </div>
        </div>
      </div>

      <div class="contact-support-links">
        <a href="/pages/faq" class="contact-link-pill">FAQ</a>
        <a href="/pages/troubleshooting" class="contact-link-pill">Troubleshooting</a>
        <a href="/pages/warranty" class="contact-link-pill">Warranty</a>
        <a href="/pages/compatibility" class="contact-link-pill">Compatibility</a>
        <a href="/pages/downloads" class="contact-link-pill">Downloads</a>
      </div>
    </div>

    <!-- Form card column -->
    <div class="contact-form-card" id="contact-form-card-{{ section.id }}">
      <div class="contact-form-card__spotlight" aria-hidden="true"></div>
      <div class="contact-form-card__beam" aria-hidden="true"></div>

      {% form 'contact', class: 'contact-form', id: 'contact-form-{{ section.id }}' %}
        {% if form.posted_successfully? %}
          <div class="contact-success" role="alert">{{ section.settings.success_message }}</div>
        {% endif %}

        {% if form.errors %}
          <div class="contact-errors" role="alert">{{ form.errors | default_errors }}</div>
        {% endif %}

        <div class="contact-form__grid">
          <div class="contact-form__field contact-form__field--full">
            <label class="contact-form__label" for="ContactFormIntent-{{ section.id }}">Request type</label>
            <select id="ContactFormIntent-{{ section.id }}" class="contact-form__select" name="contact[Request type]" required>
              <option value="">Select one</option>
              <option value="Product help">Product help</option>
              <option value="Order help">Order help</option>
              <option value="Warranty help">Warranty help</option>
            </select>
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactFormProduct-{{ section.id }}">Product name</label>
            <input id="ContactFormProduct-{{ section.id }}" class="contact-form__input" type="text" name="contact[Product name]">
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactFormOrder-{{ section.id }}">Order reference</label>
            <input id="ContactFormOrder-{{ section.id }}" class="contact-form__input" type="text" name="contact[Order reference]">
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactFormName-{{ section.id }}">Name</label>
            <input id="ContactFormName-{{ section.id }}" class="contact-form__input" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactFormEmail-{{ section.id }}">Email</label>
            <input id="ContactFormEmail-{{ section.id }}" class="contact-form__input" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" autocorrect="off" autocapitalize="off" required>
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactFormPhone-{{ section.id }}">Phone</label>
            <input id="ContactFormPhone-{{ section.id }}" class="contact-form__input" type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
          </div>

          <div class="contact-form__field contact-form__field--full">
            <label class="contact-form__label" for="ContactFormMessage-{{ section.id }}">Message</label>
            <textarea id="ContactFormMessage-{{ section.id }}" class="contact-form__textarea" rows="5" name="contact[body]" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <div class="contact-form__field contact-form__field--full">
            <div class="contact-form__submit-row">
              <button type="submit" class="contact-form__submit">Send support request</button>
              <p class="contact-form__note">We reply with product, order, or warranty help based on your request.</p>
            </div>
          </div>
        </div>
      {% endform %}
    </div>

  </div>
</section>

<script>
(function () {
  var card = document.getElementById('contact-form-card-{{ section.id }}');
  if (!card) return;
  var spotlight = card.querySelector('.contact-form-card__spotlight');
  if (!spotlight) return;

  card.addEventListener('mousemove', function (e) {
    var rect = card.getBoundingClientRect();
    var x = e.clientX - rect.left;
    var y = e.clientY - rect.top;
    spotlight.style.background = 'radial-gradient(500px circle at ' + x + 'px ' + y + 'px, rgba(245,158,11,0.1), transparent 60%)';
  });
  card.addEventListener('mouseleave', function () {
    spotlight.style.background = '';
  });
})();
</script>

{% schema %}
{
  "name": "Contact form panel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Get in touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Send us a message" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Use the form for support requests, order questions, and warranty claims. For fastest help, include your product name and order number." },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for reaching out. Your message has been sent and our team will reply within one business day." }
  ],
  "presets": [
    { "name": "Contact form panel" }
  ]
}
{% endschema %}
