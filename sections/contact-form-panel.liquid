{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero relative overflow-hidden">
  <div class="support-hero__wrap w-full">
    <p class="support-hero__kicker">Contact</p>
    <h2 class="support-hero__heading">
      We respond within<br>1 business day
    </h2>
    <p class="support-hero__sub">
      Every message is read by a real person.
      No ticket queues, no bots.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'contact' %}

<div class="support-body">
  <div class="contact-layout">

    <div class="contact-info">

      <div class="contact-channels">

        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M2 5A1.5 1.5 0 013.5 3.5h11A1.5 1.5 0 0116 5v8A1.5 1.5 0 0114.5 14.5h-11A1.5 1.5 0 012 13V5z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M2 5.5l7 4.5 7-4.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <p class="contact-channel__label">Email</p>
            <p class="contact-channel__value">Via this form — we reply directly to your email</p>
          </div>
        </div>

        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 4.5A1.5 1.5 0 014.5 3h1.26a1 1 0 01.95.68l.74 2.22a1 1 0 01-.23 1.02L6 8.14A9 9 0 009.86 12l1.22-1.22a1 1 0 011.02-.23l2.22.74A1 1 0 0115 12.24V13.5a1.5 1.5 0 01-1.5 1.5A10.5 10.5 0 013 4.5z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <p class="contact-channel__label">Phone</p>
            <a href="tel:18008819305" class="contact-channel__value contact-channel__link hover:text-[var(--ez-black)] hover:decoration-[var(--ez-black)]">1-800-881-9305</a>
          </div>
        </div>

        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M9 5.5v3.75L11.25 11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="contact-channel__label">Hours</p>
            <p class="contact-channel__value">Mon–Fri, 9 am–5 pm PST</p>
          </div>
        </div>

      </div>

      <div class="contact-support-links">
        <p class="contact-support-links__label">Looking for something specific?</p>
        <div class="contact-support-links__grid">
          <a href="/pages/faq" class="contact-link-pill hover:border-[var(--ez-amber)] hover:text-[var(--ez-black)] hover:bg-[var(--ez-amber-05)]">FAQ</a>
          <a href="/pages/compatibility" class="contact-link-pill hover:border-[var(--ez-amber)] hover:text-[var(--ez-black)] hover:bg-[var(--ez-amber-05)]">Compatibility</a>
          <a href="/pages/troubleshooting" class="contact-link-pill hover:border-[var(--ez-amber)] hover:text-[var(--ez-black)] hover:bg-[var(--ez-amber-05)]">Troubleshooting</a>
          <a href="/pages/warranty" class="contact-link-pill hover:border-[var(--ez-amber)] hover:text-[var(--ez-black)] hover:bg-[var(--ez-amber-05)]">Warranty</a>
          <a href="/pages/downloads" class="contact-link-pill hover:border-[var(--ez-amber)] hover:text-[var(--ez-black)] hover:bg-[var(--ez-amber-05)]">Downloads</a>
        </div>
      </div>

    </div>

    <div class="contact-form-card hover:border-[var(--ez-amber-25)] hover:shadow-[0_8px_40px_rgba(0,0,0,0.06)]" id="contact-card-{{ section.id }}">
      <div class="contact-form-card__spotlight" aria-hidden="true"></div>

      {% form 'contact', id: 'contact-form-{{ section.id }}', class: 'contact-form relative z-[1]' %}

        {% if form.posted_successfully? %}
          <div class="contact-success text-center py-12 px-6" role="alert">
            <div class="contact-success__icon" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="18" stroke="var(--ez-amber)" stroke-width="1.5"/>
                <path d="M13 20l5 5 9-10" stroke="var(--ez-amber)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="contact-success__heading">{{ 'contact.success' | t }}</h3>
            <p class="contact-success__body">{{ 'contact.success_body' | t: email: form.email }}</p>
          </div>

        {% else %}

          {% if form.errors %}
            <div class="contact-errors" role="alert">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="contact-form__grid">

            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-name-{{ section.id }}">{{ 'contact.name' | t }}</label>
              <input type="text" id="contact-name-{{ section.id }}" name="contact[name]" class="contact-form__input focus:border-[var(--ez-amber)] focus:shadow-[0_0_0_3px_var(--ez-amber-10)]" required autocomplete="name" placeholder="Alex Johnson" value="{% if customer %}{{ customer.name }}{% endif %}">
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-email-{{ section.id }}">{{ 'contact.email' | t }}</label>
              <input type="email" id="contact-email-{{ section.id }}" name="contact[email]" class="contact-form__input focus:border-[var(--ez-amber)] focus:shadow-[0_0_0_3px_var(--ez-amber-10)]" required autocomplete="email" placeholder="alex@company.com" value="{% if customer %}{{ customer.email }}{% endif %}">
            </div>

            <div class="contact-form__field contact-form__field--full col-span-full">
              <label class="contact-form__label" for="contact-subject-{{ section.id }}">What is this about?</label>
              <select id="contact-subject-{{ section.id }}" name="contact[subject]" class="contact-form__input focus:border-[var(--ez-amber)] focus:shadow-[0_0_0_3px_var(--ez-amber-10)]">
                <option value="" disabled selected>Select a topic</option>
                <option>Product question</option>
                <option>Order support</option>
                <option>Compatibility help</option>
                <option>Warranty claim</option>
                <option>Returns</option>
                <option>Firmware or drivers</option>
                <option>Other</option>
              </select>
            </div>

            <div class="contact-form__field contact-form__field--full col-span-full">
              <label class="contact-form__label" for="contact-message-{{ section.id }}">{{ 'contact.message' | t }}</label>
              <textarea id="contact-message-{{ section.id }}" name="contact[body]" class="contact-form__input contact-form__textarea focus:border-[var(--ez-amber)] focus:shadow-[0_0_0_3px_var(--ez-amber-10)] resize-y min-h-[120px]" rows="5" required placeholder="Tell us what you need…"></textarea>
            </div>

          </div>

          <button type="submit" class="btn btn--primary contact-form__submit">{{ 'contact.send_message' | t }}</button>
          <p class="contact-form__note">{{ 'contact.note' | t }}</p>

        {% endif %}

      {% endform %}
    </div>

  </div>
</div>


<script>
(function(){
  var card = document.getElementById('contact-card-{{ section.id }}');
  if (!card) return;
  var spot = card.querySelector('.contact-form-card__spotlight');
  if (!spot) return;
  card.addEventListener('mousemove', function(e){
    var r = card.getBoundingClientRect();
    var x = ((e.clientX - r.left) / r.width)  * 100;
    var y = ((e.clientY - r.top)  / r.height) * 100;
    spot.style.background = 'radial-gradient(circle at '+x+'% '+y+'%,rgba(254, 211, 0, .08) 0%,transparent 55%)';
  });
  card.addEventListener('mouseleave', function(){
    spot.style.background = 'none';
  });
})();
</script>

{% schema %}
{
  "name": "Contact form panel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support Form" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tell us what you need" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Choose the request type, add the key details, and keep the message focused on the next step you need." },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for reaching out. Your message has been sent and our team will reply within one business day." }
  ],
  "presets": [{ "name": "Contact form panel" }]
}
{% endschema %}
