{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero">
  <div class="support-hero__wrap">
    <p class="support-hero__kicker">Contact</p>
    <h2 class="support-hero__heading">
      We respond within<br>1 business day
    </h2>
    <p class="support-hero__sub">
      Every message is read by a real person.
      No ticket queues, no bots.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'contact' %}

<div class="support-body">
  <div class="contact-layout">

    <div class="contact-info">

      <div class="contact-channels">

        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M2 5A1.5 1.5 0 013.5 3.5h11A1.5 1.5 0 0116 5v8A1.5 1.5 0 0114.5 14.5h-11A1.5 1.5 0 012 13V5z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M2 5.5l7 4.5 7-4.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <p class="contact-channel__label">Email</p>
            <p class="contact-channel__value">Via this form — we reply directly to your email</p>
          </div>
        </div>

        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 4.5A1.5 1.5 0 014.5 3h1.26a1 1 0 01.95.68l.74 2.22a1 1 0 01-.23 1.02L6 8.14A9 9 0 009.86 12l1.22-1.22a1 1 0 011.02-.23l2.22.74A1 1 0 0115 12.24V13.5a1.5 1.5 0 01-1.5 1.5A10.5 10.5 0 013 4.5z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <p class="contact-channel__label">Phone</p>
            <a href="tel:18008819305" class="contact-channel__value contact-channel__link">1-800-881-9305</a>
          </div>
        </div>

        <div class="contact-channel">
          <div class="contact-channel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M9 5.5v3.75L11.25 11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div>
            <p class="contact-channel__label">Hours</p>
            <p class="contact-channel__value">Mon–Fri, 9 am–5 pm PST</p>
          </div>
        </div>

      </div>

      <div class="contact-support-links">
        <p class="contact-support-links__label">Looking for something specific?</p>
        <div class="contact-support-links__grid">
          <a href="/pages/faq" class="contact-link-pill">FAQ</a>
          <a href="/pages/compatibility" class="contact-link-pill">Compatibility</a>
          <a href="/pages/troubleshooting" class="contact-link-pill">Troubleshooting</a>
          <a href="/pages/warranty" class="contact-link-pill">Warranty</a>
          <a href="/pages/downloads" class="contact-link-pill">Downloads</a>
        </div>
      </div>

    </div>

    <div class="contact-form-card" id="contact-card-{{ section.id }}">
      <div class="contact-form-card__spotlight" aria-hidden="true"></div>

      {% form 'contact', id: 'contact-form-{{ section.id }}', class: 'contact-form' %}

        {% if form.posted_successfully? %}
          <div class="contact-success" role="alert">
            <div class="contact-success__icon" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="18" stroke="var(--ez-amber)" stroke-width="1.5"/>
                <path d="M13 20l5 5 9-10" stroke="var(--ez-amber)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="contact-success__heading">{{ 'contact.success' | t }}</h3>
            <p class="contact-success__body">{{ 'contact.success_body' | t: email: form.email }}</p>
          </div>

        {% else %}

          {% if form.errors %}
            <div class="contact-errors" role="alert">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="contact-form__grid">

            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-name-{{ section.id }}">{{ 'contact.name' | t }}</label>
              <input type="text" id="contact-name-{{ section.id }}" name="contact[name]" class="contact-form__input" required autocomplete="name" placeholder="Alex Johnson" value="{% if customer %}{{ customer.name }}{% endif %}">
            </div>

            <div class="contact-form__field">
              <label class="contact-form__label" for="contact-email-{{ section.id }}">{{ 'contact.email' | t }}</label>
              <input type="email" id="contact-email-{{ section.id }}" name="contact[email]" class="contact-form__input" required autocomplete="email" placeholder="alex@company.com" value="{% if customer %}{{ customer.email }}{% endif %}">
            </div>

            <div class="contact-form__field contact-form__field--full">
              <label class="contact-form__label" for="contact-subject-{{ section.id }}">What is this about?</label>
              <select id="contact-subject-{{ section.id }}" name="contact[subject]" class="contact-form__input">
                <option value="" disabled selected>Select a topic</option>
                <option>Product question</option>
                <option>Order support</option>
                <option>Compatibility help</option>
                <option>Warranty claim</option>
                <option>Returns</option>
                <option>Firmware or drivers</option>
                <option>Other</option>
              </select>
            </div>

            <div class="contact-form__field contact-form__field--full">
              <label class="contact-form__label" for="contact-message-{{ section.id }}">{{ 'contact.message' | t }}</label>
              <textarea id="contact-message-{{ section.id }}" name="contact[body]" class="contact-form__input contact-form__textarea" rows="5" required placeholder="Tell us what you need…"></textarea>
            </div>

          </div>

          <button type="submit" class="btn btn--primary contact-form__submit">{{ 'contact.send_message' | t }}</button>
          <p class="contact-form__note">{{ 'contact.note' | t }}</p>

        {% endif %}

      {% endform %}
    </div>

  </div>
</div>

<style>
.contact-layout{display:grid;grid-template-columns:minmax(320px,440px) minmax(0,1fr);gap:clamp(3rem,6vw,6rem);align-items:start}
@media(max-width:900px){.contact-layout{grid-template-columns:1fr}}
.contact-channels{display:flex;flex-direction:column;gap:1.5rem;margin-bottom:2.5rem}
.contact-channel{display:flex;align-items:flex-start;gap:.875rem}
.contact-channel__icon{width:36px;height:36px;border-radius:10px;background:rgba(251, 206, 42, .08);border:1px solid rgba(251, 206, 42, .18);color:var(--ez-amber);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.contact-channel__label{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ez-grey);margin:0 0 .2rem}
.contact-channel__value{font-size:14px;color:var(--ez-black);font-weight:500;line-height:1.45;margin:0}
.contact-channel__link{text-decoration:none;transition:color .2s}
.contact-channel__link:hover{color:var(--ez-amber)}
.contact-support-links__label{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ez-grey);margin:0 0 .875rem}
.contact-support-links__grid{display:flex;flex-wrap:wrap;gap:.5rem}
.contact-link-pill{padding:.375rem .875rem;border-radius:100px;border:1.5px solid rgba(0,0,0,.1);font-size:13px;color:var(--ez-grey);text-decoration:none;transition:all .2s}
.contact-link-pill:hover{border-color:var(--ez-amber);color:var(--ez-black);background:rgba(251, 206, 42, .05)}

.contact-form-card{position:relative;border-radius:20px;border:1.5px solid rgba(0,0,0,.08);padding:clamp(1.75rem,3vw,2.5rem);background:#fff;overflow:hidden;transition:border-color .25s,box-shadow .3s}
.contact-form-card:hover{border-color:rgba(251, 206, 42, .25);box-shadow:0 8px 40px rgba(0,0,0,.06)}
.contact-form-card__spotlight{position:absolute;inset:0;pointer-events:none;z-index:0;border-radius:inherit}

.contact-form{position:relative;z-index:1}
.contact-form__grid{display:grid;grid-template-columns:1fr 1fr;gap:1.125rem}
@media(max-width:580px){.contact-form__grid{grid-template-columns:1fr}}
.contact-form__field{display:flex;flex-direction:column;gap:.375rem}
.contact-form__field--full{grid-column:1/-1}
.contact-form__label{font-size:13px;font-weight:500;color:var(--ez-black)}
.contact-form__input{padding:.75rem 1rem;border:1.5px solid rgba(0,0,0,.12);border-radius:10px;font-size:15px;color:var(--ez-black);background:#fff;width:100%;transition:border-color .2s,box-shadow .2s;outline:none;appearance:none;-webkit-appearance:none;font-family:inherit}
.contact-form__input::placeholder{color:var(--ez-grey);opacity:.6}
.contact-form__input:focus{border-color:var(--ez-amber);box-shadow:0 0 0 3px rgba(251, 206, 42, .1)}
.contact-form__textarea{resize:vertical;min-height:120px}
.contact-form__submit{width:100%;margin-top:1.25rem;min-height:52px;font-size:16px;border-radius:100px}
.contact-form__note{font-size:12px;color:var(--ez-grey);text-align:center;margin:.875rem 0 0;line-height:1.5}

.contact-success{text-align:center;padding:3rem 1.5rem}
.contact-success__icon{margin:0 auto 1.25rem;width:56px;height:56px;border-radius:50%;background:rgba(251, 206, 42, .08);display:flex;align-items:center;justify-content:center}
.contact-success__heading{font-size:22px;font-weight:500;margin:0 0 .5rem;letter-spacing:-.02em;color:var(--ez-black)}
.contact-success__body{font-size:15px;color:var(--ez-grey);margin:0}

.contact-errors{padding:1rem 1.25rem;border:1.5px solid rgba(220,38,38,.25);border-radius:10px;background:rgba(220,38,38,.04);color:#9a1c1f;font-size:14px;margin-bottom:1.25rem}
</style>

<script>
(function(){
  var card = document.getElementById('contact-card-{{ section.id }}');
  if (!card) return;
  var spot = card.querySelector('.contact-form-card__spotlight');
  if (!spot) return;
  card.addEventListener('mousemove', function(e){
    var r = card.getBoundingClientRect();
    var x = ((e.clientX - r.left) / r.width)  * 100;
    var y = ((e.clientY - r.top)  / r.height) * 100;
    spot.style.background = 'radial-gradient(circle at '+x+'% '+y+'%,rgba(251, 206, 42, .08) 0%,transparent 55%)';
  });
  card.addEventListener('mouseleave', function(){
    spot.style.background = 'none';
  });
})();
</script>

{% schema %}
{
  "name": "Contact form panel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support Form" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tell us what you need" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Choose the request type, add the key details, and keep the message focused on the next step you need." },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for reaching out. Your message has been sent and our team will reply within one business day." }
  ],
  "presets": [{ "name": "Contact form panel" }]
}
{% endschema %}
