{% comment %}
  COLLECTION FILTERS
  Filter sidebar is built and ready.
  For filters to appear, configure filter groups in Shopify admin:
  Online Store → Navigation → Search & discovery → Filters
  Or: Online Store → Themes → Customize → Collections → Enable filtering
  Without admin config, collection.filters.size = 0 and
  the sidebar will not render (this is correct behavior).
{% endcomment %}
{% paginate collection.products by 100 %}
  {%- liquid
        assign intro_copy = section.settings.intro_copy | default: collection.description
        assign collection_visual = blank
        assign lead_product = collection.products.first
        assign fallback_product_handles = blank
        assign fallback_visible_count = 0
        assign total_visible_products = collection.products_count
        assign promo_handle = blank
        assign promo_eyebrow = 'Next step'
        assign promo_title = blank
        assign promo_copy = blank
        assign promo_link_label = blank
        assign promo_image = blank
        assign promo_insert_index = 4
        assign family_handle_list = 'hubs-adapters|docking-stations|chargers-power|accessories' | split: '|'
        assign family_compare_url = '/pages/compare'

        if intro_copy == blank
          case collection.handle
            when 'hubs-adapters'
              assign intro_copy = 'USB-C hubs and adapters for lighter desks, travel kits, and everyday expansion.'
            when 'docking-stations'
              assign intro_copy = 'Desk-ready docks that bring displays, charging, Ethernet, and peripherals into one cleaner footprint.'
            when 'chargers-power'
              assign intro_copy = 'Charging essentials for lighter travel kits, cleaner desks, and reliable everyday power.'
            when 'accessories'
              assign intro_copy = 'Cables and finishing pieces that make the setup feel complete and dependable.'
            else
              assign intro_copy = 'EZQuest products with the right mix of ports, power, and display support.'
          endcase
        endif

        case collection.handle
          when 'hubs-adapters'
            assign fallback_product_handles = 'usb-c-multimedia-hub,usb-c-travel-hub'
            assign promo_handle = 'docking-stations'
            assign promo_title = 'Ready for a full desk?'
            assign promo_copy = 'See the docks built for displays, Ethernet, charging, and a cleaner desk.'
            assign promo_link_label = 'View docking stations'
            assign promo_image = section.settings.promo_ready_for_desk_image
          when 'docking-stations'
            assign fallback_product_handles = 'usb-c-pro-dock'
            assign promo_handle = 'chargers-power'
            assign promo_title = 'Power, refined'
            assign promo_copy = 'Pair the desk with chargers and power accessories that keep every device ready.'
            assign promo_link_label = 'View chargers and power'
            assign promo_image = section.settings.promo_power_up_image
          when 'chargers-power'
            assign promo_handle = 'accessories'
            assign promo_title = 'Finish the setup'
            assign promo_copy = 'Add the cables and accessories that keep power clean and dependable.'
            assign promo_link_label = 'View accessories'
            assign promo_image = section.settings.promo_duraguard_cables_image
          when 'accessories'
            assign promo_handle = 'hubs-adapters'
            assign promo_title = 'Expand the setup'
            assign promo_copy = 'Add hubs and adapters when the setup needs more ports and more reach.'
            assign promo_link_label = 'View hubs and adapters'
            assign promo_image = section.settings.promo_travel_kit_image
        endcase

        if lead_product == blank and fallback_product_handles != blank
          assign fallback_handle_list = fallback_product_handles | split: ','
          for fallback_handle in fallback_handle_list
            assign fallback_product = all_products[fallback_handle]
            if fallback_product != blank
              assign fallback_visible_count = fallback_visible_count | plus: 1
              if lead_product == blank
                assign lead_product = fallback_product
              endif
            endif
          endfor
        endif

        if total_visible_products == 0
          assign total_visible_products = fallback_visible_count
        endif

        if collection.handle != blank
          assign family_compare_url = family_compare_url | append: '?collection=' | append: collection.handle
        endif

        if total_visible_products < promo_insert_index
          assign promo_insert_index = 2
        endif

        if section.settings.show_collection_image
          if collection.image != blank
            assign collection_visual = collection.image
          elsif lead_product != blank and lead_product.images.size > 0
            assign collection_candidate_image = lead_product.featured_image | default: lead_product.images.first
            assign collection_best_image = blank
            assign collection_non_technical_image = blank
            assign collection_ratio_image = blank

            for candidate_image in lead_product.images
              assign candidate_alt = candidate_image.alt | downcase
              assign candidate_is_technical = false
              assign candidate_has_preferred_ratio = false

              if candidate_alt contains 'illustration'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'diagram'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'schematic'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'placeholder'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'port'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'icon'
                assign candidate_is_technical = true
              endif

              if candidate_image.aspect_ratio >= 1.0 and candidate_image.aspect_ratio <= 1.9
                assign candidate_has_preferred_ratio = true
              endif

              if collection_best_image == blank and candidate_is_technical == false and candidate_has_preferred_ratio
                assign collection_best_image = candidate_image
              endif

              if collection_non_technical_image == blank and candidate_is_technical == false
                assign collection_non_technical_image = candidate_image
              endif

              if collection_ratio_image == blank and candidate_has_preferred_ratio
                assign collection_ratio_image = candidate_image
              endif
            endfor

            assign collection_visual = collection_best_image | default: collection_non_technical_image | default: collection_ratio_image | default: collection_candidate_image
          endif

          if collection_visual == blank
            for browse_product in collection.products limit: 4
              if browse_product.images.size > 0
                assign collection_candidate_image = browse_product.featured_image | default: browse_product.images.first
                assign collection_best_image = blank
                assign collection_non_technical_image = blank
                assign collection_ratio_image = blank

                for candidate_image in browse_product.images
                  assign candidate_alt = candidate_image.alt | downcase
                  assign candidate_is_technical = false
                  assign candidate_has_preferred_ratio = false

                  if candidate_alt contains 'illustration'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'diagram'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'schematic'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'placeholder'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'port'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'icon'
                    assign candidate_is_technical = true
                  endif

                  if candidate_image.aspect_ratio >= 1.0 and candidate_image.aspect_ratio <= 1.9
                    assign candidate_has_preferred_ratio = true
                  endif

                  if collection_best_image == blank and candidate_is_technical == false and candidate_has_preferred_ratio
                    assign collection_best_image = candidate_image
                  endif

                  if collection_non_technical_image == blank and candidate_is_technical == false
                    assign collection_non_technical_image = candidate_image
                  endif

                  if collection_ratio_image == blank and candidate_has_preferred_ratio
                    assign collection_ratio_image = candidate_image
                  endif
                endfor

                assign collection_visual = collection_best_image | default: collection_non_technical_image | default: collection_ratio_image | default: collection_candidate_image
              endif

              if collection_visual != blank
                break
              endif
            endfor
          endif
        endif
      -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ collection.title | json }},
    "description": {{ intro_copy | strip_html | json }},
    "url": {{ shop.url | append: collection.url | json }}
  }
  </script>

  {%- liquid
    assign active_count = 0
    for filter in collection.filters
      assign active_count = active_count | plus: filter.active_values.size
      if filter.type == 'price_range'
        if filter.min_value.value != blank or filter.max_value.value != blank
          assign active_count = active_count | plus: 1
        endif
      endif
    endfor
  -%}

  <div class="collection-subnav">
    <div class="container-shell collection-subnav__inner">

        <nav class="collection-subnav__tabs" aria-label="Collection families">
          {% for family_handle in family_handle_list %}
            {% assign family_collection = collections[family_handle] %}
            {% if family_collection != blank %}
              <a href="{{ family_collection.url }}"
                 class="collection-subnav__tab{% if family_handle == collection.handle %} is-active{% endif %}"
                 {% if family_handle == collection.handle %}aria-current="page"{% endif %}>
                {{ family_collection.title }}<span class="collection-subnav__count"> ({{ family_collection.products_count }})</span>
              </a>
            {% endif %}
          {% endfor %}
        </nav>

        <div class="collection-subnav__actions">
          {% if collection.filters.size > 0 %}
            <button
              class="collection-subnav__btn collection-filter-toggle collection-filter-btn"
              id="collection-filter-toggle"
              aria-expanded="false"
              aria-controls="collection-filters"
              type="button">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span class="collection-subnav__btn-label">Filter</span>
              <span class="collection-subnav__filter-badge collection-filter-toggle__badge collection-filter-btn__count{% if active_count == 0 %} is-hidden{% endif %}">{{ active_count }}</span>
            </button>
            <span class="collection-subnav__divider" aria-hidden="true"></span>
          {% endif %}
          {% if section.settings.show_sort %}
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- assign active_sort_label = 'Featured' -%}
            {%- for option in collection.sort_options -%}
              {%- if option.value == sort_by -%}{%- assign active_sort_label = option.name -%}{%- endif -%}
            {%- endfor -%}
            <form method="get" class="collection-subnav__sort-form">
              <button type="submit" class="sr-only">Apply sort</button>
              <div class="collection-subnav__btn-wrap">
                <select id="CollectionSort" name="sort_by" class="collection-sort-select-native" aria-label="Sort by">
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
                <span class="collection-subnav__btn" aria-hidden="true">
                  {{ active_sort_label }}
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="collection-subnav__sort-caret">
                    <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </form>
          {% endif %}
        </div>

      </div>
    </div>

    <div class="container-shell">

      <div class="collection-layout mt-8 lg:mt-10">

        {% if collection.filters.size > 0 %}
          <aside class="collection-filters collection-filter" id="collection-filters" aria-label="Product filters" data-filter-sidebar data-filter-drawer data-animate>

            <div class="collection-filters__header">
              <h2 class="collection-filters__title collection-filter__heading">Filter</h2>
              {% if active_count > 0 %}
                <a href="{{ collection.url }}" class="collection-filters__clear filter-clear-all">
                  Clear all ({{ active_count }})
                </a>
              {% endif %}
              <button class="collection-filters__close filter-drawer__close" type="button" aria-label="Close filters" data-filter-close>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
            </div>

            <form id="collection-filter-form" action="{{ collection.url }}" method="get">
              {% if collection.sort_by != blank %}
                <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
              {% endif %}
              <button type="submit" class="sr-only">Apply filters</button>

              {% for filter in collection.filters %}
                <details class="collection-filter-group filter-group js-filter" {% if filter.active_values.size > 0 or forloop.first %}open{% endif %}>
                  <summary class="collection-filter-group__header">
                    <span class="collection-filter-group__name">{{ filter.label }}</span>
                    {% if filter.active_values.size > 0 %}
                      <span class="collection-filter-group__count filter-group__active-count" aria-label="{{ filter.active_values.size }} active">{{ filter.active_values.size }}</span>
                    {% endif %}
                    <svg class="collection-filter-group__chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </summary>

                  <div class="collection-filter-group__body">
                    {% case filter.type %}
                      {% when 'boolean', 'list' %}
                        <ul class="collection-filter-options filter-group__options" role="list">
                          {% for value in filter.values %}
                            <li class="collection-filter-option filter-option" data-count="{{ value.count }}">
                              <label class="collection-filter-option__label{% if value.active %} is-active{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}">
                                <input
                                  type="checkbox"
                                  name="{{ value.param_name }}"
                                  value="{{ value.value }}"
                                  aria-label="{{ filter.label | escape }}: {{ value.label | escape }}"
                                  {% if value.active %}checked{% endif %}
                                  {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                  class="collection-filter-option__input"
                                >
                                <span class="collection-filter-option__text">{{ value.label }}</span>
                                <span class="collection-filter-option__count filter-option__count" data-count="{{ value.count }}">{{ value.count }}</span>
                              </label>
                            </li>
                          {% endfor %}
                        </ul>

                      {% when 'price_range' %}
                        <div class="collection-filter-price">
                          <div class="collection-filter-price__inputs filter-price-inputs">
                            <div class="collection-filter-price__field">
                              <label for="filter-price-min" class="collection-filter-price__label">Min</label>
                              <div class="collection-filter-price__input-wrap">
                                <span class="collection-filter-price__symbol">$</span>
                                <input
                                  type="number"
                                  id="filter-price-min"
                                  name="{{ filter.min_value.param_name }}"
                                  value="{{ filter.min_value.value | divided_by: 100 | default: '' }}"
                                  min="0"
                                  max="{{ filter.range_max | divided_by: 100 }}"
                                  placeholder="0"
                                  class="collection-filter-price__input filter-price-input"
                                >
                              </div>
                            </div>
                            <span class="collection-filter-price__separator filter-price-separator">—</span>
                            <div class="collection-filter-price__field">
                              <label for="filter-price-max" class="collection-filter-price__label">Max</label>
                              <div class="collection-filter-price__input-wrap">
                                <span class="collection-filter-price__symbol">$</span>
                                <input
                                  type="number"
                                  id="filter-price-max"
                                  name="{{ filter.max_value.param_name }}"
                                  value="{{ filter.max_value.value | divided_by: 100 | default: '' }}"
                                  min="0"
                                  max="{{ filter.range_max | divided_by: 100 }}"
                                  placeholder="{{ filter.range_max | divided_by: 100 }}"
                                  class="collection-filter-price__input filter-price-input"
                                >
                              </div>
                            </div>
                          </div>
                          <button type="submit" class="btn btn--secondary btn--sm collection-filter-price__apply">Apply</button>
                        </div>

                    {% endcase %}
                  </div>
                </details>
              {% endfor %}
            </form>

            <div class="collection-filters__footer filter-drawer__footer">
              <button class="collection-filters__apply filter-drawer__apply" type="button" data-filter-close>Apply</button>
              <a href="{{ collection.url }}" class="collection-filters__footer-clear filter-drawer__clear">Clear</a>
            </div>

          </aside>
          <div class="collection-filter-overlay filter-drawer-overlay" data-filter-overlay hidden></div>
        {% endif %}

        <div class="collection-main">

          {% if active_count > 0 %}
            <div class="collection-filter-toolbar">
              <div class="collection-filter-toolbar__right active-filters-row active-facets">
                {% for filter in collection.filters %}
                  {% for value in filter.active_values %}
                    <a href="{{ value.url_to_remove }}" class="collection-active-filter active-filter-pill active-facets__button" aria-label="Remove filter: {{ value.label | escape }}">
                      {{ value.label }}
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M2 2l8 8M10 2l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    </a>
                  {% endfor %}
                {% endfor %}
                <a href="{{ collection.url }}" class="filter-clear-all active-facets__clear-link">Clear all</a>
              </div>
            </div>
          {% endif %}

          <div id="collection-grid" class="collection-showroom-grid grid gap-x-5 gap-y-8 md:grid-cols-2 md:gap-x-6 lg:grid-cols-3 xl:grid-cols-4 xl:gap-x-7 reveal-stagger" aria-busy="false">
        {% assign promo_inserted = false %}
        {% for product in collection.products %}
          <div class="collection-product-slot">
            {% comment %} Card media supports CSS-only rollover when a product has a second image. {% endcomment %}
            {% render 'card-product', product: product, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0, image_rollover: true %}
          </div>
          {% if promo_inserted == false and promo_handle != blank and forloop.index == promo_insert_index %}
            {% render 'collection-promo-tile',
              promo_handle: promo_handle,
              promo_eyebrow: promo_eyebrow,
              promo_title: promo_title,
              promo_copy: promo_copy,
              promo_link_label: promo_link_label,
              promo_image: promo_image
            %}
            {% assign promo_inserted = true %}
          {% endif %}
        {% else %}
          {% if fallback_visible_count > 0 %}
            {% assign fallback_handle_list = fallback_product_handles | split: ',' %}
            {% for fallback_handle in fallback_handle_list %}
              {% assign fallback_product = all_products[fallback_handle] %}
              {% if fallback_product != blank %}
                <div class="collection-product-slot">
                  {% render 'card-product', product: fallback_product, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0, image_rollover: true %}
                </div>
                {% if promo_inserted == false and promo_handle != blank and forloop.index == promo_insert_index %}
                  {% render 'collection-promo-tile',
                    promo_handle: promo_handle,
                    promo_eyebrow: promo_eyebrow,
                    promo_title: promo_title,
                    promo_copy: promo_copy,
                    promo_link_label: promo_link_label,
                    promo_image: promo_image
                  %}
                  {% assign promo_inserted = true %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="panel-primary md:col-span-2 xl:col-span-4">
              <p class="section-kicker">Collection</p>
              <h2 class="mt-4 text-2xl font-medium tracking-tight text-slate-950">This collection is being refined.</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">View all families, compare the lineup, or get product guidance.</p>
              <div class="mt-6 flex flex-wrap items-center gap-3">
                <a href="{{ routes.collections_url }}" class="button-secondary">View all families</a>
                <a href="/pages/compare" class="site-meta-link">Compare models</a>
                <a href="/pages/support" class="site-meta-link">Product guidance</a>
              </div>
            </div>
          {% endif %}
        {% endfor %}
        {% if promo_inserted == false and promo_handle != blank %}
          {% render 'collection-promo-tile',
            promo_handle: promo_handle,
            promo_eyebrow: promo_eyebrow,
            promo_title: promo_title,
            promo_copy: promo_copy,
            promo_link_label: promo_link_label,
            promo_image: promo_image
          %}
        {% endif %}
      </div>

        </div>{% comment %} /collection-main {% endcomment %}
      </div>{% comment %} /collection-layout {% endcomment %}
    </div>{% comment %} /container-shell {% endcomment %}

    <script src="{{ 'collection-filter.js' | asset_url }}" defer></script>
    <script>
    (function() {
      'use strict';

      /* ── AJAX filter / sort ── */
      var collectionGrid = document.getElementById('collection-grid');
      if (!collectionGrid) return;

      var currentRequest = null;
      var sortStorageKey = 'ez_collection_sort:' + window.location.pathname;
      var sortSelectInitial = document.getElementById('CollectionSort');
      var paramsInitial = new URLSearchParams(window.location.search);
      var shouldRestoreSort = false;

      try {
        var savedSort = sessionStorage.getItem(sortStorageKey);
        if (sortSelectInitial && savedSort && !paramsInitial.has('sort_by') && sortSelectInitial.value !== savedSort) {
          sortSelectInitial.value = savedSort;
          paramsInitial.set('sort_by', savedSort);
          window.history.replaceState({}, '', window.location.pathname + '?' + paramsInitial.toString());
          shouldRestoreSort = true;
        }
      } catch (e) {}

      function showSkeleton() {
        collectionGrid = document.getElementById('collection-grid');
        if (!collectionGrid) return;
        Array.from(collectionGrid.children).forEach(function(item) {
          item.style.opacity = '0.4';
          item.style.pointerEvents = 'none';
        });
        collectionGrid.setAttribute('aria-busy', 'true');
      }

      function hideSkeleton() {
        collectionGrid = document.getElementById('collection-grid');
        if (!collectionGrid) return;
        Array.from(collectionGrid.children).forEach(function(item) {
          item.style.opacity = '';
          item.style.pointerEvents = '';
        });
        collectionGrid.setAttribute('aria-busy', 'false');
      }

      function buildUrl() {
        var filterForm = document.getElementById('collection-filter-form');
        if (!filterForm) return window.location.pathname;
        var formData = new FormData(filterForm);
        var params = new URLSearchParams(formData);
        var sortSelect = document.getElementById('CollectionSort');
        if (sortSelect && sortSelect.value) params.set('sort_by', sortSelect.value);
        var toDelete = [];
        params.forEach(function(v, k) { if (!v) toDelete.push(k); });
        toDelete.forEach(function(k) { params.delete(k); });
        return window.location.pathname + '?' + params.toString();
      }

      function replaceFromResponse(doc, selector) {
        var current = document.querySelector(selector);
        var next = doc.querySelector(selector);
        if (current && next) current.innerHTML = next.innerHTML;
      }

      function fetchFilteredProducts(url) {
        if (currentRequest) currentRequest.abort();
        showSkeleton();
        var controller = new AbortController();
        currentRequest = controller;

        fetch(url + (url.indexOf('?') > -1 ? '&' : '?') + 'sections=main', {
          signal: controller.signal
        })
        .then(function(response) {
          if (!response.ok) throw new Error('filter-fetch-failed');
          return response.json();
        })
        .then(function(data) {
          if (data['main']) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(data['main'], 'text/html');
            var newGrid = doc.getElementById('collection-grid');
            if (newGrid) {
              collectionGrid = document.getElementById('collection-grid');
              collectionGrid.innerHTML = newGrid.innerHTML;
              collectionGrid.className = newGrid.className;
            }
            replaceFromResponse(doc, '#collection-filters');
            replaceFromResponse(doc, '.collection-filter-toolbar');
            if (window.EZCollectionFilter && window.EZCollectionFilter.refresh) {
              window.EZCollectionFilter.refresh();
            }
            if (window.EZReveal) {
              collectionGrid.querySelectorAll('.reveal-on-scroll').forEach(function(el) {
                window.EZReveal.observe(el);
              });
            }
          } else {
            window.location.href = url;
          }
        })
        .catch(function(err) {
          if (err.name === 'AbortError') return;
          window.location.href = url;
        })
        .finally(function() {
          hideSkeleton();
          currentRequest = null;
        });

        history.pushState({}, '', url);
        collectionGrid = document.getElementById('collection-grid');
        var gridTop = collectionGrid.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: gridTop, behavior: 'smooth' });
      }

      document.addEventListener('change', function(e) {
        if (e.target.closest('#collection-filter-form') && e.target.type === 'checkbox') {
          fetchFilteredProducts(buildUrl());
        }
      });

      document.addEventListener('click', function(e) {
        var priceApply = e.target.closest('.collection-filter-price__apply');
        if (!priceApply) return;
        e.preventDefault();
        fetchFilteredProducts(buildUrl());
      });

      document.addEventListener('change', function(e) {
        if (e.target && e.target.id === 'CollectionSort') {
          try {
            sessionStorage.setItem(sortStorageKey, e.target.value);
          } catch (err) {}
          fetchFilteredProducts(buildUrl());
        }
      });

      document.addEventListener('click', function(e) {
        var pill = e.target.closest('.collection-active-filter');
        if (!pill) return;
        e.preventDefault();
        var href = pill.getAttribute('href');
        if (href) fetchFilteredProducts(href);
      });

      document.addEventListener('click', function(e) {
        var clearLink = e.target.closest('.collection-filters__clear, .filter-clear-all, .collection-filters__footer-clear');
        if (!clearLink) return;
        e.preventDefault();
        var href = clearLink.getAttribute('href');
        if (href) fetchFilteredProducts(href);
      });

      window.addEventListener('popstate', function() {
        fetchFilteredProducts(window.location.href);
      });

      if (shouldRestoreSort) {
        fetchFilteredProducts(window.location.href);
      }

    })();
    </script>

    <div class="collection-perks-bar">
      <div class="container-shell">
        <div class="collection-perks-grid">
          {%- assign perks = section.blocks | where: 'type', 'perk' -%}
          {% if perks.size > 0 %}
            {% for block in perks %}
              <div class="collection-perk" {{ block.shopify_attributes }}>
                <span class="collection-perk-icon" aria-hidden="true">
                  {% render 'icon', name: block.settings.icon | default: 'shield' %}
                </span>
                <div class="collection-perk-copy">
                  <strong>{{ block.settings.title }}</strong>
                  {% if block.settings.text != blank %}
                    <span>{{ block.settings.text }}</span>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="collection-perk">
              <span class="collection-perk-icon" aria-hidden="true">{% render 'icon', name: 'headphones' %}</span>
              <div class="collection-perk-copy"><strong>Customer service</strong><span>Dedicated support before and after purchase.</span></div>
            </div>
            <div class="collection-perk">
              <span class="collection-perk-icon" aria-hidden="true">{% render 'icon', name: 'truck' %}</span>
              <div class="collection-perk-copy"><strong>Fast Free Shipping</strong><span>Free shipping on orders of $150 or more.</span></div>
            </div>
            <div class="collection-perk">
              <span class="collection-perk-icon" aria-hidden="true">{% render 'icon', name: 'user' %}</span>
              <div class="collection-perk-copy"><strong>Refer a friend</strong><span>Refer a friend and get 15% off each other.</span></div>
            </div>
            <div class="collection-perk">
              <span class="collection-perk-icon" aria-hidden="true">{% render 'icon', name: 'shield' %}</span>
              <div class="collection-perk-copy"><strong>Secure payment</strong><span>Your payment information is processed securely.</span></div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

  {%- if collection.filters.size > 0 or section.settings.show_sort -%}
    <div class="collection-mobile-bar" aria-label="Filter and sort" role="toolbar">
      {%- if collection.filters.size > 0 -%}
        <button type="button"
                class="collection-mobile-bar__btn collection-filter-toggle"
                aria-label="Open filters"
                aria-controls="collection-filters">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Filter
        </button>
      {%- endif -%}
      {%- if section.settings.show_sort -%}
        <button type="button"
                class="collection-mobile-bar__btn"
                id="collection-mobile-sort-btn"
                aria-label="Sort products">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 5h8M2 8h5M2 11h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M11 3v10M9 11l2 2 2-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Sort
        </button>
        <script>
        (function() {
          var sortBtn = document.getElementById('collection-mobile-sort-btn');
          var sortSelect = document.getElementById('CollectionSort');
          if (sortBtn && sortSelect) {
            sortBtn.addEventListener('click', function() { sortSelect.focus(); sortSelect.click(); });
          }
        })();
        </script>
      {%- endif -%}
    </div>
  {%- endif -%}

{% endpaginate %}

