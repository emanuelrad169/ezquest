        </div>{% comment %} /collection-main {% endcomment %}
      </div>{% comment %} /collection-layout {% endcomment %}
    </div>{% comment %} /container-shell {% endcomment %}

    <script src="{{ 'collection-filter.js' | asset_url }}" defer></script>
    <script>
    (function() {
      'use strict';

      /* ── AJAX filter / sort ── */
      var collectionGrid = document.getElementById('collection-grid');
      if (!collectionGrid) return;

      var currentRequest = null;

      function showSkeleton() {
        collectionGrid = document.getElementById('collection-grid');
        if (!collectionGrid) return;
        Array.from(collectionGrid.children).forEach(function(item) {
          item.style.opacity = '0.4';
          item.style.pointerEvents = 'none';
        });
        collectionGrid.setAttribute('aria-busy', 'true');
      }

      function hideSkeleton() {
        collectionGrid = document.getElementById('collection-grid');
        if (!collectionGrid) return;
        Array.from(collectionGrid.children).forEach(function(item) {
          item.style.opacity = '';
          item.style.pointerEvents = '';
        });
        collectionGrid.setAttribute('aria-busy', 'false');
      }

      function buildUrl() {
        var filterForm = document.getElementById('collection-filter-form');
        if (!filterForm) return window.location.pathname;
        var formData = new FormData(filterForm);
        var params = new URLSearchParams(formData);
        var sortSelect = document.getElementById('CollectionSort');
        if (sortSelect && sortSelect.value) params.set('sort_by', sortSelect.value);
        var toDelete = [];
        params.forEach(function(v, k) { if (!v) toDelete.push(k); });
        toDelete.forEach(function(k) { params.delete(k); });
        return window.location.pathname + '?' + params.toString();
      }

      function replaceFromResponse(doc, selector) {
        var current = document.querySelector(selector);
        var next = doc.querySelector(selector);
        if (current && next) current.innerHTML = next.innerHTML;
      }

      function fetchFilteredProducts(url) {
        if (currentRequest) currentRequest.abort();
        showSkeleton();
        var controller = new AbortController();
        currentRequest = controller;

        fetch(url + (url.indexOf('?') > -1 ? '&' : '?') + 'sections=main', {
          signal: controller.signal
        })
        .then(function(response) {
          if (!response.ok) throw new Error('filter-fetch-failed');
          return response.json();
        })
        .then(function(data) {
          if (data['main']) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(data['main'], 'text/html');
            var newGrid = doc.getElementById('collection-grid');
            if (newGrid) {
              collectionGrid = document.getElementById('collection-grid');
              collectionGrid.innerHTML = newGrid.innerHTML;
              collectionGrid.className = newGrid.className;
            }
            replaceFromResponse(doc, '#collection-filters');
            replaceFromResponse(doc, '.collection-filter-toolbar');
            if (window.EZCollectionFilter && window.EZCollectionFilter.refresh) {
              window.EZCollectionFilter.refresh();
            }
            if (window.EZReveal) {
              collectionGrid.querySelectorAll('.reveal-on-scroll').forEach(function(el) {
                window.EZReveal.observe(el);
              });
            }
          } else {
            window.location.href = url;
          }
        })
        .catch(function(err) {
          if (err.name === 'AbortError') return;
          window.location.href = url;
        })
        .finally(function() {
          hideSkeleton();
          currentRequest = null;
        });

        history.pushState({}, '', url);
        collectionGrid = document.getElementById('collection-grid');
        var gridTop = collectionGrid.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: gridTop, behavior: 'smooth' });
      }

      document.addEventListener('change', function(e) {
        if (e.target.closest('#collection-filter-form') && e.target.type === 'checkbox') {
          fetchFilteredProducts(buildUrl());
        }
      });

      document.addEventListener('click', function(e) {
        var priceApply = e.target.closest('.collection-filter-price__apply');
        if (!priceApply) return;
        e.preventDefault();
        fetchFilteredProducts(buildUrl());
      });

      document.addEventListener('change', function(e) {
        if (e.target && e.target.id === 'CollectionSort') {
          fetchFilteredProducts(buildUrl());
        }
      });

      document.addEventListener('click', function(e) {
        var pill = e.target.closest('.collection-active-filter');
        if (!pill) return;
        e.preventDefault();
        var href = pill.getAttribute('href');
        if (href) fetchFilteredProducts(href);
      });

      document.addEventListener('click', function(e) {
        var clearLink = e.target.closest('.collection-filters__clear, .filter-clear-all, .collection-filters__footer-clear');
        if (!clearLink) return;
        e.preventDefault();
        var href = clearLink.getAttribute('href');
        if (href) fetchFilteredProducts(href);
      });

      window.addEventListener('popstate', function() {
        fetchFilteredProducts(window.location.href);
      });

    })();
    </script>

    {%- liquid
      assign banner_eyebrow = section.settings.banner_eyebrow | default: collection.title
      assign banner_heading = section.settings.banner_heading | default: collection.title
      assign banner_copy = section.settings.banner_copy | default: collection.description
    -%}
    <div class="collection-editorial-banner-shell" data-ceb-root>
      <div class="collection-editorial-banner{% if section.settings.banner_image == blank %} collection-editorial-banner--no-image{% endif %}" data-ceb-banner>
        <div class="collection-editorial-banner-media" data-ceb-media>
          {% if section.settings.banner_image != blank %}
            {{ section.settings.banner_image | image_url: width: 2800 | image_tag: loading: 'lazy', fetchpriority: 'low', class: 'collection-editorial-banner-img' }}
          {% endif %}
        </div>
        <div class="collection-editorial-banner-overlay"></div>
        <div class="container-shell collection-editorial-banner-inner">
          <div class="collection-editorial-banner-copy" data-ceb-copy>
            <div class="collection-editorial-banner-copy-inner">
              {% if banner_eyebrow != blank %}
                <p class="collection-editorial-banner-eyebrow" data-ceb-item>{{ banner_eyebrow }}</p>
              {% endif %}
              {% if banner_heading != blank %}
                <h2 class="collection-editorial-banner-heading" data-ceb-item>{{ banner_heading }}</h2>
              {% endif %}
              {% if banner_copy != blank %}
                <p class="collection-editorial-banner-text" data-ceb-item>{{ banner_copy }}</p>
              {% endif %}
              <div class="collection-editorial-banner-actions" data-ceb-item>
                <a href="{{ collection.url }}" class="collection-editorial-banner-cta">
                  Shop {{ collection.title }}
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="/pages/compare" class="collection-editorial-banner-link">Compare lineup</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <script>
      (function () {
        var root = document.currentScript.closest('[data-ceb-root]');
        if (!root) return;
        var banner = root.querySelector('[data-ceb-banner]');
        var media  = root.querySelector('[data-ceb-media]');
        var copy   = root.querySelector('[data-ceb-copy]');
        var items  = root.querySelectorAll('[data-ceb-item]');

        /* ── Parallax ── */
        if (media && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          function onScroll() {
            var rect = banner.getBoundingClientRect();
            var vh   = window.innerHeight;
            if (rect.bottom < 0 || rect.top > vh) return;
            var progress = (vh - rect.top) / (vh + rect.height);
            media.style.transform = 'translateY(' + ((progress - 0.5) * 70) + 'px)';
          }
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        }

        /* ── Entrance animation via IntersectionObserver ── */
        if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) return;
              items.forEach(function (el, i) {
                el.style.transitionDelay = (0.08 + i * 0.1) + 's';
                el.classList.add('is-visible');
              });
              io.unobserve(entry.target);
            });
          }, { threshold: 0.15 });
          if (copy) io.observe(copy);
        } else {
          items.forEach(function (el) { el.classList.add('is-visible'); });
        }
      }());
      </script>

