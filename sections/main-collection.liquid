{% paginate collection.products by section.settings.products_per_page %}
  <section class="section-shell">
    <div class="container-shell">
      {% render 'breadcrumbs' %}
      {%- liquid
        assign intro_copy = section.settings.intro_copy | default: collection.description
        assign category_label = 'Product family'
        assign category_statement = 'Choose the EZQuest family that matches the setup, then narrow the right ports, power, and footprint.'
        assign category_support_note = 'Use compare or support only when you want a final confirmation.'
        assign category_decision_note = 'Choose this family when the setup already points in a clear direction.'
        assign category_stat_one = 'Built for cleaner workflows'
        assign category_stat_two = 'Engineered to reduce setup friction'
        assign category_stat_three = 'Setup help after purchase'
        assign collection_visual = blank
        assign lead_product = collection.products.first
        assign fallback_product_handles = blank
        assign fallback_visible_count = 0

        if intro_copy == blank
          case collection.handle
            when 'hubs-adapters'
              assign intro_copy = 'USB-C hubs and adapters for everyday expansion, presentations, travel setups, and lighter single-cable upgrades.'
            when 'docking-stations'
              assign intro_copy = 'Desk-ready docks that bring displays, charging, Ethernet, and peripherals into one calmer workstation footprint.'
            when 'chargers-power'
              assign intro_copy = 'Charging essentials built for cleaner travel kits, lighter desk charging, and reliable everyday power.'
            when 'accessories'
              assign intro_copy = 'Charge-and-sync cables and finishing accessories that make the setup feel complete, dependable, and easier to live with.'
            else
              assign intro_copy = 'Browse the EZQuest family that best matches your ports, power, charging, and workflow needs.'
          endcase
        endif

        case collection.handle
          when 'hubs-adapters'
            assign category_label = 'Hybrid + travel'
            assign category_statement = 'Hubs and adapters for everyday expansion, portable desks, presentations, and lighter single-display setups.'
            assign category_support_note = 'Best for portable desks, presentations, and everyday expansion.'
            assign category_decision_note = 'Choose hubs and adapters when flexibility matters more than a permanent workstation footprint.'
            assign category_stat_one = 'Everyday port expansion'
            assign category_stat_two = 'Travel-to-desk flexibility'
            assign category_stat_three = 'Single-cable simplicity'
            assign fallback_product_handles = 'usb-c-multimedia-hub,usb-c-travel-hub'
          when 'docking-stations'
            assign category_label = 'Desk command'
            assign category_statement = 'Docking stations for permanent desks that need displays, Ethernet, charging, and a calmer workstation footprint.'
            assign category_support_note = 'Best for stepping up from smaller hubs into a more complete desk setup.'
            assign category_decision_note = 'Choose docking stations when the desk stays put and the workflow needs more authority.'
            assign category_stat_one = 'Permanent desk control'
            assign category_stat_two = 'Display + Ethernet ready'
            assign category_stat_three = 'Stronger workstation fit'
            assign fallback_product_handles = 'usb-c-pro-dock'
          when 'chargers-power'
            assign category_label = 'Power layer'
            assign category_statement = 'Charging products that keep travel kits, home desks, and multi-device routines lighter, faster, and less cluttered.'
            assign category_support_note = 'Best when charging matters before port count does.'
            assign category_decision_note = 'Choose chargers and power when the setup works, but the charging layer still needs to be cleaner and more reliable.'
            assign category_stat_one = 'Travel and desk charging'
            assign category_stat_two = 'Less charger clutter'
            assign category_stat_three = 'Multi-device routines'
          when 'accessories'
            assign category_label = 'Finish the setup'
            assign category_statement = 'Cables and finishing pieces that make the setup feel complete, dependable, and easier to live with every day.'
            assign category_support_note = 'Best for tightening cable paths, replacing weak links, and finishing the setup cleanly.'
            assign category_decision_note = 'Choose accessories when the last layer of the setup still needs cleaner routing or a more dependable final piece.'
            assign category_stat_one = 'Cleaner cable paths'
            assign category_stat_two = 'Reliable daily accessories'
            assign category_stat_three = 'Finishing-layer utility'
        endcase

        if lead_product == blank and fallback_product_handles != blank
          assign fallback_handle_list = fallback_product_handles | split: ','
          for fallback_handle in fallback_handle_list
            assign fallback_product = all_products[fallback_handle]
            if fallback_product != blank
              assign fallback_visible_count = fallback_visible_count | plus: 1
              if lead_product == blank
                assign lead_product = fallback_product
              endif
            endif
          endfor
        endif

        if section.settings.show_collection_image and collection.image != blank
          assign collection_visual = collection.image
        endif
      -%}

      <header class="collection-hero{% if collection_visual == blank %} collection-hero--simple{% endif %}">
        <div class="collection-hero-copy">
          {% if section.settings.eyebrow != blank %}
            <p class="section-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <p class="collection-hero-label">{{ category_label }}</p>
          <h1 class="section-heading">{{ section.settings.intro_heading | default: collection.title }}</h1>
          <p class="collection-hero-statement">{{ category_statement }}</p>
          {% if intro_copy != blank %}
            <p class="section-copy">{{ intro_copy | strip_html | truncatewords: 26 }}</p>
          {% endif %}
          <p class="collection-hero-decision-note">{{ category_decision_note }}</p>

          <div class="merch-stat-grid">
            <div class="merch-stat-card">{{ category_stat_one }}</div>
            <div class="merch-stat-card">{{ category_stat_two }}</div>
            <div class="merch-stat-card">{{ category_stat_three }}</div>
          </div>

          <div class="collection-hero-footer">
            <p class="collection-hero-note">{{ category_support_note }}</p>
            <div class="collection-inline-support" aria-label="Collection helpers">
              <a href="/pages/compare" class="collection-inline-link">Compare nearby options</a>
              <a href="{{ section.settings.support_url | default: '/pages/support' }}" class="collection-inline-link">Need help choosing the right setup?</a>
            </div>
          </div>
        </div>

        <div class="collection-hero-side">
          {% if collection_visual != blank %}
            {{ collection_visual | image_url: width: 900 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'collection-hero-image' }}
          {% else %}
            {% render 'owned-collection-visual',
              collection_handle: collection.handle,
              collection_title: collection.title,
              width: 1200,
              height: 900,
              class: 'collection-hero-image',
              loading: 'eager',
              fetchpriority: 'high'
            %}
          {% endif %}
          {% if lead_product != blank %}
            <div class="collection-hero-lead-product">
              <p class="collection-hero-lead-kicker">First pick</p>
              <h2 class="collection-hero-lead-title">{{ lead_product.title }}</h2>
              {% if lead_product.metafields.ezquest.feature_highlights != blank and lead_product.metafields.ezquest.feature_highlights.value.count > 0 %}
                <p class="collection-hero-lead-copy">{{ lead_product.metafields.ezquest.feature_highlights.value.first }}</p>
              {% elsif lead_product.metafields.ezquest.compatibility_summary != blank %}
                <p class="collection-hero-lead-copy">{{ lead_product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | truncatewords: 14 }}</p>
              {% endif %}
              <a href="{{ lead_product.url }}" class="collection-inline-link">See first pick</a>
            </div>
          {% endif %}
        </div>
      </header>

      <div class="collection-toolbar">
        <p class="collection-results-label">Showing {% if collection.products_count > 0 %}{{ collection.products_count }}{% else %}{{ fallback_visible_count }}{% endif %} products</p>

        <div class="collection-toolbar-actions">
          {% if section.settings.show_sort %}
            <form method="get" class="collection-sort-form">
              <label class="sr-only" for="CollectionSort">Sort</label>
              <select id="CollectionSort" name="sort_by" class="collection-sort-select" onchange="this.form.submit()">
                {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                {% for option in collection.sort_options %}
                  <option value="{{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name }}</option>
                {% endfor %}
              </select>
            </form>
          {% endif %}

          <p class="collection-toolbar-note">Compare nearby options if the choice is still close. Support is here if you want a final confirmation.</p>
        </div>
      </div>

      <div class="collection-shopping-note" aria-label="Collection guidance">
        <p class="collection-shopping-note-kicker">Category confidence</p>
        <p class="collection-shopping-note-copy">{{ category_support_note }}</p>
        <div class="collection-inline-support">
          <a href="/pages/compare" class="collection-inline-link">Compare nearby options</a>
          <a href="{{ section.settings.support_url | default: '/pages/support' }}" class="collection-inline-link">Get setup help</a>
        </div>
      </div>

      <div class="section-stack-lg product-grid">
        {% for product in collection.products %}
          <div class="collection-product-slot{% if forloop.first %} is-lead{% elsif forloop.index == 2 %} is-secondary{% endif %}">
            {% render 'card-product', product: product, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
          </div>
        {% else %}
          {% if fallback_visible_count > 0 %}
            {% assign fallback_handle_list = fallback_product_handles | split: ',' %}
            {% for fallback_handle in fallback_handle_list %}
              {% assign fallback_product = all_products[fallback_handle] %}
              {% if fallback_product != blank %}
                <div class="collection-product-slot{% if forloop.first %} is-lead{% elsif forloop.index == 2 %} is-secondary{% endif %}">
                  {% render 'card-product', product: fallback_product, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="panel-primary md:col-span-2 xl:col-span-4">
              <p class="section-kicker">Collection</p>
              <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">This product family is being merchandised now.</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">Browse all product families, compare the core lineup, or open support if you want help choosing the right product.</p>
              <div class="mt-6 flex flex-wrap items-center gap-3">
                <a href="{{ routes.collections_url }}" class="button-secondary">Browse product families</a>
                <a href="/pages/compare" class="site-meta-link">Compare core products</a>
                <a href="/pages/support" class="site-meta-link">Open support center</a>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="mt-12 flex items-center justify-center gap-3" aria-label="Pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="button-secondary">Previous</a>
          {% endif %}
          <span class="text-sm font-medium uppercase tracking-wide text-slate-500">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="button-secondary">Next</a>
          {% endif %}
        </nav>
      {% endif %}
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Heading override"
    },
    {
      "type": "textarea",
      "id": "intro_copy",
      "label": "Description override"
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support panel heading",
      "default": "Need help choosing the right fit?"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support panel link"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sorting controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    }
  ]
}
{% endschema %}
