{% paginate collection.products by section.settings.products_per_page %}
  {%- liquid
        assign intro_copy = section.settings.intro_copy | default: collection.description
        assign category_label = section.settings.eyebrow | default: 'Product family'
        assign category_statement = 'Find the EZQuest family with the right ports, power, and footprint.'
        assign category_stat_one = 'Cleaner setups'
        assign category_stat_two = 'Reliable fit'
        assign category_stat_three = 'Support close'
        assign collection_visual = blank
        assign lead_product = collection.products.first
        assign lead_price = blank
        assign fallback_product_handles = blank
        assign fallback_visible_count = 0
        assign total_visible_products = collection.products_count
        assign promo_handle = blank
        assign promo_eyebrow = 'Next step'
        assign promo_title = blank
        assign promo_copy = blank
        assign promo_link_label = blank
        assign promo_insert_index = 4
        assign family_handle_list = 'hubs-adapters|docking-stations|chargers-power|accessories' | split: '|'

        if intro_copy == blank
          case collection.handle
            when 'hubs-adapters'
              assign intro_copy = 'USB-C hubs and adapters for lighter desks, travel kits, and everyday expansion.'
            when 'docking-stations'
              assign intro_copy = 'Desk-ready docks that bring displays, charging, Ethernet, and peripherals into one cleaner footprint.'
            when 'chargers-power'
              assign intro_copy = 'Charging essentials for lighter travel kits, cleaner desks, and reliable everyday power.'
            when 'accessories'
              assign intro_copy = 'Cables and finishing pieces that make the setup feel complete and dependable.'
            else
              assign intro_copy = 'EZQuest products with the right mix of ports, power, and fit.'
          endcase
        endif

        case collection.handle
          when 'hubs-adapters'
            assign category_label = 'Hybrid + travel'
            assign category_statement = 'Everyday expansion for travel, hybrid desks, and lighter display setups.'
            assign category_stat_one = 'Everyday expansion'
            assign category_stat_two = 'Travel ready'
            assign category_stat_three = 'Single-cable ease'
            assign fallback_product_handles = 'usb-c-multimedia-hub,usb-c-travel-hub'
            assign promo_handle = 'docking-stations'
            assign promo_title = 'Ready for a full desk?'
            assign promo_copy = 'See the docks built for displays, Ethernet, charging, and a cleaner desk.'
            assign promo_link_label = 'View docking stations'
          when 'docking-stations'
            assign category_label = 'Desk command'
            assign category_statement = 'Docking stations for permanent desks that need displays, Ethernet, charging, and control.'
            assign category_stat_one = 'Desk control'
            assign category_stat_two = 'Display + Ethernet'
            assign category_stat_three = 'Workstation power'
            assign fallback_product_handles = 'usb-c-pro-dock'
            assign promo_handle = 'chargers-power'
            assign promo_title = 'Power, refined'
            assign promo_copy = 'Pair the desk with chargers and power accessories that keep every device ready.'
            assign promo_link_label = 'View chargers and power'
          when 'chargers-power'
            assign category_label = 'Power layer'
            assign category_statement = 'Charging products for cleaner travel kits, desks, and multi-device routines.'
            assign category_stat_one = 'Fast charging'
            assign category_stat_two = 'Less charger clutter'
            assign category_stat_three = 'Multi-device ready'
            assign promo_handle = 'accessories'
            assign promo_title = 'Finish the setup'
            assign promo_copy = 'Add the cables and accessories that keep power clean and dependable.'
            assign promo_link_label = 'View accessories'
          when 'accessories'
            assign category_label = 'Finish the setup'
            assign category_statement = 'Cables and finishing pieces that make the setup feel complete and dependable.'
            assign category_stat_one = 'Clean cable runs'
            assign category_stat_two = 'Daily reliability'
            assign category_stat_three = 'Refined finish'
            assign promo_handle = 'hubs-adapters'
            assign promo_title = 'Expand the setup'
            assign promo_copy = 'Add hubs and adapters when the setup needs more ports and more reach.'
            assign promo_link_label = 'View hubs and adapters'
        endcase

        if lead_product == blank and fallback_product_handles != blank
          assign fallback_handle_list = fallback_product_handles | split: ','
          for fallback_handle in fallback_handle_list
            assign fallback_product = all_products[fallback_handle]
            if fallback_product != blank
              assign fallback_visible_count = fallback_visible_count | plus: 1
              if lead_product == blank
                assign lead_product = fallback_product
              endif
            endif
          endfor
        endif

        if total_visible_products == 0
          assign total_visible_products = fallback_visible_count
        endif

        if lead_product != blank and lead_product.selected_or_first_available_variant != blank
          assign lead_price = lead_product.selected_or_first_available_variant.price | money
        endif

        if total_visible_products < promo_insert_index
          assign promo_insert_index = 2
        endif

        if section.settings.show_collection_image
          if collection.image != blank
            assign collection_visual = collection.image
          elsif lead_product != blank and lead_product.images.size > 0
            assign collection_candidate_image = lead_product.featured_image | default: lead_product.images.first
            assign collection_best_image = blank
            assign collection_non_technical_image = blank
            assign collection_ratio_image = blank

            for candidate_image in lead_product.images
              assign candidate_alt = candidate_image.alt | downcase
              assign candidate_is_technical = false
              assign candidate_has_preferred_ratio = false

              if candidate_alt contains 'illustration'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'diagram'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'schematic'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'placeholder'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'port'
                assign candidate_is_technical = true
              elsif candidate_alt contains 'icon'
                assign candidate_is_technical = true
              endif

              if candidate_image.aspect_ratio >= 1.0 and candidate_image.aspect_ratio <= 1.9
                assign candidate_has_preferred_ratio = true
              endif

              if collection_best_image == blank and candidate_is_technical == false and candidate_has_preferred_ratio
                assign collection_best_image = candidate_image
              endif

              if collection_non_technical_image == blank and candidate_is_technical == false
                assign collection_non_technical_image = candidate_image
              endif

              if collection_ratio_image == blank and candidate_has_preferred_ratio
                assign collection_ratio_image = candidate_image
              endif
            endfor

            assign collection_visual = collection_best_image | default: collection_non_technical_image | default: collection_ratio_image | default: collection_candidate_image
          endif

          if collection_visual == blank
            for browse_product in collection.products limit: 4
              if browse_product.images.size > 0
                assign collection_candidate_image = browse_product.featured_image | default: browse_product.images.first
                assign collection_best_image = blank
                assign collection_non_technical_image = blank
                assign collection_ratio_image = blank

                for candidate_image in browse_product.images
                  assign candidate_alt = candidate_image.alt | downcase
                  assign candidate_is_technical = false
                  assign candidate_has_preferred_ratio = false

                  if candidate_alt contains 'illustration'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'diagram'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'schematic'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'placeholder'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'port'
                    assign candidate_is_technical = true
                  elsif candidate_alt contains 'icon'
                    assign candidate_is_technical = true
                  endif

                  if candidate_image.aspect_ratio >= 1.0 and candidate_image.aspect_ratio <= 1.9
                    assign candidate_has_preferred_ratio = true
                  endif

                  if collection_best_image == blank and candidate_is_technical == false and candidate_has_preferred_ratio
                    assign collection_best_image = candidate_image
                  endif

                  if collection_non_technical_image == blank and candidate_is_technical == false
                    assign collection_non_technical_image = candidate_image
                  endif

                  if collection_ratio_image == blank and candidate_has_preferred_ratio
                    assign collection_ratio_image = candidate_image
                  endif
                endfor

                assign collection_visual = collection_best_image | default: collection_non_technical_image | default: collection_ratio_image | default: collection_candidate_image
              endif

              if collection_visual != blank
                break
              endif
            endfor
          endif
        endif
      -%}
  <section class="section-shell pt-0">
    <div class="collection-showcase-shell">
      <header class="collection-showcase">
        <div class="collection-showcase-media">
          {% if collection_visual != blank %}
            {{ collection_visual | image_url: width: 1800 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'collection-showcase-image' }}
          {% else %}
            {% render 'owned-collection-visual',
              collection_handle: collection.handle,
              collection_title: collection.title,
              width: 1800,
              height: 1200,
              class: 'collection-showcase-image',
              loading: 'eager',
              fetchpriority: 'high'
            %}
          {% endif %}
        </div>
        <div class="collection-showcase-scrim" aria-hidden="true"></div>
        <div class="container-shell collection-showcase-inner">
          <div class="collection-showcase-copy">
            <div class="collection-showcase-copy-shell">
              <nav class="collection-showcase-breadcrumb" aria-label="Breadcrumb">
                <a href="{{ routes.root_url }}">Home</a>
                <span>/</span>
                <a href="{{ routes.collections_url }}">Collections</a>
                <span>/</span>
                <span>{{ collection.title }}</span>
              </nav>

              <div class="space-y-4">
                <p class="collection-showcase-label">{{ category_label }}</p>
                <h1 class="collection-showcase-heading">{{ section.settings.intro_heading | default: collection.title }}</h1>
                <p class="collection-showcase-statement">{{ category_statement }}</p>
              </div>

              <div class="collection-showcase-actions">
                {% if lead_product != blank %}
                  <a href="{{ lead_product.url }}" class="collection-showcase-action">View {{ lead_product.title }}</a>
                {% else %}
                  <a href="{{ routes.all_products_collection_url }}" class="collection-showcase-action">View featured picks</a>
                {% endif %}
              </div>
            </div>
          </div>

          <div class="collection-showcase-side">
            {% if lead_product != blank %}
              <a href="{{ lead_product.url }}" class="collection-showcase-lead">
                <div class="collection-showcase-lead-top">
                  <p class="collection-showcase-lead-kicker">Lead pick</p>
                </div>
                {% if lead_product != blank %}
                  <div class="collection-showcase-lead-media">
                    {% render 'product-browse-media',
                      product: lead_product,
                      context: 'collection',
                      variant: 'compare',
                      width: 960,
                      height: 720,
                      class: 'collection-showcase-lead-image'
                    %}
                  </div>
                {% endif %}
                <h2 class="collection-showcase-lead-title">{{ lead_product.title }}</h2>
                {% if lead_product.metafields.ezquest.feature_highlights != blank and lead_product.metafields.ezquest.feature_highlights.value.count > 0 %}
                  <p class="collection-showcase-lead-copy">{{ lead_product.metafields.ezquest.feature_highlights.value.first }}</p>
                {% elsif lead_product.metafields.ezquest.compatibility_summary != blank %}
                  <p class="collection-showcase-lead-copy">{{ lead_product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | truncatewords: 14 }}</p>
                {% endif %}
                <div class="collection-showcase-lead-footer">
                  {% if lead_price != blank %}
                    <span class="collection-showcase-lead-price">{{ lead_price }}</span>
                  {% endif %}
                  <span class="collection-showcase-lead-link">View product</span>
                </div>
              </a>
            {% endif %}
          </div>

        </div>
      </header>
    </div>

    <div class="container-shell">
      <div class="collection-merch-layer relative z-20 -mt-5 lg:-mt-8">
        <div class="collection-merch-bar flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="collection-merch-left flex flex-col gap-4 lg:flex-row lg:items-center lg:gap-5">
            <nav class="collection-family-tabs -mx-1 flex-nowrap overflow-x-auto px-1 pb-1 lg:mx-0 lg:flex-wrap lg:overflow-visible lg:px-0 lg:pb-0" aria-label="Collection families">
              {% for family_handle in family_handle_list %}
                {% assign family_collection = collections[family_handle] %}
                {% if family_collection != blank %}
                  <a href="{{ family_collection.url }}" class="collection-family-tab shrink-0{% if family_handle == collection.handle %} is-active{% endif %}"{% if family_handle == collection.handle %} aria-current="page"{% endif %}>
                    <span>{{ family_collection.title }}</span>
                    <sup>{{ family_collection.products_count }}</sup>
                  </a>
                {% endif %}
              {% endfor %}
            </nav>
          </div>

          <div class="collection-merch-right flex flex-wrap items-center gap-3 lg:gap-4">
            <div class="collection-merch-summary">
              <span class="collection-merch-count-pill">{{ total_visible_products }} products</span>
            </div>
            {% if section.settings.show_sort %}
              <form method="get" class="collection-sort-form">
                <label class="collection-sort-label" for="CollectionSort">Sort by</label>
                <select id="CollectionSort" name="sort_by" class="collection-sort-select" onchange="this.form.submit()">
                  {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
              </form>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="collection-showcase-stat-row collection-showcase-stat-row--after-hero" aria-label="Collection highlights">
        <span class="collection-showcase-stat">{{ category_stat_one }}</span>
        <span class="collection-showcase-stat">{{ category_stat_two }}</span>
        <span class="collection-showcase-stat">{{ category_stat_three }}</span>
      </div>

      <div class="section-stack-lg collection-showroom-grid mt-10 grid gap-5 md:grid-cols-2 md:gap-6 lg:mt-12 lg:grid-cols-3 xl:grid-cols-4 xl:gap-7">
        {% assign promo_inserted = false %}
        {% for product in collection.products %}
          {% assign showroom_slot_mod = forloop.index | modulo: 6 %}
          <div class="collection-product-slot{% if showroom_slot_mod == 2 %} collection-product-slot--offset{% elsif showroom_slot_mod == 5 %} collection-product-slot--settled{% endif %}">
            {% render 'card-product', product: product, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
          </div>
          {% if promo_inserted == false and promo_handle != blank and forloop.index == promo_insert_index %}
            {% render 'collection-promo-tile',
              promo_handle: promo_handle,
              promo_eyebrow: promo_eyebrow,
              promo_title: promo_title,
              promo_copy: promo_copy,
              promo_link_label: promo_link_label
            %}
            {% assign promo_inserted = true %}
          {% endif %}
        {% else %}
          {% if fallback_visible_count > 0 %}
            {% assign fallback_handle_list = fallback_product_handles | split: ',' %}
            {% for fallback_handle in fallback_handle_list %}
              {% assign fallback_product = all_products[fallback_handle] %}
              {% if fallback_product != blank %}
                {% assign showroom_slot_mod = forloop.index | modulo: 6 %}
                <div class="collection-product-slot{% if showroom_slot_mod == 2 %} collection-product-slot--offset{% elsif showroom_slot_mod == 5 %} collection-product-slot--settled{% endif %}">
                  {% render 'card-product', product: fallback_product, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
                </div>
                {% if promo_inserted == false and promo_handle != blank and forloop.index == promo_insert_index %}
                  {% render 'collection-promo-tile',
                    promo_handle: promo_handle,
                    promo_eyebrow: promo_eyebrow,
                    promo_title: promo_title,
                    promo_copy: promo_copy,
                    promo_link_label: promo_link_label
                  %}
                  {% assign promo_inserted = true %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="panel-primary md:col-span-2 xl:col-span-4">
              <p class="section-kicker">Collection</p>
              <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">This collection is being refined.</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">View all families, compare the lineup, or get product guidance.</p>
              <div class="mt-6 flex flex-wrap items-center gap-3">
                <a href="{{ routes.collections_url }}" class="button-secondary">View all families</a>
                <a href="/pages/compare" class="site-meta-link">Compare models</a>
                <a href="/pages/support" class="site-meta-link">Product guidance</a>
              </div>
            </div>
          {% endif %}
        {% endfor %}
        {% if promo_inserted == false and promo_handle != blank %}
          {% render 'collection-promo-tile',
            promo_handle: promo_handle,
            promo_eyebrow: promo_eyebrow,
            promo_title: promo_title,
            promo_copy: promo_copy,
            promo_link_label: promo_link_label
          %}
        {% endif %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="mt-12 flex items-center justify-center gap-3" aria-label="Pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="button-secondary">Previous</a>
          {% endif %}
          <span class="text-sm font-medium uppercase tracking-wide text-slate-500">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="button-secondary">Next</a>
          {% endif %}
        </nav>
      {% endif %}
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Heading override"
    },
    {
      "type": "textarea",
      "id": "intro_copy",
      "label": "Description override"
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support panel heading",
      "default": "Product guidance"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support panel link"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sorting controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    }
  ]
}
{% endschema %}
