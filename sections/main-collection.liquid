{% paginate collection.products by section.settings.products_per_page %}
  <section class="section-shell">
    <div class="container-shell">
      {% render 'breadcrumbs' %}

      <header class="collection-hero{% unless section.settings.show_collection_image and collection.image != blank %} collection-hero--simple{% endunless %}">
        <div class="collection-hero-copy">
          {%- liquid
            assign intro_copy = section.settings.intro_copy | default: collection.description
            if intro_copy == blank
              case collection.handle
                when 'hubs-adapters'
                  assign intro_copy = 'USB-C hubs and adapters for everyday port expansion, presentations, travel setups, and single-cable productivity upgrades.'
                when 'docking-stations'
                  assign intro_copy = 'Desk-ready docks that simplify displays, charging, Ethernet, and everyday workstation connectivity.'
                when 'chargers-power'
                  assign intro_copy = 'Wall chargers and power essentials designed for cleaner travel kits, desktop charging, and reliable everyday use.'
                when 'accessories'
                  assign intro_copy = 'Charge-and-sync cables and practical accessories that finish the setup with dependable everyday connectivity.'
                else
                  assign intro_copy = 'Browse the EZQuest product family that best matches your ports, power, charging, and workflow needs.'
              endcase
            endif
          -%}
          {% if section.settings.eyebrow != blank %}
            <p class="section-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <h1 class="section-heading">{{ section.settings.intro_heading | default: collection.title }}</h1>
          {% if intro_copy != blank %}
            <p class="section-copy">{{ intro_copy | strip_html | truncatewords: 20 }}</p>
          {% endif %}
        </div>

        <div class="collection-hero-side">
          {% if section.settings.show_collection_image and collection.image != blank %}
            {{ collection.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'collection-hero-image' }}
          {% endif %}
        </div>
      </header>

      <div class="collection-toolbar">
        <p class="collection-results-label">Showing {{ collection.products_count }} products</p>

        <div class="collection-toolbar-actions">
          {% if section.settings.show_sort %}
            <form method="get" class="collection-sort-form">
              <label class="sr-only" for="CollectionSort">Sort</label>
              <select id="CollectionSort" name="sort_by" class="collection-sort-select" onchange="this.form.submit()">
                {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                {% for option in collection.sort_options %}
                  <option value="{{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name }}</option>
                {% endfor %}
              </select>
            </form>
          {% endif %}

          <div class="collection-inline-support" aria-label="Collection helpers">
            <a href="/pages/compare" class="collection-inline-link">Compare nearby options</a>
            <a href="{{ section.settings.support_url | default: '/pages/support' }}" class="collection-inline-link">Need help choosing the right setup?</a>
          </div>
        </div>
      </div>

      <div class="section-stack-lg product-grid">
        {% for product in collection.products %}
          {% render 'card-product', product: product, card_style: 'featured-strip', card_index: forloop.index0 %}
        {% else %}
          <div class="panel-primary md:col-span-2 xl:col-span-4">
            <p class="section-kicker">Collection</p>
            <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">This product family is being merchandised now.</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">Browse the full catalog, compare nearby products, or move into support if you need help choosing the right EZQuest setup.</p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <a href="{{ routes.all_products_collection_url }}" class="button-secondary">Browse all products</a>
              <a href="/pages/compare" class="site-meta-link">Compare options</a>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="mt-12 flex items-center justify-center gap-3" aria-label="Pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="button-secondary">Previous</a>
          {% endif %}
          <span class="text-sm font-medium uppercase tracking-wide text-slate-500">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="button-secondary">Next</a>
          {% endif %}
        </nav>
      {% endif %}
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Heading override"
    },
    {
      "type": "textarea",
      "id": "intro_copy",
      "label": "Description override"
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support panel heading",
      "default": "Need help choosing the right fit?"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support panel link"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sorting controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    }
  ]
}
{% endschema %}
