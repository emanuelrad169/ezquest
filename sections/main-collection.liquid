{% paginate collection.products by section.settings.products_per_page %}
  <section class="section-shell">
    <div class="container-shell">
      {% render 'breadcrumbs' %}

      <header class="collection-hero">
        <div class="space-y-5">
          {% if section.settings.eyebrow != blank %}
            <p class="section-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <h1 class="section-heading">{{ section.settings.intro_heading | default: collection.title }}</h1>
          {% assign intro_copy = section.settings.intro_copy | default: collection.description %}
          {% if intro_copy != blank %}
            <div class="section-copy">{{ intro_copy }}</div>
          {% endif %}

          <div class="collection-toolbar">
            <p class="text-sm text-slate-500">{{ collection.products_count }} products</p>

            {% if section.settings.show_sort %}
              <form method="get" class="flex items-center gap-3">
                <label class="text-sm text-slate-600" for="CollectionSort">Sort</label>
                <select id="CollectionSort" name="sort_by" class="min-h-11 rounded-full border border-slate-300 px-4 py-2 text-sm" onchange="this.form.submit()">
                  {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
              </form>
            {% endif %}
          </div>
        </div>

        <div class="space-y-4">
          {% if section.settings.show_collection_image and collection.image != blank %}
            {{ collection.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'aspect-[4/3] w-full rounded-3xl border border-slate-200 object-cover' }}
          {% endif %}

          {% if section.settings.show_support_panel %}
            <aside class="section-frame">
              <p class="section-kicker">Need guidance</p>
              <h2 class="mt-3 text-lg font-semibold tracking-tight text-slate-900">{{ section.settings.support_label }}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-600">Use this area for collection-level buying help, compatibility guidance, or a support entry point.</p>
              {% if section.settings.support_url != blank %}
                <div class="mt-5">
                  {% render 'button', label: 'Explore support', url: section.settings.support_url, style: 'secondary' %}
                </div>
              {% endif %}
            </aside>
          {% endif %}
        </div>
      </header>

      <div class="product-grid">
        {% for product in collection.products %}
          {% render 'card-product', product: product %}
        {% else %}
          <div class="card-shell md:col-span-2 xl:col-span-4">No products found in this collection.</div>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="mt-10 flex items-center justify-center gap-3" aria-label="Pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="button-secondary">Previous</a>
          {% endif %}
          <span class="text-sm text-slate-500">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="button-secondary">Next</a>
          {% endif %}
        </nav>
      {% endif %}
    </div>
  </section>
{% endpaginate %}

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collection"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Heading override"
    },
    {
      "type": "textarea",
      "id": "intro_copy",
      "label": "Description override"
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support panel heading",
      "default": "Need help choosing?"
    },
    {
      "type": "url",
      "id": "support_url",
      "label": "Support panel link"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "Show collection image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sorting controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    }
  ]
}
{% endschema %}
