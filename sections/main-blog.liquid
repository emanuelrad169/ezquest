{{ 'pages.css' | asset_url | stylesheet_tag }}

{% comment %} 1. HERO {% endcomment %}
{% assign blog_hero_image = section.settings.hero_image %}
<section class="page-hero-dark{% if blog_hero_image != blank %} page-hero-dark--has-image{% endif %}">
  {% if blog_hero_image != blank %}
    <div class="page-hero-dark__media" aria-hidden="true">
      {{ blog_hero_image | image_url: width: 1800 | image_tag: loading: 'eager', fetchpriority: 'high', alt: '', class: 'page-hero-dark__image' }}
    </div>
  {% endif %}
  <div style="max-width:1280px;margin:0 auto;padding:0 clamp(1.25rem,5vw,5rem);">
    <p class="page-hero-dark__kicker">{{ blog.title }}</p>
    <h1 class="page-hero-dark__heading">Guides, tips &amp; setup help.</h1>
    <p class="page-hero-dark__body">Setup guides, compatibility advice, and buying guidance — everything you need to choose the right EZQuest product and get the most from it.</p>
    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-top:2rem;">
      <span style="font-size:13px;color:rgba(255,255,255,.45);">{{ blog.articles_count }} articles</span>
      <a href="/pages/support" style="font-size:13px;color:var(--ez-amber);text-decoration:none;">Support center →</a>
    </div>
  </div>
</section>

{% comment %} 2. CATEGORY FILTER {% endcomment %}
{% if blog.articles_count > 0 %}
<div style="background:#fff;border-bottom:1px solid #e5e5ea;">
  <div style="max-width:1280px;margin:0 auto;padding:.875rem clamp(1.25rem,5vw,5rem);display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;">
    <a href="{{ blog.url }}" class="filter-pill{% unless current_tags %} is-active{% endunless %}" style="text-decoration:none;">All</a>
    {% for tag in blog.all_tags %}
      <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="filter-pill{% if current_tags contains tag %} is-active{% endif %}" style="text-decoration:none;">{{ tag }}</a>
    {% endfor %}
  </div>
</div>
{% endif %}

{% comment %} 3. FEATURED ARTICLE {% endcomment %}
{% assign featured = blog.articles.first %}
{% if featured != blank %}
<section class="page-section page-section--white" style="padding-top:clamp(40px,5vw,56px);padding-bottom:0;">
  <div style="max-width:1280px;margin:0 auto;padding:0 clamp(1.25rem,5vw,5rem) clamp(40px,5vw,56px);">
    <p style="font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ez-grey);margin-bottom:1.25rem;">Featured</p>
    <a href="{{ featured.url }}" class="article-featured" style="text-decoration:none;">
      <div class="article-featured__image">
        {% if featured.image != blank %}
          {{ featured.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: featured.title }}
        {% elsif section.settings.default_article_image != blank %}
          {{ section.settings.default_article_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: featured.title }}
        {% else %}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--ez-black) 0%,#3a3a3c 100%);display:flex;align-items:center;justify-content:center;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" aria-hidden="true"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
        {% endif %}
      </div>
      <div class="article-featured__body">
        {% if featured.tags.first %}
          <p class="article-card__tag">{{ featured.tags.first }}</p>
        {% else %}
          <p class="article-card__tag">{{ featured.blog.title }}</p>
        {% endif %}
        <h2 class="article-featured__title">{{ featured.title }}</h2>
        <p class="article-featured__excerpt">{{ featured.excerpt_or_content | strip_html | truncatewords: 32 }}</p>
        <div class="article-featured__meta">
          <span>{{ featured.published_at | date: '%B %d, %Y' }}</span>
          <span style="color:var(--ez-amber);font-weight:500;">Read article →</span>
        </div>
      </div>
    </a>
  </div>
</section>
{% endif %}

{% comment %} 4. ARTICLE GRID {% endcomment %}
<section class="page-section page-section--white">
  <div style="max-width:1280px;margin:0 auto;padding:clamp(40px,5vw,56px) clamp(1.25rem,5vw,5rem);">
    {% if blog.articles_count > 1 %}
      {% paginate blog.articles by 9 %}
      <p style="font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ez-grey);margin-bottom:1.5rem;">
        {% if current_tags %}{{ current_tags | join: ' · ' }}{% else %}All articles{% endif %}
      </p>
      <div class="article-grid">
        {% for article in blog.articles %}
          {% unless forloop.first and current_tags == blank %}
            <a href="{{ article.url }}" class="article-card" style="text-decoration:none;">
              <div class="article-card__image">
                {% if article.image != blank %}
                  {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
                {% elsif section.settings.default_article_image != blank %}
                  {{ section.settings.default_article_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
                {% else %}
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--ez-light) 0%,#e5e5ea 100%);display:flex;align-items:center;justify-content:center;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#c7c7cc" stroke-width="1.5" aria-hidden="true"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                  </div>
                {% endif %}
              </div>
              <div class="article-card__body">
                {% if article.tags.first %}
                  <p class="article-card__tag">{{ article.tags.first }}</p>
                {% else %}
                  <p class="article-card__tag">{{ article.blog.title }}</p>
                {% endif %}
                <h3 class="article-card__title">{{ article.title }}</h3>
                <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
                <p class="article-card__date">{{ article.published_at | date: '%B %d, %Y' }}</p>
              </div>
            </a>
          {% endunless %}
        {% endfor %}
      </div>

      {% comment %} Pagination {% endcomment %}
      {% if paginate.pages > 1 %}
        <div style="display:flex;justify-content:center;align-items:center;gap:.75rem;margin-top:3rem;flex-wrap:wrap;">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" style="padding:.625rem 1.25rem;border-radius:8px;font-size:13px;font-weight:500;color:var(--ez-black);background:var(--ez-light);text-decoration:none;">← Previous</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" style="padding:.625rem 1rem;border-radius:8px;font-size:13px;font-weight:500;color:var(--ez-black);background:var(--ez-light);text-decoration:none;">{{ part.title }}</a>
            {% elsif part.title == paginate.current_page %}
              <span style="padding:.625rem 1rem;border-radius:8px;font-size:13px;font-weight:600;color:#fff;background:var(--ez-black);">{{ part.title }}</span>
            {% else %}
              <span style="padding:.625rem 1rem;font-size:13px;color:var(--ez-grey);">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" style="padding:.625rem 1.25rem;border-radius:8px;font-size:13px;font-weight:500;color:var(--ez-black);background:var(--ez-light);text-decoration:none;">Next →</a>
          {% endif %}
        </div>
      {% endif %}
      {% endpaginate %}

    {% else %}
      <div style="text-align:center;padding:3rem 0;">
        <p style="font-size:15px;color:var(--ez-grey);line-height:1.6;">Setup guides, compatibility explainers, and buying articles will appear here as the EZQuest resource center grows.</p>
      </div>
    {% endif %}
  </div>
</section>

{% comment %} 5. CTA {% endcomment %}
<section class="page-cta">
  <div class="page-cta__inner container-shell">
    <div class="page-cta__copy">
      <p class="page-cta__kicker">Resources</p>
      <p class="page-cta__heading">Need help choosing?</p>
      <p class="page-cta__sub">Answer a few quick questions and we'll find the right product for your setup.</p>
    </div>
    <div class="page-cta__actions">
      <a href="/pages/help-me-choose" class="page-cta__btn">
        Help me choose
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/pages/support" class="page-cta__btn" style="background:transparent;border:1.5px solid rgba(0,0,0,0.15);color:var(--ez-black);box-shadow:none;">
        Support center
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Blog hero image" },
    { "type": "image_picker", "id": "default_article_image", "label": "Default article image" }
  ]
}
{% endschema %}
