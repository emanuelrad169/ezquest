<section class="section-shell">
  <div class="container-shell">
    <div class="editorial-shell">
      <div class="grid gap-8 lg:grid-cols-editorial lg:items-end">
        <div class="max-w-3xl">
          <p class="section-kicker">Resources</p>
          <h1 class="section-heading mt-5">{{ blog.title }}</h1>
          <p class="section-copy mt-5">Explore setup guides, compatibility advice, and product know-how that help customers choose the right EZQuest product and get more from it after purchase.</p>
          <div class="mt-6 flex flex-wrap items-center gap-3">
            <span class="product-meta-pill">{{ blog.articles_count }} articles</span>
            <span class="product-meta-pill">Knowledge center</span>
          </div>
        </div>
        <div class="hero-side-panel">
          <p class="section-kicker">Reading path</p>
          <p class="mt-4 text-sm leading-7 text-slate-600">Start with product fit, move into setup guidance, and keep support one step away when the next answer depends on your exact device or workflow.</p>
          <div class="support-crosslink-list">
            <a href="/pages/support" class="support-crosslink">
              <span>Open support center</span>
              <span class="text-slate-400">Help</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    {% assign lead_article = blog.articles.first %}
    {% if lead_article != blank %}
      <div class="blog-lead-shell">
        <article class="blog-lead-card">
          {% if lead_article.image != blank %}
            {{ lead_article.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'blog-lead-image' }}
          {% else %}
            {% render 'placeholder-visual', kind: 'editorial', text: lead_article.title, width: 1400, height: 900, class: 'blog-lead-image' %}
          {% endif %}
          <div class="blog-lead-copy">
            <p class="section-kicker">{{ lead_article.blog.title }}</p>
            <h2 class="blog-lead-title"><a href="{{ lead_article.url }}">{{ lead_article.title }}</a></h2>
            <p class="blog-lead-excerpt">{{ lead_article.excerpt_or_content | strip_html | truncatewords: 28 }}</p>
            <div class="blog-lead-footer">
              <span>{{ lead_article.published_at | date: '%B %d, %Y' }}</span>
              {% render 'button', label: 'Read article', url: lead_article.url, style: 'tertiary' %}
            </div>
          </div>
        </article>

        <div class="blog-stack">
          {% for article in blog.articles limit: 4 %}
            {% unless forloop.first %}
              <article class="blog-stack-card">
                <p class="section-kicker">{{ article.blog.title }}</p>
                <h3 class="card-title mt-3"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ article.excerpt_or_content | strip_html | truncatewords: 16 }}</p>
                <div class="blog-stack-footer">
                  <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                  <a href="{{ article.url }}" class="site-meta-link">Read</a>
                </div>
              </article>
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="panel-primary">Buying guides, compatibility explainers, and setup articles will appear here as the EZQuest resource center grows.</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": []
}
{% endschema %}
