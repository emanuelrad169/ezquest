<section class="section-shell">
  <div class="container-shell">

    <div class="section-intro">
      <div>
        <p class="section-kicker">Resources</p>
        <h1 class="section-heading mt-4">{{ blog.title }}</h1>
        <p class="section-copy mt-4">Use setup guides, compatibility advice, and product guidance to choose the right EZQuest product and get more from it after purchase.</p>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="product-meta-pill">{{ blog.articles_count }} articles</span>
          <a href="/pages/support" class="support-inline-link">Support center</a>
        </div>
      </div>
    </div>

    {% assign lead_article = blog.articles.first %}
    {% if lead_article != blank %}
      <div class="blog-lead-shell">
        <a href="{{ lead_article.url }}" class="blog-lead-card">
          {% if lead_article.image != blank %}
            {{ lead_article.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'blog-lead-image' }}
          {% else %}
            {% render 'owned-product-visual', product_handle: 'usb-c-multimedia-hub', variant: 'hero', width: 1400, height: 900, class: 'blog-lead-image' %}
          {% endif %}
          <div class="blog-lead-copy">
            <p class="section-kicker">{{ lead_article.blog.title }}</p>
            <h2 class="blog-lead-title mt-4">{{ lead_article.title }}</h2>
            <p class="blog-lead-excerpt">{{ lead_article.excerpt_or_content | strip_html | truncatewords: 28 }}</p>
            <div class="blog-lead-footer">
              <span>{{ lead_article.published_at | date: '%B %d, %Y' }}</span>
              {% render 'button', label: 'Read article', url: lead_article.url, style: 'tertiary' %}
            </div>
          </div>
        </a>

        <div class="blog-stack">
          {% for article in blog.articles limit: 4 %}
            {% unless forloop.first %}
              <a href="{{ article.url }}" class="blog-stack-card">
                <p class="section-kicker">{{ article.blog.title }}</p>
                <h3 class="card-title mt-3">{{ article.title }}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ article.excerpt_or_content | strip_html | truncatewords: 16 }}</p>
                <div class="blog-stack-footer">
                  <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                  <span class="blog-stack-arrow">→</span>
                </div>
              </a>
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="section-frame mt-10">
        <p class="section-copy">Buying guides, compatibility explainers, and setup articles will appear here as the EZQuest resource center grows.</p>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": []
}
{% endschema %}
