<section class="section-shell">
  <div class="container-shell">
    <h1 class="section-heading">{{ blog.title }}</h1>
    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {% for article in blog.articles %}
        {% render 'card-article', article: article, excerpt: article.excerpt_or_content | strip_html | truncatewords: 22 %}
      {% else %}
        <div class="card-shell md:col-span-2 xl:col-span-3">Blog listing scaffold.</div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": []
}
{% endschema %}
