<section class="section-shell bg-slate-50">
  <div class="container-shell">
    {%- liquid
      assign current_product = blank
      assign structured_entries = blank
      assign has_product_entries = false
      assign use_product_entries = false
      assign use_global_entries = false
      assign platform_filter = section.settings.platform_filter | downcase | strip
      assign device_filter = section.settings.device_filter | downcase | strip
      assign workflow_filter = section.settings.workflow_filter | downcase | strip

      if product != blank
        assign current_product = product
      elsif section.settings.source_product != blank
        assign current_product = section.settings.source_product
      endif

      if current_product != blank and current_product.metafields.ezquest.compatibility_entries != blank
        assign structured_entries = current_product.metafields.ezquest.compatibility_entries.value
        if structured_entries.count > 0
          assign has_product_entries = true
        endif
      endif

      case section.settings.structured_source
        when 'product'
          if has_product_entries
            assign use_product_entries = true
          endif
        when 'global'
          assign use_global_entries = true
        when 'auto'
          if has_product_entries
            assign use_product_entries = true
          else
            assign use_global_entries = true
          endif
      endcase
    -%}

    <div class="resource-list-shell">
      <div class="resource-list-intro">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}
          <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% endif %}
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="product-meta-pill">Compatibility</span>
          {% if section.settings.structured_source != 'blocks' %}
            <span class="product-meta-pill">Structured-ready</span>
          {% endif %}
        </div>
        {% if section.settings.source_note != blank %}
          <p class="mt-4 text-sm leading-6 text-slate-500">{{ section.settings.source_note }}</p>
        {% endif %}

        <div class="support-crosslink-list">
          <a href="/pages/manuals" class="support-crosslink">
            <span>Open manuals</span>
            <span class="text-slate-400">Guides</span>
          </a>
          <a href="/pages/downloads" class="support-crosslink">
            <span>Open downloads</span>
            <span class="text-slate-400">Resources</span>
          </a>
          <a href="/pages/contact" class="support-crosslink">
            <span>Need help confirming fit</span>
            <span class="text-slate-400">Support</span>
          </a>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
      {% if use_product_entries %}
        {%- assign rendered_entries = 0 -%}
        {% for entry in structured_entries %}
          {%- liquid
            assign entry_platform = blank
            assign entry_device = blank
            assign entry_workflow = blank
            assign entry_status = blank
            assign entry_summary = blank
            assign entry_context = blank
            assign primary_url = blank
            assign primary_label = blank
            assign secondary_url = blank
            assign secondary_label = blank
            assign matches_platform = true
            assign matches_device = true
            assign matches_workflow = true

            if entry.platform != blank and entry.platform.value != blank
              assign entry_platform = entry.platform.value
            endif
            if entry.device != blank and entry.device.value != blank
              assign entry_device = entry.device.value
            endif
            if entry.workflow != blank and entry.workflow.value != blank
              assign entry_workflow = entry.workflow.value
            endif
            if entry.status != blank and entry.status.value != blank
              assign entry_status = entry.status.value
            endif
            if entry.summary != blank and entry.summary.value != blank
              assign entry_summary = entry.summary.value
            endif

            if platform_filter != blank
              assign normalized_platform = entry_platform | downcase
              if normalized_platform != platform_filter
                assign matches_platform = false
              endif
            endif
            if device_filter != blank
              assign normalized_device = entry_device | downcase
              if normalized_device != device_filter
                assign matches_device = false
              endif
            endif
            if workflow_filter != blank
              assign normalized_workflow = entry_workflow | downcase
              if normalized_workflow != workflow_filter
                assign matches_workflow = false
              endif
            endif

            if entry.products != blank and entry.products.value.count > 0
              assign primary_url = entry.products.value.first.url
              assign primary_label = section.settings.product_link_label
            endif

            if entry.downloads != blank and entry.downloads.value.count > 0
              assign linked_download = entry.downloads.value.first
              if linked_download.file != blank and linked_download.file.value != blank
                assign secondary_url = linked_download.file.value.url
              elsif linked_download.external_url != blank and linked_download.external_url.value != blank
                assign secondary_url = linked_download.external_url.value
              endif
              assign secondary_label = section.settings.download_link_label
            elsif entry.manuals != blank and entry.manuals.value.count > 0
              assign linked_manual = entry.manuals.value.first
              if linked_manual.file != blank and linked_manual.file.value != blank
                assign secondary_url = linked_manual.file.value.url
              elsif linked_manual.external_url != blank and linked_manual.external_url.value != blank
                assign secondary_url = linked_manual.external_url.value
              endif
              assign secondary_label = section.settings.manual_link_label
            endif

            if entry_platform != blank
              assign entry_context = entry_platform
            endif
            if entry_device != blank
              if entry_context != blank
                assign entry_context = entry_context | append: ' / '
              endif
              assign entry_context = entry_context | append: entry_device
            endif
            if entry_workflow != blank
              if entry_context != blank
                assign entry_context = entry_context | append: ' / '
              endif
              assign entry_context = entry_context | append: entry_workflow
            endif
          -%}

          {% if matches_platform and matches_device and matches_workflow and rendered_entries < section.settings.entry_limit %}
            <article class="compatibility-card">
              <div class="flex flex-wrap items-center justify-between gap-3">
                {% if entry_status != blank %}
                  <p class="section-kicker">{{ entry_status }}</p>
                {% else %}
                  <p class="section-kicker">Compatibility entry</p>
                {% endif %}
                {% if entry_context != blank %}
                  <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{{ entry_context }}</span>
                {% endif %}
              </div>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">{{ entry.title.value }}</h3>
              {% if entry_summary != blank %}
                <p class="mt-3 text-sm leading-6 text-slate-600">{{ entry_summary }}</p>
              {% endif %}
              <div class="mt-6 flex flex-wrap gap-3">
                {% if primary_url != blank %}
                  {% render 'button', label: primary_label, url: primary_url, style: 'secondary' %}
                {% endif %}
                {% if secondary_url != blank %}
                  {% render 'button', label: secondary_label, url: secondary_url, style: 'secondary' %}
                {% endif %}
              </div>
            </article>
            {%- assign rendered_entries = rendered_entries | plus: 1 -%}
          {% endif %}
        {% endfor %}

        {% if rendered_entries == 0 %}
          {% for i in (1..3) %}
            <article class="compatibility-card">
              <p class="section-kicker">Compatibility entry</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">Compatibility scenario</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Add compatibility entries in Shopify or use section blocks to populate this module.</p>
            </article>
          {% endfor %}
        {% endif %}
      {% elsif use_global_entries %}
        {%- assign rendered_entries = 0 -%}
        {% for entry in metaobjects.ezquest_compatibility_entry.values %}
          {%- liquid
            assign entry_platform = blank
            assign entry_device = blank
            assign entry_workflow = blank
            assign entry_status = blank
            assign entry_summary = blank
            assign entry_context = blank
            assign primary_url = blank
            assign primary_label = blank
            assign secondary_url = blank
            assign secondary_label = blank
            assign matches_platform = true
            assign matches_device = true
            assign matches_workflow = true
            assign matches_collection = true
            assign matches_product = true

            if entry.platform != blank and entry.platform.value != blank
              assign entry_platform = entry.platform.value
            endif
            if entry.device != blank and entry.device.value != blank
              assign entry_device = entry.device.value
            endif
            if entry.workflow != blank and entry.workflow.value != blank
              assign entry_workflow = entry.workflow.value
            endif
            if entry.status != blank and entry.status.value != blank
              assign entry_status = entry.status.value
            endif
            if entry.summary != blank and entry.summary.value != blank
              assign entry_summary = entry.summary.value
            endif

            if platform_filter != blank
              assign normalized_platform = entry_platform | downcase
              if normalized_platform != platform_filter
                assign matches_platform = false
              endif
            endif
            if device_filter != blank
              assign normalized_device = entry_device | downcase
              if normalized_device != device_filter
                assign matches_device = false
              endif
            endif
            if workflow_filter != blank
              assign normalized_workflow = entry_workflow | downcase
              if normalized_workflow != workflow_filter
                assign matches_workflow = false
              endif
            endif

            if section.settings.source_collection != blank
              assign matches_collection = false
              if entry.collections != blank and entry.collections.value.count > 0
                for linked_collection in entry.collections.value
                  if linked_collection.id == section.settings.source_collection.id
                    assign matches_collection = true
                    break
                  endif
                endfor
              endif
            endif

            if current_product != blank and section.settings.limit_to_source_product
              assign matches_product = false
              if entry.products != blank and entry.products.value.count > 0
                for linked_product in entry.products.value
                  if linked_product.id == current_product.id
                    assign matches_product = true
                    break
                  endif
                endfor
              endif
            endif

            if entry.products != blank and entry.products.value.count > 0
              assign primary_url = entry.products.value.first.url
              assign primary_label = section.settings.product_link_label
            endif

            if entry.downloads != blank and entry.downloads.value.count > 0
              assign linked_download = entry.downloads.value.first
              if linked_download.file != blank and linked_download.file.value != blank
                assign secondary_url = linked_download.file.value.url
              elsif linked_download.external_url != blank and linked_download.external_url.value != blank
                assign secondary_url = linked_download.external_url.value
              endif
              assign secondary_label = section.settings.download_link_label
            elsif entry.manuals != blank and entry.manuals.value.count > 0
              assign linked_manual = entry.manuals.value.first
              if linked_manual.file != blank and linked_manual.file.value != blank
                assign secondary_url = linked_manual.file.value.url
              elsif linked_manual.external_url != blank and linked_manual.external_url.value != blank
                assign secondary_url = linked_manual.external_url.value
              endif
              assign secondary_label = section.settings.manual_link_label
            endif

            if entry_platform != blank
              assign entry_context = entry_platform
            endif
            if entry_device != blank
              if entry_context != blank
                assign entry_context = entry_context | append: ' / '
              endif
              assign entry_context = entry_context | append: entry_device
            endif
            if entry_workflow != blank
              if entry_context != blank
                assign entry_context = entry_context | append: ' / '
              endif
              assign entry_context = entry_context | append: entry_workflow
            endif
          -%}

          {% if matches_platform and matches_device and matches_workflow and matches_collection and matches_product and rendered_entries < section.settings.entry_limit %}
            <article class="compatibility-card">
              <div class="flex flex-wrap items-center justify-between gap-3">
                {% if entry_status != blank %}
                  <p class="section-kicker">{{ entry_status }}</p>
                {% else %}
                  <p class="section-kicker">Compatibility entry</p>
                {% endif %}
                {% if entry_context != blank %}
                  <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{{ entry_context }}</span>
                {% endif %}
              </div>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">{{ entry.title.value }}</h3>
              {% if entry_summary != blank %}
                <p class="mt-3 text-sm leading-6 text-slate-600">{{ entry_summary }}</p>
              {% endif %}
              <div class="mt-6 flex flex-wrap gap-3">
                {% if primary_url != blank %}
                  {% render 'button', label: primary_label, url: primary_url, style: 'secondary' %}
                {% endif %}
                {% if secondary_url != blank %}
                  {% render 'button', label: secondary_label, url: secondary_url, style: 'secondary' %}
                {% endif %}
              </div>
            </article>
            {%- assign rendered_entries = rendered_entries | plus: 1 -%}
          {% endif %}
        {% endfor %}

        {% if rendered_entries == 0 %}
          {% for i in (1..3) %}
            <article class="compatibility-card">
              <p class="section-kicker">Compatibility entry</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">Compatibility scenario</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Add compatibility entries in Shopify or use section blocks to populate this module.</p>
            </article>
          {% endfor %}
        {% endif %}
      {% else %}
        {% for block in section.blocks %}
          <article class="compatibility-card" {{ block.shopify_attributes }}>
            {% if block.settings.eyebrow != blank %}
              <p class="section-kicker">{{ block.settings.eyebrow }}</p>
            {% else %}
              <p class="section-kicker">Compatibility entry</p>
            {% endif %}
            <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">{{ block.settings.title }}</h3>
            {% if block.settings.copy != blank %}
              <p class="mt-3 text-sm leading-6 text-slate-600">{{ block.settings.copy }}</p>
            {% endif %}
            {% if block.settings.link_url != blank %}
              <div class="mt-6">
                {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
              </div>
            {% endif %}
          </article>
        {% else %}
          {% for i in (1..3) %}
            <article class="compatibility-card">
              <p class="section-kicker">Compatibility entry</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">Compatibility scenario</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Add compatibility entries in Shopify or use section blocks to populate this module.</p>
            </article>
          {% endfor %}
        {% endfor %}
      {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Compatibility entry list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compatibility" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Compatibility and fit guidance" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Use this section for compatibility entries that can later be filtered by platform, device, workflow, and product family." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "product", "label": "Product-linked compatibility entries" },
        { "value": "global", "label": "Global compatibility entries" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    { "type": "product", "id": "source_product", "label": "Source product" },
    { "type": "checkbox", "id": "limit_to_source_product", "label": "Filter global entries to the source product", "default": false },
    { "type": "collection", "id": "source_collection", "label": "Filter global entries by collection" },
    { "type": "text", "id": "platform_filter", "label": "Platform filter" },
    { "type": "text", "id": "device_filter", "label": "Device filter" },
    { "type": "text", "id": "workflow_filter", "label": "Workflow filter" },
    {
      "type": "range",
      "id": "entry_limit",
      "label": "Entry limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    { "type": "textarea", "id": "source_note", "label": "Support note", "default": "Best results come from ordering entries consistently in Shopify and using filters only where they improve clarity." },
    { "type": "text", "id": "product_link_label", "label": "Product link label", "default": "View related product" },
    { "type": "text", "id": "download_link_label", "label": "Download link label", "default": "Open related download" },
    { "type": "text", "id": "manual_link_label", "label": "Manual link label", "default": "Open related manual" }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "Compatibility entry",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compatibility entry" },
        { "type": "text", "id": "title", "label": "Title", "default": "Compatibility scenario" },
        { "type": "textarea", "id": "copy", "label": "Summary", "default": "Compatibility summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View related products" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Compatibility entry list",
      "blocks": [{ "type": "entry" }, { "type": "entry" }, { "type": "entry" }]
    }
  ]
}
{% endschema %}
