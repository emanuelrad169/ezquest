<section class="section-shell pt-8 lg:pt-10">
  <div class="container-shell">
    {% render 'breadcrumbs' %}
    <div class="hero-surface mt-6">
      <div class="grid gap-8 lg:grid-cols-editorial lg:items-end">
        <div class="max-w-3xl">
          {% if section.settings.eyebrow != blank %}
            <p class="section-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <h1 class="section-heading mt-5">{{ section.settings.heading | default: page.title | default: blog.title | default: article.title }}</h1>
          {% if section.settings.copy != blank %}
            <p class="section-copy mt-5">{{ section.settings.copy }}</p>
          {% endif %}
        </div>

        {% if section.settings.support_note != blank or section.settings.link_label != blank %}
          <div class="hero-panel">
            {% if section.settings.support_eyebrow != blank %}
              <p class="section-kicker">{{ section.settings.support_eyebrow }}</p>
            {% endif %}
            {% if section.settings.support_note != blank %}
              <p class="mt-4 text-sm leading-7 text-slate-600">{{ section.settings.support_note }}</p>
            {% endif %}
            {% if section.settings.link_label != blank and section.settings.link_url != blank %}
              <div class="mt-6">
                {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading override" },
    { "type": "textarea", "id": "copy", "label": "Copy" },
    { "type": "text", "id": "support_eyebrow", "label": "Side panel eyebrow", "default": "Context" },
    { "type": "textarea", "id": "support_note", "label": "Side panel note" },
    { "type": "text", "id": "link_label", "label": "Side panel link label" },
    { "type": "url", "id": "link_url", "label": "Side panel link URL" }
  ],
  "presets": [
    { "name": "Page hero" }
  ]
}
{% endschema %}
