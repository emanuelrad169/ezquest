{%- liquid
  assign hero_eyebrow    = section.settings.eyebrow
  assign hero_heading    = section.settings.heading | default: page.title | default: blog.title | default: article.title
  assign hero_copy       = section.settings.copy
  assign hero_image      = section.settings.background_image
  assign structured_group = blank
  assign support_scene = blank

  if section.settings.structured_source == 'group_handle' and section.settings.comparison_group_handle != blank
    assign structured_group = metaobjects.ezquest_comparison_group[section.settings.comparison_group_handle]
  endif

  if structured_group != blank
    if structured_group.eyebrow != blank and structured_group.eyebrow.value != blank
      assign hero_eyebrow = structured_group.eyebrow.value
    endif
    if structured_group.heading != blank and structured_group.heading.value != blank
      assign hero_heading = structured_group.heading.value
    endif
    if structured_group.description != blank and structured_group.description.value != blank
      assign hero_copy = structured_group.description.value
    endif
  endif

  if hero_image == blank
    if page != blank
      case page.handle
        when 'support'
          assign support_scene = 'support'
        when 'downloads'
          assign support_scene = 'downloads'
        when 'manuals'
          assign support_scene = 'manuals'
        when 'compatibility'
          assign support_scene = 'compatibility'
      endcase
    elsif blog != blank and blog.handle == 'resources'
      assign support_scene = 'resources'
    endif
  endif
-%}

<div class="collection-showcase-shell">
  <div class="collection-showcase collection-showcase--page{% if hero_image == blank and support_scene == blank %} collection-showcase--ambient{% endif %}">

    {% if hero_image != blank %}
      <div class="collection-showcase-media">
        {{ hero_image | image_url: width: 2400 | image_tag: loading: 'eager', decoding: 'async', alt: hero_heading, class: 'collection-showcase-image' }}
      </div>
    {% elsif support_scene == 'resources' %}
      <div class="collection-showcase-media">
        {% render 'owned-editorial-visual', visual: 'guide', title: hero_heading, class: 'collection-showcase-image collection-showcase-image--scene', loading: 'eager', fetchpriority: 'high' %}
      </div>
    {% elsif support_scene != blank %}
      <div class="collection-showcase-media">
        {% render 'owned-support-visual', visual: support_scene, class: 'collection-showcase-image collection-showcase-image--scene', loading: 'eager', fetchpriority: 'high' %}
      </div>
    {% endif %}

    <div class="collection-showcase-scrim"></div>

    <div class="collection-showcase-inner container-shell">
      <nav class="collection-showcase-breadcrumb" aria-label="breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span aria-hidden="true">›</span>
        <span>{{ hero_heading }}</span>
      </nav>

      <div class="collection-showcase-copy">
        {% if hero_eyebrow != blank %}
          <p class="collection-showcase-label">{{ hero_eyebrow }}</p>
        {% endif %}
        <h1 class="page-hero-heading">{{ hero_heading }}</h1>
        {% if hero_copy != blank %}
          <p class="collection-showcase-statement">{{ hero_copy }}</p>
        {% endif %}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "group_handle", "label": "Comparison group handle" }
      ]
    },
    { "type": "text", "id": "comparison_group_handle", "label": "Comparison group handle" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading override" },
    { "type": "textarea", "id": "copy", "label": "Subtext" },
    { "type": "text", "id": "link_label", "label": "CTA label" },
    { "type": "url", "id": "link_url", "label": "CTA URL" }
  ],
  "presets": [
    { "name": "Page hero" }
  ]
}
{% endschema %}
