        </div>
        <span class="ts-resource-card__arrow group-hover:text-[var(--ez-amber)] group-hover:translate-x-[3px]" aria-hidden="true">→</span>
      </a>

      <a href="/pages/manuals" class="ts-resource-card group hover:border-[var(--ez-amber-35)] hover:shadow-[0_8px_28px_rgba(0,0,0,0.06)]">
        <div class="ts-resource-card__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M5 3h10a1 1 0 011 1v13a1 1 0 01-1 1H5a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 7h6M7 10h6M7 13h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="ts-resource-card__body flex-1">
          <p class="ts-resource-card__type">Guides</p>
          <p class="ts-resource-card__title">Product Manuals</p>
          <p class="ts-resource-card__desc">Setup guides, quick-start cards, and full product documentation.</p>
        </div>
        <span class="ts-resource-card__arrow group-hover:text-[var(--ez-amber)] group-hover:translate-x-[3px]" aria-hidden="true">→</span>
      </a>

      <a href="/pages/contact" class="ts-resource-card group hover:border-[var(--ez-amber-35)] hover:shadow-[0_8px_28px_rgba(0,0,0,0.06)]">
        <div class="ts-resource-card__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 5a2 2 0 012-2h10a2 2 0 012 2v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 7l7 5 7-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="ts-resource-card__body flex-1">
          <p class="ts-resource-card__type">Direct help</p>
          <p class="ts-resource-card__title">Get Help Now</p>
          <p class="ts-resource-card__desc">Submit one request with the product, symptom, and what you've tried. We'll reply fast.</p>
        </div>
        <span class="ts-resource-card__arrow group-hover:text-[var(--ez-amber)] group-hover:translate-x-[3px]" aria-hidden="true">→</span>
      </a>

    </div>
  </div>
</section>

