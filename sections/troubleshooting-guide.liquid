{{ 'support-cluster.css' | asset_url | stylesheet_tag }}
{{ 'pages.css' | asset_url | stylesheet_tag }}
{%- assign chargers_collection = collections['chargers-power'] -%}

{% comment %} ── HERO ─────────────────────────────────────── {% endcomment %}
<section class="ts-hero bg-[linear-gradient(135deg,var(--ez-light)_0%,#ffffff_100%)] border-b border-black/[6%] pt-[clamp(52px,6vw,84px)] pb-[clamp(36px,4vw,52px)]">
  <div class="ts-hero__inner max-w-[80rem] mx-auto px-[clamp(1.25rem,5vw,2rem)]">
    <p class="ts-hero__kicker text-[11px] font-semibold tracking-[.12em] uppercase text-[var(--ez-grey)] mb-3.5">Troubleshooting</p>
    <h1 class="ts-hero__heading text-[clamp(32px,5vw,60px)] font-medium tracking-[-0.04em] leading-[1.05] text-[var(--ez-black)] mb-4 max-w-[18ch]">Fix it by symptom</h1>
    <p class="ts-hero__sub text-[clamp(15px,1.5vw,17px)] text-[var(--ez-grey)] leading-[1.65] max-w-[54ch] m-0">Start with the symptom you see. Take the shortest recovery step. Escalate to support only if the issue stays.</p>
  </div>
</section>

{% comment %} ── ISSUE GRID ───────────────────────────────── {% endcomment %}
<div class="ts-body max-w-[80rem] mx-auto px-[clamp(1.25rem,5vw,2rem)] py-[clamp(48px,6vw,72px)] flex flex-col gap-[clamp(3rem,5vw,5rem)]">

  <div class="ts-category">
    <p class="ts-category__label text-[11px] font-bold tracking-[.1em] uppercase text-[var(--ez-grey)] mb-5">USB Hub</p>
    <div class="ts-grid grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">01</span>
        <p class="ts-card__title">Hub not recognized after plugging in</p>
        <p class="ts-card__copy">Check that the host USB-C port supports data, not just charging. Try a different port or a shorter cable rated for USB 3.0+. Reboot the computer with the hub connected.</p>
        <div class="ts-card__foot">
          <a href="/pages/compatibility" class="ts-card__cta hover:decoration-[var(--ez-black)]">Check compatibility →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">02</span>
        <p class="ts-card__title">Hub works intermittently or disconnects</p>
        <p class="ts-card__copy">Intermittency is most often cable-related. Swap to a known-good USB-C cable and avoid extension cables. Connect the hub directly to the laptop — avoid docking chains.</p>
        <div class="ts-card__foot">
          <a href="/pages/manuals" class="ts-card__cta hover:decoration-[var(--ez-black)]">View setup guide →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">03</span>
        <p class="ts-card__title">All hub ports stop working after a while</p>
        <p class="ts-card__copy">This is typically a thermal or power event. Disconnect all peripherals, wait 10 seconds, and reconnect. Make sure the hub is ventilated and not stacked on other devices.</p>
        <div class="ts-card__foot">
          <a href="/pages/contact" class="ts-card__cta hover:decoration-[var(--ez-black)]">Open a support ticket →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">04</span>
        <p class="ts-card__title">Hub recognized on one laptop but not another</p>
        <p class="ts-card__copy">Not all USB-C ports carry the same capabilities — charging-only ports won't enumerate a hub. Confirm the port on the second laptop supports USB 3.1 or DisplayPort Alt Mode.</p>
        <div class="ts-card__foot">
          <a href="/pages/compatibility" class="ts-card__cta hover:decoration-[var(--ez-black)]">Check port compatibility →</a>
        </div>
      </div>

    </div>
  </div>

  <div class="ts-category">
    <p class="ts-category__label text-[11px] font-bold tracking-[.1em] uppercase text-[var(--ez-grey)] mb-5">Display</p>
    <div class="ts-grid grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">05</span>
        <p class="ts-card__title">External monitor shows no signal</p>
        <p class="ts-card__copy">Confirm your laptop port supports DisplayPort Alt Mode — not all USB-C ports carry video. Set the display to the correct HDMI input, try a different HDMI cable, and update display drivers.</p>
        <div class="ts-card__foot">
          <a href="/pages/help-me-choose" class="ts-card__cta hover:decoration-[var(--ez-black)]">Find the right hub →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">06</span>
        <p class="ts-card__title">Display flickers or cuts out randomly</p>
        <p class="ts-card__copy">Reseat the HDMI cable at both ends. Replace the cable if it's over 2m. On macOS, go to System Settings → Displays and disable "Automatically adjust brightness." Update macOS if a recent update is pending.</p>
        <div class="ts-card__foot">
          <a href="/pages/downloads" class="ts-card__cta hover:decoration-[var(--ez-black)]">Check for driver updates →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">07</span>
        <p class="ts-card__title">Resolution is lower than expected on external screen</p>
        <p class="ts-card__copy">Open display settings and manually set the resolution — macOS and Windows don't always default to native. 4K output requires a USB-C port that supports 4K Alt Mode and a hub rated for it.</p>
        <div class="ts-card__foot">
          <a href="/pages/compatibility" class="ts-card__cta hover:decoration-[var(--ez-black)]">Check 4K compatibility →</a>
        </div>
      </div>

    </div>
  </div>

  <div class="ts-category">
    <p class="ts-category__label text-[11px] font-bold tracking-[.1em] uppercase text-[var(--ez-grey)] mb-5">Charging</p>
    <div class="ts-grid grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">08</span>
        <p class="ts-card__title">Laptop charges slowly through the hub</p>
        <p class="ts-card__copy">Verify the charger wattage meets your laptop's requirement. The hub PD pass-through deducts a small overhead (typically 5–15W). Use the PD-labeled port on the hub and connect the charger directly to it.</p>
        <div class="ts-card__foot">
          <a href="{{ chargers_collection.url | default: routes.collections_url }}" class="ts-card__cta hover:decoration-[var(--ez-black)]">View GaN chargers →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">09</span>
        <p class="ts-card__title">Charger not reaching expected wattage</p>
        <p class="ts-card__copy">Use a USB-C cable rated for the full wattage — not all USB-C cables carry high power. Connect your device to the charger's primary port (highest-rated). Disconnect other devices sharing the charger.</p>
        <div class="ts-card__foot">
          <a href="/pages/contact" class="ts-card__cta hover:decoration-[var(--ez-black)]">Report a defect →</a>
        </div>
      </div>

    </div>
  </div>

  <div class="ts-category">
    <p class="ts-category__label text-[11px] font-bold tracking-[.1em] uppercase text-[var(--ez-grey)] mb-5">USB Ports &amp; Ethernet</p>
    <div class="ts-grid grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">10</span>
        <p class="ts-card__title">USB-A devices not detected on hub</p>
        <p class="ts-card__copy">Try a different USB-A port on the hub. Test the device directly on the laptop to confirm it works independently. Install the latest driver from the Downloads page if prompted by Windows.</p>
        <div class="ts-card__foot">
          <a href="/pages/downloads" class="ts-card__cta hover:decoration-[var(--ez-black)]">Find downloads →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">11</span>
        <p class="ts-card__title">Gigabit Ethernet not connecting</p>
        <p class="ts-card__copy">On macOS: System Settings → Network — look for a new Ethernet interface. On Windows: download the Realtek driver from the Downloads page and restart. Check the network cable and wall port.</p>
        <div class="ts-card__foot">
          <a href="/pages/manuals" class="ts-card__cta hover:decoration-[var(--ez-black)]">Find manuals →</a>
        </div>
      </div>

    </div>
  </div>

  <div class="ts-category">
    <p class="ts-category__label text-[11px] font-bold tracking-[.1em] uppercase text-[var(--ez-grey)] mb-5">Card Reader &amp; Storage</p>
    <div class="ts-grid grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">12</span>
        <p class="ts-card__title">SD card not appearing on desktop</p>
        <p class="ts-card__copy">Re-seat the card firmly. On macOS, open Disk Utility and check if the volume needs to be mounted. On Windows, check Disk Management. Try a different card to rule out card failure.</p>
        <div class="ts-card__foot">
          <a href="/pages/contact" class="ts-card__cta hover:decoration-[var(--ez-black)]">Contact support →</a>
        </div>
      </div>

      <div class="ts-card border border-black/[7%] rounded-2xl p-7 bg-white relative flex flex-col gap-0 transition-[border-color] duration-200 hover:border-[var(--ez-amber-25)]">
        <span class="ts-card__num absolute top-5 right-5 text-[11px] font-bold tracking-[.06em] text-black/[58%] [font-variant-numeric:tabular-nums]" aria-hidden="true">13</span>
        <p class="ts-card__title">USB drive transfer speeds are slower than expected</p>
        <p class="ts-card__copy">Transfer speed is limited by the slowest link — the drive, cable, or hub port. Confirm the hub USB-A port is USB 3.2 (not USB 2.0) and the drive is formatted for maximum performance.</p>
        <div class="ts-card__foot">
          <a href="/pages/compatibility" class="ts-card__cta hover:decoration-[var(--ez-black)]">Check specs →</a>
        </div>
      </div>

    </div>
  </div>

</div>

{% comment %} ── WHERE TO GO FROM HERE ──────────────────── {% endcomment %}
<section class="ts-resources">
