{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero">
  <div class="support-hero__wrap">
    <p class="support-hero__kicker">Troubleshooting</p>
    <h1 class="support-hero__heading">
      Fix it in minutes
    </h1>
    <p class="support-hero__sub">
      Step-by-step solutions for the most common EZQuest
      product issues — written and tested by our team.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'troubleshooting' %}

<div class="support-body">

  <div class="ts-grid">

    {% assign ts_items = shop.metaobjects.ezquest_troubleshooting_item.values %}

    {% if ts_items.size > 0 %}

      {% for item in ts_items %}
        <div class="ts-card">
          <div class="ts-card__header">
            <div class="ts-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/>
                <path d="M9 5.5v4M9 11.5v.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <p class="ts-card__problem">{{ item.problem.value }}</p>
              {% if item.product_family.value != blank %}
                <span class="product-pill">{{ item.product_family.value }}</span>
              {% endif %}
            </div>
          </div>

          {% if item.steps.value != blank %}
            <ol class="ts-steps">
              {% assign step_list = item.steps.value | newline_to_br | split: '<br />' %}
              {% for step in step_list %}
                {% unless step == blank %}
                  <li class="ts-step">{{ step | strip_html }}</li>
                {% endunless %}
              {% endfor %}
            </ol>
          {% endif %}

          <div class="ts-escalation">
            {% if item.escalation_text.value != blank %}
              <p class="ts-escalation__text">{{ item.escalation_text.value }}</p>
            {% else %}
              <p class="ts-escalation__text">Still not resolved? Our team can help directly.</p>
            {% endif %}
            <a href="/pages/contact" class="ts-escalation__link">Contact support →</a>
          </div>
        </div>
      {% endfor %}

    {% else %}

      <div class="ts-card">
        <div class="ts-card__header">
          <div class="ts-card__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/><path d="M9 5.5v4M9 11.5v.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          </div>
          <div>
            <p class="ts-card__problem">Hub not recognized by laptop</p>
            <span class="product-pill">Hubs &amp; Adapters</span>
          </div>
        </div>
        <ol class="ts-steps">
          <li class="ts-step">Make sure the USB-C cable is fully seated on both ends.</li>
          <li class="ts-step">Try a different USB-C port on your laptop.</li>
          <li class="ts-step">Disconnect all peripherals from the hub, then reconnect one at a time.</li>
          <li class="ts-step">Test with a different USB-C cable if available.</li>
          <li class="ts-step">On Windows: open Device Manager and look for unknown devices under Universal Serial Bus controllers.</li>
        </ol>
        <div class="ts-escalation">
          <p class="ts-escalation__text">If the hub still doesn't appear, it may need replacement.</p>
          <a href="/pages/contact" class="ts-escalation__link">Contact support →</a>
        </div>
      </div>

      <div class="ts-card">
        <div class="ts-card__header">
          <div class="ts-card__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/><path d="M9 5.5v4M9 11.5v.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          </div>
          <div>
            <p class="ts-card__problem">No display output via HDMI</p>
            <span class="product-pill">Hubs &amp; Adapters</span>
          </div>
        </div>
        <ol class="ts-steps">
          <li class="ts-step">Ensure the display is powered on and set to the correct input source.</li>
          <li class="ts-step">Swap to a known-working HDMI cable.</li>
          <li class="ts-step">Connect the hub to your laptop without any other devices attached, then test the display alone.</li>
          <li class="ts-step">Check your laptop's display settings — macOS: System Settings → Displays; Windows: Settings → Display.</li>
          <li class="ts-step">Confirm your laptop supports video output over USB-C (not all USB-C ports carry DisplayPort signal).</li>
        </ol>
        <div class="ts-escalation">
          <p class="ts-escalation__text">Contact us with your laptop model and OS version for further diagnosis.</p>
          <a href="/pages/contact" class="ts-escalation__link">Contact support →</a>
        </div>
      </div>

      <div class="ts-card">
        <div class="ts-card__header">
          <div class="ts-card__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/><path d="M9 5.5v4M9 11.5v.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          </div>
          <div>
            <p class="ts-card__problem">Ethernet not showing up</p>
            <span class="product-pill">Hubs &amp; Adapters</span>
          </div>
        </div>
        <ol class="ts-steps">
          <li class="ts-step">On macOS: go to System Settings → Network and look for a new Ethernet interface.</li>
          <li class="ts-step">On Windows 10: download and install the Realtek driver from the Downloads page. Restart after install.</li>
          <li class="ts-step">Try a different Ethernet cable and a different wall port or switch.</li>
          <li class="ts-step">Check that the hub is receiving power — some hubs require host power-delivery to activate the Ethernet chip.</li>
        </ol>
        <div class="ts-escalation">
          <p class="ts-escalation__text">Still not appearing after a driver install and restart?</p>
          <a href="/pages/contact" class="ts-escalation__link">Contact support →</a>
        </div>
      </div>

      <div class="ts-card">
        <div class="ts-card__header">
          <div class="ts-card__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.25"/><path d="M9 5.5v4M9 11.5v.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
          </div>
          <div>
            <p class="ts-card__problem">Charger not delivering expected wattage</p>
            <span class="product-pill">Chargers &amp; Power</span>
          </div>
        </div>
        <ol class="ts-steps">
          <li class="ts-step">Use a USB-C cable rated for the wattage you need — not all USB-C cables carry full power.</li>
          <li class="ts-step">Connect your device directly to the charger's primary USB-C port (usually labeled or marked first).</li>
          <li class="ts-step">Check your device's battery settings — some devices cap charging speed when battery exceeds 80%.</li>
          <li class="ts-step">Disconnect other devices from the charger — shared ports divide available wattage.</li>
        </ol>
        <div class="ts-escalation">
          <p class="ts-escalation__text">If wattage is consistently below spec, the unit may be defective.</p>
          <a href="/pages/contact" class="ts-escalation__link">Contact support →</a>
        </div>
      </div>

    {% endif %}

  </div>

  <div class="support-cta-strip">
    <div>
      <p class="support-cta-strip__heading">Issue not listed here?</p>
      <p class="support-cta-strip__body">Describe what's happening and we'll diagnose it for you.</p>
    </div>
    <div class="support-cta-strip__actions">
      <a href="/pages/contact" class="btn btn--primary">Submit a ticket</a>
      <a href="/pages/contact" class="btn btn--secondary" style="color:#f5f5f7;border-color:rgba(255,255,255,.2)">Quick message</a>
    </div>
  </div>

</div>

<style>
.ts-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
@media(max-width:768px){.ts-grid{grid-template-columns:1fr}}
.ts-card{border:1px solid rgba(0,0,0,.07);border-radius:16px;padding:1.75rem;background:#fff;display:flex;flex-direction:column;gap:0;transition:border-color .2s}
.ts-card:hover{border-color:rgba(250, 204, 21, .25)}
.ts-card__header{display:flex;gap:.875rem;align-items:flex-start;margin-bottom:1.25rem}
.ts-card__icon{width:32px;height:32px;border-radius:8px;background:rgba(250, 204, 21, .08);color:rgba(250, 204, 21, 0.96);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.125rem}
.ts-card__problem{font-size:15px;font-weight:500;color:#1d1d1f;letter-spacing:-.01em;line-height:1.35;margin:0 0 .375rem}
.ts-steps{list-style:none;padding:0;margin:0 0 1.25rem;display:flex;flex-direction:column;gap:.625rem;counter-reset:step}
.ts-step{display:flex;gap:.875rem;align-items:flex-start;font-size:14px;color:#3d3d3f;line-height:1.55;counter-increment:step}
.ts-step::before{content:counter(step);width:22px;height:22px;border-radius:50%;background:rgba(250, 204, 21, .1);color:rgba(250, 204, 21, 0.96);font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.15rem}
.ts-escalation{border-top:1px solid rgba(0,0,0,.06);padding-top:1rem;margin-top:auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.ts-escalation__text{font-size:13px;color:#6e6e73;line-height:1.5;margin:0;flex:1}
.ts-escalation__link{font-size:13px;font-weight:500;color:rgba(250, 204, 21, 0.96);text-decoration:none;white-space:nowrap;transition:opacity .15s}
.ts-escalation__link:hover{opacity:.7}
</style>

{% schema %}{"name":"Troubleshooting","tag":"section","settings":[],"presets":[{"name":"Troubleshooting"}]}{% endschema %}
