<section
  class="recently-viewed section--grey"
  id="recently-viewed"
  aria-label="Recently viewed products"
  data-max="{{ section.settings.max_products }}"
  style="display:none"
>
  <div class="recently-viewed__inner page-width">
    <div class="recently-viewed__header">
      <p class="section-kicker">
        {{ section.settings.kicker | default: 'Continue browsing' | escape }}
      </p>
      <h2 class="recently-viewed__heading">
        {{ section.settings.heading | default: 'Recently viewed' | escape }}
      </h2>
    </div>
    <div class="recently-viewed__grid" id="rv-grid"></div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .recently-viewed {
    padding: clamp(48px, 6vw, 72px) 0;
  }

  #shopify-section-{{ section.id }} .recently-viewed__header {
    margin-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .recently-viewed__heading {
    margin: 0;
    color: #1d1d1f;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .recently-viewed__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.07);
  }

  #shopify-section-{{ section.id }} .rv-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: #fff;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  #shopify-section-{{ section.id }} .rv-card:hover {
    background: #fafafa;
  }

  #shopify-section-{{ section.id }} .rv-card__img-wrap {
    overflow: hidden;
    aspect-ratio: 1;
    border-radius: 10px;
    background: #f5f5f7;
  }

  #shopify-section-{{ section.id }} .rv-card__img {
    width: 100%;
    height: 100%;
    padding: 8px;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .rv-card__title {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: #1d1d1f;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .rv-card__price {
    margin: auto 0 0;
    color: #1d1d1f;
    font-size: 14px;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .recently-viewed__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Recently viewed",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Continue browsing"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently viewed"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products to show",
      "min": 4,
      "max": 8,
      "step": 2,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
