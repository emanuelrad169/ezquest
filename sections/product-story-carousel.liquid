<section class="section-shell section--grey product-story-section">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Product details that matter in real setups'
      assign section_copy = section.settings.copy | default: 'See the product details that matter most for ports, power, displays, and everyday use.'
      assign structured_highlights = blank
      assign structured_highlight_count = 0
      assign has_structured_highlights = false
      assign use_structured_highlights = false
      assign support_summary_text = blank
      assign compatibility_summary_text = blank
      assign setup_label = 'Everyday setup'
      assign story_intro_note = 'See how this product handles ports, power, displays, and day-to-day setup.'
      assign story_note_one = 'What this changes in the setup.'
      assign story_note_two = 'How it keeps everyday use cleaner once it is on the desk or in the bag.'
      assign story_note_three = 'What stays easy after purchase, from manuals to support.'

      if product != blank and product.metafields.ezquest.feature_highlights != blank
        assign structured_highlights = product.metafields.ezquest.feature_highlights.value
      endif

      if structured_highlights != blank
        for highlight in structured_highlights
          assign normalized_highlight = highlight | strip
          if normalized_highlight != blank
            assign structured_highlight_count = structured_highlight_count | plus: 1
          endif
        endfor
      endif

      if structured_highlight_count > 0
        assign has_structured_highlights = true
      endif

      if product != blank and product.metafields.ezquest.support_summary != blank
        assign support_summary_text = product.metafields.ezquest.support_summary | metafield_tag | strip_html | strip
      endif

      if product != blank and product.metafields.ezquest.compatibility_summary != blank
        assign compatibility_summary_text = product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | strip
      endif

      case product.handle
        when 'usb-c-travel-hub'
          assign setup_label = 'Travel-first setup'
          assign section_heading = 'Why this hub works on the move'
          assign section_copy = 'See how the travel-first role, lighter footprint, and ownership path separate it from broader desk options.'
          assign story_intro_note = 'Choose this when portability matters more than extra desk connections.'
          assign story_note_one = 'Built for presentations, hotel desks, classrooms, and everyday carry where lighter expansion matters.'
          assign story_note_two = 'Keeps HDMI, charging, and core ports close without turning the mobile setup into a cable project.'
          assign story_note_three = 'Manuals, downloads, and support stay close when you need help on the move.'
        when 'usb-c-pro-dock'
          assign setup_label = 'Desk-first setup'
          assign section_heading = 'Why this dock belongs at the desk'
          assign section_copy = 'See how the workstation role, broader connectivity, and ownership support justify stepping up from lighter hubs.'
          assign story_intro_note = 'Choose this when the desk needs more displays, power, and permanent connections.'
          assign story_note_one = 'Designed for permanent desks that need more peripherals, stronger display support, and calmer cable control.'
          assign story_note_two = 'Makes the step up from smaller hubs feel clear when the setup has become more workstation-like.'
          assign story_note_three = 'Keeps longer-term ownership easier with manuals, downloads, and support attached to the product.'
        when 'usb-c-multimedia-hub'
          assign setup_label = 'Balanced everyday setup'
          assign section_heading = 'Why this hub earns its place on the everyday desk'
          assign section_copy = 'See how the balanced role, broader daily coverage, and support path make it the strongest all-around EZQuest choice.'
          assign story_intro_note = 'Choose this when one compact hub needs to cover the everyday desk.'
          assign story_note_one = 'Built for everyday desks that want HDMI, charging, Ethernet, and accessory access in one adapter.'
          assign story_note_two = 'Gives hybrid work setups a cleaner center of gravity without demanding a full dock footprint.'
          assign story_note_three = 'Keeps support and compatibility close when the desk needs one dependable everyday hub.'
      endcase

      if section.settings.structured_source == 'blocks'
        assign use_structured_highlights = false
      elsif has_structured_highlights
        assign use_structured_highlights = true
      endif
    -%}

    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        <p class="product-story-intro-note">{{ story_intro_note }}</p>
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    <div class="scroll-snap-row mt-10">
      {% if use_structured_highlights %}
        {% for highlight in structured_highlights limit: section.settings.structured_limit %}
          {% assign normalized_highlight = highlight | strip %}
          {% if normalized_highlight == blank %}
            {% continue %}
          {% endif %}
          {%- liquid
            assign story_support_copy = story_note_one
            assign story_visual_variant = 'hero'
            if forloop.index == 2
              assign story_visual_variant = 'ports'
              if compatibility_summary_text != blank
                assign story_support_copy = compatibility_summary_text
              else
                assign story_support_copy = story_note_two
              endif
            elsif forloop.index == 3
              assign story_visual_variant = 'setup'
              if support_summary_text != blank
                assign story_support_copy = support_summary_text
              else
                assign story_support_copy = story_note_three
              endif
            endif
          -%}
          <article class="compare-card scroll-snap-item">
            {% render 'owned-product-visual', product_handle: product.handle, product_title: normalized_highlight, variant: story_visual_variant, kind: 'story', width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
            <div class="mt-5 flex items-center justify-between gap-4">
              <p class="section-kicker">{{ setup_label }}</p>
              {% if section.settings.show_sequence %}
                <span class="text-sm font-medium text-slate-400">{{ forloop.index | prepend: '0' }}</span>
              {% endif %}
            </div>
            <h3 class="mt-3 text-2xl font-medium tracking-tight text-slate-950">{{ normalized_highlight }}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{{ story_support_copy }}</p>
          </article>
        {% endfor %}
      {% elsif section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {%- liquid
            assign story_eyebrow = block.settings.eyebrow
            assign story_visual_variant = 'hero'
            if story_eyebrow == blank and section.settings.show_sequence
              assign story_eyebrow = 'Feature'
            endif
            if forloop.index == 2
              assign story_visual_variant = 'ports'
            elsif forloop.index == 3
              assign story_visual_variant = 'setup'
            endif
          -%}
          <article class="compare-card scroll-snap-item" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {% render 'media', image: block.settings.image, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2', object_fit: 'object-contain' %}
            {% else %}
              {% render 'owned-product-visual', product_handle: product.handle, product_title: block.settings.title, variant: story_visual_variant, kind: 'story', width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
            {% endif %}
            <div class="mt-5 flex items-center justify-between gap-4">
              {% if story_eyebrow != blank %}
                <p class="section-kicker">{{ story_eyebrow }}</p>
              {% endif %}
              {% if section.settings.show_sequence %}
                <span class="text-sm font-medium text-slate-400">{{ forloop.index | prepend: '0' }}</span>
              {% endif %}
            </div>
            <h3 class="mt-3 text-2xl font-medium tracking-tight text-slate-950">{{ block.settings.title | default: 'Designed for cleaner desk setups' }}</h3>
            {% if block.settings.copy != blank %}
              <p class="mt-3 text-sm leading-7 text-slate-600">{{ block.settings.copy }}</p>
            {% endif %}
            {% if block.settings.link != blank %}
              <div class="mt-6">
                {% render 'button', label: block.settings.link_label, url: block.settings.link, style: 'secondary' %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          {%- liquid
            assign fallback_title = 'Built for cleaner setups'
            assign fallback_copy = 'Highlight the product detail that matters most for ports, power, displays, or everyday use.'
            assign story_visual_variant = 'hero'

            if forloop.index == 2
              assign fallback_title = 'Ports, power, and displays in one place'
              assign fallback_copy = 'Show how the product reduces cable sprawl while keeping charging, display, and device expansion clear.'
              assign story_visual_variant = 'ports'
            elsif forloop.index == 3
              assign fallback_title = 'Manuals and support stay close'
              assign fallback_copy = 'Reinforce that manuals, downloads, and compatibility help stay easy to find after purchase.'
              assign story_visual_variant = 'setup'
            endif
          -%}
          <article class="compare-card scroll-snap-item">
            {% render 'owned-product-visual', product_handle: product.handle, product_title: fallback_title, variant: story_visual_variant, kind: 'story', width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
            <div class="mt-5 flex items-center justify-between gap-4">
              <p class="section-kicker">Feature</p>
              {% if section.settings.show_sequence %}
                <span class="text-sm font-medium text-slate-400">{{ i | prepend: '0' }}</span>
              {% endif %}
            </div>
            <h3 class="mt-3 text-2xl font-medium tracking-tight text-slate-950">{{ fallback_title }}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{{ fallback_copy }}</p>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product story carousel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Product story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product details that matter in real setups" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "See the product details that matter most for ports, power, displays, and everyday use." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "product", "label": "Product feature highlights" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    { "type": "text", "id": "structured_eyebrow", "label": "Structured card eyebrow", "default": "Feature highlight" },
    {
      "type": "range",
      "id": "structured_limit",
      "label": "Structured highlight limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    { "type": "checkbox", "id": "show_sequence", "label": "Show sequence labels", "default": true },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Feature" },
        { "type": "text", "id": "title", "label": "Title", "default": "Designed for cleaner desk setups" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Story description" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product story carousel",
      "blocks": [{ "type": "story" }, { "type": "story" }, { "type": "story" }]
    }
  ]
}
{% endschema %}
