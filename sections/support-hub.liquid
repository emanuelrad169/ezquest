{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

{%- assign support_hero_image = section.settings.image -%}

<section class="support-hero{% if support_hero_image != blank %} support-hero--has-image{% endif %}">
  {% if support_hero_image != blank %}
    <div class="support-hero__media" aria-hidden="true">
      {{ support_hero_image | image_url: width: 1800 | image_tag: loading: 'eager', fetchpriority: 'high', alt: '', class: 'support-hero__image' }}
    </div>
  {% endif %}
  <div class="support-hero__wrap">
    <p class="support-hero__kicker">Support Center</p>
    <h1 class="support-hero__heading">
      How can we help?
    </h1>
    <p class="support-hero__sub">
      Find answers, download files, and get in touch.
      Most questions are answered in under a minute.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'support' %}

<div class="support-body">

  <div class="shub-stats">
    <div class="shub-stat">
      <span class="shub-stat__number">2 yr</span>
      <span class="shub-stat__label">Warranty on all products</span>
    </div>
    <div class="shub-stat">
      <span class="shub-stat__number">1 day</span>
      <span class="shub-stat__label">Typical support response</span>
    </div>
    <div class="shub-stat">
      <span class="shub-stat__number">0</span>
      <span class="shub-stat__label">Drivers required (most products)</span>
    </div>
    <div class="shub-stat">
      <span class="shub-stat__number">60+</span>
      <span class="shub-stat__label">Products with documentation</span>
    </div>
  </div>

  <p class="section-label" style="margin-top:3rem">Browse by topic</p>

  <div class="shub-grid">
    {% assign support_links = 'Downloads,Get drivers utilities and setup files,/pages/downloads,download|Manuals,Full product documentation and specs,/pages/manuals,manual|Firmware,Update your device software,/pages/firmware,firmware|User Guides,Step-by-step setup and usage,/pages/user-guides,guide|Compatibility,Check devices ports and systems,/pages/compatibility,compat|Troubleshooting,Fix common issues step by step,/pages/troubleshooting,trouble|Warranty,Coverage terms and claim process,/pages/warranty,warranty|FAQ,Quick answers to common questions,/pages/faq,faq|Contact,Reach the EZQuest team directly,/pages/contact,contact' | split: '|' %}

    {% for link_data in support_links %}
      {% assign parts = link_data | split: ',' %}
      <a href="{{ parts[2] }}" class="shub-card">
        <div class="shub-card__icon" aria-hidden="true">
          {% case parts[3] %}
            {% when 'download' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 3v9m0 0l-3-3m3 3l3-3M4 14v1a2 2 0 002 2h8a2 2 0 002-2v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% when 'manual' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M6 3h8a2 2 0 012 2v10a2 2 0 01-2 2H6a2 2 0 01-2-2V5a2 2 0 012-2z" stroke="currentColor" stroke-width="1.5"/><path d="M8 7h4M8 10h4M8 13h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            {% when 'firmware' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 6h12M4 10h12M4 14h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="15" cy="14" r="2" stroke="currentColor" stroke-width="1.5"/></svg>
            {% when 'guide' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5a2 2 0 012-2h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="1.5"/><path d="M7 9l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% when 'compat' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="3" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="11" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="11" y="11" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg>
            {% when 'trouble' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4.5M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            {% when 'warranty' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 3l6 2.5V10c0 3.5-2.5 5.5-6 7-3.5-1.5-6-3.5-6-7V5.5L10 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            {% when 'faq' %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 8a2 2 0 114 0c0 1.5-2 2-2 3.5M10 14.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/></svg>
            {% else %}
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M2.5 6.5A1.5 1.5 0 014 5h12a1.5 1.5 0 011.5 1.5v7A1.5 1.5 0 0116 15H4a1.5 1.5 0 01-1.5-1.5v-7zM2.5 7l7.5 4.5L17.5 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          {% endcase %}
        </div>
        <div>
          <p class="shub-card__title">{{ parts[0] }}</p>
          <p class="shub-card__desc">{{ parts[1] }}</p>
        </div>
        <svg class="shub-card__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {% endfor %}
  </div>

  <div class="support-cta-strip">
    <div>
      <p class="support-cta-strip__heading">Still need help?</p>
      <p class="support-cta-strip__body">
        Send us a message. We respond within 1 business day.
      </p>
    </div>
    <div class="support-cta-strip__actions">
      <a href="/pages/contact" class="btn btn--primary">Contact support</a>
      <a href="tel:18008819305" class="btn btn--secondary" style="color:var(--ez-light);border-color:rgba(255,255,255,0.2)">1-800-881-9305</a>
    </div>
  </div>

</div>

<style>
.support-hero{position:relative;overflow:hidden}
.support-hero__media{position:absolute;inset:0;z-index:0}
.support-hero__image{width:100%;height:100%;object-fit:cover}
.support-hero--has-image .support-hero__wrap{position:relative;z-index:1}
.support-hero--has-image:after{content:"";position:absolute;inset:0;z-index:0;background:linear-gradient(90deg,rgba(248,250,252,.96),rgba(248,250,252,.72) 45%,rgba(248,250,252,.18))}
.shub-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(0,0,0,.07);border:1px solid rgba(0,0,0,.07);border-radius:16px;overflow:hidden;margin-bottom:3rem}
@media(max-width:768px){.shub-stats{grid-template-columns:repeat(2,1fr)}}
.shub-stat{background:#fff;padding:1.5rem;display:flex;flex-direction:column;gap:.375rem}
.shub-stat__number{font-size:clamp(24px,3vw,36px);font-weight:500;letter-spacing:-.03em;color:var(--ez-black);line-height:1}
.shub-stat__label{font-size:13px;color:var(--ez-grey);line-height:1.4;max-width:18ch}
.shub-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(0,0,0,.07);border:1px solid rgba(0,0,0,.07);border-radius:16px;overflow:hidden}
@media(max-width:900px){.shub-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:540px){.shub-grid{grid-template-columns:1fr}}
.shub-card{background:#fff;padding:1.5rem;text-decoration:none;display:grid;grid-template-columns:36px 1fr 16px;align-items:center;gap:1rem;transition:background .15s}
.shub-card:hover{background:var(--ez-light)}
.shub-card__icon{width:36px;height:36px;border-radius:10px;background:rgba(251, 206, 42, .08);color:var(--ez-amber);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.shub-card__title{font-size:15px;font-weight:500;color:var(--ez-black);margin:0 0 .2rem;letter-spacing:-.01em}
.shub-card__desc{font-size:13px;color:var(--ez-grey);margin:0;line-height:1.45}
.shub-card__arrow{color:rgba(0,0,0,.2);transition:color .15s,transform .15s}
.shub-card:hover .shub-card__arrow{color:var(--ez-amber);transform:translateX(3px)}
</style>

{% schema %}
{
  "name": "Support hub",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [
    { "name": "Support hub" }
  ]
}
{% endschema %}
