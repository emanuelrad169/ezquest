<section class="shoppable-video section--dark" aria-label="{{ section.settings.heading | escape }}">
  <div class="shoppable-video__media">
    {% if section.settings.video != blank %}
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          class: 'shoppable-video__video'
      }}
    {% elsif section.settings.video_url != blank %}
      <iframe
        src="{{ section.settings.video_url | escape }}"
        class="shoppable-video__iframe"
        frameborder="0"
        allow="autoplay; fullscreen"
        allowfullscreen
        title="{{ section.settings.heading | escape }}"
      ></iframe>
    {% else %}
      <div class="shoppable-video__placeholder">
        <p>Upload a video in the theme customizer</p>
      </div>
    {% endif %}

    <div class="shoppable-video__overlay" aria-hidden="true"></div>
  </div>

  <div class="shoppable-video__content page-width">
    {% if section.settings.kicker != blank %}
      <p class="section-kicker shoppable-video__kicker">{{ section.settings.kicker | escape }}</p>
    {% endif %}

    <h2 class="shoppable-video__heading">{{ section.settings.heading | escape }}</h2>

    {% if section.settings.body != blank %}
      <p class="shoppable-video__body">{{ section.settings.body | escape }}</p>
    {% endif %}

    {% if section.settings.cta_label != blank %}
      <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--primary shoppable-video__cta">
        {{ section.settings.cta_label | escape }}
      </a>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="shoppable-video__products" aria-hidden="true">
      {% for block in section.blocks %}
        {% if block.type == 'product' %}
          {%- assign tagged_product = block.settings.product -%}
          {% if tagged_product != blank %}
            <a
              href="{{ tagged_product.url }}"
              class="shoppable-product-tag"
              aria-label="{{ tagged_product.title | escape }}"
              {{ block.shopify_attributes }}
              style="--x: {{ block.settings.x_position }}%; --y: {{ block.settings.y_position }}%"
            >
              {% if tagged_product.featured_image %}
                <img
                  src="{{ tagged_product.featured_image | image_url: width: 80 }}"
                  alt="{{ tagged_product.title | escape }}"
                  class="shoppable-product-tag__image"
                  width="40"
                  height="40"
                  loading="lazy"
                >
              {% endif %}
              <span class="shoppable-product-tag__info">
                <span class="shoppable-product-tag__title">{{ tagged_product.title }}</span>
                <span class="shoppable-product-tag__price">{{ tagged_product.price | money }}</span>
              </span>
            </a>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Shoppable video",
  "tag": "section",
  "class": "section-shoppable-video",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it in action"
    },
    { "type": "textarea", "id": "body", "label": "Body text" },
    { "type": "video", "id": "video", "label": "Video file" },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video embed URL (YouTube/Vimeo — fallback)"
    },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product tag",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        {
          "type": "range",
          "id": "x_position",
          "label": "Horizontal position %",
          "min": 5,
          "max": 95,
          "step": 5,
          "default": 50
        },
        {
          "type": "range",
          "id": "y_position",
          "label": "Vertical position %",
          "min": 5,
          "max": 95,
          "step": 5,
          "default": 50
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Shoppable video" }
  ]
}
{% endschema %}
