<section class="section-shell resources-categories-section">
  <div class="container-shell">
    <div class="resources-categories-header">
      {% if section.settings.eyebrow != blank %}
        <p class="section-kicker">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="section-heading mt-4">{{ section.settings.heading | default: 'Browse product guidance' }}</h2>
    </div>

    <div class="resources-categories-grid mt-10">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <div class="resources-category-card" {{ block.shopify_attributes }}>
            <div class="resources-category-top">
              <h3 class="resources-category-title">{{ block.settings.title }}</h3>
              {% if block.settings.desc != blank %}
                <p class="resources-category-desc">{{ block.settings.desc }}</p>
              {% endif %}
            </div>
            <ul class="resources-category-links">
              {% if block.settings.link1_label != blank %}
                <li><a href="{{ block.settings.link1_url }}" class="resources-category-link">{{ block.settings.link1_label }}</a></li>
              {% endif %}
              {% if block.settings.link2_label != blank %}
                <li><a href="{{ block.settings.link2_url }}" class="resources-category-link">{{ block.settings.link2_label }}</a></li>
              {% endif %}
              {% if block.settings.link3_label != blank %}
                <li><a href="{{ block.settings.link3_url }}" class="resources-category-link">{{ block.settings.link3_label }}</a></li>
              {% endif %}
              {% if block.settings.link4_label != blank %}
                <li><a href="{{ block.settings.link4_url }}" class="resources-category-link">{{ block.settings.link4_label }}</a></li>
              {% endif %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Resource categories",
  "settings": [
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow", "default": "Browse by topic" },
    { "type": "text", "id": "heading",  "label": "Heading",  "default": "Browse product guidance" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text",     "id": "title",       "label": "Title",         "default": "Product guides" },
        { "type": "textarea", "id": "desc",         "label": "Description",   "default": "Product guides, compatibility help, and support resources for EZQuest products." },
        { "type": "text",     "id": "link1_label",  "label": "Link 1 label",  "default": "Hub setup guide" },
        { "type": "url",      "id": "link1_url",    "label": "Link 1 URL" },
        { "type": "text",     "id": "link2_label",  "label": "Link 2 label" },
        { "type": "url",      "id": "link2_url",    "label": "Link 2 URL" },
        { "type": "text",     "id": "link3_label",  "label": "Link 3 label" },
        { "type": "url",      "id": "link3_url",    "label": "Link 3 URL" },
        { "type": "text",     "id": "link4_label",  "label": "Link 4 label" },
        { "type": "url",      "id": "link4_url",    "label": "Link 4 URL" }
      ]
    }
  ],
  "presets": [
    { "name": "Resource categories" }
  ]
}
{% endschema %}
