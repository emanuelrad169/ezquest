{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero relative overflow-hidden bg-[var(--ez-light)] pt-[clamp(48px,6vw,80px)] pb-[clamp(32px,4vw,48px)]">
  <div class="support-hero__wrap w-full">
    <p class="support-hero__kicker">Manuals</p>
    <h1 class="support-hero__heading">
      Product manuals &amp;<br>documentation
    </h1>
    <p class="support-hero__sub">
      Full setup guides, spec sheets, and reference manuals
      for every current EZQuest product.
    </p>
  </div>
</section>

<div class="support-body pt-[clamp(48px,6vw,80px)] pb-[clamp(48px,6vw,80px)]">

  <div class="data-table-wrap border border-black/[7%] rounded-2xl overflow-hidden">
    <table class="data-table w-full border-collapse text-sm">
      <thead>
        <tr>
          <th style="width:52px"></th>
          <th>Product</th>
          <th>Manual</th>
          <th>Pages</th>
          <th>Language</th>
          <th>Updated</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for block in section.blocks %}
          {% if block.type == 'manual' %}
            {% assign p = block.settings.product %}
            <tr {{ block.shopify_attributes }}>
              <td>
                {% if p != blank and p.featured_image %}
                  <img src="{{ p.featured_image | image_url: width: 48, format: 'pjpg' }}" alt="{{ p.title | escape }}" width="40" height="40" style="border-radius:8px;object-fit:contain;background:var(--ez-light);display:block">
                {% else %}
                  <div style="width:40px;height:40px;border-radius:8px;background:var(--ez-light);display:flex;align-items:center;justify-content:center">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="12" height="14" rx="2" stroke="var(--ez-grey)" stroke-width="1.25"/><path d="M5 5h6M5 8h6M5 11h3" stroke="var(--ez-grey)" stroke-width="1.25" stroke-linecap="round"/></svg>
                  </div>
                {% endif %}
              </td>
              <td data-label="Product" style="font-weight:500">
                {{ block.settings.product_name | default: p.title | default: 'EZQuest Product' }}
              </td>
              <td data-label="Manual">{{ block.settings.manual_title }}</td>
              <td data-label="Pages" style="color:var(--ez-grey)">{{ block.settings.page_count | default: '—' }}</td>
              <td data-label="Language" style="color:var(--ez-grey)">{{ block.settings.language | default: 'English' }}</td>
              <td data-label="Updated" style="color:var(--ez-grey);font-size:13px">{{ block.settings.updated | default: '2025' }}</td>
              <td>
                {% if block.settings.file_url != blank and block.settings.file_url != '#' %}
                  <a href="{{ block.settings.file_url }}" class="btn-download hover:bg-[var(--ez-amber)]" download>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 2v7m0 0L4.5 6.5M7 9l2.5-2.5M2 11h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    PDF
                  </a>
                {% else %}
                  <span style="font-size:13px;color:var(--ez-grey)">Uploading</span>
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}

        {% if section.blocks.size == 0 %}
          <tr>
            <td colspan="7">
              <div class="empty-state text-center py-16 px-8 border border-black/[7%] rounded-2xl bg-[var(--ez-light)]">
                <p class="empty-state__heading text-[18px] font-medium text-[var(--ez-black)] mb-2">Manuals are being uploaded</p>
                <p class="empty-state__body text-sm text-[var(--ez-grey)] mb-6">Check back shortly or contact us for direct access.</p>
                <a href="/pages/contact" class="btn btn--primary">Request a manual</a>
              </div>
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>


</div>

{%- render 'page-cta',
  variant: 'dark',
  kicker: 'Manuals',
  heading: 'Missing a manual?',
  subhead: 'Let us know the product and we'll send it.',
  primary_label: 'Request manual',
  primary_url: '/pages/contact'
-%}

{% schema %}
{
  "name": "Manuals",
  "tag": "section",
  "blocks": [
    {
      "type": "manual",
      "name": "Manual",
      "settings": [
        {"type":"product","id":"product","label":"Product"},
        {"type":"text","id":"product_name","label":"Product name override"},
        {"type":"text","id":"manual_title","label":"Manual title","placeholder":"User Manual — English"},
        {"type":"url","id":"file_url","label":"PDF file URL"},
        {"type":"text","id":"page_count","label":"Page count","placeholder":"48 pages"},
        {"type":"text","id":"language","label":"Language","default":"English"},
        {"type":"text","id":"updated","label":"Last updated","placeholder":"2025"}
      ]
    }
  ],
  "presets":[{"name":"Manuals"}]
}
{% endschema %}
