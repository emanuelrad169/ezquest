<section class="section-shell pt-10 lg:pt-16 home-confidence-section">
  <div class="container-shell">

    <div class="home-confidence-grid mt-8 reveal-stagger">

      {%- comment -%} Row 1 · Col 1 — Fast shipping {%- endcomment -%}
      <article class="home-confidence-card home-confidence-card--shipping">
        <div class="home-confidence-card-copy">
          <h3 class="home-confidence-card-title">Fast shipping</h3>
          <p class="home-confidence-card-sub">Orders ship within 1–2 business days with full tracking provided.</p>
        </div>
        <div class="home-confidence-card-icon" style="--icon-bg:#FEF3C7;--icon-color:#92400E">
          {% render 'icon', name: 'truck', size: 28 %}
        </div>
      </article>

      {%- comment -%} Row 1 · Cols 2–3 — 2-Year Warranty HERO {%- endcomment -%}
      <article class="home-confidence-card home-confidence-card--hero">
        <div class="home-confidence-hero-watermark" aria-hidden="true">
          <svg width="240" height="240" viewBox="0 0 18 18" fill="none">
            <path d="M9 2.9 13.9 4.6v3.6c0 3-2 5.65-4.9 6.9-2.9-1.25-4.9-3.9-4.9-6.9V4.6L9 2.9Z" fill="#fff"/>
          </svg>
        </div>
        <div class="home-confidence-hero-copy">
          <p class="home-confidence-hero-eyebrow">EZQuest Promise</p>
          <p class="home-confidence-hero-title">2-year warranty</p>
          <p class="home-confidence-hero-sub">Every product. No fine print.</p>
        </div>
        <div class="home-confidence-hero-bottom">
          <svg class="home-confidence-hero-badge" width="72" height="72" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M9 2.9 13.9 4.6v3.6c0 3-2 5.65-4.9 6.9-2.9-1.25-4.9-3.9-4.9-6.9V4.6L9 2.9Z" fill="var(--ez-amber,#FED300)"/>
            <path d="M6.5 9.2L8.3 11l3.2-3.2" stroke="#111" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <p class="home-confidence-hero-badge-label">2-year coverage</p>
            <a href="/pages/warranty" class="btn btn--link-on-dark">View warranty</a>
          </div>
        </div>
      </article>

      {%- comment -%} Row 2 · Col 1 — Easy returns {%- endcomment -%}
      <article class="home-confidence-card home-confidence-card--returns">
        <div class="home-confidence-card-copy">
          <h3 class="home-confidence-card-title">Easy returns</h3>
          <p class="home-confidence-card-sub">Hassle-free returns within 30 days. No questions asked.</p>
        </div>
        <div class="home-confidence-card-icon" style="--icon-bg:#DBEAFE;--icon-color:#1E40AF">
          {% render 'icon', name: 'refresh-cw', size: 28 %}
        </div>
      </article>

      {%- comment -%} Row 2 · Col 2 — Manuals & downloads {%- endcomment -%}
      <article class="home-confidence-card home-confidence-card--manuals">
        <div class="home-confidence-card-copy">
          <h3 class="home-confidence-card-title">Manuals &amp; downloads</h3>
          <p class="home-confidence-card-sub">Setup guides, firmware, and docs ready when you need them.</p>
        </div>
        <div class="home-confidence-card-icon" style="--icon-bg:#E0E7FF;--icon-color:#3730A3">
          {% render 'icon', name: 'file-text', size: 28 %}
        </div>
      </article>

      {%- comment -%} Row 2 · Col 3 — Customer support {%- endcomment -%}
      <article class="home-confidence-card home-confidence-card--support">
        <div class="home-confidence-card-copy">
          <h3 class="home-confidence-card-title">Live support</h3>
          <p class="home-confidence-card-sub">Real humans, fast replies. Help by email, chat, or phone.</p>
        </div>
        <div class="home-confidence-card-icon" style="--icon-bg:#D1FAE5;--icon-color:#065F46">
          {% render 'icon', name: 'support', size: 28 %}
        </div>
      </article>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home confidence grid",
  "settings": [],
  "presets": [
    {
      "name": "Home confidence grid"
    }
  ]
}
{% endschema %}
