{%- liquid
  assign hero_image = section.settings.background_image | default: section.settings.image
  assign hero_kicker = section.settings.kicker
  assign hero_heading = section.settings.heading
  assign hero_subheading = section.settings.subheading
  assign use_gradient = false

  if request.page_type == 'product' and product
    assign hero_kicker = section.settings.kicker | default: product.type
    assign hero_heading = section.settings.heading | default: product.title
    assign hero_subheading = section.settings.subheading | default: product.metafields.custom.tagline.value
    assign hero_image = section.settings.background_image | default: section.settings.image | default: product.featured_image

    if hero_subheading == blank
      assign hero_subheading = product.description | strip_html | truncate: 100
    endif
  elsif request.page_type == 'collection' and collection
    assign hero_kicker = section.settings.kicker | default: 'Collection'
    assign hero_heading = section.settings.heading | default: collection.title
    assign hero_subheading = section.settings.subheading | default: collection.description | strip_html | truncate: 120
    assign hero_image = section.settings.background_image | default: section.settings.image | default: collection.featured_image
  elsif hero_heading == blank
    if request.page_type == 'search'
      assign hero_heading = 'Search results'
    elsif request.page_type == 'cart'
      assign hero_heading = 'Your cart'
    elsif request.page_type == '404'
      assign hero_heading = "We couldn't find that page"
    elsif page
      assign hero_heading = page.title
    else
      assign hero_heading = 'Page title'
    endif
  endif

  if request.page_type == 'search'
    if search.performed and search.terms != blank
      capture hero_subheading
        echo 'Showing results for "'
        echo search.terms | escape
        echo '"'
      endcapture
    else
      assign hero_subheading = 'Use the search box to explore products, guides, and support articles.'
    endif
  endif

  comment
    For templates without a dynamic or configured image, fall back
    to a gradient instead of a flat solid color.
  endcomment
  if hero_image == blank
    assign use_gradient = true
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .page-hero {
    background-color: {{ section.settings.background_color | default: '#020617' }};
    min-height: {{ section.settings.height | default: 360 }}px;
    {%- if hero_image != blank -%}
      background-image: url('{{ hero_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .page-hero__overlay {
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 35 | divided_by: 100.0 }});
  }
{%- endstyle -%}

<section class="page-hero {% if use_gradient %}page-hero--gradient{% endif %}" aria-label="{{ hero_heading | escape }}">
  <div class="page-hero__overlay"></div>

  <div class="page-hero__inner container-shell">
    {% if hero_kicker != blank %}
      <p class="page-hero__kicker">{{ hero_kicker | escape }}</p>
    {% endif %}

    {% if hero_heading != blank %}
      <h1 class="page-hero__heading">{{ hero_heading | escape }}</h1>
    {% endif %}

    {% if hero_subheading != blank %}
      <p class="page-hero__subheading">{{ hero_subheading | escape }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (legacy)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback color",
      "default": "#020617"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (small label above heading)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page title"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub-heading"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Hero height (px)",
      "min": 240,
      "max": 600,
      "step": 20,
      "default": 360
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark overlay opacity (for text legibility)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 35
    }
  ],
  "presets": [
    {
      "name": "Page hero"
    }
  ]
}
{% endschema %}
