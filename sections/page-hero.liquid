{%- liquid
  assign hero_image = section.settings.background_image | default: section.settings.image
  assign hero_background_url = blank
  assign hero_kicker = section.settings.kicker
  assign hero_heading = section.settings.heading
  assign hero_subheading = section.settings.subheading
  assign use_gradient = false

  if request.page_type == 'product' and product
    assign hero_kicker = section.settings.kicker | default: product.type
    assign hero_heading = section.settings.heading | default: product.title
    assign hero_subheading = section.settings.subheading | default: product.metafields.custom.tagline.value
    assign hero_image = section.settings.background_image | default: section.settings.image | default: product.featured_image

    if hero_subheading == blank
      assign hero_subheading = product.description | strip_html | truncate: 100
    endif
  elsif request.page_type == 'collection' and collection
    assign hero_kicker = section.settings.kicker | default: 'Collection'
    assign hero_heading = section.settings.heading | default: collection.title
    assign hero_subheading = section.settings.subheading | default: collection.description | strip_html | truncate: 120
    assign hero_image = section.settings.background_image | default: section.settings.image | default: collection.featured_image
  elsif request.page_type == 'article' and article
    assign hero_kicker = section.settings.kicker | default: article.tags.first | upcase
    assign hero_heading = section.settings.heading | default: article.title
    assign hero_subheading = section.settings.subheading | default: article.excerpt | strip_html | truncate: 160
    assign hero_image = section.settings.background_image | default: section.settings.image | default: article.image
  elsif hero_heading == blank
    if request.page_type == 'search'
      assign hero_heading = 'Search results'
    elsif request.page_type == 'cart'
      assign hero_heading = 'Your cart'
    elsif request.page_type == '404'
      assign hero_heading = "We couldn't find that page"
    elsif page
      assign hero_heading = page.title
    else
      assign hero_heading = 'Page title'
    endif
  endif

  if request.page_type == 'search'
    if search.performed and search.terms != blank
      capture hero_subheading
        echo 'Showing results for "'
        echo search.terms | escape
        echo '"'
      endcapture
    else
      assign hero_subheading = 'Use the search box to explore products, guides, and support articles.'
    endif
  endif

  comment
    For templates without a dynamic or configured image, fall back
    to a gradient instead of a flat solid color.
  endcomment
  if hero_image != blank
    assign hero_background_url = hero_image | image_url: width: 2000
  elsif request.page_type == 'page' and page and page.handle == 'compatibility'
    assign hero_background_url = 'support-compatibility.svg' | asset_url
  endif

  if hero_image == blank
    assign use_gradient = true
  endif

  if hero_background_url != blank
    assign use_gradient = false
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .page-hero {
    background-color: {{ section.settings.background_color | default: '#020617' }};
    min-height: {% if request.page_type == 'product' %}240px{% else %}{{ section.settings.height | default: 360 }}px{% endif %};
    {%- if hero_background_url != blank -%}
      background-image: url('{{ hero_background_url }}');
      background-size: cover;
      background-position: center;
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .page-hero__overlay {
    {%- if use_gradient -%}
    background: transparent;
    {%- else -%}
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 35 | divided_by: 100.0 }});
    {%- endif -%}
  }
{%- endstyle -%}

{{ 'page-hero.css' | asset_url | stylesheet_tag }}

<section class="page-hero {% if use_gradient %}page-hero--gradient{% endif %}" aria-label="{{ hero_heading | escape }}">
  <div class="page-hero__overlay"></div>

  {%- unless request.page_type == 'product' -%}
    <div class="page-hero__inner container-shell">
      {%- if section.settings.show_breadcrumb -%}
        <nav class="page-hero__breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span class="page-hero__breadcrumb-sep" aria-hidden="true">/</span>
          <span aria-current="page">{{ hero_heading | escape }}</span>
        </nav>
      {%- endif -%}

      {% if hero_kicker != blank %}
        <p class="page-hero__kicker">{%- if section.settings.eyebrow_pulse -%}<span class="page-hero__pulse" aria-hidden="true"></span>{%- endif -%}{{ hero_kicker | escape }}</p>
      {% endif %}

      {% if hero_heading != blank %}
        <h1 class="page-hero__heading">{{ hero_heading | escape }}</h1>
      {% endif %}

      {% if hero_subheading != blank %}
        <p class="page-hero__subheading">{{ hero_subheading | escape }}</p>
      {% endif %}

      {%- if section.settings.cta_label != blank -%}
        <div class="page-hero__actions">
          <a href="{{ section.settings.cta_link | default: '#' }}" class="page-hero__cta">{{ section.settings.cta_label | escape }}</a>
          {%- if section.settings.cta_secondary_label != blank -%}
            <a href="{{ section.settings.cta_secondary_link | default: '#' }}" class="page-hero__cta-secondary">{{ section.settings.cta_secondary_label | escape }} <span aria-hidden="true">&rarr;</span></a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_trust -%}
        {%- capture trust_raw -%}{{ section.settings.trust_1 }}|{{ section.settings.trust_2 }}|{{ section.settings.trust_3 }}|{{ section.settings.trust_4 }}{%- endcapture -%}
        {%- assign trust_list = trust_raw | split: '|' -%}
        {%- assign trust_has = false -%}
        {%- for t in trust_list -%}{%- assign t = t | strip -%}{%- if t != blank -%}{%- assign trust_has = true -%}{%- endif -%}{%- endfor -%}
        {%- if trust_has -%}
          <ul class="page-hero__trust">
            {%- for t in trust_list -%}
              {%- assign t = t | strip -%}
              {%- if t != blank -%}
                <li class="page-hero__trust-chip">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ t }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      {%- endif -%}
    </div>
  {%- endunless -%}
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (legacy)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background fallback color",
      "default": "#020617"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (small label above heading)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page title"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub-heading"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Hero height (px)",
      "min": 240,
      "max": 600,
      "step": 20,
      "default": 360
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark overlay opacity (for text legibility)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 35
    },
    { "type": "header", "content": "Conversion" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "checkbox", "id": "eyebrow_pulse", "label": "Eyebrow pulse dot", "default": true },
    { "type": "text", "id": "cta_label", "label": "Primary button label" },
    { "type": "url", "id": "cta_link", "label": "Primary button link" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary link label" },
    { "type": "url", "id": "cta_secondary_link", "label": "Secondary link URL" },
    { "type": "header", "content": "Trust strip" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust strip", "default": true },
    { "type": "text", "id": "trust_1", "label": "Trust item 1", "default": "1-year warranty" },
    { "type": "text", "id": "trust_2", "label": "Trust item 2", "default": "30-day returns" },
    { "type": "text", "id": "trust_3", "label": "Trust item 3", "default": "Free shipping over $90" },
    { "type": "text", "id": "trust_4", "label": "Trust item 4" }
  ],
  "presets": [
    {
      "name": "Page hero"
    }
  ]
}
{% endschema %}
