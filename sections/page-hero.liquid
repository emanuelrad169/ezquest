{%- liquid
  assign hero_image = section.settings.image
-%}
<section
  class="page-hero{% if hero_image != blank %} page-hero--has-image{% endif %}{% if section.settings.light_mode %} page-hero--light{% endif %}"
  {% if hero_image != blank %}style="--hero-bg: url({{ hero_image | image_url: width: 1800 }})"{% endif %}
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="page-hero__inner container-shell">
    {% if section.settings.kicker != blank %}
      <p class="page-hero__kicker">{{ section.settings.kicker | escape }}</p>
    {% endif %}
    <h1 class="page-hero__heading">{{ section.settings.heading | default: page.title | escape }}</h1>
    {% if section.settings.subheading != blank %}
      <p class="page-hero__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}
    {% if section.settings.cta_label != blank %}
      <div class="page-hero__actions">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="btn btn--primary">
          {{ section.settings.cta_label | escape }}
        </a>
        {% if section.settings.cta2_label != blank %}
          <a href="{{ section.settings.cta2_url | default: '#' }}" class="btn btn--secondary">
            {{ section.settings.cta2_label | escape }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    { "type": "text",  "id": "kicker",     "label": "Kicker" },
    { "type": "text",  "id": "heading",    "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text",  "id": "cta_label",  "label": "Primary CTA label" },
    { "type": "url",   "id": "cta_url",    "label": "Primary CTA URL" },
    { "type": "text",  "id": "cta2_label", "label": "Secondary CTA label" },
    { "type": "url",   "id": "cta2_url",   "label": "Secondary CTA URL" },
    { "type": "checkbox", "id": "light_mode", "label": "Light background (for support pages)", "default": false }
  ],
  "presets": [
    { "name": "Page hero" }
  ]
}
{% endschema %}
