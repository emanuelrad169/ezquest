<section class="section-shell home-feature-bento-section">
  <div class="container-shell">

    {% if section.settings.heading != blank or section.settings.eyebrow != blank %}
      <div class="home-feature-bento-header">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="section-heading mt-3">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="home-feature-bento-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign card_size = block.settings.size | default: 'normal'
          assign card_stat = block.settings.stat
          assign card_label = block.settings.label
          assign card_sublabel = block.settings.sublabel
          assign card_image = block.settings.image
          assign card_style = block.settings.card_style | default: 'light'
        -%}
        <div class="home-feature-bento-card home-feature-bento-card--{{ card_size }} home-feature-bento-card--{{ card_style }}" {{ block.shopify_attributes }}>
          <div class="home-feature-bento-media">
            {% if card_image != blank %}
              {{ card_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'home-feature-bento-img', alt: card_label }}
            {% else %}
              <div class="home-feature-bento-placeholder">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <rect width="48" height="48" rx="12" fill="currentColor" fill-opacity="0.06"/>
                  <rect x="10" y="10" width="28" height="20" rx="3" fill="currentColor" fill-opacity="0.1"/>
                  <circle cx="17" cy="16" r="3" fill="currentColor" fill-opacity="0.2"/>
                  <path d="M10 26l8-7 7 6 5-4 8 5v3H10v-3Z" fill="currentColor" fill-opacity="0.12"/>
                  <rect x="10" y="34" width="18" height="3" rx="1.5" fill="currentColor" fill-opacity="0.1"/>
                  <rect x="10" y="40" width="11" height="2" rx="1" fill="currentColor" fill-opacity="0.07"/>
                </svg>
                <span class="home-feature-bento-placeholder-label">Add image</span>
              </div>
            {% endif %}
          </div>
          {% if card_stat != blank or card_label != blank %}
            <div class="home-feature-bento-copy">
              {% if card_stat != blank %}
                <p class="home-feature-bento-stat">{{ card_stat }}</p>
              {% endif %}
              {% if card_label != blank %}
                <p class="home-feature-bento-label">{{ card_label }}</p>
              {% endif %}
              {% if card_sublabel != blank %}
                <p class="home-feature-bento-sublabel">{{ card_sublabel }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Home feature bento",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "select",
          "id": "size",
          "label": "Card size",
          "options": [
            { "value": "normal", "label": "Normal (1×1)" },
            { "value": "wide", "label": "Wide (2×1)" },
            { "value": "tall", "label": "Tall (1×2)" },
            { "value": "featured", "label": "Featured (2×2)" }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "card_style",
          "label": "Card style",
          "options": [
            { "value": "light", "label": "Light" },
            { "value": "dark", "label": "Dark" },
            { "value": "blue", "label": "Blue" }
          ],
          "default": "light"
        },
        { "type": "text", "id": "stat", "label": "Stat / number", "info": "e.g. 100W or 4K 60Hz" },
        { "type": "text", "id": "label", "label": "Label", "info": "e.g. Power delivery" },
        { "type": "text", "id": "sublabel", "label": "Sub-label", "info": "e.g. dual-display desk support" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home feature bento",
      "blocks": [
        { "type": "feature", "settings": { "size": "normal", "card_style": "light", "stat": "8-in-1", "label": "Hub expansion" } },
        { "type": "feature", "settings": { "size": "normal", "card_style": "blue", "label": "USB-C charging" } },
        { "type": "feature", "settings": { "size": "normal", "card_style": "light", "stat": "4K 60Hz", "label": "Display support" } },
        { "type": "feature", "settings": { "size": "normal", "card_style": "light" } },
        { "type": "feature", "settings": { "size": "normal", "card_style": "light", "stat": "100W", "label": "Power delivery" } },
        { "type": "feature", "settings": { "size": "wide", "card_style": "blue", "stat": "Travel-ready", "label": "Compact chargers and hubs" } },
        { "type": "feature", "settings": { "size": "normal", "card_style": "light", "stat": "2.5GbE", "label": "Wired networking" } }
      ]
    }
  ]
}
{% endschema %}
