<section class="section-shell">
  <div class="container-shell">
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}
          <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% endif %}
      </div>
      {% if section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>
    <div class="mt-10 editorial-grid">
      {% assign source_blog = blogs[section.settings.blog] %}
      {% if source_blog != blank %}
        {% for article in source_blog.articles limit: section.settings.limit %}
          {% render 'card-article', article: article, excerpt: article.excerpt_or_content | strip_html | truncatewords: 22 %}
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          {% render 'card-article', excerpt: 'Reserved for editorial cards and blog discovery.' %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Article feed",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Journal" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Editorial framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for blog previews, education, and evergreen content modules." },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "limit", "label": "Article limit", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all articles" },
    { "type": "url", "id": "link_url", "label": "Link" }
  ],
  "presets": [
    { "name": "Article feed" }
  ]
}
{% endschema %}
