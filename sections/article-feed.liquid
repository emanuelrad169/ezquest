<section class="section-shell home-editorial-section">
  <div class="container-shell">
    {% assign source_blog = blogs[section.settings.blog] %}
    <div class="home-editorial-shell">
      <div class="home-editorial-intro">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}
          <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% endif %}
        {% if section.settings.link_url != blank %}
          <div class="mt-8">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}
      </div>

      <div class="home-editorial-grid">
        {% if source_blog != blank %}
          {%- liquid
            assign lead_fallback_image = blank
            assign editorial_secondary_image = blank
            assign editorial_tertiary_image = blank

            if all_products['usb-c-multimedia-hub'] != blank
              assign lead_fallback_image = all_products['usb-c-multimedia-hub'].featured_image
            endif
            if all_products['usb-c-pro-dock'] != blank
              assign editorial_secondary_image = all_products['usb-c-pro-dock'].featured_image
            endif
            if all_products['usb-c-travel-hub'] != blank
              assign editorial_tertiary_image = all_products['usb-c-travel-hub'].featured_image
            endif
          -%}
          {% assign lead_article = source_blog.articles.first %}
          {% if lead_article != blank %}
            <article class="home-editorial-feature">
              <div class="home-editorial-feature-media">
                {% if lead_article.image != blank %}
                  {{ lead_article.image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
                {% elsif lead_fallback_image != blank %}
                  {{ lead_fallback_image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
                {% else %}
                  {% render 'placeholder-visual',
                    kind: 'editorial',
                    text: lead_article.title,
                    width: 1400,
                    height: 1050,
                    class: 'home-editorial-image aspect-card w-full object-cover'
                  %}
                {% endif %}
              </div>
              <p class="section-kicker">{{ lead_article.blog.title }}</p>
              <h3 class="display-heading mt-4 text-display sm:text-display-2xl">{{ lead_article.title }}</h3>
              <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">{{ lead_article.excerpt_or_content | strip_html | truncatewords: 26 }}</p>
              <div class="home-editorial-meta mt-6">
                <span>{{ lead_article.published_at | date: '%b %d, %Y' }}</span>
                {% render 'button', label: 'Read article', url: lead_article.url, style: 'tertiary' %}
              </div>
            </article>
          {% endif %}

          <div class="home-editorial-stack">
          {% for article in source_blog.articles limit: section.settings.limit %}
            {% unless forloop.first %}
              {%- liquid
                assign editorial_fallback_image = blank
                if forloop.index == 2 and editorial_secondary_image != blank
                  assign editorial_fallback_image = editorial_secondary_image
                elsif editorial_tertiary_image != blank
                  assign editorial_fallback_image = editorial_tertiary_image
                endif
              -%}
              <article class="home-editorial-card">
                <div class="home-editorial-card-media">
                  {% if article.image != blank %}
                    {{ article.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
                  {% elsif editorial_fallback_image != blank %}
                    {{ editorial_fallback_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
                  {% else %}
                    {% render 'placeholder-visual',
                      kind: 'editorial',
                      text: article.title,
                      width: 900,
                      height: 700,
                      class: 'home-editorial-image aspect-card w-full object-cover'
                    %}
                  {% endif %}
                </div>
                <p class="section-kicker">{{ article.blog.title }}</p>
                <h3 class="card-title mt-4"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
                <div class="home-editorial-meta mt-6">
                  <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                  {% render 'button', label: 'Open', url: article.url, style: 'tertiary' %}
                </div>
              </article>
            {% endunless %}
          {% endfor %}
          </div>
        {% else %}
          {%- liquid
            assign lead_fallback_image = blank
            assign editorial_secondary_image = blank
            assign editorial_tertiary_image = blank

            if all_products['usb-c-multimedia-hub'] != blank
              assign lead_fallback_image = all_products['usb-c-multimedia-hub'].featured_image
            endif
            if all_products['usb-c-pro-dock'] != blank
              assign editorial_secondary_image = all_products['usb-c-pro-dock'].featured_image
            endif
            if all_products['usb-c-travel-hub'] != blank
              assign editorial_tertiary_image = all_products['usb-c-travel-hub'].featured_image
            endif
          -%}
          <article class="home-editorial-feature">
            <div class="home-editorial-feature-media">
              {% if lead_fallback_image != blank %}
                {{ lead_fallback_image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
              {% else %}
                {% render 'placeholder-visual',
                  kind: 'editorial',
                  text: 'EZQuest Resource Guide',
                  width: 1400,
                  height: 1050,
                  class: 'home-editorial-image aspect-card w-full object-cover'
                %}
              {% endif %}
            </div>
            <p class="section-kicker">Buying guide</p>
            <h3 class="display-heading mt-4 text-display sm:text-display-2xl">Setup guidance, compatibility notes, and buying clarity.</h3>
            <p class="mt-4 max-w-2xl text-base leading-7 text-slate-600">Start with the buying questions customers ask first, then move into setup help, compatibility checks, and product-specific guidance.</p>
          </article>
          <div class="home-editorial-stack">
            {% for i in (1..2) %}
              {%- liquid
                assign fallback_title = 'Choosing the right hub for a cleaner desk setup'
                assign fallback_copy = 'Use product fit, display needs, and charging requirements to narrow the right model faster.'

                if forloop.index == 2
                  assign fallback_title = 'What to check before buying a USB-C accessory'
                  assign fallback_copy = 'Start with compatibility, then move into manuals, downloads, and support only when the next step is clear.'
                endif
              -%}
              <article class="home-editorial-card">
                <div class="home-editorial-card-media">
                  {% if forloop.index == 1 and editorial_secondary_image != blank %}
                    {{ editorial_secondary_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
                  {% elsif forloop.index == 2 and editorial_tertiary_image != blank %}
                    {{ editorial_tertiary_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'home-editorial-image aspect-card w-full object-cover' }}
                  {% else %}
                    {% render 'placeholder-visual',
                      kind: 'editorial',
                      text: 'Setup Guide',
                      width: 900,
                      height: 700,
                      class: 'home-editorial-image aspect-card w-full object-cover'
                    %}
                  {% endif %}
                </div>
                <p class="section-kicker">Setup guide</p>
                <h3 class="card-title mt-4">{{ fallback_title }}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ fallback_copy }}</p>
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Article feed",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Resources" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Setup guides, compatibility notes, and product know-how" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Practical articles that help customers choose the right EZQuest product, install it with confidence, and keep the setup running smoothly." },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "limit", "label": "Article limit", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all articles" },
    { "type": "url", "id": "link_url", "label": "Link" }
  ],
  "presets": [
    { "name": "Article feed" }
  ]
}
{% endschema %}
