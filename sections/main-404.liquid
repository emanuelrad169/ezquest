<div class="not-found-shell">
  <div class="not-found-visual" aria-hidden="true">
    <img
      src="{{ 'hero-home-desktop.svg' | asset_url }}"
      alt=""
      class="not-found-bg"
      width="1600"
      height="900"
      loading="eager"
      decoding="async"
    >
    <div class="not-found-scrim"></div>
  </div>

  <div class="not-found-body">
    <div class="not-found-content">
      <p class="not-found-code" aria-hidden="true">404</p>
      <h1 class="not-found-heading">{{ section.settings.heading | default: 'This page went missing.' }}</h1>
      <p class="not-found-copy">{{ section.settings.copy | default: 'It may have moved or no longer exists. Here are some better places to start.' }}</p>

      <div class="not-found-actions">
        <a href="{{ routes.all_products_collection_url }}" class="not-found-btn-primary">{{ section.settings.cta_primary | default: 'Browse products' }}</a>
        <a href="/pages/compare" class="not-found-btn-secondary">{{ section.settings.cta_secondary | default: 'Compare products' }}</a>
      </div>

      <div class="not-found-links">
        <a href="{{ routes.collections_url }}/hubs-adapters" class="not-found-link">Hubs &amp; adapters</a>
        <a href="{{ routes.collections_url }}/chargers-power" class="not-found-link">Chargers &amp; power</a>
        <a href="{{ routes.collections_url }}/docking-stations" class="not-found-link">Docking stations</a>
        <a href="{{ routes.root_url }}pages/support" class="not-found-link">Support</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404 page",
  "settings": [
    { "type": "text",     "id": "heading",       "label": "Heading",         "default": "This page went missing." },
    { "type": "textarea", "id": "copy",           "label": "Supporting copy", "default": "It may have moved or no longer exists. Here are some better places to start." },
    { "type": "text",     "id": "cta_primary",    "label": "Primary CTA",     "default": "Browse products" },
    { "type": "text",     "id": "cta_secondary",  "label": "Secondary CTA",   "default": "Compare products" }
  ],
  "presets": [
    { "name": "404 page" }
  ]
}
{% endschema %}
