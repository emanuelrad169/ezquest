<section class="not-found section--dark" aria-label="Page not found">
  <div class="page-width not-found__inner">

    <p class="not-found__kicker">404</p>

    <h1 class="not-found__heading">
      {{ section.settings.heading | default: "This page isn't plugged in." | escape }}
    </h1>

    <p class="not-found__body">
      {{ section.settings.copy | default: 'The link may have moved or the URL may be wrong.' | escape }}
    </p>

    <div class="not-found__actions">
      <a href="{{ routes.root_url }}" class="btn btn--primary not-found__btn-primary">
        Go home
      </a>
      <a href="{{ routes.collections_url }}" class="btn btn--secondary not-found__btn-secondary">
        Browse products
      </a>
    </div>

    <div class="not-found__families">
      <p class="not-found__families-label">Or browse by family:</p>
      <div class="not-found__family-links">
        <a href="{{ routes.collections_url }}/hubs-adapters" class="not-found__family-pill">Hubs &amp; Adapters</a>
        <a href="{{ routes.collections_url }}/docking-stations" class="not-found__family-pill">Docking Stations</a>
        <a href="{{ routes.collections_url }}/chargers-power" class="not-found__family-pill">Chargers &amp; Power</a>
        <a href="{{ routes.collections_url }}/accessories" class="not-found__family-pill">Accessories</a>
        <a href="/pages/support" class="not-found__family-pill">Support</a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "settings": [
    { "type": "text",     "id": "heading", "label": "Heading",         "default": "This page isn't connected." },
    { "type": "textarea", "id": "copy",    "label": "Supporting copy", "default": "The link might have moved or the URL might be wrong. Here is where to go instead." }
  ],
  "presets": [
    { "name": "404 page" }
  ]
}
{% endschema %}
