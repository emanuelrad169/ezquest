{% liquid
  assign msg_blocks = section.blocks | where: 'type', 'message'
  assign announcement_count = msg_blocks.size | default: 0
  if announcement_count == 0
    assign announcement_count = 3
  endif
%}

<div
  class="announcement-bar"
  role="region"
  aria-label="Announcements"
  id="announcement-bar"
  data-count="{{ announcement_count }}"
  data-interval="{{ section.settings.interval }}"
>
  <div
    class="announcement-bar__track"
    id="announcement-track"
    aria-live="polite"
    aria-atomic="true"
  >
    {% if msg_blocks.size > 0 %}
      {% for block in msg_blocks %}
        <div
          class="announcement-bar__slide{% if forloop.first %} is-active{% endif %}"
          id="announcement-{{ forloop.index0 }}"
          role="text"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.icon != blank %}
            <span class="announcement-bar__icon" aria-hidden="true">
              {{ block.settings.icon | escape }}
            </span>
          {% endif %}

          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link | escape }}" class="announcement-bar__link">
              {{ block.settings.text | escape }}
            </a>
          {% else %}
            <span class="announcement-bar__text">
              {{ block.settings.text | escape }}
            </span>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      {% assign fallback_messages = 'Free Shipping Over $100|30-Day Returns' | split: '|' %}
      {% for fallback_message in fallback_messages %}
      <div
        class="announcement-bar__slide{% if forloop.first %} is-active{% endif %}"
        id="announcement-{{ forloop.index0 }}"
        role="text"
      >
        <span class="announcement-bar__text">{{ fallback_message | escape }}</span>
      </div>
      {% endfor %}
    {% endif %}
  </div>

  {% if announcement_count > 1 %}
    <div class="announcement-bar__controls" aria-label="Announcement navigation">
      <button
        type="button"
        class="announcement-bar__btn"
        id="announcement-prev"
        aria-label="Previous announcement"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 3L5 7l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="announcement-bar__counter" aria-label="Announcement 1 of {{ announcement_count }}">
        <span id="announcement-current">1</span>
        <span aria-hidden="true">/</span>
        <span>{{ announcement_count }}</span>
      </span>
      <button
        type="button"
        class="announcement-bar__btn"
        id="announcement-next"
        aria-label="Next announcement"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  {% endif %}
</div>

<style>
  /* Merchant-configurable colors emitted as custom properties.
     Static layout rules live in pages.css (loaded globally via footer). */
  #shopify-section-{{ section.id }} {
    --ab-bg: {{ section.settings.background_color }};
    --ab-text: {{ section.settings.text_color }};
  }
</style>

<script>
  (function() {
    var bar = document.getElementById('announcement-bar');
    if (!bar) return;
    var count = parseInt(bar.dataset.count, 10);
    if (count <= 1) return;

    var interval = parseInt(bar.dataset.interval, 10) || 4000;
    var current = 0;
    var timer = null;

    function getSlide(i) {
      return document.getElementById('announcement-' + i);
    }

    function getCounter() {
      return document.getElementById('announcement-current');
    }

    function goTo(next) {
      var prev = current;
      if (next === prev) return;

      var prevSlide = getSlide(prev);
      var nextSlide = getSlide(next);
      if (!prevSlide || !nextSlide) return;

      prevSlide.classList.add('is-exiting');
      prevSlide.classList.remove('is-active');

      setTimeout(function() {
        prevSlide.classList.remove('is-exiting');
      }, 400);

      nextSlide.classList.add('is-active');

      current = next;
      var counter = getCounter();
      if (counter) counter.textContent = next + 1;

      var ariaLabel = bar.querySelector('.announcement-bar__counter');
      if (ariaLabel) {
        ariaLabel.setAttribute('aria-label', 'Announcement ' + (next + 1) + ' of ' + count);
      }
    }

    function next() {
      goTo((current + 1) % count);
    }

    function prev() {
      goTo((current - 1 + count) % count);
    }

    function startTimer() {
      timer = setInterval(next, interval);
    }

    function stopTimer() {
      clearInterval(timer);
    }

    var prevBtn = document.getElementById('announcement-prev');
    var nextBtn = document.getElementById('announcement-next');

    if (prevBtn) prevBtn.addEventListener('click', function() {
      stopTimer(); prev(); startTimer();
    });
    if (nextBtn) nextBtn.addEventListener('click', function() {
      stopTimer(); next(); startTimer();
    });

    bar.addEventListener('mouseenter', stopTimer);
    bar.addEventListener('mouseleave', startTimer);

    bar.addEventListener('focusin', stopTimer);
    bar.addEventListener('focusout', startTimer);

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      startTimer();
    }
  })();
</script>

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FED300"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0f172a"
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Rotation interval (ms)",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 4000
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping Over $100",
          "placeholder": "Free Shipping Over $100"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or leave blank)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "Free Shipping Over $100"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "30-Day Returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
