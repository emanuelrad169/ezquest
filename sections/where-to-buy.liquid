{% comment %} sections/where-to-buy.liquid {% endcomment %}

{{ 'pages.css' | asset_url | stylesheet_tag }}

{% comment %} ── Group blocks by category ─────────── {% endcomment %}
{% assign categories = 'us_retailer,intl_reseller,intl_distributor' | split: ',' %}
{% assign cat_labels = 'U.S. Retailers,International Resellers,International Distributors' | split: ',' %}

{% for cat in categories %}
  {% assign cat_label = cat_labels[forloop.index0] %}

  {% comment %} Check if any blocks belong to this category {% endcomment %}
  {% assign has_blocks = false %}
  {% for block in section.blocks %}
    {% if block.settings.category == cat %}
      {% assign has_blocks = true %}
    {% endif %}
  {% endfor %}

  {% if has_blocks %}
    <section class="wtb-group container-shell">
      <h2 class="wtb-group__heading" data-animate>{{ cat_label }}</h2>
      <div class="wtb-grid">
        {% for block in section.blocks %}
          {% if block.settings.category == cat %}
            <a
              href="{{ block.settings.url | default: '#' }}"
              class="wtb-card"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ block.settings.name | escape }}"
              {{ block.shopify_attributes }}>

              <div class="wtb-card__logo-wrap">
                {%- if block.settings.logo != blank -%}
                  {{- block.settings.logo | image_url: width: 320
                      | image_tag:
                          class: 'wtb-card__logo',
                          alt: block.settings.name,
                          loading: 'lazy',
                          width: 160,
                          height: 60 -}}
                {%- elsif block.settings.logo_asset != blank -%}
                  <img
                    src="{{ block.settings.logo_asset | asset_url }}"
                    alt="{{ block.settings.name | escape }}"
                    class="wtb-card__logo"
                    width="160"
                    height="60"
                    loading="lazy"
                    decoding="async">
                {%- else -%}
                  <span class="wtb-card__name-fallback">
                    {{ block.settings.name }}
                  </span>
                {%- endif -%}
              </div>

              {% if block.settings.region != blank %}
                <span class="wtb-card__region">
                  {{ block.settings.region }}
                </span>
              {% endif %}

            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endfor %}

{% comment %} ── CTA ──────────────────────────────── {% endcomment %}
{% if section.settings.show_cta %}
  {%- render 'page-cta',
    variant: 'light',
    kicker: 'Partnership',
    heading: section.settings.cta_text | default: 'Interested in carrying EZQuest products?',
    primary_label: section.settings.cta_label | default: 'Become a reseller',
    primary_url: section.settings.cta_url | default: '/pages/contact'
  -%}
{% endif %}

