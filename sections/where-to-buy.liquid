{% comment %} sections/where-to-buy.liquid {% endcomment %}

{{ 'pages.css' | asset_url | stylesheet_tag }}

{% style %}
.wtb-hero {
  background: linear-gradient(135deg,var(--ez-light) 0%,#fff 100%);
  padding: clamp(56px,7vw,88px) 0;
  border-bottom: 0.5px solid rgba(0,0,0,0.06);
}
.wtb-hero .page-width {
  max-width:1280px;margin:0 auto;
  padding:0 clamp(1.25rem,5vw,5rem);
}
.wtb-hero__kicker {
  font-size:11px;font-weight:600;letter-spacing:0.1em;
  text-transform:uppercase;color:var(--ez-grey);margin-bottom:1rem;
}
.wtb-hero__heading {
  font-size:clamp(32px,5vw,56px);font-weight:500;
  letter-spacing:-0.03em;color:var(--ez-black);margin-bottom:0.875rem;
}
.wtb-hero__body {
  font-size:clamp(15px,1.5vw,17px);color:var(--ez-grey);
  line-height:1.65;max-width:52ch;
}
.wtb-group {
  max-width:1280px;margin:0 auto;
  padding:clamp(40px,5vw,60px) clamp(1.25rem,5vw,5rem);
}
.wtb-group + .wtb-group { padding-top:0; }
.wtb-group__heading {
  font-size:11px;font-weight:600;letter-spacing:0.1em;
  text-transform:uppercase;color:var(--ez-grey);
  margin-bottom:1.25rem;padding-bottom:0.875rem;
  border-bottom:0.5px solid rgba(0,0,0,0.07);
}
.wtb-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
  gap:1rem;
}
@media(max-width:639px){ .wtb-grid{grid-template-columns:repeat(2,1fr);} }
.wtb-card {
  display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:0.5rem;padding:1.5rem 1rem;
  background:#fff;border:0.5px solid rgba(0,0,0,0.08);
  border-radius:16px;text-decoration:none;min-height:120px;
  transition:border-color 0.2s,box-shadow 0.2s,transform 0.15s;
}
.wtb-card:hover {
  border-color:rgba(254, 211, 0,0.45);
  box-shadow:0 4px 20px rgba(0,0,0,0.07);
  transform:translateY(-2px);
}
.wtb-card__logo-wrap {
  display:flex;align-items:center;justify-content:center;
  width:100%;height:56px;
}
.wtb-card__logo { max-width:140px;max-height:52px;object-fit:contain; }
.wtb-card__name-fallback { font-size:13px;font-weight:500;color:var(--ez-black);text-align:center; }
.wtb-card__region { font-size:11px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--ez-grey); }
.wtb-cta { background:var(--ez-dark);padding:clamp(48px,6vw,72px) clamp(1.25rem,5vw,5rem);text-align:center;margin-top:0; }
.wtb-cta__text { font-size:clamp(18px,2.5vw,28px);font-weight:500;letter-spacing:-0.02em;color:#f5f5f7;margin-bottom:1.5rem; }
{% endstyle %}

{% comment %} ── Hero ─────────────────────────────── {% endcomment %}
<section class="wtb-hero">
  <div class="wtb-hero__inner page-width">
    <p class="wtb-hero__kicker">EZQuest products</p>
    <h1 class="wtb-hero__heading">
      {{ section.settings.heading | default: 'Where to buy' }}
    </h1>
    <p class="wtb-hero__body">
      {{ section.settings.subheading
         | default: 'EZQuest products are sold through these authorised retailers and distributors worldwide.' }}
    </p>
  </div>
</section>

{% comment %} ── Group blocks by category ─────────── {% endcomment %}
{% assign categories = 'us_retailer,intl_reseller,intl_distributor' | split: ',' %}
{% assign cat_labels = 'U.S. Retailers,International Resellers,International Distributors' | split: ',' %}

{% for cat in categories %}
  {% assign cat_label = cat_labels[forloop.index0] %}

  {% comment %} Check if any blocks belong to this category {% endcomment %}
  {% assign has_blocks = false %}
  {% for block in section.blocks %}
    {% if block.settings.category == cat %}
      {% assign has_blocks = true %}
    {% endif %}
  {% endfor %}

  {% if has_blocks %}
    <section class="wtb-group container-shell">
      <h2 class="wtb-group__heading" data-animate>{{ cat_label }}</h2>
      <div class="wtb-grid">
        {% for block in section.blocks %}
          {% if block.settings.category == cat %}
            <a
              href="{{ block.settings.url | default: '#' }}"
              class="wtb-card"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ block.settings.name | escape }}"
              {{ block.shopify_attributes }}>

              <div class="wtb-card__logo-wrap">
                {%- if block.settings.logo != blank -%}
                  {{- block.settings.logo | image_url: width: 320
                      | image_tag:
                          class: 'wtb-card__logo',
                          alt: block.settings.name,
                          loading: 'lazy',
                          width: 160,
                          height: 60 -}}
                {%- elsif block.settings.logo_asset != blank -%}
                  <img
                    src="{{ block.settings.logo_asset | asset_url }}"
                    alt="{{ block.settings.name | escape }}"
                    class="wtb-card__logo"
                    width="160"
                    height="60"
                    loading="lazy"
                    decoding="async">
                {%- else -%}
                  <span class="wtb-card__name-fallback">
                    {{ block.settings.name }}
                  </span>
                {%- endif -%}
              </div>

              {% if block.settings.region != blank %}
                <span class="wtb-card__region">
                  {{ block.settings.region }}
                </span>
              {% endif %}

            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endfor %}

{% comment %} ── CTA ──────────────────────────────── {% endcomment %}
{% if section.settings.show_cta %}
  {%- render 'page-cta',
    variant: 'light',
    kicker: 'Partnership',
    heading: section.settings.cta_text | default: 'Interested in carrying EZQuest products?',
    primary_label: section.settings.cta_label | default: 'Become a reseller',
    primary_url: section.settings.cta_url | default: '/pages/contact'
  -%}
{% endif %}

