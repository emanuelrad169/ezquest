{% comment %} sections/where-to-buy.liquid {% endcomment %}

<style>
.wtb-hero {
  position: relative;
  background: #0f1114;
  padding: clamp(48px,5vw,72px) clamp(1.25rem,3vw,2.5rem) clamp(44px,5vw,64px);
  border-bottom: 0.5px solid rgba(255,255,255,0.07);
  overflow: hidden;
  min-height: 40vh;
  display: flex;
  align-items: flex-end;
}
.wtb-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: var(--wtb-bg);
  background-size: cover;
  background-position: center;
  opacity: 0.35;
}
.wtb-hero__inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100rem;
  margin: 0 auto;
}
.wtb-hero__kicker {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ez-amber); margin-bottom: 1rem;
}
.wtb-hero__heading {
  font-size: clamp(32px,5vw,56px);
  font-weight: 500; letter-spacing: -0.03em;
  color: var(--ez-light); margin-bottom: 0.875rem;
}
.wtb-hero__body {
  font-size: clamp(15px,1.5vw,17px);
  color: rgba(255,255,255,0.55); line-height: 1.65; max-width: 54ch;
}
.wtb-group {
  max-width: 100rem; margin: 0 auto;
  padding: clamp(40px,5vw,64px) clamp(1.25rem,2vw,2rem);
}
@media (min-width: 640px)  { .wtb-group { padding-left: 1.5rem; padding-right: 1.5rem; } }
@media (min-width: 1024px) { .wtb-group { padding-left: 2rem;   padding-right: 2rem;   } }
.wtb-group + .wtb-group { padding-top: 0; }
.wtb-group__heading {
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ez-grey); margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 0.5px solid rgba(0,0,0,0.08);
}
.wtb-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}
@media (max-width: 639px) {
  .wtb-grid { grid-template-columns: repeat(2,1fr); gap: 1rem; }
}
.wtb-card {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 1rem; padding: 2.5rem 2rem;
  background: #fff;
  border: 0.5px solid rgba(0,0,0,0.08);
  border-radius: 20px; text-decoration: none;
  min-height: 200px;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
}
.wtb-card:hover {
  border-color: rgba(251,206,42,0.5);
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  transform: translateY(-2px);
}
.wtb-card__logo-wrap {
  display: flex; align-items: center;
  justify-content: center;
  width: 100%; height: 100px;
}
.wtb-card__logo {
  max-width: 220px; max-height: 90px;
  width: auto; height: auto; object-fit: contain;
}
.wtb-card__name-fallback {
  font-size: 13px; font-weight: 500;
  color: var(--ez-black); text-align: center;
}
.wtb-card__region {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--ez-grey); text-align: center;
}
.wtb-cta {
  position: relative;
  background: var(--ez-light);
  padding: clamp(56px,7vw,88px) clamp(1.25rem,2vw,2rem);
  overflow: hidden;
  border-top: 0.5px solid rgba(0,0,0,0.07);
}
.wtb-cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 0% 50%, rgba(251,206,42,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.wtb-cta__inner {
  position: relative;
  z-index: 1;
  max-width: 100rem;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.wtb-cta__copy { flex: 1; min-width: 260px; }
.wtb-cta__kicker {
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--ez-amber-dark); margin-bottom: 0.75rem;
}
.wtb-cta__heading {
  font-size: clamp(22px,3vw,36px); font-weight: 500;
  letter-spacing: -0.025em; color: var(--ez-black);
  line-height: 1.15;
}
.wtb-cta__btn {
  flex-shrink: 0;
  display: inline-flex; align-items: center; gap: 0.5rem;
  height: 52px; padding: 0 2rem;
  background: var(--ez-amber); color: var(--ez-black);
  border-radius: 100px; border: none;
  font-size: 15px; font-weight: 600;
  text-decoration: none; white-space: nowrap;
  transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
}
.wtb-cta__btn:hover {
  background: var(--ez-amber-hover);
  transform: translateY(-1px);
  box-shadow: 0 6px 24px rgba(251,206,42,0.25);
}
.wtb-cta__btn svg { flex-shrink: 0; }
@media (max-width: 639px) {
  .wtb-cta__inner { flex-direction: column; align-items: flex-start; }
  .wtb-cta__btn { width: 100%; justify-content: center; }
}
</style>

{% comment %} ── Hero ─────────────────────────────── {% endcomment %}
<section class="wtb-hero"
  {% if section.settings.hero_image != blank %}
    style="--wtb-bg: url('{{ section.settings.hero_image | image_url: width: 1800 }}')"
  {% endif %}>
  <div class="wtb-hero__inner">
    <p class="wtb-hero__kicker">EZQuest products</p>
    <h1 class="wtb-hero__heading">
      {{ section.settings.heading | default: 'Where to buy' }}
    </h1>
    <p class="wtb-hero__body">
      {{ section.settings.subheading
         | default: 'EZQuest products are sold through these authorised retailers and distributors worldwide.' }}
    </p>
  </div>
</section>

{% comment %} ── Group blocks by category ─────────── {% endcomment %}
{% assign categories = 'us_retailer,intl_reseller,intl_distributor' | split: ',' %}
{% assign cat_labels = 'U.S. Retailers,International Resellers,International Distributors' | split: ',' %}

{% for cat in categories %}
  {% assign cat_label = cat_labels[forloop.index0] %}

  {% comment %} Check if any blocks belong to this category {% endcomment %}
  {% assign has_blocks = false %}
  {% for block in section.blocks %}
    {% if block.settings.category == cat %}
      {% assign has_blocks = true %}
    {% endif %}
  {% endfor %}

  {% if has_blocks %}
    <section class="wtb-group container-shell">
      <h2 class="wtb-group__heading">{{ cat_label }}</h2>
      <div class="wtb-grid">
        {% for block in section.blocks %}
          {% if block.settings.category == cat %}
            <a
              href="{{ block.settings.url | default: '#' }}"
              class="wtb-card"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ block.settings.name | escape }}"
              {{ block.shopify_attributes }}>

              <div class="wtb-card__logo-wrap">
                {%- if block.settings.logo != blank -%}
                  {{- block.settings.logo | image_url: width: 320
                      | image_tag:
                          class: 'wtb-card__logo',
                          alt: block.settings.name,
                          loading: 'lazy',
                          width: 160,
                          height: 60 -}}
                {%- elsif block.settings.logo_asset != blank -%}
                  <img
                    src="{{ block.settings.logo_asset | asset_url }}"
                    alt="{{ block.settings.name | escape }}"
                    class="wtb-card__logo"
                    width="160"
                    height="60"
                    loading="lazy"
                    decoding="async">
                {%- else -%}
                  <span class="wtb-card__name-fallback">
                    {{ block.settings.name }}
                  </span>
                {%- endif -%}
              </div>

              {% if block.settings.region != blank %}
                <span class="wtb-card__region">
                  {{ block.settings.region }}
                </span>
              {% endif %}

            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endfor %}

{% comment %} ── CTA ──────────────────────────────── {% endcomment %}
{% if section.settings.show_cta %}
  <section class="page-cta">
    <div class="page-cta__inner container-shell">
      <div class="page-cta__copy">
        <p class="page-cta__kicker">Partnership</p>
        <p class="page-cta__heading">
          {{ section.settings.cta_text | default: 'Interested in carrying EZQuest products?' }}
        </p>
      </div>
      <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="page-cta__btn">
        {{ section.settings.cta_label | default: 'Become a reseller' }}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>
{% endif %}

