<section class="section-shell">
  <div class="container-shell">
    {%- liquid
      assign current_product = blank
      assign structured_entries = blank
      assign has_structured_entries = false
      assign use_global_entries = false
      assign sorted_global_resource_keys = '' | split: ''
      assign platform_filter = section.settings.platform_filter | downcase | strip
      assign resource_count_note = 'Manuals tied to the right product and setup stage.'

      case section.settings.resource_kind
        when 'downloads'
          assign resource_count_note = 'Downloads tied to the right product and platform.'
        when 'firmware'
          assign resource_count_note = 'Firmware tied to the right product, version, and update sequence.'
        when 'guides'
          assign resource_count_note = 'Guides tied to the right setup and workflow.'
      endcase

      if product != blank
        assign current_product = product
      elsif section.settings.source_product != blank
        assign current_product = section.settings.source_product
      endif

      if section.settings.structured_source != 'blocks'
        if current_product != blank and section.settings.resource_kind == 'manuals' and current_product.metafields.ezquest.manuals != blank and current_product.metafields.ezquest.manuals.value.count > 0
          assign structured_entries = current_product.metafields.ezquest.manuals.value
          assign has_structured_entries = true
        elsif current_product != blank and section.settings.resource_kind == 'downloads' and current_product.metafields.ezquest.downloads != blank and current_product.metafields.ezquest.downloads.value.count > 0
          assign structured_entries = current_product.metafields.ezquest.downloads.value
          assign has_structured_entries = true
        elsif current_product != blank and section.settings.resource_kind == 'firmware' and current_product.metafields.ezquest.firmware != blank and current_product.metafields.ezquest.firmware.value.count > 0
          assign structured_entries = current_product.metafields.ezquest.firmware.value
          assign has_structured_entries = true
        elsif current_product != blank and section.settings.resource_kind == 'guides' and current_product.metafields.ezquest.user_guides != blank and current_product.metafields.ezquest.user_guides.value.count > 0
          assign structured_entries = current_product.metafields.ezquest.user_guides.value
          assign has_structured_entries = true
        endif

        if section.settings.structured_source == 'global'
          assign use_global_entries = true
        elsif section.settings.structured_source == 'auto' and has_structured_entries == false
          assign use_global_entries = true
        endif
      endif

      if use_global_entries
        capture sorted_resources_raw
          case section.settings.resource_kind
            when 'manuals'
              for resource_entry in metaobjects.ezquest_manual.values
                capture order_token_raw
                  echo '000000'
                  echo resource_entry.sort_order.value | default: 999999 | plus: 0
                endcapture
                assign order_token = order_token_raw | strip | slice: -6, 6
                echo order_token
                echo '::'
                echo resource_entry.system.handle
                echo '||'
              endfor
            when 'firmware'
              for resource_entry in metaobjects.ezquest_firmware.values
                capture order_token_raw
                  echo '000000'
                  echo resource_entry.sort_order.value | default: 999999 | plus: 0
                endcapture
                assign order_token = order_token_raw | strip | slice: -6, 6
                echo order_token
                echo '::'
                echo resource_entry.system.handle
                echo '||'
              endfor
            when 'guides'
              for resource_entry in metaobjects.ezquest_user_guide.values
                capture order_token_raw
                  echo '000000'
                  echo resource_entry.sort_order.value | default: 999999 | plus: 0
                endcapture
                assign order_token = order_token_raw | strip | slice: -6, 6
                echo order_token
                echo '::'
                echo resource_entry.system.handle
                echo '||'
              endfor
            when 'downloads'
              for resource_entry in metaobjects.ezquest_download.values
                capture order_token_raw
                  echo '000000'
                  echo resource_entry.sort_order.value | default: 999999 | plus: 0
                endcapture
                assign order_token = order_token_raw | strip | slice: -6, 6
                echo order_token
                echo '::'
                echo resource_entry.system.handle
                echo '||'
              endfor
          endcase
        endcapture
        assign sorted_global_resource_keys = sorted_resources_raw | split: '||' | sort_natural
      endif
    -%}

    <div class="resource-list-shell resource-list-shell--support">
      <div class="resource-list-intro resource-list-intro--support">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        <p class="support-resource-count">{{ resource_count_note }}</p>
        {% if section.settings.source_note != blank %}
          <div class="support-utility-note mt-6">{{ section.settings.source_note }}</div>
        {% endif %}
        <div class="support-context-panel" data-support-context hidden>
          <p class="section-kicker" data-support-context-kicker>Product context</p>
          <h3 class="support-context-title mt-4" data-support-context-title>Keep the product in view</h3>
          <p class="support-context-copy" data-support-context-copy>These resources stay tied to the product or lineup you were already checking.</p>
        </div>
        {% if section.settings.show_search %}
          <div class="mt-8">
            {% render 'support-search-form' %}
          </div>
        {% endif %}
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <div class="mt-8">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}

        <div class="support-next-step-list">
          {% if section.settings.resource_kind == 'downloads' %}
            <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
            <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
          {% elsif section.settings.resource_kind == 'firmware' %}
            <a href="/pages/downloads" class="support-inline-link" data-support-context-link>Find downloads</a>
            <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
          {% elsif section.settings.resource_kind == 'guides' %}
            <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
            <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
          {% else %}
            <a href="/pages/downloads" class="support-inline-link" data-support-context-link>Find downloads</a>
            <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
          {% endif %}
          <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
        </div>
      </div>

      <div class="space-y-5">
        {% if has_structured_entries %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_entry in structured_entries %}
            {%- liquid
              assign resource_meta = blank
              assign resource_copy = blank
              assign resource_url = blank
              assign resource_label = section.settings.default_link_label
              assign resource_context = blank
              assign resource_secondary_context = blank
              assign matches_platform = true
              assign matches_resource_kind = true

              if section.settings.resource_kind == 'manuals'
                assign resource_meta = resource_entry.manual_type.value
              elsif section.settings.resource_kind == 'firmware'
                assign resource_meta = resource_entry.firmware_type.value
              elsif section.settings.resource_kind == 'guides'
                assign resource_meta = resource_entry.guide_type.value
              else
                assign resource_meta = resource_entry.download_type.value
                assign normalized_download_type = resource_entry.download_type.value | downcase
                if normalized_download_type contains 'firmware'
                  assign matches_resource_kind = false
                endif
              endif

              if resource_entry.version != blank and resource_entry.version.value != blank
                if resource_meta != blank
                  assign resource_meta = resource_meta | append: ' / '
                endif
                assign resource_meta = resource_meta | append: resource_entry.version.value
              endif

              if resource_entry.summary != blank and resource_entry.summary.value != blank
                assign resource_copy = resource_entry.summary.value
              endif

              if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                for platform_value in resource_entry.platforms.value
                  if resource_context != blank
                    assign resource_context = resource_context | append: ' / '
                  endif
                  assign resource_context = resource_context | append: platform_value
                endfor
              endif

              if platform_filter != blank
                assign matches_platform = false
                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    assign normalized_platform = platform_value | downcase
                    if normalized_platform == platform_filter
                      assign matches_platform = true
                      break
                    endif
                  endfor
                endif
              endif

              if resource_entry.products != blank and resource_entry.products.value.count > 0
                assign resource_secondary_context = resource_entry.products.value.first.title
              elsif resource_entry.collections != blank and resource_entry.collections.value.count > 0
                assign resource_secondary_context = resource_entry.collections.value.first.title
              endif

              if resource_entry.file != blank and resource_entry.file.value != blank
                assign resource_url = resource_entry.file.value.url
              elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                assign resource_url = resource_entry.external_url.value
              endif

              if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                assign resource_label = resource_entry.button_label.value
              endif
            -%}

            {% if matches_platform and matches_resource_kind and rendered_resources < section.settings.resource_limit %}
              {% render 'support-resource-card',
                meta: resource_meta,
                title: resource_entry.title.value,
                copy: resource_copy,
                context: resource_context,
                secondary_context: resource_secondary_context,
                url: resource_url,
                label: resource_label
              %}
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if rendered_resources == 0 %}
            <article class="resource-card structured-empty-state">
              <p class="section-kicker">Resources</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">No matching resources yet</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Manuals and downloads will appear here when they are linked to the current product, collection, or platform filter.</p>
              <div class="support-next-step-list mt-6">
                <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
                <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
                <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
              </div>
            </article>
          {% endif %}
        {% elsif use_global_entries and section.settings.resource_kind == 'manuals' %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_key in sorted_global_resource_keys %}
            {% if resource_key == blank %}
              {% continue %}
            {% endif %}
            {% assign resource_handle = resource_key | split: '::' | last %}
            {% assign resource_entry = metaobjects.ezquest_manual[resource_handle] %}
            {%- liquid
              assign matches_collection = true
              assign matches_product = true
              assign matches_platform = true

              if section.settings.source_collection != blank
                assign matches_collection = false
                if resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  for linked_collection in resource_entry.collections.value
                    if linked_collection.id == section.settings.source_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif

              if current_product != blank and section.settings.limit_to_source_product
                assign matches_product = false
                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  for linked_product in resource_entry.products.value
                    if linked_product.id == current_product.id
                      assign matches_product = true
                      break
                    endif
                  endfor
                endif
              endif

              if platform_filter != blank
                assign matches_platform = false
                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    assign normalized_platform = platform_value | downcase
                    if normalized_platform == platform_filter
                      assign matches_platform = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}

            {% if matches_collection and matches_product and matches_platform and rendered_resources < section.settings.resource_limit %}
              {%- liquid
                assign resource_meta = resource_entry.manual_type.value
                assign resource_context = blank
                assign resource_secondary_context = blank
                assign resource_label = section.settings.default_link_label
                assign resource_url = blank

                if resource_entry.version != blank and resource_entry.version.value != blank
                  if resource_meta != blank
                    assign resource_meta = resource_meta | append: ' / '
                  endif
                  assign resource_meta = resource_meta | append: resource_entry.version.value
                endif

                if resource_entry.file != blank and resource_entry.file.value != blank
                  assign resource_url = resource_entry.file.value.url
                elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                  assign resource_url = resource_entry.external_url.value
                endif

                if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                  assign resource_label = resource_entry.button_label.value
                endif

                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    if resource_context != blank
                      assign resource_context = resource_context | append: ' / '
                    endif
                    assign resource_context = resource_context | append: platform_value
                  endfor
                endif

                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  assign resource_secondary_context = resource_entry.products.value.first.title
                elsif resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  assign resource_secondary_context = resource_entry.collections.value.first.title
                endif
              -%}

              {% render 'support-resource-card',
                meta: resource_meta,
                title: resource_entry.title.value,
                copy: resource_entry.summary.value,
                context: resource_context,
                secondary_context: resource_secondary_context,
                url: resource_url,
                label: resource_label
              %}
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if rendered_resources == 0 %}
            <article class="resource-card structured-empty-state">
              <p class="section-kicker">Manuals</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">No matching manuals yet</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Manuals will appear here when they are linked to the current product, collection, or platform filter.</p>
              <div class="support-next-step-list mt-6">
                <a href="/pages/downloads" class="support-inline-link" data-support-context-link>Find downloads</a>
                <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
                <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
              </div>
            </article>
          {% endif %}
        {% elsif use_global_entries and section.settings.resource_kind == 'firmware' %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_key in sorted_global_resource_keys %}
            {% if resource_key == blank %}
              {% continue %}
            {% endif %}
            {% assign resource_handle = resource_key | split: '::' | last %}
            {% assign resource_entry = metaobjects.ezquest_firmware[resource_handle] %}
            {%- liquid
              assign matches_collection = true
              assign matches_product = true
              assign matches_platform = true

              if section.settings.source_collection != blank
                assign matches_collection = false
                if resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  for linked_collection in resource_entry.collections.value
                    if linked_collection.id == section.settings.source_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif

              if current_product != blank and section.settings.limit_to_source_product
                assign matches_product = false
                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  for linked_product in resource_entry.products.value
                    if linked_product.id == current_product.id
                      assign matches_product = true
                      break
                    endif
                  endfor
                endif
              endif

              if platform_filter != blank
                assign matches_platform = false
                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    assign normalized_platform = platform_value | downcase
                    if normalized_platform == platform_filter
                      assign matches_platform = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}

            {% if matches_collection and matches_product and matches_platform and rendered_resources < section.settings.resource_limit %}
              {%- liquid
                assign resource_meta = resource_entry.firmware_type.value
                assign resource_context = blank
                assign resource_secondary_context = blank
                assign resource_label = section.settings.default_link_label
                assign resource_url = blank

                if resource_entry.version != blank and resource_entry.version.value != blank
                  if resource_meta != blank
                    assign resource_meta = resource_meta | append: ' / '
                  endif
                  assign resource_meta = resource_meta | append: resource_entry.version.value
                endif

                if resource_entry.file != blank and resource_entry.file.value != blank
                  assign resource_url = resource_entry.file.value.url
                elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                  assign resource_url = resource_entry.external_url.value
                endif

                if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                  assign resource_label = resource_entry.button_label.value
                endif

                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    if resource_context != blank
                      assign resource_context = resource_context | append: ' / '
                    endif
                    assign resource_context = resource_context | append: platform_value
                  endfor
                endif

                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  assign resource_secondary_context = resource_entry.products.value.first.title
                elsif resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  assign resource_secondary_context = resource_entry.collections.value.first.title
                endif
              -%}

              {% render 'support-resource-card',
                meta: resource_meta,
                title: resource_entry.title.value,
                copy: resource_entry.summary.value,
                context: resource_context,
                secondary_context: resource_secondary_context,
                url: resource_url,
                label: resource_label
              %}
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if rendered_resources == 0 %}
            <article class="resource-card structured-empty-state">
              <p class="section-kicker">Firmware</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">No matching firmware yet</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Firmware entries will appear here when they are linked to the current product, collection, or platform filter.</p>
              <div class="support-next-step-list mt-6">
                <a href="/pages/downloads" class="support-inline-link" data-support-context-link>Find downloads</a>
                <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
                <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
              </div>
            </article>
          {% endif %}
        {% elsif use_global_entries and section.settings.resource_kind == 'guides' %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_key in sorted_global_resource_keys %}
            {% if resource_key == blank %}
              {% continue %}
            {% endif %}
            {% assign resource_handle = resource_key | split: '::' | last %}
            {% assign resource_entry = metaobjects.ezquest_user_guide[resource_handle] %}
            {%- liquid
              assign matches_collection = true
              assign matches_product = true
              assign matches_platform = true

              if section.settings.source_collection != blank
                assign matches_collection = false
                if resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  for linked_collection in resource_entry.collections.value
                    if linked_collection.id == section.settings.source_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif

              if current_product != blank and section.settings.limit_to_source_product
                assign matches_product = false
                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  for linked_product in resource_entry.products.value
                    if linked_product.id == current_product.id
                      assign matches_product = true
                      break
                    endif
                  endfor
                endif
              endif

              if platform_filter != blank
                assign matches_platform = false
                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    assign normalized_platform = platform_value | downcase
                    if normalized_platform == platform_filter
                      assign matches_platform = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}

            {% if matches_collection and matches_product and matches_platform and rendered_resources < section.settings.resource_limit %}
              {%- liquid
                assign resource_meta = resource_entry.guide_type.value
                assign resource_context = blank
                assign resource_secondary_context = blank
                assign resource_label = section.settings.default_link_label
                assign resource_url = blank

                if resource_entry.version != blank and resource_entry.version.value != blank
                  if resource_meta != blank
                    assign resource_meta = resource_meta | append: ' / '
                  endif
                  assign resource_meta = resource_meta | append: resource_entry.version.value
                endif

                if resource_entry.file != blank and resource_entry.file.value != blank
                  assign resource_url = resource_entry.file.value.url
                elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                  assign resource_url = resource_entry.external_url.value
                endif

                if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                  assign resource_label = resource_entry.button_label.value
                endif

                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    if resource_context != blank
                      assign resource_context = resource_context | append: ' / '
                    endif
                    assign resource_context = resource_context | append: platform_value
                  endfor
                endif

                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  assign resource_secondary_context = resource_entry.products.value.first.title
                elsif resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  assign resource_secondary_context = resource_entry.collections.value.first.title
                endif
              -%}

              {% render 'support-resource-card',
                meta: resource_meta,
                title: resource_entry.title.value,
                copy: resource_entry.summary.value,
                context: resource_context,
                secondary_context: resource_secondary_context,
                url: resource_url,
                label: resource_label
              %}
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if rendered_resources == 0 %}
            <article class="resource-card structured-empty-state">
              <p class="section-kicker">User guides</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">No matching guides yet</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Guides will appear here when they are linked to the current product, collection, or platform filter.</p>
              <div class="support-next-step-list mt-6">
                <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
                <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
                <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
              </div>
            </article>
          {% endif %}
        {% elsif use_global_entries and section.settings.resource_kind == 'downloads' %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_key in sorted_global_resource_keys %}
            {% if resource_key == blank %}
              {% continue %}
            {% endif %}
            {% assign resource_handle = resource_key | split: '::' | last %}
            {% assign resource_entry = metaobjects.ezquest_download[resource_handle] %}
            {%- liquid
              assign matches_collection = true
              assign matches_product = true
              assign matches_platform = true
              assign matches_resource_kind = true
              assign normalized_download_type = resource_entry.download_type.value | downcase

              if normalized_download_type contains 'firmware'
                assign matches_resource_kind = false
              endif

              if section.settings.source_collection != blank
                assign matches_collection = false
                if resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  for linked_collection in resource_entry.collections.value
                    if linked_collection.id == section.settings.source_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif

              if current_product != blank and section.settings.limit_to_source_product
                assign matches_product = false
                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  for linked_product in resource_entry.products.value
                    if linked_product.id == current_product.id
                      assign matches_product = true
                      break
                    endif
                  endfor
                endif
              endif

              if platform_filter != blank
                assign matches_platform = false
                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    assign normalized_platform = platform_value | downcase
                    if normalized_platform == platform_filter
                      assign matches_platform = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}

            {% if matches_collection and matches_product and matches_platform and matches_resource_kind and rendered_resources < section.settings.resource_limit %}
              {%- liquid
                assign resource_meta = resource_entry.download_type.value
                assign resource_context = blank
                assign resource_secondary_context = blank
                assign resource_label = section.settings.default_link_label
                assign resource_url = blank

                if resource_entry.version != blank and resource_entry.version.value != blank
                  if resource_meta != blank
                    assign resource_meta = resource_meta | append: ' / '
                  endif
                  assign resource_meta = resource_meta | append: resource_entry.version.value
                endif

                if resource_entry.file != blank and resource_entry.file.value != blank
                  assign resource_url = resource_entry.file.value.url
                elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                  assign resource_url = resource_entry.external_url.value
                endif

                if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                  assign resource_label = resource_entry.button_label.value
                endif

                if resource_entry.platforms != blank and resource_entry.platforms.value.count > 0
                  for platform_value in resource_entry.platforms.value
                    if resource_context != blank
                      assign resource_context = resource_context | append: ' / '
                    endif
                    assign resource_context = resource_context | append: platform_value
                  endfor
                endif

                if resource_entry.products != blank and resource_entry.products.value.count > 0
                  assign resource_secondary_context = resource_entry.products.value.first.title
                elsif resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  assign resource_secondary_context = resource_entry.collections.value.first.title
                endif
              -%}

              {% render 'support-resource-card',
                meta: resource_meta,
                title: resource_entry.title.value,
                copy: resource_entry.summary.value,
                context: resource_context,
                secondary_context: resource_secondary_context,
                url: resource_url,
                label: resource_label
              %}
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if rendered_resources == 0 %}
            <article class="resource-card structured-empty-state">
              <p class="section-kicker">Downloads</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">No matching downloads yet</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Downloads will appear here when they are linked to the current product, collection, or platform filter.</p>
              <div class="support-next-step-list mt-6">
                <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
                <a href="/pages/compatibility" class="support-inline-link" data-support-context-link>Check compatibility</a>
                <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
              </div>
            </article>
          {% endif %}
        {% else %}
          {% for block in section.blocks %}
            {% render 'support-resource-card',
              meta: block.settings.meta,
              title: block.settings.title,
              copy: block.settings.copy,
              url: block.settings.link_url,
              label: block.settings.link_label,
              attributes: block.shopify_attributes
            %}
          {% else %}
            <article class="resource-card structured-empty-state">
              <p class="section-kicker">Resources</p>
              <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-900">No resources available yet</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">Add manuals or downloads in Shopify to replace this empty state.</p>
              <div class="support-next-step-list mt-6">
                <a href="/pages/downloads" class="support-inline-link" data-support-context-link>Find downloads</a>
                <a href="/pages/manuals" class="support-inline-link" data-support-context-link>Find manuals</a>
                <a href="/pages/contact" class="support-inline-link" data-support-context-link>Get help now</a>
              </div>
            </article>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support resource list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Resources" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Support resources by product or task" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Browse manuals and downloads by product, platform, or the task you need to complete." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "product", "label": "Product-linked resources" },
        { "value": "global", "label": "Global metaobject list" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    {
      "type": "select",
      "id": "resource_kind",
      "label": "Resource type",
      "default": "downloads",
      "options": [
        { "value": "downloads", "label": "Downloads" },
        { "value": "firmware", "label": "Firmware" },
        { "value": "manuals", "label": "Manuals" },
        { "value": "guides", "label": "User guides" }
      ]
    },
    { "type": "product", "id": "source_product", "label": "Source product" },
    { "type": "checkbox", "id": "limit_to_source_product", "label": "Filter global results to the source product", "default": false },
    { "type": "collection", "id": "source_collection", "label": "Filter global results by collection" },
    { "type": "text", "id": "platform_filter", "label": "Platform filter" },
    {
      "type": "range",
      "id": "resource_limit",
      "label": "Resource limit",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 12
    },
    { "type": "checkbox", "id": "show_search", "label": "Show support search form", "default": true },
    { "type": "textarea", "id": "source_note", "label": "Source note" },
    { "type": "text", "id": "default_link_label", "label": "Default structured link label", "default": "Open resource" },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        { "type": "text", "id": "meta", "label": "Meta label", "default": "Resource" },
        { "type": "text", "id": "title", "label": "Title", "default": "Resource title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Resource metadata and compatibility summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Open resource" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support resource list",
      "blocks": [{ "type": "resource" }, { "type": "resource" }, { "type": "resource" }]
    }
  ]
}
{% endschema %}
