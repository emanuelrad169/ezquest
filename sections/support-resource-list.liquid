<section class="section-shell">
  <div class="container-shell">
    {%- liquid
      assign current_product = blank
      assign structured_entries = blank
      assign has_structured_entries = false
      assign use_global_entries = false

      if product != blank
        assign current_product = product
      elsif section.settings.source_product != blank
        assign current_product = section.settings.source_product
      endif

      if section.settings.structured_source != 'blocks'
        if current_product != blank and section.settings.resource_kind == 'manuals' and current_product.metafields.ezquest.manuals != blank and current_product.metafields.ezquest.manuals.value.count > 0
          assign structured_entries = current_product.metafields.ezquest.manuals.value
          assign has_structured_entries = true
        elsif current_product != blank and section.settings.resource_kind == 'downloads' and current_product.metafields.ezquest.downloads != blank and current_product.metafields.ezquest.downloads.value.count > 0
          assign structured_entries = current_product.metafields.ezquest.downloads.value
          assign has_structured_entries = true
        endif

        if section.settings.structured_source == 'global'
          assign use_global_entries = true
        elsif section.settings.structured_source == 'auto' and has_structured_entries == false
          assign use_global_entries = true
        endif
      endif
    -%}
    <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% if section.settings.source_note != blank %}
          <p class="mt-4 text-sm leading-6 text-slate-500">{{ section.settings.source_note }}</p>
        {% endif %}
        <div class="mt-6">
          {% render 'support-search-form' %}
        </div>
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <div class="mt-6">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}
      </div>
      <div class="space-y-4">
        {% if has_structured_entries %}
          {% for resource_entry in structured_entries limit: section.settings.resource_limit %}
            {%- liquid
              assign resource_meta = blank
              assign resource_copy = blank
              assign resource_url = blank
              assign resource_label = section.settings.default_link_label

              if section.settings.resource_kind == 'manuals'
                assign resource_meta = resource_entry.manual_type.value
              else
                assign resource_meta = resource_entry.download_type.value
              endif

              if resource_entry.version != blank and resource_entry.version.value != blank
                if resource_meta != blank
                  assign resource_meta = resource_meta | append: ' / '
                endif
                assign resource_meta = resource_meta | append: resource_entry.version.value
              endif

              if resource_entry.summary != blank and resource_entry.summary.value != blank
                assign resource_copy = resource_entry.summary.value
              endif

              if resource_entry.file != blank and resource_entry.file.value != blank
                assign resource_url = resource_entry.file.value.url
              elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                assign resource_url = resource_entry.external_url.value
              endif

              if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                assign resource_label = resource_entry.button_label.value
              endif
            -%}
            <div class="section-frame">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                  {% if resource_meta != blank %}
                    <p class="section-kicker">{{ resource_meta }}</p>
                  {% endif %}
                  <h3 class="mt-3 text-xl font-semibold tracking-tight">{{ resource_entry.title.value }}</h3>
                  {% if resource_copy != blank %}
                    <p class="mt-2 text-sm text-slate-600">{{ resource_copy }}</p>
                  {% endif %}
                </div>
                {% if resource_url != blank %}
                  {% render 'button', label: resource_label, url: resource_url, style: 'secondary' %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% elsif use_global_entries and section.settings.resource_kind == 'manuals' %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_entry in metaobjects.ezquest_manual.values %}
            {%- liquid
              assign matches_collection = true
              if section.settings.source_collection != blank
                assign matches_collection = false
                if resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  for linked_collection in resource_entry.collections.value
                    if linked_collection.id == section.settings.source_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}
            {% if matches_collection %}
              {%- liquid
                assign resource_meta = resource_entry.manual_type.value
                if resource_entry.version != blank and resource_entry.version.value != blank
                  if resource_meta != blank
                    assign resource_meta = resource_meta | append: ' / '
                  endif
                  assign resource_meta = resource_meta | append: resource_entry.version.value
                endif
                assign resource_url = blank
                assign resource_label = section.settings.default_link_label
                if resource_entry.file != blank and resource_entry.file.value != blank
                  assign resource_url = resource_entry.file.value.url
                elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                  assign resource_url = resource_entry.external_url.value
                endif
                if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                  assign resource_label = resource_entry.button_label.value
                endif
              -%}
              <div class="section-frame">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                  <div>
                    {% if resource_meta != blank %}
                      <p class="section-kicker">{{ resource_meta }}</p>
                    {% endif %}
                    <h3 class="mt-3 text-xl font-semibold tracking-tight">{{ resource_entry.title.value }}</h3>
                    {% if resource_entry.summary != blank and resource_entry.summary.value != blank %}
                      <p class="mt-2 text-sm text-slate-600">{{ resource_entry.summary.value }}</p>
                    {% endif %}
                  </div>
                  {% if resource_url != blank %}
                    {% render 'button', label: resource_label, url: resource_url, style: 'secondary' %}
                  {% endif %}
                </div>
              </div>
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
            {% if rendered_resources >= section.settings.resource_limit %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% if rendered_resources == 0 %}
            {% for i in (1..3) %}
              <div class="section-frame">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                  <div>
                    <p class="section-kicker">Resource</p>
                    <h3 class="mt-3 text-xl font-semibold tracking-tight">Support resource</h3>
                    <p class="mt-2 text-sm text-slate-600">Add download or manual entries in the theme editor to populate this list.</p>
                  </div>
                  {% render 'button', label: 'Open resource', url: '#', style: 'secondary' %}
                </div>
              </div>
            {% endfor %}
          {% endif %}
        {% elsif use_global_entries and section.settings.resource_kind == 'downloads' %}
          {%- assign rendered_resources = 0 -%}
          {% for resource_entry in metaobjects.ezquest_download.values %}
            {%- liquid
              assign matches_collection = true
              if section.settings.source_collection != blank
                assign matches_collection = false
                if resource_entry.collections != blank and resource_entry.collections.value.count > 0
                  for linked_collection in resource_entry.collections.value
                    if linked_collection.id == section.settings.source_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}
            {% if matches_collection %}
              {%- liquid
                assign resource_meta = resource_entry.download_type.value
                if resource_entry.version != blank and resource_entry.version.value != blank
                  if resource_meta != blank
                    assign resource_meta = resource_meta | append: ' / '
                  endif
                  assign resource_meta = resource_meta | append: resource_entry.version.value
                endif
                assign resource_url = blank
                assign resource_label = section.settings.default_link_label
                if resource_entry.file != blank and resource_entry.file.value != blank
                  assign resource_url = resource_entry.file.value.url
                elsif resource_entry.external_url != blank and resource_entry.external_url.value != blank
                  assign resource_url = resource_entry.external_url.value
                endif
                if resource_entry.button_label != blank and resource_entry.button_label.value != blank
                  assign resource_label = resource_entry.button_label.value
                endif
              -%}
              <div class="section-frame">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                  <div>
                    {% if resource_meta != blank %}
                      <p class="section-kicker">{{ resource_meta }}</p>
                    {% endif %}
                    <h3 class="mt-3 text-xl font-semibold tracking-tight">{{ resource_entry.title.value }}</h3>
                    {% if resource_entry.summary != blank and resource_entry.summary.value != blank %}
                      <p class="mt-2 text-sm text-slate-600">{{ resource_entry.summary.value }}</p>
                    {% endif %}
                  </div>
                  {% if resource_url != blank %}
                    {% render 'button', label: resource_label, url: resource_url, style: 'secondary' %}
                  {% endif %}
                </div>
              </div>
              {%- assign rendered_resources = rendered_resources | plus: 1 -%}
            {% endif %}
            {% if rendered_resources >= section.settings.resource_limit %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% if rendered_resources == 0 %}
            {% for i in (1..3) %}
              <div class="section-frame">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                  <div>
                    <p class="section-kicker">Resource</p>
                    <h3 class="mt-3 text-xl font-semibold tracking-tight">Support resource</h3>
                    <p class="mt-2 text-sm text-slate-600">Add download or manual entries in the theme editor to populate this list.</p>
                  </div>
                  {% render 'button', label: 'Open resource', url: '#', style: 'secondary' %}
                </div>
              </div>
            {% endfor %}
          {% endif %}
        {% else %}
          {% for block in section.blocks %}
            <div class="section-frame" {{ block.shopify_attributes }}>
              <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                  {% if block.settings.meta != blank %}
                    <p class="section-kicker">{{ block.settings.meta }}</p>
                  {% endif %}
                  <h3 class="mt-3 text-xl font-semibold tracking-tight">{{ block.settings.title }}</h3>
                  <p class="mt-2 text-sm text-slate-600">{{ block.settings.copy }}</p>
                </div>
                {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
              </div>
            </div>
          {% else %}
            {% for i in (1..3) %}
              <div class="section-frame">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                  <div>
                    <p class="section-kicker">Resource</p>
                    <h3 class="mt-3 text-xl font-semibold tracking-tight">Support resource</h3>
                    <p class="mt-2 text-sm text-slate-600">Add download or manual entries in the theme editor to populate this list.</p>
                  </div>
                  {% render 'button', label: 'Open resource', url: '#', style: 'secondary' %}
                </div>
              </div>
            {% endfor %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support resource list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Resources" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Downloads and manuals framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for search, filtering, and grouped support resources." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "product", "label": "Product-linked resources" },
        { "value": "global", "label": "Global metaobject list" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    {
      "type": "select",
      "id": "resource_kind",
      "label": "Resource kind",
      "default": "downloads",
      "options": [
        { "value": "downloads", "label": "Downloads" },
        { "value": "manuals", "label": "Manuals" }
      ]
    },
    { "type": "product", "id": "source_product", "label": "Source product" },
    { "type": "collection", "id": "source_collection", "label": "Filter global list by collection" },
    {
      "type": "range",
      "id": "resource_limit",
      "label": "Resource limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    { "type": "textarea", "id": "source_note", "label": "Source note" },
    { "type": "text", "id": "default_link_label", "label": "Default structured link label", "default": "Open resource" },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        { "type": "text", "id": "meta", "label": "Meta label", "default": "Resource" },
        { "type": "text", "id": "title", "label": "Title", "default": "Resource title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Resource metadata and compatibility summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Open resource" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support resource list",
      "blocks": [{ "type": "resource" }, { "type": "resource" }, { "type": "resource" }]
    }
  ]
}
{% endschema %}
