<section class="section-shell">
  <div class="container-shell">
    <div class="grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% if section.settings.source_note != blank %}
          <p class="mt-4 text-sm leading-6 text-slate-500">{{ section.settings.source_note }}</p>
        {% endif %}
        <div class="mt-6">
          {% render 'support-search-form' %}
        </div>
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <div class="mt-6">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}
      </div>
      <div class="space-y-4">
        {% for block in section.blocks %}
          <div class="section-frame" {{ block.shopify_attributes }}>
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
              <div>
                {% if block.settings.meta != blank %}
                  <p class="section-kicker">{{ block.settings.meta }}</p>
                {% endif %}
                <h3 class="mt-3 text-xl font-semibold tracking-tight">{{ block.settings.title }}</h3>
                <p class="mt-2 text-sm text-slate-600">{{ block.settings.copy }}</p>
              </div>
              {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
            </div>
          </div>
        {% else %}
          {% for i in (1..3) %}
            <div class="section-frame">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                  <p class="section-kicker">Resource</p>
                  <h3 class="mt-3 text-xl font-semibold tracking-tight">Support resource</h3>
                  <p class="mt-2 text-sm text-slate-600">Add download or manual entries in the theme editor to populate this list.</p>
                </div>
                {% render 'button', label: 'Open resource', url: '#', style: 'secondary' %}
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support resource list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Resources" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Downloads and manuals framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for search, filtering, and grouped support resources." },
    { "type": "textarea", "id": "source_note", "label": "Source note" },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        { "type": "text", "id": "meta", "label": "Meta label", "default": "Resource" },
        { "type": "text", "id": "title", "label": "Title", "default": "Resource title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Resource metadata and compatibility summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Open resource" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support resource list",
      "blocks": [{ "type": "resource" }, { "type": "resource" }, { "type": "resource" }]
    }
  ]
}
{% endschema %}
