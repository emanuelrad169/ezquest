{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero">
  <div class="support-hero__wrap">
    <p class="support-hero__kicker">User Guides</p>
    <h1 class="support-hero__heading">
      Setup guides for<br>every scenario
    </h1>
    <p class="support-hero__sub">
      Step-by-step instructions for first setup,
      display configuration, and advanced use cases.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'user-guides' %}

<div class="support-body">

  <div class="guide-grid">
    {% for block in section.blocks %}
      {% if block.type == 'guide' %}
        {% assign p = block.settings.product %}
        <a href="{{ block.settings.file_url | default: '#' }}"
           class="guide-card"
           {{ block.shopify_attributes }}
           {% unless block.settings.file_url != blank and block.settings.file_url != '#' %}
             aria-disabled="true"
           {% endunless %}
        >
          <div class="guide-card__image-wrap">
            {% if p != blank and p.featured_image %}
              <img src="{{ p.featured_image | image_url: width: 320 }}" alt="{{ p.title | escape }}" class="guide-card__image" loading="lazy" width="320" height="200">
            {% else %}
              <div class="guide-card__image-placeholder"></div>
            {% endif %}
            <span class="guide-card__type-pill">{{ block.settings.guide_type | default: 'Setup guide' }}</span>
          </div>

          <div class="guide-card__body">
            <div class="guide-card__meta">
              <span class="guide-card__steps">{{ block.settings.step_count | default: '5' }} steps</span>
              <span class="guide-card__difficulty guide-card__difficulty--{{ block.settings.difficulty | default: 'easy' | downcase }}">
                {{ block.settings.difficulty | default: 'Easy' }}
              </span>
            </div>
            <h3 class="guide-card__title">{{ block.settings.title }}</h3>
            <p class="guide-card__desc">{{ block.settings.description }}</p>
          </div>

          <div class="guide-card__footer">
            {% if block.settings.file_url != blank and block.settings.file_url != '#' %}
              <span class="guide-card__cta">
                View guide
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            {% else %}
              <span style="font-size:13px;color:var(--ez-grey)">Coming soon</span>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}

    {% if section.blocks.size == 0 %}
      <div class="empty-state" style="grid-column:1/-1">
        <p class="empty-state__heading">Guides are being written</p>
        <p class="empty-state__body">We're preparing step-by-step guides for every product.</p>
        <a href="/pages/contact" class="btn btn--primary">Ask a question</a>
      </div>
    {% endif %}
  </div>

  <div class="support-cta-strip">
    <div>
      <p class="support-cta-strip__heading">Need a walkthrough?</p>
      <p class="support-cta-strip__body">Our support team can guide you through setup in real time.</p>
    </div>
    <div class="support-cta-strip__actions">
      <a href="/pages/contact" class="btn btn--primary">Contact support</a>
    </div>
  </div>

</div>

<style>
.guide-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
@media(max-width:900px){.guide-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.guide-grid{grid-template-columns:1fr}}
.guide-card{border:1px solid rgba(0,0,0,.07);border-radius:16px;overflow:hidden;background:#fff;text-decoration:none;display:flex;flex-direction:column;transition:border-color .2s,transform .25s cubic-bezier(.34,1.56,.64,1)}
.guide-card:hover{border-color:rgba(251, 206, 42, .3);transform:translateY(-2px)}
.guide-card__image-wrap{position:relative;background:var(--ez-light);aspect-ratio:16/9;overflow:hidden}
.guide-card__image{width:100%;height:100%;object-fit:contain;padding:1rem}
.guide-card__image-placeholder{width:100%;height:100%;background:linear-gradient(135deg,var(--ez-light) 0%,#e5e5e7 100%)}
.guide-card__type-pill{position:absolute;top:.75rem;left:.75rem;font-size:11px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;background:rgba(251, 206, 42, .1);color:var(--ez-amber);border:1px solid rgba(251, 206, 42, .25);padding:.2rem .625rem;border-radius:100px}
.guide-card__body{padding:1.25rem;flex:1}
.guide-card__meta{display:flex;align-items:center;gap:.625rem;margin-bottom:.75rem}
.guide-card__steps{font-size:12px;color:var(--ez-grey);font-weight:500}
.guide-card__difficulty{font-size:11px;font-weight:600;padding:.15rem .5rem;border-radius:100px;text-transform:uppercase;letter-spacing:.05em}
.guide-card__difficulty--easy{background:rgba(21,128,61,.07);color:#15803d}
.guide-card__difficulty--medium{background:rgba(251, 206, 42, .07);color:var(--ez-amber)}
.guide-card__difficulty--advanced{background:rgba(239,68,68,.07);color:#b91c1c}
.guide-card__title{font-size:15px;font-weight:500;color:var(--ez-black);letter-spacing:-.01em;line-height:1.35;margin:0 0 .375rem}
.guide-card__desc{font-size:13px;color:var(--ez-grey);line-height:1.55;margin:0}
.guide-card__footer{padding:.875rem 1.25rem;border-top:1px solid rgba(0,0,0,.06)}
.guide-card__cta{display:inline-flex;align-items:center;gap:.375rem;font-size:13px;font-weight:500;color:var(--ez-amber);transition:gap .15s}
.guide-card:hover .guide-card__cta{gap:.625rem}
</style>

{% schema %}
{
  "name": "User guides",
  "tag": "section",
  "blocks": [
    {
      "type": "guide",
      "name": "Guide",
      "settings": [
        {"type":"product","id":"product","label":"Product"},
        {"type":"text","id":"title","label":"Guide title"},
        {"type":"text","id":"description","label":"Short description"},
        {"type":"url","id":"file_url","label":"PDF or page URL"},
        {"type":"text","id":"guide_type","label":"Guide type","default":"Setup guide"},
        {"type":"text","id":"step_count","label":"Number of steps","default":"5"},
        {
          "type":"select","id":"difficulty","label":"Difficulty",
          "options":[
            {"value":"Easy","label":"Easy"},
            {"value":"Medium","label":"Medium"},
            {"value":"Advanced","label":"Advanced"}
          ],"default":"Easy"
        }
      ]
    }
  ],
  "presets":[{"name":"User guides"}]
}
{% endschema %}
