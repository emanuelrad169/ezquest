{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero relative overflow-hidden">
  <div class="support-hero__wrap">
    <p class="support-hero__kicker">User Guides</p>
    <h1 class="support-hero__heading">
      Setup guides for<br>every scenario
    </h1>
    <p class="support-hero__sub">
      Step-by-step instructions for first setup,
      display configuration, and advanced use cases.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'user-guides' %}

<div class="support-body">

  <div class="guide-grid">
    {% for block in section.blocks %}
      {% if block.type == 'guide' %}
        {% assign p = block.settings.product %}
        <a href="{{ block.settings.file_url | default: '#' }}"
           class="guide-card group hover:border-[var(--ez-amber-30)] hover:-translate-y-0.5"
           {{ block.shopify_attributes }}
           {% unless block.settings.file_url != blank and block.settings.file_url != '#' %}
             aria-disabled="true"
           {% endunless %}
        >
          <div class="guide-card__image-wrap">
            {% if p != blank and p.featured_image %}
              <img src="{{ p.featured_image | image_url: width: 320, format: 'pjpg' }}" alt="{{ p.title | escape }}" class="guide-card__image" loading="lazy" width="320" height="200">
            {% else %}
              <div class="guide-card__image-placeholder"></div>
            {% endif %}
            <span class="guide-card__type-pill">{{ block.settings.guide_type | default: 'Setup guide' }}</span>
          </div>

          <div class="guide-card__body p-5 flex-1">
            <div class="guide-card__meta">
              <span class="guide-card__steps">{{ block.settings.step_count | default: '5' }} steps</span>
              <span class="guide-card__difficulty guide-card__difficulty--{{ block.settings.difficulty | default: 'easy' | downcase }}">
                {{ block.settings.difficulty | default: 'Easy' }}
              </span>
            </div>
            <h3 class="guide-card__title">{{ block.settings.title }}</h3>
            <p class="guide-card__desc">{{ block.settings.description }}</p>
          </div>

          <div class="guide-card__footer">
            {% if block.settings.file_url != blank and block.settings.file_url != '#' %}
              <span class="guide-card__cta group-hover:gap-2.5">
                View guide
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            {% else %}
              <span style="font-size:13px;color:var(--ez-grey)">Available on request</span>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}

    {% if section.blocks.size == 0 %}
      <div class="empty-state" style="grid-column:1/-1">
        <p class="empty-state__heading">Guides are being written</p>
        <p class="empty-state__body">We're preparing step-by-step guides for every product.</p>
        <a href="/pages/contact" class="btn btn--primary">Ask a question</a>
      </div>
    {% endif %}
  </div>


</div>

{%- render 'page-cta',
  variant: 'dark',
  kicker: 'User guides',
  heading: 'Need a walkthrough?',
  subhead: 'Our support team can guide you through setup in real time.',
  primary_label: 'Contact support',
  primary_url: '/pages/contact'
-%}

{% schema %}
{
  "name": "User guides",
  "tag": "section",
  "blocks": [
    {
      "type": "guide",
      "name": "Guide",
      "settings": [
        {"type":"product","id":"product","label":"Product"},
        {"type":"text","id":"title","label":"Guide title"},
        {"type":"text","id":"description","label":"Short description"},
        {"type":"url","id":"file_url","label":"PDF or page URL"},
        {"type":"text","id":"guide_type","label":"Guide type","default":"Setup guide"},
        {"type":"text","id":"step_count","label":"Number of steps","default":"5"},
        {
          "type":"select","id":"difficulty","label":"Difficulty",
          "options":[
            {"value":"Easy","label":"Easy"},
            {"value":"Medium","label":"Medium"},
            {"value":"Advanced","label":"Advanced"}
          ],"default":"Easy"
        }
      ]
    }
  ],
  "presets":[{"name":"User guides"}]
}
{% endschema %}
