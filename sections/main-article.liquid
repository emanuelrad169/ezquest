{{ 'pages.css' | asset_url | stylesheet_tag }}

<article class="section-shell main-article-section">
  {%- liquid
    assign words = article.content | strip_html | split: ' '
    assign read_time = words.size | divided_by: 200 | plus: 1
  -%}
  <div class="container-shell">
    {% render 'breadcrumbs' %}

    <div class="article-header">
      <p class="article-header__category">{{ article.blog.title | default: 'Article' }}</p>
      <h1 class="article-header__title">{{ article.title }}</h1>
      <div class="article-header__meta">
        <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
        <span class="article-header__meta-divider" aria-hidden="true"></span>
        <span>{{ read_time }} min read</span>
        {% if article.tags.size > 0 %}
          <span class="article-header__meta-divider" aria-hidden="true"></span>
          {% for tag in article.tags limit: 2 %}
            <span>{{ tag }}</span>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="article-featured-image-wrap">
      {% if article.image != blank %}
        {{ article.image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'article-featured-image' }}
      {% elsif section.settings.default_article_image != blank %}
        {{ section.settings.default_article_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: article.title, class: 'article-featured-image' }}
      {% else %}
        {% render 'owned-editorial-visual', visual: 'guide', title: article.title, class: 'article-featured-image' %}
      {% endif %}
    </div>

    <div class="article-body richtext-content">
      {{ article.content }}
    </div>

    <div class="article-footer">
      <div class="article-tags">
        {% for tag in article.tags %}
          <a href="{{ article.blog.url }}/tagged/{{ tag | handle }}" class="article-tag">{{ tag }}</a>
        {% endfor %}
      </div>
      <div class="article-continuation-links">
        <span class="article-continuation-label">Continue:</span>
        <a href="/pages/support" class="support-inline-link">Support center</a>
        <a href="/pages/manuals" class="support-inline-link">Manuals</a>
        <a href="/pages/downloads" class="support-inline-link">Downloads</a>
        <a href="/pages/compatibility" class="support-inline-link">Compatibility</a>
      </div>
    </div>
  </div>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt | default: article.content | strip_html | truncate: 200 | json }},
  "url": {{ canonical_url | json }},
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": {
    "@type": "Person",
    "name": {{ article.author | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "logo": {
      "@type": "ImageObject",
      "url": "{{ settings.share_image | image_url: width: 400 }}"
    }
  }{% if article.image %},
  "image": {
    "@type": "ImageObject",
    "url": "{{ article.image | image_url: width: 1200 }}",
    "width": 1200
  }{% endif %}
}
</script>

{% schema %}
{
  "name": "Main article",
  "settings": [
    { "type": "image_picker", "id": "default_article_image", "label": "Default article image" }
  ]
}
{% endschema %}
