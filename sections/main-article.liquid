<article class="section-shell">
  <div class="container-shell">
    {% render 'breadcrumbs' %}

    <div class="article-header-shell mt-6">
      <div class="article-header-copy">
        <p class="section-kicker">{{ article.blog.title | default: 'Article' }}</p>
        <h1 class="section-heading mt-4">{{ article.title }}</h1>
        <div class="article-meta-row mt-4">
          <span class="article-meta-date">{{ article.published_at | date: '%B %d, %Y' }}</span>
          {% if article.tags.size > 0 %}
            {% for tag in article.tags limit: 2 %}
              <span class="product-meta-pill">{{ tag }}</span>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <div class="article-header-panel section-frame">
        <p class="section-kicker">Next useful step</p>
        <p class="mt-3 text-sm leading-6 text-slate-500">Use this guide to answer the product question first, then open support, manuals, or downloads if you need more detail.</p>
        <div class="support-crosslink-list mt-4">
          <a href="{{ article.blog.url | default: '/blogs/resources' }}" class="support-crosslink">
            <span>Back to resources</span>
            <span class="text-slate-400">Browse</span>
          </a>
          <a href="/pages/compatibility" class="support-crosslink">
            <span>Check compatibility</span>
            <span class="text-slate-400">Guide</span>
          </a>
          <a href="/pages/support" class="support-crosslink">
            <span>Need direct help</span>
            <span class="text-slate-400">Support</span>
          </a>
        </div>
      </div>
    </div>

    <div class="article-content-shell mt-10">
      {% if article.image != blank %}
        <div class="article-feature-shell">
          {{ article.image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'article-feature-image' }}
        </div>
      {% endif %}
      <div class="richtext-content max-w-none">
        {{ article.content }}
      </div>
    </div>

    <div class="article-continuation-shell">
      <span class="article-continuation-label">Continue</span>
      <a href="/pages/support" class="support-inline-link">Support center</a>
      <a href="/pages/manuals" class="support-inline-link">Manuals</a>
      <a href="/pages/downloads" class="support-inline-link">Downloads</a>
      <a href="/pages/compatibility" class="support-inline-link">Compatibility</a>
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Main article",
  "settings": []
}
{% endschema %}
