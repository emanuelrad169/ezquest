{%- comment -%}
  Renders a single standard product card for a given product.
  Fetched client-side by recently-viewed.js via the Section Rendering API:
  /products/{handle}?section_id=recently-viewed-card
{%- endcomment -%}
{% if product != blank %}
  {% render 'card-product', product: product, card_style: 'featured-strip', card_context: 'collection', image_rollover: true %}
{% endif %}
{% schema %}
{
  "name": "Recently viewed card"
}
{% endschema %}
