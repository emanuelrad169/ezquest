<section class="section-shell surface-muted">
  <div class="container-shell">
    <div class="support-nav-layout">
      <div class="support-aside">
        <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        <p class="support-aside-meta">{{ section.blocks.size }} support paths, from self-serve resources to direct help</p>

        <div class="support-context-panel" data-support-context hidden>
          <p class="section-kicker" data-support-context-kicker>Product context</p>
          <h3 class="support-context-title mt-4" data-support-context-title>The right help, tied to the right product</h3>
          <p class="support-context-copy" data-support-context-copy>Support stays connected to the product you were already viewing.</p>
          <div class="mt-5">
            <a href="/pages/support" class="button-secondary" data-support-context-return hidden>Return to product</a>
          </div>
        </div>

        {% if section.settings.show_search %}
          <div class="mt-8">
            {% render 'support-search-form' %}
          </div>
        {% endif %}

        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <div class="mt-8">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}

        <div class="mt-8">
          <p class="section-kicker">More support topics</p>
          <div class="support-next-step-list mt-4">
            <a href="/pages/troubleshooting" class="support-inline-link" data-support-context-link>Troubleshooting</a>
            <a href="/pages/faq" class="support-inline-link" data-support-context-link>FAQ</a>
            <a href="/pages/warranty" class="support-inline-link" data-support-context-link>Warranty</a>
            <a href="/pages/shipping-returns" class="support-inline-link" data-support-context-link>Shipping & returns</a>
          </div>
        </div>

        <script type="application/json" data-support-context-config>
          {
            "productTitles": {
              "usb-c-multimedia-hub": {{ all_products['usb-c-multimedia-hub'].title | default: 'USB-C Multimedia Hub' | json }},
              "usb-c-travel-hub": {{ all_products['usb-c-travel-hub'].title | default: 'USB-C Travel Hub' | json }},
              "usb-c-pro-dock": {{ all_products['usb-c-pro-dock'].title | default: 'USB-C Pro Dock' | json }}
            }
          }
        </script>
      </div>

      <div class="support-nav-cards">
        {% for block in section.blocks %}
          {%- liquid
            assign block_eyebrow = block.settings.eyebrow
            assign support_visual = 'support'
            if block_eyebrow == blank
              assign block_eyebrow = forloop.index | prepend: '0'
            endif
            if block.settings.link_url contains '/pages/downloads'
              assign support_visual = 'downloads'
            elsif block.settings.link_url contains '/pages/manuals'
              assign support_visual = 'manuals'
            elsif block.settings.link_url contains '/pages/compatibility'
              assign support_visual = 'compatibility'
            endif
          -%}
          <article class="support-tile{% if forloop.first %} support-tile--featured{% endif %} motion-lift" {{ block.shopify_attributes }}>
            <div class="support-tile-visual">
              {% render 'owned-support-visual', visual: support_visual, class: 'support-tile-visual-image' %}
            </div>
            <div class="flex items-center justify-between gap-4">
              <p class="section-kicker">{{ block_eyebrow }}</p>
              <span class="support-tile-badge">
                {% if block.settings.link_url contains '/pages/contact' %}
                  Direct support
                {% elsif block.settings.link_url contains '/pages/compatibility' %}
                  Compatibility
                {% else %}
                  Self-serve
                {% endif %}
              </span>
            </div>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">{{ block.settings.title | default: 'Support path' }}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{{ block.settings.copy }}</p>
            <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200/80 pt-5">
              <p class="support-tile-note">
                {% if block.settings.link_url contains '/pages/contact' %}
                  Best for product, order, or warranty questions
                {% elsif block.settings.link_url contains '/pages/compatibility' %}
                  Best for checking devices, displays, and platform support
                {% else %}
                  Best for manuals, downloads, and setup files
                {% endif %}
              </p>
              {% if block.settings.link_url != blank %}
                <a href="{{ block.settings.link_url }}" class="button-secondary"{% if block.settings.link_url contains '/pages/' %} data-support-context-link{% endif %}>{{ block.settings.link_label | default: 'View page' }}</a>
              {% endif %}
            </div>
            </article>
          {% else %}
          {% for i in (1..4) %}
            <article class="support-tile{% if forloop.first %} support-tile--featured{% endif %}">
              <div class="support-tile-visual">
                {% render 'owned-support-visual', visual: 'support', class: 'support-tile-visual-image' %}
              </div>
              <div class="flex items-center justify-between gap-4">
                <p class="section-kicker">{{ i | prepend: '0' }}</p>
                <span class="support-tile-badge">{% if forloop.first %}Fastest start{% else %}Support path{% endif %}</span>
              </div>
              <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">
                {% if forloop.index == 1 %}
                  Find a download
                {% elsif forloop.index == 2 %}
                  Find a manual
                {% elsif forloop.index == 3 %}
                  Check compatibility
                {% else %}
                  Get help now
                {% endif %}
              </h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                {% if forloop.index == 1 %}
                  Start here when the next step is a file, installer, or firmware resource tied to your product.
                {% elsif forloop.index == 2 %}
                  Move into manuals when you need setup steps, product instructions, or a quick-start path.
                {% elsif forloop.index == 3 %}
                  Check device, display, and platform compatibility before you buy or install.
                {% else %}
                  Start one support request when the answer depends on your exact setup, order, or warranty status.
                {% endif %}
              </p>
            </article>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support nav grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support hub" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose the support path" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Choose downloads, manuals, compatibility, or direct support based on what you need." },
    { "type": "checkbox", "id": "show_search", "label": "Show support search form", "default": false },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Nav item",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title", "default": "Downloads" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Show what belongs here and why it matters." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View page" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support nav grid",
      "blocks": [{ "type": "nav_item" }, { "type": "nav_item" }, { "type": "nav_item" }, { "type": "nav_item" }]
    }
  ]
}
{% endschema %}
