<section class="section-shell surface-muted">
  <div class="container-shell">
    <div class="support-nav-layout">
      <div class="support-aside">
        <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>

        {% if section.settings.show_search %}
          <div class="mt-8">
            {% render 'support-search-form' %}
          </div>
        {% endif %}

        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <div class="mt-8">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}

        <div class="support-next-step-list">
          <a href="/pages/downloads" class="support-inline-link">Downloads</a>
          <a href="/pages/manuals" class="support-inline-link">Manuals</a>
          <a href="/pages/compatibility" class="support-inline-link">Compatibility</a>
          <a href="/pages/contact" class="support-inline-link">Contact support</a>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {% for block in section.blocks %}
          {%- liquid
            assign block_eyebrow = block.settings.eyebrow
            if block_eyebrow == blank
              assign block_eyebrow = forloop.index | prepend: '0'
            endif
          -%}
          <article class="support-tile motion-lift" {{ block.shopify_attributes }}>
            <div class="flex items-center justify-between gap-4">
              <p class="section-kicker">{{ block_eyebrow }}</p>
              <span class="text-xs uppercase tracking-wide text-slate-300">Start here</span>
            </div>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">{{ block.settings.title | default: 'Support path' }}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{{ block.settings.copy }}</p>
            <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200/80 pt-5">
              <p class="text-xs font-medium uppercase tracking-wide text-slate-400">Best when this is the clearest next task</p>
              {% if block.settings.link_url != blank %}
                {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
              {% endif %}
            </div>
          </article>
        {% else %}
          {% for i in (1..4) %}
            <article class="support-tile">
              <div class="flex items-center justify-between gap-4">
                <p class="section-kicker">{{ i | prepend: '0' }}</p>
                <span class="text-xs uppercase tracking-wide text-slate-300">Support path</span>
              </div>
              <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">
                {% if forloop.index == 1 %}
                  Downloads and drivers
                {% elsif forloop.index == 2 %}
                  Manuals and setup guides
                {% elsif forloop.index == 3 %}
                  Compatibility checks
                {% else %}
                  Direct support
                {% endif %}
              </h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                {% if forloop.index == 1 %}
                  Start here when the next step is a file, installer, or firmware resource tied to your product.
                {% elsif forloop.index == 2 %}
                  Move into manuals when you need setup steps, product instructions, or a quick-start path.
                {% elsif forloop.index == 3 %}
                  Confirm the right device, display, or workflow fit before you buy or begin installation.
                {% else %}
                  Use direct support when the answer depends on your exact setup, order, or troubleshooting context.
                {% endif %}
              </p>
            </article>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support nav grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support hub" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Start with the help you need" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Find downloads, manuals, compatibility guidance, troubleshooting, and direct support from one clear starting point." },
    { "type": "checkbox", "id": "show_search", "label": "Show support search form", "default": true },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Nav item",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title", "default": "Downloads" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Explain when this support destination is the right next step." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Open support page" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support nav grid",
      "blocks": [{ "type": "nav_item" }, { "type": "nav_item" }, { "type": "nav_item" }, { "type": "nav_item" }]
    }
  ]
}
{% endschema %}
