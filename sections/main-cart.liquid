<section class="section-shell cart-page-section">
  <div class="container-shell">

    <div class="cart-page-header">
      <p class="section-kicker">Your bag</p>
      <h1 class="cart-page-title">
        {% if cart.item_count == 0 %}
          Your cart is empty
        {% elsif cart.item_count == 1 %}
          Cart (1 item)
        {% else %}
          Cart ({{ cart.item_count }} items)
        {% endif %}
      </h1>
    </div>

    {% if cart.item_count > 0 %}
      <div class="cart-page-layout">

        {%- comment -%} ── Line items ── {%- endcomment -%}
        <div class="cart-page-items">
          {% for item in cart.items %}
            <div class="cart-item">

              <a href="{{ item.url }}" class="cart-item-media" tabindex="-1" aria-hidden="true">
                {% if item.image != blank %}
                  {{ item.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: item.product.title, class: 'cart-item-image' }}
                {% endif %}
              </a>

              <div class="cart-item-body">
                <div class="cart-item-meta">
                  <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                  {% unless item.variant.title == 'Default Title' %}
                    <p class="cart-item-variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  <p class="cart-item-price">{{ item.line_price | money }}</p>
                </div>

                <div class="cart-item-controls">
                  <form action="{{ routes.cart_change_url }}" method="post" class="cart-item-qty-form">
                    <input type="hidden" name="id" value="{{ item.variant.id }}">
                    <div class="cart-item-qty-group" role="group" aria-label="Quantity for {{ item.product.title | escape }}">
                      <button
                        type="submit"
                        name="quantity"
                        value="{{ item.quantity | minus: 1 }}"
                        class="cart-item-qty-btn"
                        aria-label="Decrease quantity of {{ item.product.title | escape }}"
                        {% if item.quantity <= 1 %}disabled{% endif %}
                      >–</button>
                      <span class="cart-item-qty-display" aria-live="polite">{{ item.quantity }}</span>
                      <button
                        type="submit"
                        name="quantity"
                        value="{{ item.quantity | plus: 1 }}"
                        class="cart-item-qty-btn"
                        aria-label="Increase quantity of {{ item.product.title | escape }}"
                      >+</button>
                    </div>
                  </form>

                  <form action="{{ routes.cart_change_url }}" method="post" class="cart-item-remove-form">
                    <input type="hidden" name="id" value="{{ item.variant.id }}">
                    <button type="submit" name="quantity" value="0" class="cart-item-remove">Remove</button>
                  </form>
                </div>
              </div>

            </div>
          {% endfor %}
        </div>

        {%- comment -%} ── Order summary panel ── {%- endcomment -%}
        <div class="cart-page-summary">
          <div class="cart-summary-panel">
            <h2 class="cart-summary-heading">Order summary</h2>

            {%- liquid
              assign free_ship_threshold = 15000
              assign remaining_cents = free_ship_threshold | minus: cart.total_price
            -%}
            {% if remaining_cents > 0 %}
              <div class="cart-shipping-bar">
                <p class="cart-shipping-bar__label">
                  Add {{ remaining_cents | money }} more for free shipping
                </p>
                <div class="cart-shipping-bar__track" role="presentation">
                  <div
                    class="cart-shipping-bar__fill"
                    style="width: {{ cart.total_price | times: 100 | divided_by: free_ship_threshold | at_most: 100 }}%"
                    role="progressbar"
                    aria-valuenow="{{ cart.total_price | times: 100 | divided_by: free_ship_threshold | round }}"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-label="Free shipping progress"
                  ></div>
                </div>
              </div>
            {% else %}
              <div class="cart-shipping-bar cart-shipping-bar--complete">
                <p class="cart-shipping-bar__label">You qualify for free shipping</p>
              </div>
            {% endif %}

            {% if cart.total_discount > 0 %}
              <div class="cart-summary-row">
                <span>Savings</span>
                <span class="cart-summary-savings">–{{ cart.total_discount | money }}</span>
              </div>
            {% endif %}

            <div class="cart-summary-row cart-summary-total">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <p class="cart-summary-note">Taxes and shipping calculated at checkout.</p>

            <div class="cart-summary-trust" role="list" aria-label="Checkout assurances">
              <span class="cart-trust-item" role="listitem">
                <span class="cart-trust-icon" aria-hidden="true">{% render 'icon', name: 'shield' %}</span>
                Secure checkout
              </span>
              <span class="cart-trust-item" role="listitem">
                <span class="cart-trust-icon" aria-hidden="true">{% render 'icon', name: 'truck' %}</span>
                Free shipping on orders $150+
              </span>
              <span class="cart-trust-item" role="listitem">
                <span class="cart-trust-icon" aria-hidden="true">{% render 'icon', name: 'shield' %}</span>
                2-year warranty on every product
              </span>
            </div>

            <a href="/checkout" class="cart-checkout-btn">
              Proceed to checkout
            </a>

            <div class="cart-continue-btn">
              {% render 'button', label: 'Continue shopping', url: routes.collections_url, style: 'secondary' %}
            </div>

          </div>
        </div>

      </div>
    {% else %}

      <div class="cart-empty-state">
        <p class="cart-empty-body">You haven't added anything yet. Browse the product families to find the right hub, dock, charger, or accessory for your setup.</p>
        <div class="cart-empty-actions">
          {% render 'button', label: 'Browse products', url: routes.collections_url, style: 'primary' %}
          <a href="/pages/help-me-choose" class="site-meta-link">Not sure? Get setup guidance</a>
        </div>
      </div>

    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
