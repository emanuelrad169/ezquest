{{ 'pages.css' | asset_url | stylesheet_tag }}

{% comment %} 1. HERO {% endcomment %}
<section class="page-hero-light">
  <div style="max-width:1280px;margin:0 auto;">
    <p class="page-hero-light__kicker">Shipping &amp; returns</p>
    <h1 class="page-hero-light__heading">Fast shipping. Easy returns.</h1>
    <p class="page-hero-light__body">
      Free shipping on all US orders over $100.
      30-day hassle-free returns. 2-year warranty on everything.
    </p>
    <div class="page-hero-light__meta">
      <div>
        <p class="page-hero-light__stat-value">Free</p>
        <p class="page-hero-light__stat-label">shipping over $100 in the US</p>
      </div>
      <div>
        <p class="page-hero-light__stat-value">30</p>
        <p class="page-hero-light__stat-label">day return window</p>
      </div>
      <div>
        <p class="page-hero-light__stat-value">2yr</p>
        <p class="page-hero-light__stat-label">warranty on all products</p>
      </div>
    </div>
  </div>
</section>

{% comment %} 2. FREE SHIPPING STRIP {% endcomment %}
<div class="free-shipping-strip">
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
    <path d="M8.5 3.5L3 10h5.5L7 16.5l9.5-9H11L12.5 3.5z" stroke="#FBCE2A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <p>Free shipping automatically applied on all US orders over $100 — no code needed.</p>
</div>

{% comment %} 3. 2-COL CONTENT {% endcomment %}
<section class="page-section page-section--white">
  <div class="two-col">

    <div>
      <p style="font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#6e6e73;margin-bottom:1.25rem;">US shipping rates</p>
      <div class="shipping-table-wrap">
        <table class="shipping-table">
          <thead><tr><th>Order total</th><th>Rate</th><th>Delivery</th></tr></thead>
          <tbody>
            <tr><td>Under $25</td><td>$4.97</td><td>2–7 business days</td></tr>
            <tr><td>$25 – $50</td><td>$6.54</td><td>2–7 business days</td></tr>
            <tr><td>$50 – $100</td><td>$7.97</td><td>2–7 business days</td></tr>
            <tr><td>Over $100</td><td class="shipping-free">Free</td><td>2–7 business days</td></tr>
          </tbody>
        </table>
      </div>

      <p style="font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#6e6e73;margin:2rem 0 1.25rem;">International shipping</p>
      <div class="shipping-table-wrap">
        <table class="shipping-table">
          <thead><tr><th>Order total</th><th>Rate</th><th>Delivery</th></tr></thead>
          <tbody>
            <tr><td>Under $25</td><td>$14.99</td><td>5–15 days</td></tr>
            <tr><td>$25 – $50</td><td>$19.99</td><td>5–15 days</td></tr>
            <tr><td>$50 – $100</td><td>$23.99</td><td>5–15 days</td></tr>
            <tr><td>Over $250</td><td>$35.99</td><td>5–15 days</td></tr>
          </tbody>
        </table>
      </div>
      <p style="font-size:12px;color:#6e6e73;margin-top:.75rem;line-height:1.5;">International orders may be subject to customs duties and taxes — these are the responsibility of the recipient.</p>
    </div>

    <div>
      <p style="font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#6e6e73;margin-bottom:1.25rem;">How returns work</p>
      <div class="return-steps">
        <div class="return-step">
          <div class="return-step__num">1</div>
          <div>
            <p class="return-step__title">Contact us</p>
            <p class="return-step__body">Email support@ezq.com with your order number and reason for return. We respond within 1 business day.</p>
          </div>
        </div>
        <div class="return-step">
          <div class="return-step__num">2</div>
          <div>
            <p class="return-step__title">Get your RMA</p>
            <p class="return-step__body">We'll email you a Return Materials Authorization number and step-by-step return instructions.</p>
          </div>
        </div>
        <div class="return-step">
          <div class="return-step__num">3</div>
          <div>
            <p class="return-step__title">Ship it back</p>
            <p class="return-step__body">Write your RMA number on the outside of the package. Use a trackable shipping method — we can't accept responsibility for lost returns.</p>
          </div>
        </div>
        <div class="return-step">
          <div class="return-step__num">4</div>
          <div>
            <p class="return-step__title">Get your refund</p>
            <p class="return-step__body">Once received and inspected, refunds process within 5–7 business days back to your original payment method.</p>
          </div>
        </div>
      </div>
      <div style="margin-top:2rem;padding:1.25rem;background:#f5f5f7;border-radius:14px;">
        <p style="font-size:13px;font-weight:500;color:#1d1d1f;margin-bottom:.375rem;">30-day return window</p>
        <p style="font-size:13px;color:#6e6e73;line-height:1.6;">Items must be returned within 30 days of delivery, unused, and in original packaging. Items showing signs of use may not be eligible for a full refund.</p>
      </div>
    </div>

  </div>
</section>

{% comment %} 4. QUICK FAQ {% endcomment %}
<section class="page-section page-section--grey">
  <div style="max-width:1280px;margin:0 auto;padding:clamp(48px,6vw,72px) clamp(1.25rem,5vw,5rem);">
    <div style="margin-bottom:2rem;">
      <p class="section-intro__kicker">Common questions</p>
      <h2 class="section-intro__heading" style="text-align:left;">Shipping &amp; returns FAQ</h2>
    </div>
    <div class="page-faq">
      <div class="page-faq-item">
        <button class="page-faq-trigger" aria-expanded="false">
          When will my order ship?
          <svg class="page-faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        </button>
        <div class="page-faq-body">
          <div class="page-faq-content">Orders placed before 2pm PST on business days typically ship same day. Orders placed Friday after 2pm, Saturday, or Sunday ship the following Monday.</div>
        </div>
      </div>
      <div class="page-faq-item">
        <button class="page-faq-trigger" aria-expanded="false">
          Can I return a product I've already opened?
          <svg class="page-faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        </button>
        <div class="page-faq-body">
          <div class="page-faq-content">Yes — if the product is in like-new condition within 30 days. If the product has a defect, it's covered by the 2-year warranty regardless of whether it's been opened.</div>
        </div>
      </div>
      <div class="page-faq-item">
        <button class="page-faq-trigger" aria-expanded="false">
          Does free shipping apply to international orders?
          <svg class="page-faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        </button>
        <div class="page-faq-body">
          <div class="page-faq-content">Free shipping applies to US orders only. International shipping rates are calculated at checkout based on order weight and destination.</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% comment %} 5. CTA {% endcomment %}
<section class="page-cta-dark">
  <h2 class="page-cta-dark__heading">Questions? We're here.</h2>
  <p class="page-cta-dark__body">Our team responds within 1 business day.</p>
  <a href="/pages/contact" class="btn btn--primary" style="background:#FBCE2A;color:#1d1d1f;">Contact support</a>
</section>

<script>
(function(){
  document.querySelectorAll('.page-faq-trigger').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = this.closest('.page-faq-item');
      var isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.page-faq-item.is-open').forEach(function(el){
        el.classList.remove('is-open');
        el.querySelector('.page-faq-trigger').setAttribute('aria-expanded','false');
      });
      if(!isOpen){
        item.classList.add('is-open');
        this.setAttribute('aria-expanded','true');
      }
    });
  });
})();
</script>

{% schema %}
{ "name": "Shipping & returns", "tag": "section" }
{% endschema %}
