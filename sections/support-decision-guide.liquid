{%- liquid
  assign use_global_entries = false
  assign sorted_guide_keys = '' | split: ''
  if section.settings.structured_source == 'global' or section.settings.structured_source == 'auto'
    assign use_global_entries = true
  endif
  if use_global_entries and metaobjects.ezquest_decision_guide_entry != blank
    capture sorted_guides_raw
      for guide_entry in metaobjects.ezquest_decision_guide_entry.values
        capture order_token_raw
          echo '000000'
          echo guide_entry.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo guide_entry.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_guide_keys = sorted_guides_raw | split: '||' | sort_natural
  endif
-%}

<section class="decision-guide" aria-label="Find your setup">
  <div class="page-width">
    <div class="decision-guide__header">
      {% if section.settings.eyebrow != blank %}
        <p class="decision-guide__kicker"><span class="shiny-text">{{ section.settings.eyebrow }}</span></p>
      {% endif %}
      <h2 class="decision-guide__heading">{{ section.settings.heading | default: 'Pick the role that matches the way you work' }}</h2>
      {% if section.settings.copy != blank %}
        <p class="decision-guide__subhead">{{ section.settings.copy }}</p>
      {% endif %}
    </div>

    <div class="decision-bento" id="decision-bento-{{ section.id }}">
      {%- if use_global_entries and metaobjects.ezquest_decision_guide_entry != blank -%}
        {%- assign rendered_entries = 0 -%}
        {%- for guide_key in sorted_guide_keys -%}
          {%- if guide_key == blank -%}{%- continue -%}{%- endif -%}
          {%- if rendered_entries >= section.settings.entry_limit -%}{%- break -%}{%- endif -%}
          {%- assign guide_handle = guide_key | split: '::' | last -%}
          {%- assign guide_entry = metaobjects.ezquest_decision_guide_entry[guide_handle] -%}
          {%- assign idx = rendered_entries -%}
          {%- assign cta_url = guide_entry.primary_url.value -%}
          <a href="{{ cta_url | default: '/collections' }}"
             class="decision-card decision-card--{{ idx }}"
             data-bento-index="{{ idx }}"
             data-reveal-delay="{{ idx | times: 60 }}"
             aria-label="{{ guide_entry.title.value | escape }}">
            <div class="decision-card__inner">
              <div class="decision-card__top">
                {%- if guide_entry.role_label.value != blank -%}
                  <span class="decision-card__kicker">{{ guide_entry.role_label.value }}</span>
                {%- endif -%}
                {%- if idx == 0 -%}<span class="decision-card__badge">Most popular</span>{%- endif -%}
              </div>
              <h3 class="decision-card__title">{{ guide_entry.title.value }}</h3>
              {%- if guide_entry.summary.value != blank -%}
                <p class="decision-card__body">{{ guide_entry.summary.value }}</p>
              {%- endif -%}
              <div class="decision-card__actions">
                {%- if cta_url != blank -%}
                  <span class="decision-card__cta">{{ guide_entry.primary_label.value | default: 'Shop this setup' }} <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                {%- endif -%}
              </div>
            </div>
          </a>
          {%- assign rendered_entries = rendered_entries | plus: 1 -%}
        {%- endfor -%}

        {%- if rendered_entries == 0 -%}
          <div class="decision-card decision-card--0 decision-card--is-revealed">
            <div class="decision-card__inner">
              <p class="decision-card__kicker">Decision guide</p>
              <h3 class="decision-card__title">No entries yet</h3>
              <p class="decision-card__body">Add decision guide metaobject entries in Shopify to populate this guide.</p>
            </div>
          </div>
        {%- endif -%}

      {%- else -%}
        {%- for block in section.blocks -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign cta_url = block.settings.primary_url -%}
          <a href="{{ cta_url | default: '/collections' }}"
             class="decision-card decision-card--{{ idx }}"
             data-bento-index="{{ idx }}"
             data-reveal-delay="{{ idx | times: 60 }}"
             aria-label="{{ block.settings.title | escape }}"
             {{ block.shopify_attributes }}>
            <div class="decision-card__inner">
              <div class="decision-card__top">
                {%- if block.settings.eyebrow != blank -%}
                  <span class="decision-card__kicker">{{ block.settings.eyebrow }}</span>
                {%- endif -%}
                {%- if idx == 0 -%}<span class="decision-card__badge">Most popular</span>{%- endif -%}
              </div>
              <h3 class="decision-card__title">{{ block.settings.title }}</h3>
              {%- if block.settings.copy != blank -%}
                <p class="decision-card__body">{{ block.settings.copy }}</p>
              {%- endif -%}
              <div class="decision-card__actions">
                {%- if cta_url != blank -%}
                  <span class="decision-card__cta">{{ block.settings.primary_label | default: 'Shop this setup' }} <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- else -%}
          <div class="decision-card decision-card--0 decision-card--is-revealed">
            <div class="decision-card__inner">
              <p class="decision-card__kicker">Decision guide</p>
              <h3 class="decision-card__title">No entries configured</h3>
              <p class="decision-card__body">Add decision guide blocks or enable metaobject entries to populate this guide.</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function () {
  var bento = document.getElementById('decision-bento-{{ section.id }}');
  if (!bento) return;
  var cards = bento.querySelectorAll('.decision-card');

  // BlurFade reveal via IntersectionObserver
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          var el = e.target;
          var delay = parseInt(el.dataset.revealDelay || '0', 10) || 0;
          setTimeout(function () { el.classList.add('is-revealed'); }, delay);
          io.unobserve(el);
        }
      });
    }, { threshold: 0.08 });
    cards.forEach(function (c) { io.observe(c); });
  } else {
    cards.forEach(function (c) { c.classList.add('is-revealed'); });
  }
})();
</script>

{% schema %}
{
  "name": "Support decision guide",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Choose a setup" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick the role that matches the way you work" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Choose the role first, then move into the product family and the product built for that setup." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "global", "label": "Global metaobject list" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    {
      "type": "range",
      "id": "entry_limit",
      "label": "Entry limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "guide",
      "name": "Decision guide entry",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Setup role" },
        { "type": "text", "id": "title", "label": "Title", "default": "Balanced everyday setup" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Best for everyday hybrid desks that need ports, power, and display without a full dock." },
        { "type": "text", "id": "primary_label", "label": "Primary label", "default": "View family" },
        { "type": "url", "id": "primary_url", "label": "Primary link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Compare options" },
        { "type": "url", "id": "secondary_url", "label": "Secondary link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support decision guide",
      "blocks": [{ "type": "guide" }, { "type": "guide" }, { "type": "guide" }]
    }
  ]
}
{% endschema %}
