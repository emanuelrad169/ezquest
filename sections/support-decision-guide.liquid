<section class="section-shell pb-8 lg:pb-12">
  <div class="container-shell">
    {%- liquid
      assign guide_heading = section.settings.heading | default: 'Help me choose the right setup'
      assign guide_copy = section.settings.copy
      assign use_global_entries = false
      assign sorted_guide_keys = '' | split: ''
      if section.settings.structured_source == 'global'
        assign use_global_entries = true
      elsif section.settings.structured_source == 'auto'
        assign use_global_entries = true
      endif
      if use_global_entries and metaobjects.ezquest_decision_guide_entry != blank
        capture sorted_guides_raw
          for guide_entry in metaobjects.ezquest_decision_guide_entry.values
            capture order_token_raw
              echo '000000'
              echo guide_entry.sort_order.value | default: 999999 | plus: 0
            endcapture
            assign order_token = order_token_raw | strip | slice: -6, 6
            echo order_token
            echo '::'
            echo guide_entry.system.handle
            echo '||'
          endfor
        endcapture
        assign sorted_guide_keys = sorted_guides_raw | split: '||' | sort_natural
      endif
    -%}

    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ guide_heading }}</h2>
        {% if guide_copy != blank %}
          <p class="section-copy mt-4">{{ guide_copy }}</p>
        {% endif %}
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    <div class="decision-guide-grid">
      {% if use_global_entries and metaobjects.ezquest_decision_guide_entry != blank %}
        {%- assign rendered_entries = 0 -%}
        {% for guide_key in sorted_guide_keys %}
          {% if guide_key == blank %}
            {% continue %}
          {% endif %}
          {% assign guide_handle = guide_key | split: '::' | last %}
          {% assign guide_entry = metaobjects.ezquest_decision_guide_entry[guide_handle] %}
          {%- liquid
            assign entry_title = guide_entry.title.value
            assign entry_summary = guide_entry.summary.value
            assign entry_role = guide_entry.role_label.value
            assign entry_primary_label = guide_entry.primary_label.value
            assign entry_primary_url = guide_entry.primary_url.value
            assign entry_secondary_label = guide_entry.secondary_label.value
            assign entry_secondary_url = guide_entry.secondary_url.value

            if entry_primary_label == blank
              assign entry_primary_label = 'View setup'
            endif
          -%}
          {% if rendered_entries < section.settings.entry_limit %}
            <article class="info-card decision-guide-card">
              {% if entry_role != blank %}
                <p class="section-kicker">{{ entry_role }}</p>
              {% endif %}
              <h3 class="card-title mt-4">{{ entry_title }}</h3>
              {% if entry_summary != blank %}
                <p class="section-copy mt-3">{{ entry_summary }}</p>
              {% endif %}
              <div class="decision-guide-actions">
                {% if entry_primary_url != blank %}
                  {% render 'button', label: entry_primary_label, url: entry_primary_url, style: 'secondary' %}
                {% endif %}
                {% if entry_secondary_url != blank and entry_secondary_label != blank %}
                  <a href="{{ entry_secondary_url }}" class="site-meta-link">{{ entry_secondary_label }}</a>
                {% endif %}
              </div>
            </article>
            {%- assign rendered_entries = rendered_entries | plus: 1 -%}
          {% endif %}
        {% endfor %}

        {% if rendered_entries == 0 %}
          <article class="info-card structured-empty-state">
            <p class="section-kicker">Decision guide</p>
            <h3 class="mt-4 text-xl font-medium tracking-tight text-slate-900">No decision entries yet</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">Decision entries will appear here when they are added to the EZQuest decision guide metaobjects.</p>
          </article>
        {% endif %}
      {% else %}
        {% for block in section.blocks %}
          <article class="info-card decision-guide-card" {{ block.shopify_attributes }}>
            {% if block.settings.eyebrow != blank %}
              <p class="section-kicker">{{ block.settings.eyebrow }}</p>
            {% endif %}
            <h3 class="card-title mt-4">{{ block.settings.title }}</h3>
            {% if block.settings.copy != blank %}
              <p class="section-copy mt-3">{{ block.settings.copy }}</p>
            {% endif %}
            <div class="decision-guide-actions">
              {% if block.settings.primary_url != blank %}
                {% render 'button', label: block.settings.primary_label, url: block.settings.primary_url, style: 'secondary' %}
              {% endif %}
              {% if block.settings.secondary_url != blank and block.settings.secondary_label != blank %}
                <a href="{{ block.settings.secondary_url }}" class="site-meta-link">{{ block.settings.secondary_label }}</a>
              {% endif %}
            </div>
          </article>
        {% else %}
          <article class="info-card structured-empty-state">
            <p class="section-kicker">Decision guide</p>
            <h3 class="mt-4 text-xl font-medium tracking-tight text-slate-900">No decision entries yet</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">Add decision guide blocks or enable metaobject entries to populate this guide.</p>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support decision guide",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help me choose" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Help me choose the right setup" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Choose the setup role first, then move into the product family and the product built for that setup." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "global", "label": "Global metaobject list" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    {
      "type": "range",
      "id": "entry_limit",
      "label": "Entry limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "guide",
      "name": "Decision guide entry",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Setup role" },
        { "type": "text", "id": "title", "label": "Title", "default": "Balanced everyday setup" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Best for everyday hybrid desks that need ports, power, and display without a full dock." },
        { "type": "text", "id": "primary_label", "label": "Primary label", "default": "View family" },
        { "type": "url", "id": "primary_url", "label": "Primary link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Compare options" },
        { "type": "url", "id": "secondary_url", "label": "Secondary link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support decision guide",
      "blocks": [{ "type": "guide" }, { "type": "guide" }, { "type": "guide" }]
    }
  ]
}
{% endschema %}
