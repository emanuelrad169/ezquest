<section class="section-shell surface-muted">
  <div class="container-shell">
    {%- liquid
      assign structured_group = blank
      assign structured_compare_items = blank
      assign has_structured_compare = false

      if section.settings.structured_source == 'group_handle' and section.settings.comparison_group_handle != blank
        assign structured_group = metaobjects.ezquest_comparison_group[section.settings.comparison_group_handle]
      elsif section.settings.structured_source != 'blocks' and product != blank and product.metafields.ezquest.compare_group != blank
        assign structured_group = product.metafields.ezquest.compare_group.value
      elsif section.settings.structured_source == 'auto' and section.settings.comparison_group_handle != blank
        assign structured_group = metaobjects.ezquest_comparison_group[section.settings.comparison_group_handle]
      endif

      assign section_heading = section.settings.heading | default: 'Comparison'
      assign section_copy = section.settings.copy | default: 'Reserved for compatibility or product comparison structures.'
      assign section_eyebrow = section.settings.eyebrow
      assign source_note = section.settings.source_note
      assign structured_link_label = section.settings.structured_link_label | default: 'View product'

      if structured_group != blank
        if structured_group.products != blank and structured_group.products.value.count > 0
          assign structured_compare_items = structured_group.products.value
          assign has_structured_compare = true
        endif
        if structured_group.eyebrow != blank and structured_group.eyebrow.value != blank
          assign section_eyebrow = structured_group.eyebrow.value
        endif
        if structured_group.heading != blank and structured_group.heading.value != blank
          assign section_heading = structured_group.heading.value
        endif
        if structured_group.description != blank and structured_group.description.value != blank
          assign section_copy = structured_group.description.value
        endif
        if structured_group.support_note != blank and structured_group.support_note.value != blank
          assign source_note = structured_group.support_note.value
        endif
        if structured_group.cta_label != blank and structured_group.cta_label.value != blank
          assign structured_link_label = structured_group.cta_label.value
        endif
      endif
    -%}

    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section_eyebrow != blank %}
          <p class="section-kicker">{{ section_eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="product-meta-pill">Decision support</span>
          <span class="product-meta-pill">Structured-ready</span>
        </div>
      </div>
      {% if source_note != blank %}
        <div class="section-intro-action lg:max-w-md">
          <div class="shell-note">
            {{ source_note }}
          </div>
        </div>
      {% elsif section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    {%- liquid
      assign grid_class = 'xl:grid-cols-3'
      if section.settings.columns_desktop == 2
        assign grid_class = 'xl:grid-cols-2'
      elsif section.settings.columns_desktop == 4
        assign grid_class = 'xl:grid-cols-4'
      endif
    -%}

    <div class="mt-10 grid gap-6 md:grid-cols-2 {{ grid_class }}">
      {% if has_structured_compare %}
        {% for compare_product in structured_compare_items %}
          {%- liquid
            assign compare_support_summary = compare_product.metafields.ezquest.support_summary
            assign compare_compatibility_summary = compare_product.metafields.ezquest.compatibility_summary
          -%}
          <article class="compare-card text-sm text-slate-600">
            {% if compare_product.featured_image != blank %}
              {{ compare_product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'aspect-[4/3] w-full rounded-[1.4rem] bg-slate-50 object-cover' }}
            {% else %}
              <div class="hero-media-frame aspect-[4/3]"></div>
            {% endif %}

            <div class="mt-5 flex items-center justify-between gap-4">
              {% if compare_product.vendor != blank %}
                <p class="section-kicker">{{ compare_product.vendor }}</p>
              {% endif %}
              {% if compare_product.type != blank %}
                <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{{ compare_product.type }}</span>
              {% endif %}
            </div>

            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">{{ compare_product.title }}</h3>

            {% if compare_support_summary != blank %}
              <div class="richtext-content mt-3">{{ compare_support_summary | metafield_tag }}</div>
            {% elsif compare_compatibility_summary != blank %}
              <div class="richtext-content mt-3">{{ compare_compatibility_summary | metafield_tag }}</div>
            {% elsif compare_product.description != blank %}
              <p class="mt-3 leading-7">{{ compare_product.description | strip_html | truncatewords: 24 }}</p>
            {% endif %}

            <div class="mt-5 border-t border-slate-200 pt-5">
              {% render 'price', product: compare_product %}
            </div>

            <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-5">
              <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Compare product fit, support, and pricing</p>
              {% render 'button', label: structured_link_label, url: compare_product.url, style: 'secondary' %}
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          {% render 'compare-cell', block: block %}
        {% else %}
          {% for i in (1..3) %}
            <article class="compare-card text-sm text-slate-600">
              <div class="hero-media-frame aspect-[4/3]"></div>
              <p class="section-kicker mt-5">Compare item</p>
              <h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.empty_state_heading }}</h3>
              <p class="mt-3 leading-7">{{ section.settings.empty_state_copy }}</p>
            </article>
          {% endfor %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product compare table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Comparison" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for compatibility or product comparison structures." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "group_handle", "label": "Comparison group handle" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    { "type": "text", "id": "comparison_group_handle", "label": "Comparison group handle" },
    { "type": "textarea", "id": "source_note", "label": "Source note" },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" },
    { "type": "text", "id": "structured_link_label", "label": "Structured card link label", "default": "View product" },
    { "type": "text", "id": "empty_state_heading", "label": "Empty-state heading", "default": "Comparison item" },
    { "type": "textarea", "id": "empty_state_copy", "label": "Empty-state copy", "default": "Add compare blocks in the theme editor to preview this module with structured content." }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Compare column",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare item" },
        { "type": "text", "id": "title", "label": "Title", "default": "Comparison item" },
        { "type": "textarea", "id": "copy", "label": "Content", "default": "Comparison cell" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View product" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product compare table",
      "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}
