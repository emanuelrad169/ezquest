<section class="section-shell bg-slate-50">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Comparison'
      assign section_copy = section.settings.copy | default: 'Reserved for compatibility or product comparison structures.'
    -%}
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
      </div>
      {% if section.settings.source_note != blank %}
        <div class="section-intro-action lg:max-w-md">
          <p class="text-sm leading-6 text-slate-500">{{ section.settings.source_note }}</p>
        </div>
      {% elsif section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>
    {%- liquid
      assign grid_class = 'xl:grid-cols-3'
      if section.settings.columns_desktop == 2
        assign grid_class = 'xl:grid-cols-2'
      elsif section.settings.columns_desktop == 4
        assign grid_class = 'xl:grid-cols-4'
      endif
    -%}
    <div class="mt-10 grid gap-6 md:grid-cols-2 {{ grid_class }}">
      {% for block in section.blocks %}
        {% render 'compare-cell', block: block %}
      {% else %}
        {% for i in (1..3) %}
          <article class="feature-card text-sm text-slate-600">
            <div class="aspect-[4/3] w-full rounded-2xl bg-slate-100"></div>
            <p class="section-kicker mt-5">Compare item</p>
            <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">{{ section.settings.empty_state_heading }}</h3>
            <p class="mt-3 leading-6">{{ section.settings.empty_state_copy }}</p>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product compare table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Comparison" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for compatibility or product comparison structures." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    { "type": "textarea", "id": "source_note", "label": "Source note" },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" },
    { "type": "text", "id": "empty_state_heading", "label": "Empty-state heading", "default": "Comparison item" },
    { "type": "textarea", "id": "empty_state_copy", "label": "Empty-state copy", "default": "Add compare blocks in the theme editor to preview this module with structured content." }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Compare column",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare item" },
        { "type": "text", "id": "title", "label": "Title", "default": "Comparison item" },
        { "type": "textarea", "id": "copy", "label": "Content", "default": "Comparison cell" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View product" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product compare table",
      "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}
