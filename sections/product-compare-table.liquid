<section class="section-shell surface-muted">
  <div class="container-shell">
    {%- liquid
      assign structured_group = blank
      assign structured_compare_items = blank
      assign has_structured_compare = false
      assign current_product_id = blank
      assign compare_page_context = false

      if product != blank
        assign current_product_id = product.id
      endif

      if request.page_type == 'page' and page != blank and page.handle == 'compare'
        assign compare_page_context = true
      endif

      if section.settings.structured_source == 'group_handle' and section.settings.comparison_group_handle != blank
        assign structured_group = metaobjects.ezquest_comparison_group[section.settings.comparison_group_handle]
      elsif section.settings.structured_source != 'blocks' and product != blank and product.metafields.ezquest.compare_group != blank
        assign structured_group = product.metafields.ezquest.compare_group.value
      elsif section.settings.structured_source == 'auto' and section.settings.comparison_group_handle != blank
        assign structured_group = metaobjects.ezquest_comparison_group[section.settings.comparison_group_handle]
      endif

      assign section_heading = section.settings.heading | default: 'Compare the right product'
      assign section_copy = section.settings.copy | default: 'See how this product compares by setup role, desk footprint, and the kind of work it serves best.'
      assign section_eyebrow = section.settings.eyebrow
      assign product_compare_note = 'Compare nearby options only when the current product still feels close to one other role.'
      assign compare_page_note = 'Start with the role first. Then open the product page that matches it. Compatibility and support are here only for a final confirmation.'
      assign compare_group_param = 'source=compare&group=usb-c-workspace-connectivity-lineup'

      if structured_group != blank
        if structured_group.products != blank and structured_group.products.value.count > 0
          assign structured_compare_items = structured_group.products.value
          assign has_structured_compare = true
        endif
        if structured_group.eyebrow != blank and structured_group.eyebrow.value != blank
          assign section_eyebrow = structured_group.eyebrow.value
        endif
        if structured_group.heading != blank and structured_group.heading.value != blank
          assign section_heading = structured_group.heading.value
        endif
        if structured_group.description != blank and structured_group.description.value != blank
          assign section_copy = structured_group.description.value
        endif
      endif

      if product != blank and compare_page_context == false
        case product.handle
          when 'usb-c-travel-hub'
            assign section_heading = 'Compare the travel-first product with broader EZQuest options'
            assign section_copy = 'See whether the lighter mobile setup is the right call, or if a more balanced or desk-ready option fits better.'
            assign product_compare_note = 'Use compare only if portability leads, but you still want to confirm displays, power, or a more permanent desk role.'
          when 'usb-c-pro-dock'
            assign section_heading = 'Compare the desk-first product with lighter EZQuest options'
            assign section_copy = 'See whether the workflow really needs a fuller dock, or if a more balanced everyday or portable option fits better.'
            assign product_compare_note = 'Use compare only if the desk is the center of the workflow, but you want to confirm that a full dock is worth it.'
          when 'usb-c-multimedia-hub'
            assign section_heading = 'Compare this balanced everyday product with travel and desk-ready options'
            assign section_copy = 'See whether this all-around hub covers the daily desk, or if the workflow needs something lighter or more permanent.'
            assign product_compare_note = 'Use compare only if one compact hub feels close, but you still need to choose between lighter travel and fuller desk setups.'
        endcase
      elsif compare_page_context
        assign compare_page_note = 'Start with the role that matches the setup, then move into compatibility or support only when you want a final confirmation.'
      endif
    -%}

    <div class="section-intro product-compare-intro">
      <div class="max-w-3xl product-compare-intro-copy">
        {% if section_eyebrow != blank %}
          <p class="section-kicker">{{ section_eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        {% if compare_page_context and section.settings.source_note != blank %}
          <div class="support-utility-note mt-6">{{ section.settings.source_note }}</div>
          <p class="product-compare-note">{{ compare_page_note }}</p>
        {% elsif compare_page_context == false %}
          <p class="product-compare-note">{{ product_compare_note }}</p>
        {% endif %}
      </div>
      <div class="section-intro-action">
        {% if compare_page_context %}
          <div class="compare-intro-actions">
            <a href="/pages/compatibility?{{ compare_group_param }}" class="site-meta-link">Check compatibility</a>
            <a href="/pages/support?{{ compare_group_param }}" class="site-meta-link">Open support center</a>
          </div>
        {% else %}
          <a href="/pages/compare?product={{ product.handle }}" class="site-meta-link">Compare nearby fits</a>
        {% endif %}
      </div>
    </div>

    {%- liquid
      assign grid_class = 'xl:grid-cols-3'
      if section.settings.columns_desktop == 2
        assign grid_class = 'xl:grid-cols-2'
      elsif section.settings.columns_desktop == 4
        assign grid_class = 'xl:grid-cols-4'
      endif
    -%}

    <div class="compare-grid-shell {{ grid_class }}">
      {% if has_structured_compare %}
        {% for compare_product in structured_compare_items %}
          {%- liquid
            assign compare_highlights = compare_product.metafields.ezquest.feature_highlights.value
            assign is_primary_product = false
            assign compare_context_label = 'Alternative'
            assign compare_recommendation_label = 'Compare option'
            assign compare_positioning = 'A premium EZQuest option for Apple, PC, and mobile workflows.'
            assign compare_best_for = 'Choose this when you want one clear everyday setup.'
            assign compare_variant_class = 'compare-card--balanced'
            assign compare_handoff_label = 'Go deeper into this product'
            assign compare_support_label = 'Check compatibility'
            assign compare_support_url = '/pages/compatibility'
            assign compare_context_note = 'Use support only if one last buying detail still needs confirmation.'

            if current_product_id != blank and compare_product.id == current_product_id
              assign is_primary_product = true
              assign compare_context_label = 'Current product'
            endif

            if compare_product.handle contains 'travel'
              assign compare_recommendation_label = 'Most portable'
              assign compare_positioning = 'Built for lighter mobile setups, hotel desks, classroom work, and everyday carry.'
              assign compare_best_for = 'Choose this when the setup moves often and portability leads.'
              assign compare_variant_class = 'compare-card--portable'
              assign compare_handoff_label = 'See the travel-first product page'
              assign compare_support_label = 'Check travel compatibility'
              assign compare_context_note = 'Step up only if the desk needs more ports, more power, or a steadier display chain.'
            elsif compare_product.handle contains 'multimedia'
              assign compare_recommendation_label = 'Most balanced'
              assign compare_positioning = 'The strongest all-around choice for hybrid desks that still need HDMI, charging, Ethernet, and accessory access.'
              assign compare_best_for = 'Choose this when one compact hub should cover the everyday desk.'
              assign compare_variant_class = 'compare-card--balanced'
              assign compare_handoff_label = 'See the balanced everyday product page'
              assign compare_support_label = 'Check everyday compatibility'
              assign compare_context_note = 'Go lighter only if portability wins. Step up only if the desk needs a fuller dock.'
            elsif compare_product.handle contains 'pro-dock' or compare_product.type contains 'Dock'
              assign compare_recommendation_label = 'Most desk-ready'
              assign compare_positioning = 'Made for more permanent setups with broader connectivity, more peripherals, and a clearer workstation role.'
              assign compare_best_for = 'Choose this when the desk stays put and the workflow needs a fuller connection hub.'
              assign compare_variant_class = 'compare-card--desk'
              assign compare_handoff_label = 'See the desk-first product page'
              assign compare_support_label = 'Check workstation compatibility'
              assign compare_context_note = 'Go lighter only if portability matters more than a permanent workstation setup.'
            endif

            if compare_product.handle != blank
              assign compare_support_url = compare_support_url | append: '?product=' | append: compare_product.handle
            endif

            if compare_page_context and compare_product.handle contains 'multimedia'
              assign is_primary_product = true
            endif
          -%}
          <article class="compare-card {{ compare_variant_class }}{% if is_primary_product %} compare-card-primary{% endif %}">
            <div class="compare-card-label-row">
              <p class="section-kicker">{{ compare_context_label }}</p>
              {% if compare_product.type != blank %}
                <span class="compare-card-type">{{ compare_product.type }}</span>
              {% endif %}
            </div>
            <div class="compare-card-recommendation-row">
              <p class="compare-card-recommendation">{{ compare_recommendation_label }}</p>
              <p class="compare-card-best-for">{{ compare_best_for }}</p>
            </div>
            {% render 'card-product', product: compare_product, card_style: 'featured-strip', card_context: 'compare', card_index: forloop.index0, image_variant: 'compare' %}
            <p class="compare-card-positioning">{{ compare_positioning }}</p>
            {% if compare_highlights != blank and compare_highlights.count > 1 %}
              <div class="compare-signal-list">
                <span class="compare-signal">{{ compare_highlights.first }}</span>
                <span class="compare-signal">{{ compare_highlights[1] }}</span>
              </div>
            {% endif %}
            <p class="compare-context-note">{{ compare_context_note }}</p>
            <div class="compare-card-links">
              <a href="{{ compare_product.url }}" class="site-meta-link">{{ compare_handoff_label }}</a>
              <a href="{{ compare_support_url }}" class="site-meta-link">{{ compare_support_label }}</a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for block in section.blocks %}
          {% render 'compare-cell', block: block %}
        {% else %}
          <article class="compare-card structured-empty-state text-sm text-slate-600 xl:col-span-full">
            <p class="section-kicker">Compare</p>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">{{ section.settings.empty_state_heading }}</h3>
            <p class="mt-3 leading-7">{{ section.settings.empty_state_copy }}</p>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product compare table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Compare nearby options" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Compare nearby products by setup role, support priority, and the kind of workflow each one serves best." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "group_handle", "label": "Comparison group handle" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    { "type": "text", "id": "comparison_group_handle", "label": "Comparison group handle" },
    { "type": "textarea", "id": "source_note", "label": "Source note" },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" },
    { "type": "text", "id": "structured_link_label", "label": "Structured card link label", "default": "View product" },
    { "type": "text", "id": "empty_state_heading", "label": "Empty-state heading", "default": "EZQuest option" },
    { "type": "textarea", "id": "empty_state_copy", "label": "Empty-state copy", "default": "Compare nearby options by setup style, power profile, and support fit so the right choice becomes clearer faster." }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Compare column",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare" },
        { "type": "text", "id": "title", "label": "Title", "default": "EZQuest option" },
        { "type": "textarea", "id": "copy", "label": "Content", "default": "Explain which setup, desk, or travel workflow this option fits best." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View product" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product compare table",
      "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }]
    }
  ]
}
{% endschema %}
