{%- comment -%}
  Dynamic product comparison.
  Shoppers add products via "Compare" buttons across the site (stored in
  localStorage by compare.js). This section emits a JSON catalog of comparable
  products (with spec metafields) plus render targets; compare.js builds the
  table client-side from the shopper's selection. Liquid can't read the selection
  (localStorage / ?ids), so the catalog is rendered server-side and filtered on
  the client.
{%- endcomment -%}

{{ 'pdp.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign source_handles = 'hubs-adapters,chargers-power,accessories,usb-c-enclosures,usb-c-card-readers,docking-stations' | split: ','
  assign seen = '|'
-%}

<section class="compare-shell section-shell" data-compare-root aria-label="{{ section.settings.heading | default: 'Compare products' | escape }}">
  <div class="container-shell">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading compare-shell__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="section-copy compare-shell__body">{{ section.settings.body | escape }}</p>
    {%- endif -%}

    <div class="compare-shell__bar" data-compare-bar hidden>
      <p class="compare-shell__count" data-compare-page-count aria-live="polite"></p>
      <div class="compare-shell__actions">
        <button type="button" class="compare-shell__btn compare-shell__btn--ghost" data-compare-clear>Clear all</button>
        <button type="button" class="compare-shell__btn" data-compare-share>Share comparison</button>
      </div>
    </div>
    <p class="compare-share__status" data-compare-share-status aria-live="polite"></p>

    <div class="compare-shell__empty" data-compare-empty hidden>
      <p class="compare-shell__empty-title">No products selected yet</p>
      <p class="compare-shell__empty-copy">Browse the catalog and tap <strong>Compare</strong> on any product to line them up side by side.</p>
      <a href="{{ routes.all_products_collection_url }}" class="compare-shell__btn">Shop products</a>
    </div>

    <div class="compare-dyn" data-compare-render></div>
  </div>

  <script type="application/json" data-compare-catalog>
  [
  {%- assign first = true -%}
  {%- for ch in source_handles -%}
    {%- assign col = collections[ch] -%}
    {%- for p in col.products -%}
      {%- assign key = '|' | append: p.handle | append: '|' -%}
      {%- unless seen contains key -%}
        {%- assign seen = seen | append: p.handle | append: '|' -%}
        {%- unless first %},{% endunless -%}{%- assign first = false -%}
        {"h":{{ p.handle | json }},"t":{{ p.title | json }},"u":{{ p.url | json }},"img":{{ p.featured_image | image_url: width: 320 | json }},"price":{{ p.price | money | strip_html | json }},"type":{{ p.type | default: '' | json }},"kf":{{ p.metafields.custom.key_features.value | json }},"specs":{{ p.metafields.custom.product_specifications.value | default: '' | json }}}
      {%- endunless -%}
    {%- endfor -%}
  {%- endfor -%}
  ]
  </script>
</section>

{% schema %}
{
  "name": "Product compare",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Compare products" },
    { "type": "textarea", "id": "body", "label": "Sub-copy", "default": "Add products from anywhere on the site to compare them side by side." }
  ],
  "presets": [ { "name": "Product compare" } ]
}
{% endschema %}
