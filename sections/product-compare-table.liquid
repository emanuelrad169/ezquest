{% liquid
  assign product_blocks = section.blocks | where: 'type', 'product'
  assign spec_blocks = section.blocks | where: 'type', 'spec'
  assign col_count = product_blocks.size
%}

<section class="compare-page" aria-label="{{ section.settings.heading | escape }}">
  <div class="compare-page__header">
    {% if section.settings.kicker != blank %}
      <p class="section-kicker">{{ section.settings.kicker | escape }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="compare-page__heading">{{ section.settings.heading | escape }}</h1>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="compare-page__body">{{ section.settings.body | escape }}</p>
    {% endif %}
  </div>

  {% if col_count == 0 %}
    <div class="compare-empty-state">
      <p>Add products in the theme customizer to compare them.</p>
    </div>
  {% else %}
    <div class="compare-scroll-wrap">
      <div class="compare-table" style="--col-count: {{ col_count }}">
        <div class="compare-row compare-row--header">
          <div class="compare-label-cell compare-label-cell--header"></div>

          {% for block in product_blocks %}
            {% liquid
              assign p = block.settings.product
            %}

            <div
              class="compare-product-cell{% if block.settings.is_recommended %} compare-product-cell--recommended{% endif %}"
              {{ block.shopify_attributes }}
            >
              {% if p != blank %}
                {% if block.settings.is_recommended %}
                  <span class="compare-recommended-badge">Recommended</span>
                {% endif %}

                {% if p.featured_image != blank %}
                  <img
                    src="{{ p.featured_image | image_url: width: 200 }}"
                    alt="{{ p.title | escape }}"
                    class="compare-product-cell__img"
                    width="120"
                    height="120"
                    loading="lazy"
                  >
                {% else %}
                  <div class="compare-product-cell__img compare-product-cell__img--empty" aria-hidden="true"></div>
                {% endif %}

                <h2 class="compare-product-cell__title">{{ p.title | escape }}</h2>
                <p class="compare-product-cell__price">{{ p.price | money }}</p>
                <a href="{{ p.url | escape }}" class="compare-product-cell__link">
                  View product &rarr;
                </a>
              {% else %}
                <p class="compare-empty-product">Select a product in theme customizer</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>

        {% for spec in spec_blocks %}
          <div
            class="compare-row {% cycle 'compare-row--odd', 'compare-row--even' %}"
            {{ spec.shopify_attributes }}
          >
            <div class="compare-label-cell">
              {{ spec.settings.label | escape }}
            </div>

            {% for product_block in product_blocks %}
              {% liquid
                assign col_index = forloop.index
                assign value_key = 'value_' | append: col_index
                assign val = spec.settings[value_key]
              %}

              <div class="compare-spec-cell">
                {% if val != blank %}
                  {{ val | escape }}
                {% else %}
                  <span class="compare-spec-empty" aria-label="Not available">&mdash;</span>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</section>

<style>
  #shopify-section-{{ section.id }} .compare-page {
    max-width: 100rem;
    margin: 0 auto;
    padding: clamp(44px, 5vw, 64px) 1.25rem;
  }

  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .compare-page {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .compare-page {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  #shopify-section-{{ section.id }} .compare-page__header {
    max-width: 640px;
    margin: 0 auto clamp(2.5rem, 4vw, 4rem);
    text-align: center;
  }

  #shopify-section-{{ section.id }} .compare-page__heading {
    margin: 0;
    color: #1d1d1f;
    font-size: clamp(30px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .compare-page__body {
    max-width: 54ch;
    margin: 1rem auto 0;
    color: #6e6e73;
    font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .compare-scroll-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.15) transparent;
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 18px;
    background: #fff;
  }

  #shopify-section-{{ section.id }} .compare-table {
    position: relative;
    display: grid;
    grid-template-columns: 180px repeat(var(--col-count, 3), minmax(220px, 1fr));
    width: 100%;
    min-width: calc(180px + (var(--col-count, 3) * 220px));
  }

  #shopify-section-{{ section.id }} .compare-row {
    display: contents;
  }

  #shopify-section-{{ section.id }} .compare-row--header > .compare-label-cell,
  #shopify-section-{{ section.id }} .compare-row--header > .compare-product-cell {
    position: sticky;
    top: 0;
    z-index: 3;
  }

  #shopify-section-{{ section.id }} .compare-label-cell {
    position: sticky;
    left: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    padding: 1rem 1.25rem;
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    color: #6e6e73;
    background: #f5f5f7;
    font-size: 13px;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .compare-label-cell--header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    z-index: 4;
  }

  #shopify-section-{{ section.id }} .compare-product-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    padding: 1.5rem 1.25rem;
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.07);
    background: #fff;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .compare-product-cell--recommended {
    box-shadow: inset 0 0 0 2px rgba(245, 158, 11, 0.35);
  }

  #shopify-section-{{ section.id }} .compare-product-cell__img {
    width: 120px;
    height: 120px;
    padding: 8px;
    border-radius: 12px;
    background: #f5f5f7;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .compare-product-cell__img--empty {
    display: block;
  }

  #shopify-section-{{ section.id }} .compare-product-cell__title {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: #1d1d1f;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .compare-product-cell__price {
    margin: 0;
    color: #FBCE2A;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .compare-recommended-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 3px 8px;
    border-radius: 100px;
    background: #FBCE2A;
    color: #412402;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .compare-product-cell__link {
    margin-top: auto;
    color: #FBCE2A;
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .compare-product-cell__link:hover {
    color: #d97706;
  }

  #shopify-section-{{ section.id }} .compare-spec-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    color: #1d1d1f;
    font-size: 14px;
    line-height: 1.45;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .compare-row--odd .compare-spec-cell,
  #shopify-section-{{ section.id }} .compare-row--odd .compare-label-cell {
    background: #fff;
  }

  #shopify-section-{{ section.id }} .compare-row--even .compare-spec-cell,
  #shopify-section-{{ section.id }} .compare-row--even .compare-label-cell {
    background: #fafafa;
  }

  #shopify-section-{{ section.id }} .compare-spec-empty {
    color: #6e6e73;
    font-size: 16px;
  }

  #shopify-section-{{ section.id }} .compare-empty-state {
    grid-column: 1 / -1;
    padding: 3rem;
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 18px;
    color: #6e6e73;
    background: #f5f5f7;
    font-size: 15px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .compare-empty-state p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .compare-empty-product {
    margin: auto 0;
    padding: 1rem 0;
    color: #6e6e73;
    font-size: 12px;
    text-align: center;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .compare-page {
      padding-top: clamp(36px, 10vw, 56px);
      padding-bottom: clamp(36px, 10vw, 56px);
    }

    #shopify-section-{{ section.id }} .compare-table {
      grid-template-columns: 120px repeat(var(--col-count, 3), minmax(180px, 1fr));
      min-width: calc(120px + (var(--col-count, 3) * 180px));
    }

    #shopify-section-{{ section.id }} .compare-label-cell {
      min-width: 120px;
      padding: 0.75rem;
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .compare-product-cell {
      padding: 1.25rem 0.75rem;
    }

    #shopify-section-{{ section.id }} .compare-product-cell__img {
      width: 80px;
      height: 80px;
    }

    #shopify-section-{{ section.id }} .compare-product-cell__price {
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .compare-recommended-badge {
      position: static;
      order: -1;
    }
  }
</style>

{% schema %}
{
  "name": "Product comparison",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Compare models"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find the right EZQuest for your setup"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product column",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "is_recommended",
          "label": "Show as recommended",
          "default": false
        }
      ]
    },
    {
      "type": "spec",
      "name": "Spec row",
      "limit": 20,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "placeholder": "e.g. USB-C Ports"
        },
        {
          "type": "text",
          "id": "value_1",
          "label": "Value — column 1"
        },
        {
          "type": "text",
          "id": "value_2",
          "label": "Value — column 2"
        },
        {
          "type": "text",
          "id": "value_3",
          "label": "Value — column 3"
        },
        {
          "type": "text",
          "id": "value_4",
          "label": "Value — column 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product comparison",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "spec",
          "settings": {
            "label": "Ports"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Display output"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Power delivery"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Compatibility"
          }
        },
        {
          "type": "spec",
          "settings": {
            "label": "Warranty"
          }
        }
      ]
    }
  ]
}
{% endschema %}
