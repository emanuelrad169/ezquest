{%- liquid
  assign structured_group = blank
  assign compare_products = blank
  assign compare_page_context = false
  assign section_heading = section.settings.heading | default: 'Compare products'
  assign section_copy = section.settings.copy
  assign section_note = ''
  assign group_use_case = ''
  assign group_handle = section.settings.comparison_group_handle | default: ''

  if request.page_type == 'page' and page != blank and page.handle == 'compare'
    assign compare_page_context = true
  endif

  if section.settings.structured_source == 'group_handle' and section.settings.comparison_group_handle != blank
    assign structured_group = metaobjects.ezquest_comparison_group[section.settings.comparison_group_handle]
  elsif section.settings.structured_source != 'blocks' and product != blank and product.metafields.ezquest.compare_group != blank
    assign structured_group = product.metafields.ezquest.compare_group.value
  endif

  if structured_group != blank
    if structured_group.slug != blank and structured_group.slug.value != blank
      assign group_handle = structured_group.slug.value
    elsif structured_group.handle != blank
      assign group_handle = structured_group.handle
    endif

    if structured_group.heading != blank and structured_group.heading.value != blank
      assign section_heading = structured_group.heading.value
    elsif structured_group.title != blank and structured_group.title.value != blank
      assign section_heading = structured_group.title.value
    endif

    if structured_group.description != blank and structured_group.description.value != blank
      assign section_copy = structured_group.description.value
    endif

    if structured_group.support_note != blank and structured_group.support_note.value != blank
      assign section_note = structured_group.support_note.value
    endif

    if structured_group.use_case != blank and structured_group.use_case.value != blank
      assign group_use_case = structured_group.use_case.value
    elsif structured_group.group_type != blank and structured_group.group_type.value != blank
      assign group_use_case = structured_group.group_type.value
    endif

    if structured_group.default_products != blank and structured_group.default_products.value.count > 0
      assign compare_products = structured_group.default_products.value
    elsif structured_group.products != blank and structured_group.products.value.count > 0
      assign compare_products = structured_group.products.value
    endif
  endif

  assign compare_handles_raw = ''
  if compare_products != blank
    for compare_product in compare_products limit: 4
      if compare_product != blank
        if compare_handles_raw != ''
          assign compare_handles_raw = compare_handles_raw | append: '|'
        endif
        assign compare_handles_raw = compare_handles_raw | append: compare_product.handle
      endif
    endfor
  endif

  assign compare_count = 0
  assign compare_handles = blank
  if compare_handles_raw != ''
    assign compare_handles = compare_handles_raw | split: '|'
    assign compare_count = compare_handles.size
  endif

  assign recommended_handle = blank
  assign recommended_priority = 9999
  if compare_count > 0
    for compare_handle in compare_handles
      assign compare_product = all_products[compare_handle]
      if compare_product != blank
        assign current_priority = compare_product.metafields.ezquest.recommended_priority.value | default: compare_product.metafields.ezquest.recommended_priority | default: 9999 | plus: 0
        if recommended_handle == blank or current_priority < recommended_priority
          assign recommended_handle = compare_handle
          assign recommended_priority = current_priority
        endif
      endif
    endfor
  endif

  if recommended_handle == blank and compare_count > 0
    assign recommended_handle = compare_handles[0]
  endif

  assign ordered_handles_raw = ''
  if recommended_handle != blank
    assign ordered_handles_raw = recommended_handle
  endif
  if compare_count > 0
    for compare_handle in compare_handles
      unless compare_handle == recommended_handle
        if ordered_handles_raw != ''
          assign ordered_handles_raw = ordered_handles_raw | append: '|'
        endif
        assign ordered_handles_raw = ordered_handles_raw | append: compare_handle
      endunless
    endfor
  endif

  assign ordered_handles = blank
  if ordered_handles_raw != ''
    assign ordered_handles = ordered_handles_raw | split: '|'
  endif

  assign compare_group_is_charger = false
  if group_use_case != blank
    assign group_use_case_downcase = group_use_case | downcase
    if group_use_case_downcase contains 'charg'
      assign compare_group_is_charger = true
    endif
  endif
  if compare_group_is_charger == false and ordered_handles != blank
    for compare_handle in ordered_handles
      assign compare_product = all_products[compare_handle]
      if compare_product != blank and compare_product.type != blank
        assign compare_product_type_downcase = compare_product.type | downcase
        if compare_product_type_downcase contains 'charger'
          assign compare_group_is_charger = true
          break
        endif
      endif
    endfor
  endif

  capture compare_group_query
    echo '?source=compare'
    if group_handle != blank
      echo '&group='
      echo group_handle
    endif
  endcapture

  assign support_url = '/pages/support' | append: compare_group_query
  assign compatibility_url = '/pages/compatibility' | append: compare_group_query
  assign recommended_product = blank
  if recommended_handle != blank
    assign recommended_product = all_products[recommended_handle]
  endif
-%}

<section class="compare-page-section section-shell" data-compare-count="{{ compare_count }}">
  <div class="compare-page-inner">
    <div class="compare-page-title-block">
      {% if group_use_case != blank %}
        <p class="section-kicker">{{ group_use_case }}</p>
      {% endif %}
      <h1 class="compare-page-title">{{ section_heading }}</h1>
      {% if compare_page_context and section_copy != blank %}
        <p class="compare-page-subtitle">{{ section_copy }}</p>
      {% elsif compare_page_context == false and section_copy != blank %}
        <p class="compare-page-subtitle">{{ section_copy }}</p>
      {% endif %}
    </div>

    {% if compare_count > 0 and ordered_handles != blank %}
      <div class="compare-intent-bar">
        <div>
          <p class="compare-intent-title">One recommended option, with the key tradeoffs in view.</p>
          <p class="compare-intent-copy">See where each product stands on portability, power, ports, and desk use before you open a PDP.</p>
        </div>
        {% if section_note != blank %}
          <p class="compare-intent-note">{{ section_note }}</p>
        {% endif %}
      </div>

      {% if recommended_product != blank %}
        <div class="mt-6 grid gap-4 lg:grid-cols-2 lg:items-stretch">
          <div class="overflow-hidden rounded-card-md border border-slate-200 bg-slate-50 p-4 shadow-soft">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="section-kicker">Lineup</p>
                <h2 class="card-title mt-3">See the products side by side</h2>
              </div>
              <a href="{{ recommended_product.url | append: compare_group_query }}" class="site-meta-link">Open recommended product</a>
            </div>
            <div class="compare-lineup-scene mt-5">
              {% for compare_handle in ordered_handles %}
                {% assign compare_product = all_products[compare_handle] %}
                {% if compare_product != blank %}
                  <div class="compare-lineup-product{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
                    {% render 'product-browse-media',
                      product: compare_product,
                      context: 'compare',
                      variant: 'compare',
                      width: 480,
                      height: 480,
                      class: 'compare-lineup-image'
                    %}
                    <p class="compare-lineup-title">{{ compare_product.title }}</p>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>

          <div class="overflow-hidden rounded-card-md border border-slate-200 bg-white p-4 shadow-soft">
            <p class="section-kicker">Recommended view</p>
            <h2 class="card-title mt-3">{{ recommended_product.title }}</h2>
            <div class="compare-recommended-scene mt-5">
              {% render 'product-browse-media',
                product: recommended_product,
                context: 'compare',
                variant: 'setup',
                width: 900,
                height: 675,
                class: 'compare-recommended-image'
              %}
            </div>
            {% assign recommended_summary = recommended_product.metafields.ezquest.compare_short_reason.value | default: recommended_product.metafields.ezquest.compare_short_reason | strip %}
            {% if recommended_summary == blank and recommended_product.metafields.ezquest.support_summary != blank %}
              {% assign recommended_summary = recommended_product.metafields.ezquest.support_summary | metafield_tag | strip_html | strip %}
            {% endif %}
            {% if recommended_summary != blank %}
              <p class="mt-4 text-sm leading-7 text-slate-600">{{ recommended_summary | truncatewords: 24 }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <div class="compare-choice-grid" data-compare-count="{{ compare_count }}">
        {% for compare_handle in ordered_handles %}
          {% assign compare_product = all_products[compare_handle] %}
          {% if compare_product != blank %}
            {% render 'compare-cell',
              product: compare_product,
              recommended_handle: recommended_handle,
              group_handle: group_handle,
              source_context: 'compare'
            %}
          {% endif %}
        {% endfor %}
      </div>

      <div class="compare-detail-shell" data-compare-count="{{ compare_count }}">
        <div class="compare-detail-head">
          <h2 class="compare-detail-title">Compare the specs that matter</h2>
          <p class="compare-detail-copy">Each row is tied to live product data, compatibility guidance, and product support.</p>
        </div>

        {% assign best_for_has_content = false %}
        {% capture best_for_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.best_for.value | default: compare_product.metafields.ezquest.best_for | strip %}
            {% if cell_value != blank %}
              {% assign best_for_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if best_for_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">Best for</span></div>
            {{ best_for_cells }}
          </div>
        {% endif %}

        {% assign difference_has_content = false %}
        {% capture difference_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compare_short_reason.value | default: compare_product.metafields.ezquest.compare_short_reason | strip %}
            {% if cell_value != blank %}
              {% assign difference_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if difference_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">Key difference</span></div>
            {{ difference_cells }}
          </div>
        {% endif %}

        {% assign role_has_content = false %}
        {% capture role_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compare_role.value | default: compare_product.metafields.ezquest.compare_role | replace: '-', ' ' | strip %}
            {% if cell_value != blank %}
              {% assign role_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value | capitalize }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if role_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">{% if compare_group_is_charger %}Travel vs desk use{% else %}Usage role{% endif %}</span></div>
            {{ role_cells }}
          </div>
        {% endif %}

        {% assign ports_has_content = false %}
        {% capture ports_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = '' %}
            {% for row in compare_product.metafields.ezquest.spec_rows.value %}
              {% assign row_label = row.label.value | downcase %}
              {% if row_label contains 'ports' or row_label contains 'port count' or row_label contains 'data ports' %}
                {% assign cell_value = row.spec_value.value | strip_html | strip %}
                {% break %}
              {% elsif compare_group_is_charger and row_label contains 'output' %}
                {% assign cell_value = row.spec_value.value | strip_html | strip %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if cell_value != blank %}
              {% assign ports_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if ports_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">{% if compare_group_is_charger %}Port configuration{% else %}Port count{% endif %}</span></div>
            {{ ports_cells }}
          </div>
        {% endif %}

        {% assign power_has_content = false %}
        {% capture power_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compare_charging_power.value | default: compare_product.metafields.ezquest.compare_charging_power | strip %}
            {% if cell_value == blank %}
              {% for row in compare_product.metafields.ezquest.spec_rows.value %}
                {% assign row_label = row.label.value | downcase %}
                {% if row_label contains 'power delivery' or row_label contains 'power' or row_label contains 'charging' %}
                  {% assign cell_value = row.spec_value.value | strip_html | strip %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}
            {% if cell_value != blank %}
              {% assign power_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if power_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">{% if compare_group_is_charger %}Power output{% else %}Power delivery{% endif %}</span></div>
            {{ power_cells }}
          </div>
        {% endif %}

        {% assign portability_has_content = false %}
        {% capture portability_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compare_portability.value | default: compare_product.metafields.ezquest.compare_portability | strip %}
            {% if cell_value == blank %}
              {% for row in compare_product.metafields.ezquest.spec_rows.value %}
                {% assign row_label = row.label.value | downcase %}
                {% if row_label contains 'dimension' or row_label contains 'size' or row_label contains 'weight' or row_label contains 'length' %}
                  {% assign cell_value = row.spec_value.value | strip_html | strip %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}
            {% if cell_value != blank %}
              {% assign portability_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if portability_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">{% if compare_group_is_charger %}Size / portability{% else %}Portability{% endif %}</span></div>
            {{ portability_cells }}
          </div>
        {% endif %}

        {% assign form_factor_has_content = false %}
        {% capture form_factor_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compare_form_factor.value | default: compare_product.metafields.ezquest.compare_form_factor | strip %}
            {% if cell_value != blank %}
              {% assign form_factor_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if form_factor_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">{% if compare_group_is_charger %}Form factor{% else %}Cable style{% endif %}</span></div>
            {{ form_factor_cells }}
          </div>
        {% endif %}

        {% assign display_has_content = false %}
        {% capture display_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = '' %}
            {% for row in compare_product.metafields.ezquest.spec_rows.value %}
              {% assign row_label = row.label.value | downcase %}
              {% if row_label contains 'display support' or row_label contains 'video output' or row_label contains 'display' %}
                {% assign cell_value = row.spec_value.value | strip_html | strip %}
                {% break %}
              {% endif %}
            {% endfor %}
            {% if cell_value != blank %}
              {% assign display_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if display_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">Display support</span></div>
            {{ display_cells }}
          </div>
        {% endif %}

        {% assign connector_has_content = false %}
        {% capture connector_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compare_connector_type.value | default: compare_product.metafields.ezquest.compare_connector_type | strip %}
            {% if cell_value == blank %}
              {% for row in compare_product.metafields.ezquest.spec_rows.value %}
                {% assign row_label = row.label.value | downcase %}
                {% if row_label contains 'connector' or row_label contains 'connection type' or row_label contains 'host connection' %}
                  {% assign cell_value = row.spec_value.value | strip_html | strip %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}
            {% if cell_value != blank %}
              {% assign connector_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if connector_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">Connector type</span></div>
            {{ connector_cells }}
          </div>
        {% endif %}

        {% assign compatibility_has_content = false %}
        {% capture compatibility_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign cell_value = compare_product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | strip %}
            {% if cell_value != blank %}
              {% assign compatibility_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if cell_value != blank %}{{ cell_value | truncatewords: 18 }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if compatibility_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">Compatibility</span></div>
            {{ compatibility_cells }}
          </div>
        {% endif %}

        {% assign resources_has_content = false %}
        {% capture resource_cells %}
          {% for compare_handle in ordered_handles %}
            {% assign compare_product = all_products[compare_handle] %}
            {% assign manual_count = compare_product.metafields.ezquest.manuals.value.count | default: 0 %}
            {% assign download_count = compare_product.metafields.ezquest.downloads.value.count | default: 0 %}
            {% capture cell_value %}
              {% if manual_count > 0 %}{{ manual_count }} manual{% if manual_count != 1 %}s{% endif %}{% endif %}
              {% if manual_count > 0 and download_count > 0 %} / {% endif %}
              {% if download_count > 0 %}{{ download_count }} download{% if download_count != 1 %}s{% endif %}{% endif %}
            {% endcapture %}
            {% assign normalized_value = cell_value | strip %}
            {% if normalized_value != blank %}
              {% assign resources_has_content = true %}
            {% endif %}
            <div class="compare-detail-cell{% if compare_handle == recommended_handle %} is-recommended{% endif %}">
              {% if normalized_value != blank %}{{ normalized_value }}{% else %}&mdash;{% endif %}
            </div>
          {% endfor %}
        {% endcapture %}
        {% if resources_has_content %}
          <div class="compare-detail-row">
            <div class="compare-detail-label-cell"><span class="compare-detail-label">Manuals + downloads</span></div>
            {{ resource_cells }}
          </div>
        {% endif %}
      </div>

      <div class="compare-handoff-strip">
        <div class="compare-handoff-copy">
          <h3 class="compare-handoff-title">Keep this lineup in view</h3>
          <p class="compare-handoff-text">Open compatibility or support without losing the products you are comparing.</p>
        </div>
        <div class="compare-handoff-actions">
          {% render 'button', label: 'Check compatibility', url: compatibility_url, style: 'secondary' %}
          {% render 'button', label: 'Open support', url: support_url, style: 'tertiary' %}
        </div>
      </div>
    {% else %}
      <div class="compare-empty-state card-soft">
        <h2 class="compare-empty-state-title">{{ section.settings.empty_state_heading | default: 'Compare lineup coming soon' }}</h2>
        <p class="compare-empty-state-copy">{{ section.settings.empty_state_copy | default: 'Assign a comparison group in Shopify so this section can show the right 2–4 products, recommendation state, and handoff links.' }}</p>
        <a href="/pages/help-me-choose" class="btn btn--primary mt-6 inline-flex">Help me choose instead</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product compare table",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Compare products" },
    { "type": "textarea", "id": "copy", "label": "Subtitle copy" },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "group_handle", "label": "Comparison group handle" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    { "type": "text", "id": "comparison_group_handle", "label": "Comparison group handle" },
    { "type": "text", "id": "empty_state_heading", "label": "Empty-state heading", "default": "EZQuest option" },
    { "type": "textarea", "id": "empty_state_copy", "label": "Empty-state copy" }
  ],
  "presets": [
    { "name": "Product compare table" }
  ]
}
{% endschema %}
