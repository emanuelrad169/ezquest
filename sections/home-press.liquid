<section class="section-shell home-press-section">
  {% if section.settings.heading != blank %}
    <div class="container-shell">
      <p class="home-press-heading">{{ section.settings.heading }}</p>
    </div>
  {% endif %}

  <div class="home-press-track-outer" aria-label="{{ section.settings.heading }}">
    <div class="home-press-track" aria-hidden="false">
      {%- comment -%}Render twice for seamless infinite loop{%- endcomment -%}
      {% for _pass in (1..2) %}
        <div class="home-press-logos" aria-hidden="{% if forloop.index == 2 %}true{% else %}false{% endif %}">
          {% for block in section.blocks %}
            {%- assign logo = block.settings.logo -%}
            {%- assign label = block.settings.label | default: 'Press' -%}
            {%- assign link = block.settings.url -%}
            {%- liquid
              if link != blank
                assign tag = 'a'
              else
                assign tag = 'div'
              endif
            -%}
            <{{ tag }}{% if link != blank %} href="{{ link }}" target="_blank" rel="noopener"{% endif %} class="home-press-logo-item"{% if forloop.parentloop.index == 1 %} {{ block.shopify_attributes }}{% endif %}>
              {% if logo != blank %}
                {{ logo | image_url: width: 240 | image_tag: loading: 'lazy', alt: label, class: 'home-press-logo-img' }}
              {% else %}
                <span class="home-press-logo-placeholder" aria-label="{{ label }}">
                  <svg width="120" height="32" viewBox="0 0 120 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="120" height="32" rx="6" fill="currentColor" fill-opacity="0.06"/>
                    <rect x="12" y="13" width="96" height="6" rx="3" fill="currentColor" fill-opacity="0.18"/>
                  </svg>
                </span>
              {% endif %}
            </{{ tag }}>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home press / featured in",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "As Featured In" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo image" },
        { "type": "text", "id": "label", "label": "Alt text / publication name" },
        { "type": "url", "id": "url", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home press / featured in",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
