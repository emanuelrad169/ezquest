{%- liquid
  assign brand_images = 'brand-001.jpg,brand-002.jpg,brand-003.jpg,brand-004.jpg,brand-005.jpg,brand-006.jpg,brand-007.jpg,brand-008.jpg,brand-009.jpg' | split: ','
  assign brand_labels = "Rolling Stone,iMore,Forbes,How-To Geek,Laptop Mag,Tom's Guide,The Dallas Morning News,The Boston Globe,Tech Advisor Best of 2024" | split: ','
-%}

<section class="section-shell home-press-section">
  {% if section.settings.heading != blank %}
    <div class="container-shell">
      <p class="home-press-heading">{{ section.settings.heading }}</p>
    </div>
  {% endif %}

  <div class="home-press-track-outer" aria-label="{{ section.settings.heading }}">
    <div class="home-press-track" aria-hidden="false">
      {%- comment -%}Render twice for seamless infinite loop{%- endcomment -%}
      {% for _pass in (1..2) %}
        <div class="home-press-logos" aria-hidden="{% if forloop.index == 2 %}true{% else %}false{% endif %}">
          {% for img in brand_images %}
            {%- assign idx = forloop.index0 -%}
            {%- assign label = brand_labels[idx] -%}
            <div class="home-press-logo-item">
              <img
                src="{{ img | asset_url }}"
                alt="{{ label }}"
                width="150"
                height="50"
                loading="lazy"
                class="home-press-logo-img"
              >
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home press / featured in",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "As Featured In" }
  ],
  "presets": [
    { "name": "Home press / featured in" }
  ]
}
{% endschema %}
