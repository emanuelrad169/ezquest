<section class="section-shell">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Collection framework'
      assign section_copy = section.settings.copy | default: 'Reserved for category narrative, merchandising, and buying guidance.'
    -%}
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="product-meta-pill">Category discovery</span>
          <span class="product-meta-pill">Merchandising layer</span>
        </div>
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    {%- liquid
      assign columns_class = 'lg:grid-cols-4'
      if section.settings.columns_desktop == 2
        assign columns_class = 'lg:grid-cols-2'
      elsif section.settings.columns_desktop == 3
        assign columns_class = 'lg:grid-cols-3'
      endif
    -%}

    <div class="mt-10 grid gap-6 md:grid-cols-2 {{ columns_class }}">
      {% for block in section.blocks %}
        {%- liquid
          assign card_title = block.settings.title
          assign card_copy = block.settings.copy
          assign card_url = block.settings.link
          if block.settings.collection != blank
            assign card_title = block.settings.collection.title
            if block.settings.collection.description != blank and card_copy == blank
              assign card_copy = block.settings.collection.description | strip_html | truncatewords: 20
            endif
            assign card_url = block.settings.collection.url
          endif
          assign card_eyebrow = block.settings.eyebrow
          if card_eyebrow == blank and section.settings.show_sequence
            assign card_eyebrow = forloop.index | prepend: '0'
          endif
        -%}
        <article class="feature-card flex h-full flex-col bg-gradient-to-br from-white to-slate-50" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'mb-6 aspect-[4/3] w-full rounded-[1.5rem] border border-slate-200/80 object-cover' }}
          {% elsif block.settings.collection != blank and block.settings.collection.featured_image != blank %}
            {{ block.settings.collection.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'mb-6 aspect-[4/3] w-full rounded-[1.5rem] border border-slate-200/80 object-cover' }}
          {% else %}
            <div class="mb-6 aspect-[4/3] rounded-[1.5rem] border border-slate-200/80 bg-slate-100"></div>
          {% endif %}
          {% if card_eyebrow != blank %}
            <p class="section-kicker">{{ card_eyebrow }}</p>
          {% endif %}
          <div class="content-flow grow">
            <h3 class="text-xl font-semibold tracking-[-0.03em] text-slate-950">{{ card_title | default: 'Collection feature' }}</h3>
            {% if card_copy != blank %}
              <p class="text-sm leading-7 text-slate-600">{{ card_copy }}</p>
            {% endif %}
          </div>
          <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200/80 pt-5">
            <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Explore products, compare fit, and find support</p>
            {% if card_url != blank %}
              {% render 'button', label: block.settings.link_label, url: card_url, style: 'secondary' %}
            {% endif %}
          </div>
        </article>
      {% else %}
        {% for i in (1..section.settings.columns_desktop) %}
          <article class="feature-card flex h-full flex-col bg-gradient-to-br from-white to-slate-50">
            <div class="mb-6 aspect-[4/3] rounded-[1.5rem] border border-slate-200/80 bg-slate-100"></div>
            {% if section.settings.show_sequence %}
              <p class="section-kicker">{{ i | prepend: '0' }}</p>
            {% endif %}
            <div class="content-flow grow">
              <h3 class="text-xl font-semibold tracking-[-0.03em] text-slate-950">Collection feature</h3>
              <p class="text-sm leading-7 text-slate-600">Add collection cards in the theme editor to populate this module.</p>
            </div>
            <div class="mt-6 border-t border-slate-200/80 pt-5 text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Explore products, compare fit, and find support</div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection feature grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collection framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for category narrative, merchandising, and buying guidance." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    { "type": "checkbox", "id": "show_sequence", "label": "Show sequence labels", "default": true },
    { "type": "text", "id": "link_label", "label": "Section link label", "default": "View all products" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Feature summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View collection" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection feature grid",
      "blocks": [{ "type": "feature" }, { "type": "feature" }, { "type": "feature" }, { "type": "feature" }]
    }
  ]
}
{% endschema %}
