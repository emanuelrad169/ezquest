{%- liquid
  assign headline_lines = section.settings.headline | split: '|'
-%}
<section
  class="cinematic-reveal-section section--dark"
  data-cinematic-reveal
  aria-label="{{ section.settings.aria_label | default: 'Brand statement' | escape }}"
>
  {% if section.settings.background_image != blank %}
    <div class="cinematic-reveal-media" aria-hidden="true">
      {{ section.settings.background_image | image_url: width: 2400 | image_tag: loading: 'lazy', class: 'cinematic-reveal-image', alt: '' }}
    </div>
  {% endif %}

  <div class="cinematic-reveal-inner container-shell">

    {% if section.settings.kicker != blank %}
      <p class="cinematic-reveal-kicker section-kicker">{{ section.settings.kicker | escape }}</p>
    {% endif %}

    <div class="cinematic-reveal-lines" aria-label="{{ headline_lines | join: ' ' | escape }}">
      {% for line in headline_lines %}
        <div
          class="cinematic-reveal-line"
          data-reveal-line
          style="--line-index: {{ forloop.index0 }}; --line-last: {{ forloop.last | json }}"
        >
          <span class="cinematic-reveal-line-inner">{{ line | strip | escape }}</span>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.body_text != blank %}
      <p class="cinematic-reveal-body" data-reveal-body>{{ section.settings.body_text | escape }}</p>
    {% endif %}

    {% if section.settings.cta_label != blank %}
      <div class="cinematic-reveal-cta" data-reveal-cta>
        {% render 'button',
          label: section.settings.cta_label,
          url: section.settings.cta_url,
          style: 'primary',
          size: 'lg'
        %}
      </div>
    {% endif %}

  </div>

  <div class="cinematic-reveal-ambient" aria-hidden="true">
    <div class="cinematic-reveal-beam"></div>
  </div>
</section>

<script>
(function () {
  var section = document.querySelector('[data-cinematic-reveal]');
  if (!section) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    section.classList.add('is-revealed');
    return;
  }

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.18 });

  observer.observe(section);
})();
</script>

{% schema %}
{
  "name": "Cinematic reveal",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Backed by the right support."
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline lines (separate with |)",
      "info": "Use | to split into multiple lines. E.g. Built different.|Works better.",
      "default": "Built different.|Works better."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "EZQuest accessories are engineered for people who need the right connection, every time."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop the range"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Section aria-label",
      "default": "Brand statement"
    }
  ],
  "presets": [
    {
      "name": "Cinematic reveal"
    }
  ]
}
{% endschema %}
