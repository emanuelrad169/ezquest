<section class="section-shell collections-index-section">
  <div class="container-shell">
    {%- liquid
      assign primary_handles = 'hubs-adapters,docking-stations,chargers-power,accessories' | split: ','
      assign rendered_handles = ''
    -%}

    <div class="collections-index-header">
      <p class="section-kicker">Shop by category</p>
      <h1 class="collections-index-title">Collections</h1>
    </div>

    <div class="collections-grid">
      {% for preferred_handle in primary_handles %}
        {%- liquid
          assign col = collections[preferred_handle]
          if col != blank
            assign rendered_handles = rendered_handles | append: col.handle | append: ','
          endif
          assign card_eyebrow = blank
          case preferred_handle
            when 'hubs-adapters'
              assign card_eyebrow = 'Hubs & Adapters'
            when 'docking-stations'
              assign card_eyebrow = 'Docking Stations'
            when 'chargers-power'
              assign card_eyebrow = 'Chargers & Power'
            when 'accessories'
              assign card_eyebrow = 'Accessories'
          endcase
        -%}
        {% if col != blank %}
          <a href="{{ col.url }}" class="collection-card">
            <div class="collection-card-media">
              {% if col.image != blank %}
                {{ col.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: col.title, class: 'collection-card-image' }}
              {% else %}
                {% render 'owned-collection-visual', collection_handle: col.handle, collection_title: col.title, width: 800, height: 800, class: 'collection-card-image' %}
              {% endif %}
            </div>
            <div class="collection-card-body">
              <h2 class="collection-card-title">{{ col.title }}</h2>
              <span class="collection-card-meta">{{ col.products_count }} products</span>
            </div>
            <span class="collection-card-arrow" aria-hidden="true">→</span>
          </a>
        {% endif %}
      {% endfor %}

      {% for col in collections %}
        {%- liquid
          assign should_skip = false
          if col.handle == 'all' or col.handle == 'frontpage'
            assign should_skip = true
          endif
          if rendered_handles contains col.handle
            assign should_skip = true
          endif
        -%}
        {% unless should_skip %}
          <a href="{{ col.url }}" class="collection-card">
            <div class="collection-card-media">
              {% if col.image != blank %}
                {{ col.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: col.title, class: 'collection-card-image' }}
              {% else %}
                {% render 'owned-collection-visual', collection_handle: col.handle, collection_title: col.title, width: 800, height: 800, class: 'collection-card-image' %}
              {% endif %}
            </div>
            <div class="collection-card-body">
              <h2 class="collection-card-title">{{ col.title }}</h2>
              <span class="collection-card-meta">{{ col.products_count }} products</span>
            </div>
            <span class="collection-card-arrow" aria-hidden="true">→</span>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main list collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose the product family built for your workflow."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Browse EZQuest collections by setup type, then move into the right family with a clearer idea of the ports, power path, and footprint you need."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Header note",
      "default": "Start with the family built for your setup, then use compare or support only when you need more detail."
    }
  ],
  "presets": [
    {
      "name": "Main list collections"
    }
  ]
}
{% endschema %}
