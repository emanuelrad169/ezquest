<section class="section-shell main-product-section">
  <div class="container-shell">
    {% render 'breadcrumbs' %}
    {%- liquid
      assign structured_highlights = blank
      assign has_structured_highlights = false
      assign lead_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
      assign support_summary_text = blank
      assign compatibility_summary_text = blank
      assign first_structured_highlight = blank
      assign product_description_excerpt = blank
      assign product_positioning_text = blank
      assign role_decision_note = 'Choose this when one product should keep the setup cleaner without complicating the desk.'
      assign role_boundary_note = 'Step up only if the workflow needs more permanent desk connectivity.'
      assign compare_cta_label = 'Still deciding? Compare nearby options'
      assign ownership_heading = section.settings.support_heading | default: 'Support for this product'
      assign ownership_copy = section.settings.support_copy | default: 'Check compatibility, open the manual, or get the right download for this product without crowding the decision.'
      assign setup_label = 'Everyday setup'
      assign setup_statement = 'Connectivity that keeps the setup cleaner, calmer, and easier to trust.'
      assign setup_environment = 'Built for modern-device routines that need clearer expansion without extra clutter.'
      assign spec_count = 0
      assign manual_count = 0
      assign download_count = 0
      assign use_owned_product_gallery = false
      assign compatibility_support_url = '/pages/compatibility'
      assign manuals_support_url = '/pages/manuals'
      assign downloads_support_url = '/pages/downloads'
      assign support_center_url = '/pages/support'

      if product.metafields.ezquest.feature_highlights != blank
        assign structured_highlights = product.metafields.ezquest.feature_highlights.value
        if structured_highlights.count > 0
          assign has_structured_highlights = true
          assign first_structured_highlight = structured_highlights.first
        endif
      endif

      if section.settings.show_support_summary and product.metafields.ezquest.support_summary != blank
        assign support_summary_text = product.metafields.ezquest.support_summary | metafield_tag | strip_html | strip
      endif

      if product.metafields.ezquest.compatibility_summary != blank
        assign compatibility_summary_text = product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | strip
      endif

      if product.description != blank
        assign product_description_excerpt = product.description | strip_html | strip
      endif

      if compatibility_summary_text != blank
        assign product_positioning_text = compatibility_summary_text
      elsif support_summary_text != blank
        assign product_positioning_text = support_summary_text
      elsif product_description_excerpt != blank
        assign product_positioning_text = product_description_excerpt | truncatewords: 24
      endif

      if product.metafields.ezquest.spec_rows != blank
        assign spec_count = product.metafields.ezquest.spec_rows.value.count
      endif

      if product.metafields.ezquest.manuals != blank
        assign manual_count = product.metafields.ezquest.manuals.value.count
      endif

      if product.metafields.ezquest.downloads != blank
        assign download_count = product.metafields.ezquest.downloads.value.count
      endif

      if product.handle != blank
        assign compatibility_support_url = compatibility_support_url | append: '?product=' | append: product.handle
        assign manuals_support_url = manuals_support_url | append: '?product=' | append: product.handle
        assign downloads_support_url = downloads_support_url | append: '?product=' | append: product.handle
        assign support_center_url = support_center_url | append: '?product=' | append: product.handle
      endif

      case product.handle
        when 'usb-c-travel-hub'
          assign use_owned_product_gallery = true
          assign setup_label = 'Travel-first setup'
          assign setup_statement = 'Compact expansion for meetings, hotel desks, classrooms, and lighter mobile workflows.'
          assign setup_environment = 'Choose it when portability matters more than maximum port count or a permanent desk footprint.'
          assign role_decision_note = 'Choose this when the setup moves often and the hub should stay easy to carry.'
          assign role_boundary_note = 'Step up only if the desk needs more ports, more power, or a steadier display chain.'
          assign compare_cta_label = 'Still deciding? Compare against balanced and desk-ready options'
          assign ownership_heading = 'Support that travels well'
        when 'usb-c-pro-dock'
          assign use_owned_product_gallery = true
          assign setup_label = 'Desk-first setup'
          assign setup_statement = 'Broader connectivity for permanent desks that need displays, Ethernet, peripherals, and calmer cable control.'
          assign setup_environment = 'Built for users stepping up from lighter hubs into a more stable workstation setup.'
          assign role_decision_note = 'Choose this when the desk stays put and the workflow needs a more complete connection hub.'
          assign role_boundary_note = 'Go lighter only if portability matters more than a permanent workstation setup.'
          assign compare_cta_label = 'Still deciding? Compare against balanced and portable options'
          assign ownership_heading = 'Support for the workstation'
        when 'usb-c-multimedia-hub'
          assign use_owned_product_gallery = true
          assign setup_label = 'Balanced everyday setup'
          assign setup_statement = 'One everyday hub for charging, HDMI, Ethernet, storage access, and hybrid desk routines.'
          assign setup_environment = 'Choose it when one compact adapter should cover the daily desk.'
          assign role_decision_note = 'Choose this when one compact hub should cover the everyday desk.'
          assign role_boundary_note = 'Go lighter only if portability wins. Step up only if the desk needs a fuller dock.'
          assign compare_cta_label = 'Still deciding? Compare against travel and desk-ready options'
          assign ownership_heading = 'Support for the everyday desk'
      endcase

      if support_summary_text != blank
        assign ownership_copy = support_summary_text
      endif
    -%}

    <div class="product-layout mt-6">
      <div class="product-gallery">
        <div class="product-gallery-stage product-gallery-stage-shell">
          <div class="product-gallery-stage-note">
            <span class="product-gallery-stage-label">{{ setup_label }}</span>
            <p class="product-gallery-stage-copy">{{ setup_environment }}</p>
          </div>

          <div class="product-gallery-main">
            {% if lead_media != blank %}
              {% render 'media', media: lead_media, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
            {% elsif product.featured_image != blank %}
              {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
            {% elsif use_owned_product_gallery %}
              <div class="hero-media-frame p-2 lg:p-3">
                {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'hero', width: 1600, height: 1200, class: 'aspect-card w-full object-cover', loading: 'eager', fetchpriority: 'high' %}
              </div>
            {% else %}
              {% render 'placeholder-visual', kind: 'product', text: product.title, width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
            {% endif %}
          </div>

          {% if product.media.size > 1 %}
            <div class="product-gallery-grid mt-5">
              {% for media_item in product.media limit: 5 %}
                {% unless lead_media != blank and media_item.id == lead_media.id %}
                  <div class="product-thumb-card">
                    {% render 'media', media: media_item, aspect_ratio: 'aspect-card', class: 'bg-white p-2 shadow-none', object_fit: 'object-contain' %}
                  </div>
                {% endunless %}
              {% endfor %}
            </div>
          {% elsif use_owned_product_gallery %}
            <div class="product-gallery-grid mt-5">
              <div class="product-thumb-card">
                {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'hero', width: 800, height: 600, class: 'aspect-card w-full object-cover' %}
              </div>
              <div class="product-thumb-card">
                {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'ports', width: 800, height: 600, class: 'aspect-card w-full object-cover' %}
              </div>
              <div class="product-thumb-card">
                {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'setup', width: 800, height: 600, class: 'aspect-card w-full object-cover' %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="space-y-6 buybox-sticky">
        <div class="product-buybox">
          <div class="product-buybox-header">
            <div class="product-meta-row">
              {% if section.settings.show_vendor and product.vendor != blank %}
                <span class="product-meta-pill">{{ product.vendor }}</span>
              {% endif %}
              {% if section.settings.show_product_type and product.type != blank %}
                <span class="product-meta-pill">{{ product.type }}</span>
              {% endif %}
              {% if product.available %}
                <span class="product-meta-pill border-emerald-200 bg-emerald-50 text-emerald-700">Ready to order</span>
              {% else %}
                <span class="product-meta-pill border-slate-300 bg-slate-100 text-slate-600">Sold out</span>
              {% endif %}
            </div>

            <div class="product-buybox-lead">
              <p class="product-buybox-setup-label">{{ setup_label }}</p>
              <h1 class="section-heading mt-3">{{ product.title }}</h1>
              <p class="product-buybox-setup-statement">{{ setup_statement }}</p>
              <p class="product-buybox-role-note">{{ role_decision_note }}</p>
              <p class="product-buybox-positioning">{{ role_boundary_note }}</p>
            </div>

            <div class="product-buybox-price-row">
              <div class="product-buybox-price">
                <div>
                  {% render 'price', product: product, variant: product.selected_or_first_available_variant %}
                </div>
              </div>
              {% if product_positioning_text != blank %}
                <p class="product-buybox-positioning">{{ product_positioning_text }}</p>
              {% endif %}
            </div>

            <div class="product-buybox-signal-grid">
              <div class="product-buybox-signal">
                <p class="product-buybox-signal-label">Setup fit</p>
                <p class="product-buybox-signal-value">{{ setup_label }}</p>
              </div>
              {% if spec_count > 0 %}
                <div class="product-buybox-signal">
                  <p class="product-buybox-signal-label">Technical fit</p>
                  <p class="product-buybox-signal-value">{{ spec_count }} key spec{% if spec_count != 1 %}s{% endif %}</p>
                </div>
              {% endif %}
              {% if manual_count > 0 or download_count > 0 %}
                <div class="product-buybox-signal">
                  <p class="product-buybox-signal-label">Support nearby</p>
                  <p class="product-buybox-signal-value">
                    {% if manual_count > 0 %}{{ manual_count }} manual{% if manual_count != 1 %}s{% endif %}{% endif %}
                    {% if manual_count > 0 and download_count > 0 %} + {% endif %}
                    {% if download_count > 0 %}{{ download_count }} download{% if download_count != 1 %}s{% endif %}{% endif %}
                  </p>
                </div>
              {% endif %}
            </div>

            <div class="product-buybox-confidence">
              <p class="product-buybox-confidence-kicker">{{ section.settings.support_eyebrow | default: 'Ownership confidence' }}</p>
              <p class="product-buybox-confidence-heading">{{ ownership_heading }}</p>
              <div class="product-buybox-confidence-copy">
                {{ ownership_copy }}
              </div>
              <div class="product-buybox-confidence-links">
                <a href="{{ compatibility_support_url }}" class="collection-inline-link">Check compatibility for this product</a>
                {% if manual_count > 0 %}
                  <a href="{{ manuals_support_url }}" class="collection-inline-link">Open manuals for this product</a>
                {% elsif download_count > 0 %}
                  <a href="{{ downloads_support_url }}" class="collection-inline-link">View downloads for this product</a>
                {% else %}
                  <a href="{{ support_center_url }}" class="collection-inline-link">Open support for this model</a>
                {% endif %}
              </div>
            </div>
          </div>

          {% form 'product', product, class: 'mt-8 space-y-5' %}
            <div class="product-form-panel space-y-5">
              {% if product.has_only_default_variant == false %}
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductVariant-{{ section.id }}">Variant</label>
                  <select id="ProductVariant-{{ section.id }}" name="id" class="min-h-12 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900">
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                        {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% else %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {% endif %}

              <div class="grid gap-4 sm:grid-cols-auto-fill sm:items-end">
                {% if section.settings.show_quantity_selector %}
                  <div>
                    <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductQuantity-{{ section.id }}">Quantity</label>
                    <input id="ProductQuantity-{{ section.id }}" class="min-h-12 w-28 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900" type="number" name="quantity" value="1" min="1">
                  </div>
                {% endif %}
                <div class="product-primary-action-wrap">
                  <button class="button-primary product-primary-action" type="submit" name="add"{% unless product.available %} disabled="disabled"{% endunless %}>
                    {% if product.available %}Add to cart{% else %}Sold out{% endif %}
                  </button>
                </div>
              </div>

              <div class="product-form-meta">
              <p class="support-utility-note">Add to cart when this role matches the setup. Open compare or support only if one buying detail still needs a closer look.</p>
              <a href="/pages/compare?product={{ product.handle }}" class="hero-secondary-action">{{ compare_cta_label }}</a>
              </div>

              {% if section.settings.show_dynamic_checkout %}
                <div class="product-form-payment">
                  {{ form | payment_button }}
                </div>
              {% endif %}
            </div>
          {% endform %}

          <div class="product-assurance-grid">
            <div class="product-confidence-item">
              <p class="section-kicker">Setup fit</p>
              <p class="mt-2">
                {% if compatibility_summary_text != blank %}
                  {{ compatibility_summary_text | truncatewords: 14 }}
                {% else %}
                  Works with Mac + Windows
                {% endif %}
              </p>
            </div>
            <div class="product-confidence-item">
              <p class="section-kicker">Why choose it</p>
              <p class="mt-2">
                {% if first_structured_highlight != blank %}
                  {{ first_structured_highlight }}
                {% else %}
                  Plug &amp; play setup
                {% endif %}
              </p>
            </div>
            <div class="product-confidence-item">
              <p class="section-kicker">Ownership</p>
              <p class="mt-2">
                {% if support_summary_text != blank %}
                  {{ support_summary_text | truncatewords: 14 }}
                {% else %}
                  Manuals, downloads, and setup help for this product
                {% endif %}
              </p>
            </div>
          </div>

          <div class="product-link-row">
            <a href="/pages/compare?product={{ product.handle }}" class="site-meta-link">Compare this product</a>
            <a href="{{ downloads_support_url }}" class="site-meta-link">Downloads</a>
            <a href="{{ manuals_support_url }}" class="site-meta-link">Manuals</a>
            <a href="{{ compatibility_support_url }}" class="site-meta-link">Compatibility</a>
          </div>

          {% if has_structured_highlights or section.blocks.size > 0 %}
            {%- assign rendered_highlights = 0 -%}
            <div class="product-highlight-shell">
              <p class="section-kicker">At a glance</p>
              <div class="product-highlights mt-4">
                {% if has_structured_highlights %}
                  {% for highlight in structured_highlights limit: section.settings.highlight_limit %}
                    {% if rendered_highlights < 3 %}
                      <div class="product-highlight-card">
                        <p class="product-highlight-index">0{{ forloop.index }}</p>
                        <div class="product-highlight-copy">{{ highlight }}</div>
                      </div>
                      {%- assign rendered_highlights = rendered_highlights | plus: 1 -%}
                    {% endif %}
                  {% endfor %}
                {% elsif section.blocks.size > 0 %}
                  {% for block in section.blocks %}
                    {% if rendered_highlights < 3 %}
                      <div class="product-highlight-card" {{ block.shopify_attributes }}>
                        <p class="product-highlight-index">0{{ rendered_highlights | plus: 1 }}</p>
                        <div class="product-highlight-copy">{{ block.settings.title }}</div>
                      </div>
                      {%- assign rendered_highlights = rendered_highlights | plus: 1 -%}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show selected variant SKU",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_type",
      "label": "Show product type",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_summary",
      "label": "Show product support summary when available",
      "default": true
    },
    {
      "type": "range",
      "id": "highlight_limit",
      "label": "Structured highlight limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    },
    {
      "type": "text",
      "id": "support_eyebrow",
      "label": "Support panel eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support panel heading",
      "default": "Support guidance built around this product"
    },
    {
      "type": "textarea",
      "id": "support_copy",
      "label": "Support panel copy",
      "default": "Compatibility guidance, manuals, downloads, and direct support stay nearby without crowding the buying decision."
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Works with Mac + Windows"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Short buying-confidence point."
        }
      ]
    }
  ]
}
{% endschema %}
