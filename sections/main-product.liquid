<section class="section-shell">
  <div class="container-shell">
    {% render 'breadcrumbs' %}
    {%- liquid
      assign support_heading = section.settings.support_heading | default: 'Support-backed buying confidence'
      assign support_copy = section.settings.support_copy | default: 'Use this space for compatibility guidance, installation notes, or the clearest next support step before purchase hesitation turns into drop-off.'
      assign support_summary = product.metafields.ezquest.support_summary
      assign compatibility_summary = product.metafields.ezquest.compatibility_summary
      assign structured_highlights = blank
      assign has_structured_highlights = false
      assign lead_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media

      if product.metafields.ezquest.feature_highlights != blank
        assign structured_highlights = product.metafields.ezquest.feature_highlights.value
        if structured_highlights.count > 0
          assign has_structured_highlights = true
        endif
      endif
    -%}

    <div class="product-layout mt-6">
      <div class="product-gallery">
        <div class="section-frame overflow-hidden">
          {% if lead_media != blank %}
            {% render 'media', media: lead_media, aspect_ratio: 'aspect-[4/3]', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
          {% elsif product.featured_image != blank %}
            {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-[4/3]', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
          {% else %}
            <div class="hero-media-frame aspect-[4/3]"></div>
          {% endif %}

          {% if product.media.size > 1 %}
            <div class="product-gallery-grid mt-5">
              {% for media_item in product.media limit: 5 %}
                {% unless lead_media != blank and media_item.id == lead_media.id %}
                  {% render 'media', media: media_item, aspect_ratio: 'aspect-[4/3]', class: 'bg-white p-2', object_fit: 'object-contain' %}
                {% endunless %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="space-y-6 lg:sticky lg:top-6">
        <div class="product-buybox">
          <div class="product-meta-row">
            {% if section.settings.show_vendor and product.vendor != blank %}
              <span class="product-meta-pill">{{ product.vendor }}</span>
            {% endif %}
            {% if section.settings.show_product_type and product.type != blank %}
              <span class="product-meta-pill">{{ product.type }}</span>
            {% endif %}
            {% if section.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
              <span class="product-meta-pill">SKU {{ product.selected_or_first_available_variant.sku }}</span>
            {% endif %}
            {% if product.available %}
              <span class="product-meta-pill border-emerald-200 bg-emerald-50 text-emerald-700">Ready to order</span>
            {% else %}
              <span class="product-meta-pill border-slate-300 bg-slate-100 text-slate-600">Sold out</span>
            {% endif %}
          </div>

          <h1 class="section-heading mt-5">{{ product.title }}</h1>

          <div class="mt-5">
            {% render 'price', product: product, variant: product.selected_or_first_available_variant %}
          </div>

          <div class="product-confidence-list">
            <div class="product-confidence-item">
              <p class="section-kicker">Clarity</p>
              <p class="mt-2">Understand the fit, key features, and next step without digging through clutter.</p>
            </div>
            <div class="product-confidence-item">
              <p class="section-kicker">Compare</p>
              <p class="mt-2">Compare adjacent options quickly if the customer is choosing between tiers or setups.</p>
            </div>
            <div class="product-confidence-item">
              <p class="section-kicker">Support</p>
              <p class="mt-2">Manuals, downloads, and compatibility live close to the buy box instead of after the purchase.</p>
            </div>
          </div>

          {% if section.settings.show_description and product.description != blank %}
            <div class="section-copy mt-5 max-w-none">{{ product.description | strip_html | truncatewords: 42 }}</div>
          {% endif %}

          {% if section.settings.show_support_summary and support_summary != blank %}
            <div class="product-support-panel mt-6">
              <p class="section-kicker">Support summary</p>
              <div class="richtext-content mt-3">{{ support_summary | metafield_tag }}</div>
            </div>
          {% endif %}

          {% if has_structured_highlights or section.blocks.size > 0 %}
            <div class="mt-8">
              <div class="flex items-center justify-between gap-4">
                <p class="section-kicker">Key capabilities</p>
                {% if compatibility_summary != blank %}
                  <span class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Support-aware PDP</span>
                {% endif %}
              </div>
              <div class="product-highlights mt-4">
                {% if has_structured_highlights %}
                  {% for highlight in structured_highlights limit: section.settings.highlight_limit %}
                    <div class="product-highlight-card">
                      <div class="text-sm font-semibold text-slate-950">{{ highlight }}</div>
                    </div>
                  {% endfor %}
                {% elsif section.blocks.size > 0 %}
                  {% for block in section.blocks %}
                    <div class="product-highlight-card" {{ block.shopify_attributes }}>
                      <div class="text-sm font-semibold text-slate-950">{{ block.settings.title }}</div>
                      {% if block.settings.copy != blank %}
                        <p class="mt-2 text-sm leading-6 text-slate-600">{{ block.settings.copy }}</p>
                      {% endif %}
                    </div>
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endif %}

          {% form 'product', product, class: 'mt-8 space-y-5' %}
            <div class="product-form-panel space-y-5">
              {% if product.has_only_default_variant == false %}
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductVariant-{{ section.id }}">Variant</label>
                  <select id="ProductVariant-{{ section.id }}" name="id" class="min-h-12 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900">
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                        {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% else %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {% endif %}

              <div class="grid gap-4 sm:grid-cols-[auto_1fr] sm:items-end">
                {% if section.settings.show_quantity_selector %}
                  <div>
                    <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductQuantity-{{ section.id }}">Quantity</label>
                    <input id="ProductQuantity-{{ section.id }}" class="min-h-12 w-28 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900" type="number" name="quantity" value="1" min="1">
                  </div>
                {% endif %}
                <div class="action-cluster">
                  <button class="button-primary" type="submit" name="add"{% unless product.available %} disabled="disabled"{% endunless %}>
                    {% if product.available %}Add to cart{% else %}Sold out{% endif %}
                  </button>
                  {% if settings.support_contact_url != blank %}
                    {% render 'button', label: 'Need help choosing?', url: settings.support_contact_url, style: 'secondary' %}
                  {% endif %}
                </div>
              </div>

              <div class="cta-note-row">
                <span class="cta-note-pill">Compatibility help available</span>
                <span class="cta-note-pill">Manuals and downloads nearby</span>
                <span class="cta-note-pill">Direct support if needed</span>
              </div>

              <p class="micro-note">Built for customers who want clearer product fit, easier setup continuity, and less guesswork before checkout.</p>

              <div class="product-link-row">
                <a href="/pages/compare" class="site-meta-link">Compare nearby options</a>
                <a href="/pages/downloads" class="site-meta-link">View downloads</a>
                <a href="/pages/manuals" class="site-meta-link">See manuals</a>
              </div>

              {% if section.settings.show_dynamic_checkout %}
                <div>
                  {{ form | payment_button }}
                </div>
              {% endif %}
            </div>

            {% if section.settings.show_support_panel %}
              <div class="product-support-panel">
                <p class="section-kicker">{{ section.settings.support_eyebrow }}</p>
                <h2 class="mt-3 text-xl font-semibold tracking-tight text-slate-950">{{ support_heading }}</h2>
                {% if compatibility_summary != blank %}
                  <div class="richtext-content mt-3">{{ compatibility_summary | metafield_tag }}</div>
                {% elsif support_summary != blank %}
                  <div class="richtext-content mt-3">{{ support_summary | metafield_tag }}</div>
                {% else %}
                  <p class="mt-3 text-sm leading-6 text-slate-600">{{ support_copy }}</p>
                {% endif %}
                <div class="support-crosslink-list">
                  <a href="/pages/compatibility" class="support-crosslink">
                    <span>Check compatibility before ordering</span>
                    <span class="text-slate-400">Fit</span>
                  </a>
                  <a href="/pages/contact" class="support-crosslink">
                    <span>Talk to support if you still need a recommendation</span>
                    <span class="text-slate-400">Help</span>
                  </a>
                </div>
              </div>
            {% endif %}
          {% endform %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show selected variant SKU",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_type",
      "label": "Show product type",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_summary",
      "label": "Show product support summary when available",
      "default": true
    },
    {
      "type": "range",
      "id": "highlight_limit",
      "label": "Structured highlight limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    },
    {
      "type": "text",
      "id": "support_eyebrow",
      "label": "Support panel eyebrow",
      "default": "Support continuity"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support panel heading",
      "default": "Implementation-ready buy box"
    },
    {
      "type": "textarea",
      "id": "support_copy",
      "label": "Support panel copy",
      "default": "Reserved for compatibility guidance, installation notes, or direct support handoff messaging."
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Highlight title"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Short product buying support point."
        }
      ]
    }
  ]
}
{% endschema %}
