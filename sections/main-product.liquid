<script>
(function () {
  var productRoot = document.querySelector('[data-product-root]');
  if (!productRoot) return;

  var counter = productRoot.querySelector('#stock-counter');
  var variantSelect = productRoot.querySelector('[data-product-variant-select]');
  if (!counter) return;

  function syncCounterFromVariant(variant) {
    if (!variant) return;

    var qty = Number(variant.inventory_quantity || 0);
    var managed = variant.inventory_management === 'shopify';
    var deny = variant.inventory_policy === 'deny';
    var text = counter.querySelector('.stock-counter__text');

    if (!managed || !deny || qty <= 0) {
      counter.classList.add('stock-counter--hidden');
      counter.dataset.inventory = '0';
      return;
    }

    counter.classList.remove('stock-counter--hidden');
    counter.dataset.inventory = String(qty);

    if (qty <= 3) {
      counter.className = 'stock-counter stock-counter--critical';
      if (text) text.textContent = 'Only ' + qty + ' left — order soon';
    } else if (qty <= 5) {
      counter.className = 'stock-counter stock-counter--low';
      if (text) text.textContent = 'Only ' + qty + ' left in stock';
    } else if (qty <= 10) {
      counter.className = 'stock-counter stock-counter--low';
      if (text) text.textContent = qty + ' left in stock';
    } else {
      counter.className = 'stock-counter stock-counter--ok';
      if (text) text.textContent = 'In stock · ships within 1-2 days';
    }
  }

  function variantFromOption(option) {
    if (!option) return null;

    return {
      id: option.value,
      inventory_quantity: Number(option.dataset.variantInventoryQuantity || 0),
      inventory_management: option.dataset.variantInventoryManagement || '',
      inventory_policy: option.dataset.variantInventoryPolicy || ''
    };
  }

  if (variantSelect) {
    variantSelect.addEventListener('change', function () {
      var option = variantSelect.options[variantSelect.selectedIndex];
      syncCounterFromVariant(variantFromOption(option));
    });
  }

  document.addEventListener('variant:change', function (event) {
    var variant = event.detail && event.detail.variant;
    if (!variant) return;
    syncCounterFromVariant(variant);
  });
})();
</script>

<script>
(function () {
  var productRoot = document.querySelector('[data-product-root]');
  if (!productRoot) return;

  var productForm = productRoot.querySelector('form[id^="ProductForm-"]');
  if (!productForm) return;

  var primaryButton = productRoot.querySelector('[data-product-primary-button]');
  var primaryButtonLabel = productRoot.querySelector('[data-product-primary-button-label]');
  var primaryButtonPrice = productRoot.querySelector('[data-product-primary-button-price]');
  var primaryButtonDivider = productRoot.querySelector('[data-product-primary-button-divider]');
  var stickyButton = productRoot.querySelector('[data-sticky-atc-button]');
  var stickyButtonLabel = productRoot.querySelector('[data-sticky-atc-button-label]');
  var stickyButtonPrice = productRoot.querySelector('[data-sticky-atc-button-price]');
  var stickyButtonDivider = productRoot.querySelector('[data-sticky-atc-button-divider]');

  var addLabel = primaryButton ? (primaryButton.getAttribute('data-label-add') || 'Add to cart') : 'Add to cart';
  var addingLabel = primaryButton ? (primaryButton.getAttribute('data-label-adding') || 'Adding\u2026') : 'Adding\u2026';

  function setLoading(loading) {
    [primaryButton, stickyButton].forEach(function (btn) {
      if (!btn) return;
      btn.classList.toggle('is-loading', loading);
      btn.disabled = loading;
      btn.setAttribute('aria-busy', loading ? 'true' : 'false');
    });
    if (primaryButtonLabel) primaryButtonLabel.textContent = loading ? addingLabel : addLabel;
    if (primaryButtonPrice) primaryButtonPrice.hidden = loading;
    if (primaryButtonDivider) primaryButtonDivider.hidden = loading;
    if (stickyButtonLabel) stickyButtonLabel.textContent = loading ? addingLabel : addLabel;
    if (stickyButtonPrice) stickyButtonPrice.hidden = loading;
    if (stickyButtonDivider) stickyButtonDivider.hidden = loading;
  }

  productForm.addEventListener('submit', function (event) {
    event.preventDefault();
    var variantInput = productForm.querySelector('[name="id"]');
    var quantityInput = productForm.querySelector('[name="quantity"]');
    if (!variantInput || !variantInput.value) return;

    setLoading(true);

    fetch((window.EZRoutes && window.EZRoutes.cartAdd ? window.EZRoutes.cartAdd : '/cart/add') + '.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({
        items: [{ id: parseInt(variantInput.value, 10), quantity: quantityInput ? parseInt(quantityInput.value, 10) || 1 : 1 }]
      })
    })
    .then(function (res) {
      if (!res.ok) throw new Error('cart_error');
      return res.json();
    })
    .then(function () {
      if (primaryButtonLabel) primaryButtonLabel.textContent = 'Added!';
      if (stickyButtonLabel) stickyButtonLabel.textContent = 'Added!';
      setTimeout(function () {
        if (typeof window.refreshAndOpenCartDrawer === 'function') {
          window.refreshAndOpenCartDrawer();
          setTimeout(function () { setLoading(false); }, 350);
        } else {
          window.location.href = window.EZRoutes && window.EZRoutes.cart ? window.EZRoutes.cart : '/cart';
        }
      }, 700);
    })
    .catch(function () {
      setLoading(false);
    });
  });
})();
</script>

<script>
(function () {
  var stickyBar = document.querySelector('[data-sticky-atc]');
  var mainAtc = document.querySelector('[data-product-primary-button]');
  if (!stickyBar || !mainAtc || !window.IntersectionObserver) return;

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      var visible = !entry.isIntersecting;
      stickyBar.classList.toggle('is-visible', visible);
      stickyBar.setAttribute('aria-hidden', visible ? 'false' : 'true');
    });
  }, { threshold: 0, rootMargin: '0px 0px -80px 0px' });

  observer.observe(mainAtc);
})();
</script>

<script>
(function () {
  document.querySelectorAll('[data-pdp-tabs]').forEach(function (tabs) {
    var triggers = Array.prototype.slice.call(tabs.querySelectorAll('[data-tab]'));
    var panels   = Array.prototype.slice.call(tabs.querySelectorAll('[data-panel]'));
    triggers.forEach(function (t) {
      t.addEventListener('click', function () {
        var target = t.dataset.tab;
        triggers.forEach(function (x) {
          var active = x.dataset.tab === target;
          x.classList.toggle('is-active', active);
          x.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        panels.forEach(function (p) {
          p.classList.toggle('is-active', p.dataset.panel === target);
        });
        // Scroll active trigger into view when tab strip overflows on mobile
        var list = t.closest('.pdp-tabs__list');
        if (list) {
          var listRect = list.getBoundingClientRect();
          var tRect    = t.getBoundingClientRect();
          if (tRect.left < listRect.left || tRect.right > listRect.right) {
            t.scrollIntoView({ inline: 'nearest', block: 'nearest' });
          }
        }
      });
    });
  });
})();
</script>

<script src="{{ 'pdp-zoom.js' | asset_url }}" defer></script>

<script>
  /* Brand the Shopify "Buy it now" dynamic-checkout button: Shopify sets its
     colour via an inline !important style (store Brand colour), which external
     CSS can't override, so re-apply our brand colour once it renders. */
  (function () {
    function brand() {
      document.querySelectorAll('.shopify-payment-button__button--unbranded').forEach(function (b) {
        b.style.setProperty('background', '#1d1d1f', 'important');
        b.style.setProperty('color', '#ffffff', 'important');
      });
    }
    brand();
    var mo = new MutationObserver(brand);
    mo.observe(document.body, { childList: true, subtree: true });
    window.setTimeout(function () { mo.disconnect(); }, 6000);
  })();
</script>

<script>
  /* UGREEN-style highlight box: clamp the description, toggle on "Learn more". */
  (function () {
    document.querySelectorAll('[data-pdp-highlight]').forEach(function (box) {
      var btn = box.querySelector('[data-pdp-highlight-toggle]');
      var body = box.querySelector('.pdp-highlight__body');
      var label = box.querySelector('[data-pdp-highlight-label]');
      if (!btn || !body) return;
      // If the content already fits, drop the clamp + hide the toggle.
      if (body.scrollHeight <= body.clientHeight + 4) {
        box.classList.add('is-open');
        btn.style.display = 'none';
        return;
      }
      btn.addEventListener('click', function () {
        var open = box.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        if (label) label.textContent = open ? 'Show less' : 'Learn more';
      });
    });
  })();
</script>

