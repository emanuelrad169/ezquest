<section class="section-shell main-product-section" data-product-root>
  <div class="container-shell">
    <div class="hidden lg:block">
      {% render 'breadcrumbs' %}
    </div>
    {%- liquid
      assign structured_highlights = blank
      assign has_structured_highlights = false
      assign lead_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
      assign support_summary_text = blank
      assign compatibility_summary_text = blank
      assign first_structured_highlight = blank
      assign product_description_excerpt = blank
      assign product_positioning_text = blank
      assign review_rating_value = blank
      assign review_rating_count = blank
      assign display_rating_value = blank
      assign display_rating_count = blank
      assign show_urgency = false
      assign urgency_qty = 0
      assign selected_variant = product.selected_or_first_available_variant
      assign product_form_id = 'ProductForm-' | append: section.id
      assign mobile_proof_line = blank
      assign proof_fallback_line = blank
      assign sticky_trust_line = blank
      assign variant_reinforcement_text = blank
      assign selected_option_summary = blank
      assign selected_option_label = 'Variant'
      assign role_decision_note = 'Clean connectivity.'
      assign ownership_heading = section.settings.support_heading | default: 'Support stays close'
      assign ownership_copy = section.settings.support_copy | default: 'Compatibility, manuals, downloads, and help.'
      assign setup_label = 'Everyday'
      assign setup_statement = 'Clean connectivity for everyday devices.'
      assign setup_environment = 'Light, clean, ready.'
      assign spec_count = 0
      assign product_spec_rows = blank
      assign manual_count = 0
      assign download_count = 0
      assign use_owned_product_gallery = false
      assign compatibility_support_url = '/pages/compatibility'
      assign manuals_support_url = '/pages/manuals'
      assign downloads_support_url = '/pages/downloads'
      assign support_center_url = '/pages/support'
      assign setup_guide_url = '/pages/help-me-choose'
      assign compare_products_url = '/pages/compare'
      assign back_collection = collection
      assign back_collection_url = blank
      assign back_collection_title = blank
      assign back_collection_label = 'Back to products'

      if back_collection == blank and product.collections != blank
        for candidate_collection in product.collections
          if candidate_collection.handle == 'all' or candidate_collection.handle == 'frontpage'
            continue
          endif
          assign back_collection = candidate_collection
          break
        endfor
      endif

      if back_collection != blank
        assign back_collection_url = back_collection.url
        assign back_collection_title = back_collection.title
        assign back_collection_label = 'Back to ' | append: back_collection.title
      endif

      if product.metafields.ezquest.feature_highlights != blank
        assign structured_highlights = product.metafields.ezquest.feature_highlights.value
        if structured_highlights.count > 0
          assign has_structured_highlights = true
          assign first_structured_highlight = structured_highlights.first
        endif
      endif

      if section.settings.show_support_summary and product.metafields.ezquest.support_summary != blank
        assign support_summary_text = product.metafields.ezquest.support_summary | metafield_tag | strip_html | strip
      endif

      if product.metafields.ezquest.compatibility_summary != blank
        assign compatibility_summary_text = product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | strip
      endif

      if product.description != blank
        assign product_description_excerpt = product.description | strip_html | strip
      endif

      if compatibility_summary_text != blank
        assign product_positioning_text = compatibility_summary_text
      elsif support_summary_text != blank
        assign product_positioning_text = support_summary_text
      elsif section.settings.show_description and product_description_excerpt != blank
        assign product_positioning_text = product_description_excerpt | truncatewords: 14
      endif

      if product.metafields.ezquest.spec_rows != blank
        assign product_spec_rows = product.metafields.ezquest.spec_rows.value
        assign spec_count = product.metafields.ezquest.spec_rows.value.count
      endif

      if product.metafields.ezquest.manuals != blank
        assign manual_count = product.metafields.ezquest.manuals.value.count
      endif

      if product.metafields.ezquest.downloads != blank
        assign download_count = product.metafields.ezquest.downloads.value.count
      endif

      if product.metafields.reviews.rating != blank and product.metafields.reviews.rating.value != blank
        assign review_rating_value = product.metafields.reviews.rating.value.rating
        assign review_rating_count = product.metafields.reviews.rating_count.value | default: blank
      endif

      if review_rating_value != blank
        assign display_rating_value = review_rating_value
        assign display_rating_count = review_rating_count
      elsif section.settings.fallback_rating != blank
        assign display_rating_value = section.settings.fallback_rating
        assign display_rating_count = section.settings.fallback_rating_count
      endif

      if selected_variant != blank and selected_variant.inventory_management == 'shopify' and selected_variant.inventory_policy == 'deny'
        if selected_variant.inventory_quantity > 0 and selected_variant.inventory_quantity <= 10
          assign show_urgency = true
          assign urgency_qty = selected_variant.inventory_quantity
        endif
      endif

      if product.handle != blank
        assign compatibility_support_url = compatibility_support_url | append: '?product=' | append: product.handle
        assign manuals_support_url = manuals_support_url | append: '?product=' | append: product.handle
        assign downloads_support_url = downloads_support_url | append: '?product=' | append: product.handle
        assign support_center_url = support_center_url | append: '?product=' | append: product.handle
        assign compare_products_url = compare_products_url | append: '?product=' | append: product.handle
      endif

      case product.handle
        when 'usb-c-travel-hub'
          assign use_owned_product_gallery = true
          assign setup_label = 'Travel'
          assign setup_statement = 'Compact ports and power for work on the move.'
          assign setup_environment = 'Light in the bag. Ready anywhere.'
          assign role_decision_note = 'Made for work on the move.'
          assign ownership_heading = 'Support for the move'
        when 'usb-c-pro-dock'
          assign use_owned_product_gallery = true
          assign setup_label = 'Desk'
          assign setup_statement = 'Ports, power, and displays for the desk.'
          assign setup_environment = 'Clean, connected, in control.'
          assign role_decision_note = 'Made for the desk.'
          assign ownership_heading = 'Support for the desk'
        when 'usb-c-multimedia-hub'
          assign use_owned_product_gallery = true
          assign setup_label = 'Everyday'
          assign setup_statement = 'Balanced ports and power for everyday desks.'
          assign setup_environment = 'Charging, displays, Ethernet, and storage.'
          assign role_decision_note = 'Made for everyday desks.'
          assign ownership_heading = 'Support for everyday desks'
      endcase

      if support_summary_text != blank
        assign ownership_copy = support_summary_text
      endif

      if review_rating_value != blank
        assign mobile_proof_line = review_rating_value | append: ' / 5 rated'
        if review_rating_count != blank
          assign mobile_proof_line = mobile_proof_line | append: ' · ' | append: review_rating_count | append: ' reviews'
        endif
      endif

      assign compatibility_text_downcase = compatibility_summary_text | downcase
      assign description_text_downcase = product_description_excerpt | downcase
      assign title_text_downcase = product.title | downcase
      assign type_text_downcase = product.type | downcase

      if compatibility_text_downcase contains 'mac' and compatibility_text_downcase contains 'window'
        assign sticky_trust_line = 'Works with Mac & Windows'
      elsif description_text_downcase contains 'mac' and description_text_downcase contains 'window'
        assign sticky_trust_line = 'Works with Mac & Windows'
      elsif title_text_downcase contains 'usb-c' or type_text_downcase contains 'usb-c' or description_text_downcase contains 'usb-c'
        assign sticky_trust_line = 'Fits most USB-C laptops'
      else
        assign sticky_trust_line = 'Works with Mac & Windows'
      endif

      if review_rating_value == blank
        if manual_count > 0 and download_count > 0
          assign proof_fallback_line = 'Support, manuals, and downloads available'
        elsif manual_count > 0
          assign proof_fallback_line = 'Support and manuals available'
        elsif download_count > 0
          assign proof_fallback_line = 'Support and downloads available'
        elsif compatibility_summary_text != blank
          assign proof_fallback_line = 'Compatibility guidance available'
        else
          assign proof_fallback_line = 'EZQuest support available'
        endif

        assign mobile_proof_line = proof_fallback_line
      endif

      if product.has_only_default_variant == false and selected_variant != blank
        if product.options_with_values.first != blank
          assign selected_option_label = product.options_with_values.first.name
        endif
        assign selected_option_summary = selected_variant.options.first | default: selected_variant.title
        assign variant_reinforcement_text = 'Selected: ' | append: selected_variant.title
        if selected_variant.available
          assign variant_reinforcement_text = variant_reinforcement_text | append: ' · In stock'
        else
          assign variant_reinforcement_text = variant_reinforcement_text | append: ' · Sold out'
        endif
      elsif selected_variant != blank
        assign selected_option_summary = selected_variant.title
      endif
    -%}

    <div class="lg:hidden">
      <nav class="mb-4" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
          <li><a href="{{ routes.root_url }}" class="hover:text-slate-900">Home</a></li>
          {% if back_collection_url != blank %}
            <li aria-hidden="true">/</li>
            <li><a href="{{ back_collection_url }}" class="hover:text-slate-900">{{ back_collection_title }}</a></li>
          {% endif %}
          <li aria-hidden="true">/</li>
          <li aria-current="page">{{ product.title }}</li>
        </ol>
      </nav>
      <div class="product-context-row">
        {% if back_collection_url != blank %}
          <a href="{{ back_collection_url }}" class="site-meta-link">{{ back_collection_label }}</a>
        {% endif %}
        <a href="{{ setup_guide_url }}" class="site-meta-link">Shop by setup</a>
      </div>
    </div>

    <div class="mt-4 grid gap-8 lg:mt-6 product-layout-grid lg:items-start lg:gap-10">
      <div class="space-y-5 motion-fade-up">
        <div class="product-gallery-stage product-gallery-stage-shell">
          <div class="product-gallery-layout">
            <div class="product-gallery-grid product-gallery-grid--rail">
              {% if lead_media != blank %}
                <button type="button" class="product-thumb-card" aria-current="true">
                  {% render 'media', media: lead_media, aspect_ratio: 'aspect-square', class: 'bg-white p-2 shadow-none', object_fit: 'object-contain' %}
                </button>
              {% elsif product.featured_image != blank %}
                <button type="button" class="product-thumb-card" aria-current="true">
                  {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-square', class: 'bg-white p-2 shadow-none', object_fit: 'object-contain' %}
                </button>
              {% elsif use_owned_product_gallery and lead_media == blank and product.featured_image == blank %}
                <button type="button" class="product-thumb-card" aria-current="true">
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'hero', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
              {% endif %}

              {% if product.media.size > 1 %}
                {% for media_item in product.media limit: 6 %}
                  {% unless lead_media != blank and media_item.id == lead_media.id %}
                    <button type="button" class="product-thumb-card">
                      {% render 'media', media: media_item, aspect_ratio: 'aspect-square', class: 'bg-white p-2 shadow-none', object_fit: 'object-contain' %}
                    </button>
                  {% endunless %}
                {% endfor %}
              {% elsif use_owned_product_gallery and lead_media == blank and product.featured_image == blank %}
                <button type="button" class="product-thumb-card">
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'ports', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
                <button type="button" class="product-thumb-card">
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'setup', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
              {% endif %}
            </div>

            <div class="product-gallery-main-shell">
              <div class="product-gallery-stage-note">
                <span class="product-gallery-stage-label">{{ setup_label }}</span>
                <p class="product-gallery-stage-copy hidden lg:block">{{ setup_environment }}</p>
              </div>

              <div class="product-gallery-main">
                {% if lead_media != blank %}
                  {% render 'media', media: lead_media, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
                {% elsif product.featured_image != blank %}
                  {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
                {% elsif use_owned_product_gallery and lead_media == blank and product.featured_image == blank %}
                  <div class="hero-media-frame p-2 lg:p-3">
                    {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'hero', width: 1600, height: 1200, class: 'aspect-card w-full object-cover', loading: 'eager', fetchpriority: 'high' %}
                  </div>
                {% else %}
                  {% render 'placeholder-visual', kind: 'product', text: product.title, width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-4 lg:space-y-5 buybox-sticky motion-fade-up" style="--reveal-delay: 80ms">
        <div class="product-buybox card-elevated p-5 lg:p-6">
          <div class="product-buybox-header">
            <div class="product-buybox-topline">
              {% if section.settings.show_vendor and product.vendor != blank %}
                <p class="product-buybox-brand">{{ product.vendor }}</p>
              {% endif %}
              {% if section.settings.show_product_type and product.type != blank %}
                <span class="product-meta-pill product-meta-pill--desktop">{{ product.type }}</span>
              {% endif %}
            </div>

            <div class="product-buybox-headline-row">
              <div class="product-buybox-lead">
                <h1 class="section-heading product-buybox-title">{{ product.title }}</h1>
                {% if display_rating_value != blank %}
                  <div class="product-buybox-review-row" aria-label="Rated {{ display_rating_value }} out of 5{% if display_rating_count != blank %} from {{ display_rating_count }} reviews{% endif %}">
                    <span class="product-buybox-stars" aria-hidden="true">★★★★★</span>
                    <span class="product-buybox-review-value">{{ display_rating_value }}</span>
                    {% if display_rating_count != blank %}
                      <span class="product-buybox-review-count">{{ display_rating_count }} reviews</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>

              <div class="product-buybox-price" data-product-price-block>
                {% render 'price', product: product, variant: product.selected_or_first_available_variant %}
              </div>
            </div>

            <div class="product-buybox-price-row">
              <p class="product-buybox-setup-statement">{{ setup_statement }}</p>
              {% if product_positioning_text != blank %}
                <p class="product-buybox-positioning">{{ product_positioning_text }}</p>
              {% else %}
                <p class="product-buybox-positioning">{{ role_decision_note }}</p>
              {% endif %}
            </div>
          </div>

          {% form 'product', product, id: product_form_id, class: 'mt-5 space-y-4 lg:mt-6 lg:space-y-5' %}
            <div class="product-form-panel card-soft space-y-4 p-5 lg:space-y-5" data-main-buybox>
              {% if product.has_only_default_variant == false %}
                <div class="product-buybox-option-shell">
                  <div class="product-buybox-option-head">
                    <p class="product-buybox-option-label">{{ selected_option_label }}</p>
                    <p class="product-buybox-option-selected" data-product-selected-variant-label>{{ selected_option_summary }}</p>
                  </div>
                  <select id="ProductVariant-{{ section.id }}" name="id" class="sr-only" data-product-variant-select>
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" data-variant-price="{{ variant.price | money | escape }}" data-variant-compare-price="{{ variant.compare_at_price | money | escape }}" data-variant-save-label="{% if variant.compare_at_price > variant.price %}Save {{ variant.compare_at_price | minus: variant.price | money | escape }}{% endif %}" data-variant-available="{% if variant.available %}true{% else %}false{% endif %}" data-variant-title="{{ variant.title | escape }}" data-variant-option-label="{{ variant.options.first | default: variant.title | escape }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                        {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                  {%- assign first_opt_lower = product.options_with_values.first.name | downcase -%}
                  {%- assign is_color_option = false -%}
                  {%- if first_opt_lower contains 'color' or first_opt_lower contains 'colour' or first_opt_lower contains 'finish' -%}
                    {%- assign is_color_option = true -%}
                  {%- endif -%}
                  {% if is_color_option %}
                    <div class="product-swatch-row" role="list" aria-label="{{ selected_option_label }}">
                      {% for variant in product.variants %}
                        <button
                          type="button"
                          class="product-swatch{% if variant == product.selected_or_first_available_variant %} is-active{% endif %}"
                          data-product-variant-chip
                          data-variant-id="{{ variant.id }}"
                          aria-pressed="{% if variant == product.selected_or_first_available_variant %}true{% else %}false{% endif %}"
                          title="{{ variant.options.first | default: variant.title }}"
                          data-swatch="{{ variant.options.first | handleize }}"
                          {% unless variant.available %} data-unavailable="true"{% endunless %}
                        >
                          {% if variant.featured_image != blank %}
                            <img src="{{ variant.featured_image | image_url: width: 80 }}" alt="{{ variant.options.first }}" width="40" height="40" loading="lazy">
                          {% endif %}
                          <span class="sr-only">{{ variant.options.first | default: variant.title }}</span>
                        </button>
                      {% endfor %}
                    </div>
                  {% else %}
                    <div class="product-variant-chip-row" role="list">
                      {% for variant in product.variants %}
                        <button type="button" class="product-variant-chip{% if variant == product.selected_or_first_available_variant %} is-active{% endif %}" data-product-variant-chip data-variant-id="{{ variant.id }}" aria-pressed="{% if variant == product.selected_or_first_available_variant %}true{% else %}false{% endif %}"{% unless variant.available %} data-unavailable="true"{% endunless %}>
                          <span class="product-variant-chip-title">{{ variant.options.first | default: variant.title }}</span>
                          {% unless variant.available %}
                            <span class="product-variant-chip-meta">Sold out</span>
                          {% endunless %}
                        </button>
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% if variant_reinforcement_text != blank %}
                    <p class="product-variant-reinforcement" data-product-variant-reinforcement>{{ variant_reinforcement_text }}</p>
                  {% endif %}
                </div>
              {% else %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {% endif %}

              {% if section.settings.show_accessories_row and section.settings.accessories_collection != blank %}
                <details class="product-accessories-row">
                  <summary class="product-accessories-summary">
                    <span class="product-accessories-icon" aria-hidden="true">{% render 'icon', name: 'layers' %}</span>
                    More accessories
                    <span class="product-accessories-chevron" aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
                  </summary>
                  <div class="product-accessories-body">
                    <a href="{{ section.settings.accessories_collection.url }}" class="product-accessories-link">{{ section.settings.accessories_collection.title }}</a>
                  </div>
                </details>
              {% endif %}

              {% if show_urgency %}
                <p class="product-urgency-line" role="status">
                  Hurry, only {{ urgency_qty }} item{% if urgency_qty != 1 %}s{% endif %} left in stock!
                </p>
              {% endif %}

              <div class="product-purchase-row">
                {% if section.settings.show_quantity_selector %}
                  <div class="hidden lg:block product-buybox-quantity-shell">
                    <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductQuantity-{{ section.id }}">Quantity</label>
                    <input id="ProductQuantity-{{ section.id }}" class="product-buybox-quantity-input" type="number" name="quantity" value="1" min="1">
                  </div>
                {% endif %}

                <div class="product-primary-action-wrap w-full" data-product-primary-action-wrap>
                  <button class="button-primary product-primary-action" type="submit" name="add" data-product-primary-button{% unless product.available %} disabled="disabled"{% endunless %}>
                    <span data-product-primary-button-label>{% if product.available %}Add to cart{% else %}Sold out{% endif %}</span>
                    <span class="product-primary-action-divider" aria-hidden="true" data-product-primary-button-divider>·</span>
                    <span data-product-primary-button-price>{{ product.selected_or_first_available_variant.price | money }}</span>
                  </button>
                </div>
              </div>

              {% if section.settings.show_dynamic_checkout %}
                <div class="product-form-payment">
                  {{ form | payment_button }}
                </div>
              {% endif %}

            </div>
          {% endform %}

          {% if section.settings.show_pickup_availability %}
            <div class="product-pickup-row">
              <span class="product-pickup-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false"><circle cx="8" cy="8" r="7" fill="rgba(220,38,38,0.12)"/><circle cx="8" cy="8" r="3" fill="rgb(220,38,38)"/></svg>
              </span>
              <span class="product-pickup-text">
                {% if product.available %}
                  Pickup currently unavailable at {{ section.settings.pickup_location | default: 'local store' }}
                {% else %}
                  Pickup unavailable for this item
                {% endif %}
              </span>
              {% if section.settings.pickup_check_url != blank %}
                <a href="{{ section.settings.pickup_check_url }}" class="product-pickup-link">Check availability at other stores</a>
              {% endif %}
            </div>
          {% endif %}

          <div class="product-share-row">
            <span class="product-share-label">Share</span>
            <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url | url_encode }}" class="product-share-link" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">{% render 'icon', name: 'facebook' %}</a>
            <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url | url_encode }}&amp;text={{ product.title | url_encode }}" class="product-share-link" target="_blank" rel="noopener noreferrer" aria-label="Share on X">{% render 'icon', name: 'x-social' %}</a>
            <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url | url_encode }}&amp;description={{ product.title | url_encode }}" class="product-share-link" target="_blank" rel="noopener noreferrer" aria-label="Share on Pinterest">{% render 'icon', name: 'pinterest' %}</a>
            <a href="mailto:?subject={{ product.title | url_encode }}&amp;body={{ shop.url }}{{ product.url }}" class="product-share-link" aria-label="Share via Email">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false"><rect x="2.5" y="4.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.7"/><path d="M2.5 6.5 9 11l6.5-4.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <div class="product-trust-grid" aria-label="Purchase confidence">
            <div class="product-trust-item">
              {% render 'icon', name: 'check' %}
              <span>In stock</span>
            </div>
            <div class="product-trust-item">
              {% render 'icon', name: 'shield' %}
              <span>30-day returns</span>
            </div>
            <div class="product-trust-item">
              {% render 'icon', name: 'spark' %}
              <span>2-year warranty</span>
            </div>
            <div class="product-trust-item">
              {% render 'icon', name: 'truck' %}
              <span>Free shipping</span>
            </div>
          </div>

          <div class="product-view-details-row">
            <a href="#product-highlights" class="product-view-details-link">
              View full details
              {% render 'icon', name: 'arrow-right' %}
            </a>
          </div>

          {%- capture product_fit_content -%}
            <div class="product-mobile-detail-stack">
              <p class="product-mobile-detail-copy">{{ setup_statement }}</p>
              {% if product_positioning_text != blank %}
                <p class="product-mobile-detail-copy">{{ product_positioning_text }}</p>
              {% else %}
                <p class="product-mobile-detail-copy">{{ role_decision_note }}</p>
              {% endif %}
              <div class="product-buybox-signal-grid product-buybox-signal-grid--mobile">
                <div class="product-buybox-signal">
                  <p class="product-buybox-signal-label">Fit</p>
                  <p class="product-buybox-signal-value">{{ setup_label }}</p>
                </div>
                {% if spec_count > 0 %}
                  <div class="product-buybox-signal">
                    <p class="product-buybox-signal-label">Specs</p>
                    <p class="product-buybox-signal-value">{{ spec_count }} key spec{% if spec_count != 1 %}s{% endif %}</p>
                  </div>
                {% endif %}
                {% if manual_count > 0 or download_count > 0 %}
                  <div class="product-buybox-signal">
                    <p class="product-buybox-signal-label">Support</p>
                    <p class="product-buybox-signal-value">
                      {% if manual_count > 0 %}{{ manual_count }} manual{% if manual_count != 1 %}s{% endif %}{% endif %}
                      {% if manual_count > 0 and download_count > 0 %} + {% endif %}
                      {% if download_count > 0 %}{{ download_count }} download{% if download_count != 1 %}s{% endif %}{% endif %}
                    </p>
                  </div>
                {% endif %}
              </div>
            </div>
          {%- endcapture -%}

          {%- capture product_support_content -%}
            <div class="product-mobile-detail-stack">
              <div class="product-assurance-grid product-assurance-grid--mobile">
                <div class="product-confidence-item">
                  <p class="product-confidence-title">Fit</p>
                  <p class="mt-2">
                    {% if compatibility_summary_text != blank %}
                      {{ compatibility_summary_text | truncatewords: 10 }}
                    {% else %}
                      Mac and Windows ready
                    {% endif %}
                  </p>
                </div>
                <div class="product-confidence-item">
                  <p class="product-confidence-title">Why it stands out</p>
                  <p class="mt-2">
                    {% if first_structured_highlight != blank %}
                      {{ first_structured_highlight | truncatewords: 10 }}
                    {% else %}
                      Clean, plug-in setup
                    {% endif %}
                  </p>
                </div>
                <div class="product-confidence-item">
                  <p class="product-confidence-title">Support</p>
                  <p class="mt-2">
                    {% if support_summary_text != blank %}
                      {{ support_summary_text | truncatewords: 10 }}
                    {% else %}
                      Manuals, downloads, help
                    {% endif %}
                  </p>
                </div>
              </div>

              {% if section.settings.show_support_panel %}
                <div class="product-buybox-confidence mt-0">
                  <p class="product-buybox-confidence-kicker">{{ section.settings.support_eyebrow | default: 'Support' }}</p>
                  <p class="product-buybox-confidence-heading">{{ ownership_heading }}</p>
                  <div class="product-buybox-confidence-copy">
                    {{ ownership_copy | truncatewords: 22 }}
                  </div>
                </div>
              {% endif %}
            </div>
          {%- endcapture -%}

          {%- capture product_features_content -%}
            {% if has_structured_highlights or section.blocks.size > 0 %}
              {%- assign mobile_rendered_highlights = 0 -%}
              <div class="product-highlight-shell product-highlight-shell--mobile">
                <div class="product-highlights">
                  {% if has_structured_highlights %}
                    {% for highlight in structured_highlights limit: section.settings.highlight_limit %}
                      {% if mobile_rendered_highlights < 3 %}
                        <div class="product-highlight-card">
                          <p class="product-highlight-index">0{{ forloop.index }}</p>
                          <div class="product-highlight-copy">{{ highlight }}</div>
                        </div>
                        {%- assign mobile_rendered_highlights = mobile_rendered_highlights | plus: 1 -%}
                      {% endif %}
                    {% endfor %}
                  {% elsif section.blocks.size > 0 %}
                    {% for block in section.blocks %}
                      {% if mobile_rendered_highlights < 3 %}
                        <div class="product-highlight-card" {{ block.shopify_attributes }}>
                          <p class="product-highlight-index">0{{ mobile_rendered_highlights | plus: 1 }}</p>
                          <div class="product-highlight-copy">{{ block.settings.title }}</div>
                        </div>
                        {%- assign mobile_rendered_highlights = mobile_rendered_highlights | plus: 1 -%}
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            {% endif %}
	          {%- endcapture -%}

            {%- assign product_features_content_stripped = product_features_content | strip -%}
            {%- assign product_support_content_stripped = product_support_content | strip -%}

	          <div class="product-mobile-accordions lg:hidden">
	            {% render 'accordion-item', title: 'Fit', content: product_fit_content %}
	            {% if product_features_content_stripped != blank %}
	              {% render 'accordion-item', title: 'Features', content: product_features_content %}
	            {% endif %}
	            {% if product_support_content_stripped != blank %}
	              {% render 'accordion-item', title: 'Support', content: product_support_content %}
	            {% endif %}
	          </div>

	          <div class="product-link-row product-link-row--mobile lg:hidden">
              {% if back_collection_url != blank %}
	            <a href="{{ back_collection_url }}" class="site-meta-link">{{ back_collection_label }}</a>
              {% endif %}
	            <a href="{{ compare_products_url }}" class="site-meta-link">Compare models</a>
	            <a href="{{ support_center_url }}" class="site-meta-link">Support</a>
	          </div>

        </div>
      </div>
    </div>

    <div class="product-secondary-details hidden lg:block" id="product-highlights">
      <div class="product-highlight-shell">
        <p class="product-highlight-kicker">Key specs</p>
        <div class="product-highlights product-highlights--specs">
          {% if product_spec_rows != blank and product_spec_rows.count > 0 %}
            {% for row in product_spec_rows limit: 6 %}
              {%- assign hl_label_lower = row.label.value | downcase -%}
              {%- assign hl_icon = 'spark' -%}
              {%- if hl_label_lower contains 'speed' or hl_label_lower contains 'transfer' -%}{%- assign hl_icon = 'bolt' -%}{%- endif -%}
              {%- if hl_label_lower contains 'port' or hl_label_lower contains 'hub' -%}{%- assign hl_icon = 'layers' -%}{%- endif -%}
              {%- if hl_label_lower contains 'power' or hl_label_lower contains 'watt' or hl_label_lower contains 'charg' -%}{%- assign hl_icon = 'bolt' -%}{%- endif -%}
              {%- if hl_label_lower contains 'display' or hl_label_lower contains 'resolution' or hl_label_lower contains 'video' -%}{%- assign hl_icon = 'monitor' -%}{%- endif -%}
              {%- if hl_label_lower contains 'length' -%}{%- assign hl_icon = 'map' -%}{%- endif -%}
              {%- if hl_label_lower contains 'weight' -%}{%- assign hl_icon = 'layers' -%}{%- endif -%}
              {%- if hl_label_lower contains 'compat' or hl_label_lower contains 'system' -%}{%- assign hl_icon = 'check' -%}{%- endif -%}
              {%- if hl_label_lower contains 'connect' or hl_label_lower contains 'type' -%}{%- assign hl_icon = 'tag' -%}{%- endif -%}
              <div class="product-highlight-card product-highlight-card--spec">
                <span class="product-highlight-icon" aria-hidden="true">{% render 'icon', name: hl_icon %}</span>
                <span class="product-highlight-spec-label">{{ row.label.value }}</span>
                <span class="product-highlight-spec-value">{{ row.spec_value.value | truncatewords: 5 }}</span>
              </div>
            {% endfor %}
          {% elsif has_structured_highlights %}
            {% for highlight in structured_highlights limit: 6 %}
              <div class="product-highlight-card product-highlight-card--spec">
                <span class="product-highlight-icon" aria-hidden="true">{% render 'icon', name: 'spark' %}</span>
                <span class="product-highlight-spec-label">Highlight {{ forloop.index }}</span>
                <span class="product-highlight-spec-value">{{ highlight | truncatewords: 5 }}</span>
              </div>
            {% endfor %}
          {% elsif section.blocks.size > 0 %}
            {% for block in section.blocks limit: 6 %}
              <div class="product-highlight-card product-highlight-card--spec" {{ block.shopify_attributes }}>
                <span class="product-highlight-icon" aria-hidden="true">{% render 'icon', name: 'spark' %}</span>
                <span class="product-highlight-spec-label">Highlight {{ forloop.index }}</span>
                <span class="product-highlight-spec-value">{{ block.settings.title | truncatewords: 4 }}</span>
              </div>
            {% endfor %}
          {% else %}
            <div class="product-highlight-card product-highlight-card--spec">
              <span class="product-highlight-icon" aria-hidden="true">{% render 'icon', name: 'check' %}</span>
              <span class="product-highlight-spec-label">Fit</span>
              <span class="product-highlight-spec-value">{{ setup_label }}</span>
            </div>
            <div class="product-highlight-card product-highlight-card--spec">
              <span class="product-highlight-icon" aria-hidden="true">{% render 'icon', name: 'check' %}</span>
              <span class="product-highlight-spec-label">Compatibility</span>
              <span class="product-highlight-spec-value">Mac &amp; Windows</span>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="product-link-row">
        {% if back_collection_url != blank %}
          <a href="{{ back_collection_url }}" class="site-meta-link">{{ back_collection_label }}</a>
        {% endif %}
        <a href="{{ compare_products_url }}" class="site-meta-link">Compare models</a>
        <a href="{{ support_center_url }}" class="site-meta-link">Support</a>
      </div>
    </div>
  </div>

  <div class="product-sticky-atc" hidden data-sticky-atc>
    <div class="product-sticky-atc-shell">
      <div class="product-sticky-atc-main">
        <div class="product-sticky-atc-copy">
          <p class="product-sticky-atc-title">{{ product.title | truncate: 28 }}</p>
          <div class="product-sticky-atc-meta">
            {% if product.has_only_default_variant == false %}
              <p class="product-sticky-atc-variant" data-sticky-atc-variant>{{ selected_option_summary }}</p>
            {% endif %}
            <p class="product-sticky-atc-availability" data-sticky-atc-availability>
              {% if product.available %}In stock{% else %}Sold out{% endif %}
            </p>
            <p class="product-sticky-atc-price" data-sticky-atc-price>{{ product.selected_or_first_available_variant.price | money }}</p>
          </div>
        </div>
        <button class="button-primary product-sticky-atc-button" type="submit" name="add" form="{{ product_form_id }}" data-sticky-atc-button{% unless product.available %} disabled="disabled"{% endunless %}>
          <span data-sticky-atc-button-label>{% if product.available %}Add to cart{% else %}Sold out{% endif %}</span>
          <span class="product-primary-action-divider" aria-hidden="true" data-sticky-atc-button-divider>·</span>
          <span data-sticky-atc-button-price>{{ product.selected_or_first_available_variant.price | money }}</span>
        </button>
      </div>
      {% if sticky_trust_line != blank %}
        <p class="product-sticky-atc-trust">{{ sticky_trust_line }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show selected variant SKU",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_type",
      "label": "Show product type",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_summary",
      "label": "Show product support summary when available",
      "default": true
    },
    {
      "type": "range",
      "id": "highlight_limit",
      "label": "Structured highlight limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    },
    {
      "type": "header",
      "content": "Ratings"
    },
    {
      "type": "text",
      "id": "fallback_rating",
      "label": "Fallback rating value",
      "info": "Shown when no review metafield is set. E.g. 4.8",
      "placeholder": "4.8"
    },
    {
      "type": "text",
      "id": "fallback_rating_count",
      "label": "Fallback review count",
      "info": "Number of reviews to display as fallback. E.g. 124",
      "placeholder": "124"
    },
    {
      "type": "header",
      "content": "Purchase experience"
    },
    {
      "type": "checkbox",
      "id": "show_pickup_availability",
      "label": "Show pickup availability row",
      "default": false
    },
    {
      "type": "text",
      "id": "pickup_location",
      "label": "Pickup location name",
      "default": "German Warehouse"
    },
    {
      "type": "url",
      "id": "pickup_check_url",
      "label": "Check availability URL"
    },
    {
      "type": "checkbox",
      "id": "show_accessories_row",
      "label": "Show More accessories row",
      "default": false
    },
    {
      "type": "collection",
      "id": "accessories_collection",
      "label": "Accessories collection"
    },
    {
      "type": "header",
      "content": "Support panel"
    },
    {
      "type": "text",
      "id": "support_eyebrow",
      "label": "Support panel eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support panel heading",
      "default": "Support stays close"
    },
    {
      "type": "textarea",
      "id": "support_copy",
      "label": "Support panel copy",
      "default": "Compatibility, manuals, downloads, and help."
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Mac and Windows ready"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Clear product value."
        }
      ]
    }
  ]
}
{% endschema %}
