<section class="section-shell">
  <div class="container-shell">
    {% render 'breadcrumbs' %}
    {%- liquid
      assign structured_highlights = blank
      assign has_structured_highlights = false
      assign lead_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media

      if product.metafields.ezquest.feature_highlights != blank
        assign structured_highlights = product.metafields.ezquest.feature_highlights.value
        if structured_highlights.count > 0
          assign has_structured_highlights = true
        endif
      endif
    -%}

    <div class="product-layout mt-6">
      <div class="product-gallery">
        <div class="product-gallery-stage">
          <div class="product-gallery-main">
          {% if lead_media != blank %}
            {% render 'media', media: lead_media, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
          {% elsif product.featured_image != blank %}
            {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-card', class: 'hero-media-frame p-2 lg:p-3', object_fit: 'object-contain' %}
          {% else %}
            {% render 'placeholder-visual', kind: 'product', text: product.title, width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
          {% endif %}
          </div>

          {% if product.media.size > 1 %}
            <div class="product-gallery-grid mt-5">
              {% for media_item in product.media limit: 5 %}
                {% unless lead_media != blank and media_item.id == lead_media.id %}
                  <div class="product-thumb-card">
                    {% render 'media', media: media_item, aspect_ratio: 'aspect-card', class: 'bg-white p-2 shadow-none', object_fit: 'object-contain' %}
                  </div>
                {% endunless %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="space-y-6 buybox-sticky">
        <div class="product-buybox">
          <div class="product-buybox-header">
            <div class="product-meta-row">
              {% if section.settings.show_vendor and product.vendor != blank %}
                <span class="product-meta-pill">{{ product.vendor }}</span>
              {% endif %}
              {% if section.settings.show_product_type and product.type != blank %}
                <span class="product-meta-pill">{{ product.type }}</span>
              {% endif %}
              {% if product.available %}
                <span class="product-meta-pill border-emerald-200 bg-emerald-50 text-emerald-700">Ready to order</span>
              {% else %}
                <span class="product-meta-pill border-slate-300 bg-slate-100 text-slate-600">Sold out</span>
              {% endif %}
            </div>

            <h1 class="section-heading mt-4">{{ product.title }}</h1>

            <div class="product-buybox-price">
              <div>
                {% render 'price', product: product, variant: product.selected_or_first_available_variant %}
              </div>
            </div>

            <div class="product-buybox-confidence">
              Check compatibility, manuals, and downloads before you order if your Mac, PC, tablet, display, or charging setup needs a closer fit check.
            </div>
          </div>

          {% form 'product', product, class: 'mt-8 space-y-5' %}
            <div class="product-form-panel space-y-5">
              {% if product.has_only_default_variant == false %}
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductVariant-{{ section.id }}">Variant</label>
                  <select id="ProductVariant-{{ section.id }}" name="id" class="min-h-12 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900">
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                        {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% else %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {% endif %}

              <div class="grid gap-4 sm:grid-cols-auto-fill sm:items-end">
                {% if section.settings.show_quantity_selector %}
                  <div>
                    <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductQuantity-{{ section.id }}">Quantity</label>
                    <input id="ProductQuantity-{{ section.id }}" class="min-h-12 w-28 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900" type="number" name="quantity" value="1" min="1">
                  </div>
                {% endif %}
                <div class="product-primary-action-wrap">
                  <button class="button-primary product-primary-action" type="submit" name="add"{% unless product.available %} disabled="disabled"{% endunless %}>
                    {% if product.available %}Add to cart{% else %}Sold out{% endif %}
                  </button>
                </div>
              </div>

              <div class="product-form-meta">
                <a href="/pages/compare" class="hero-secondary-action">Compare nearby EZQuest options</a>
              </div>

              {% if section.settings.show_dynamic_checkout %}
                <div class="product-form-payment">
                  {{ form | payment_button }}
                </div>
              {% endif %}
            </div>
          {% endform %}

          <div class="product-assurance-grid">
            <div class="product-confidence-item">
              <p class="section-kicker">Compatibility</p>
              <p class="mt-2">Works with Mac + Windows</p>
            </div>
            <div class="product-confidence-item">
              <p class="section-kicker">Setup</p>
              <p class="mt-2">Plug & play setup</p>
            </div>
            <div class="product-confidence-item">
              <p class="section-kicker">Support</p>
              <p class="mt-2">Manuals, downloads, and setup help available</p>
            </div>
          </div>

          <div class="product-link-row">
            <a href="/pages/compare" class="site-meta-link">Compare this product</a>
            <a href="/pages/downloads" class="site-meta-link">Downloads</a>
            <a href="/pages/manuals" class="site-meta-link">Manuals</a>
            <a href="/pages/compatibility" class="site-meta-link">Compatibility</a>
          </div>

          {% if has_structured_highlights or section.blocks.size > 0 %}
            {%- assign rendered_highlights = 0 -%}
            <div class="product-highlight-shell">
              <p class="section-kicker">At a glance</p>
              <div class="product-highlights mt-4">
                {% if has_structured_highlights %}
                  {% for highlight in structured_highlights limit: section.settings.highlight_limit %}
                    {% if rendered_highlights < 3 %}
                      <div class="product-highlight-card">
                        <div class="text-sm font-semibold leading-6 text-slate-950">{{ highlight }}</div>
                      </div>
                      {%- assign rendered_highlights = rendered_highlights | plus: 1 -%}
                    {% endif %}
                  {% endfor %}
                {% elsif section.blocks.size > 0 %}
                  {% for block in section.blocks %}
                    {% if rendered_highlights < 3 %}
                      <div class="product-highlight-card" {{ block.shopify_attributes }}>
                        <div class="text-sm font-semibold leading-6 text-slate-950">{{ block.settings.title }}</div>
                      </div>
                      {%- assign rendered_highlights = rendered_highlights | plus: 1 -%}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show selected variant SKU",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_type",
      "label": "Show product type",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_summary",
      "label": "Show product support summary when available",
      "default": true
    },
    {
      "type": "range",
      "id": "highlight_limit",
      "label": "Structured highlight limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    },
    {
      "type": "text",
      "id": "support_eyebrow",
      "label": "Support panel eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support panel heading",
      "default": "Setup help stays close to the product"
    },
    {
      "type": "textarea",
      "id": "support_copy",
      "label": "Support panel copy",
      "default": "Compatibility guidance, manuals, downloads, and direct support stay nearby without overwhelming the buying flow."
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Works with Mac + Windows"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Short buying-confidence point."
        }
      ]
    }
  ]
}
{% endschema %}
