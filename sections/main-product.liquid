<section class="section-shell">
  <div class="container-shell">
    {% render 'breadcrumbs' %}
    {%- liquid
      assign support_heading = section.settings.support_heading | default: 'Implementation-ready buy box'
      assign support_copy = section.settings.support_copy | default: 'Reserved for compatibility guidance, installation notes, or direct support handoff messaging.'
    -%}

    <div class="product-layout">
      <div class="space-y-5">
        {%- liquid
          assign lead_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
        -%}
        {% if lead_media != blank %}
          {% render 'media', media: lead_media, aspect_ratio: 'aspect-[4/3]', class: 'bg-white p-4 lg:p-6', object_fit: 'object-contain' %}
        {% elsif product.featured_image != blank %}
          {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-[4/3]', class: 'bg-white p-4 lg:p-6', object_fit: 'object-contain' %}
        {% endif %}

        {% if product.media.size > 0 %}
          <div class="grid gap-4 sm:grid-cols-2">
            {% for media_item in product.media limit: 4 %}
              {% unless media_item.id == lead_media.id %}
                {% render 'media', media: media_item, aspect_ratio: 'aspect-[4/3]', class: 'bg-white p-3', object_fit: 'object-contain' %}
              {% endunless %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="product-buybox lg:sticky lg:top-6">
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
          {% if section.settings.show_vendor and product.vendor != blank %}
            <span>{{ product.vendor }}</span>
          {% endif %}
          {% if section.settings.show_product_type and product.type != blank %}
            <span>{{ product.type }}</span>
          {% endif %}
          {% if section.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
            <span>SKU {{ product.selected_or_first_available_variant.sku }}</span>
          {% endif %}
        </div>

        <h1 class="section-heading mt-4">{{ product.title }}</h1>

        <div class="mt-5">
          {% render 'price', product: product, variant: product.selected_or_first_available_variant %}
        </div>

        {% if section.settings.show_description and product.description != blank %}
          <div class="section-copy mt-5">{{ product.description | strip_html | truncatewords: 42 }}</div>
        {% endif %}

        <div class="product-highlights mt-8">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              <div class="product-highlight-card" {{ block.shopify_attributes }}>
                <div class="text-sm font-medium text-slate-900">{{ block.settings.title }}</div>
                {% if block.settings.copy != blank %}
                  <p class="mt-2 text-sm text-slate-600">{{ block.settings.copy }}</p>
                {% endif %}
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..3) %}
              <div class="product-highlight-card">
                <div class="text-sm font-medium text-slate-900">Highlight {{ i }}</div>
                <p class="mt-2 text-sm text-slate-600">Add highlight blocks in the theme editor to reinforce product capabilities and support continuity.</p>
              </div>
            {% endfor %}
          {% endif %}
        </div>

        {% form 'product', product, class: 'mt-8 space-y-5' %}
          <div class="space-y-5 rounded-3xl border border-slate-200 bg-slate-50 p-5">
            {% if product.has_only_default_variant == false %}
              <div>
                <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductVariant-{{ section.id }}">Variant</label>
                <select id="ProductVariant-{{ section.id }}" name="id" class="min-h-12 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3">
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                      {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            {% endif %}

            <div class="grid gap-4 sm:grid-cols-[auto_1fr] sm:items-end">
              {% if section.settings.show_quantity_selector %}
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductQuantity-{{ section.id }}">Quantity</label>
                  <input id="ProductQuantity-{{ section.id }}" class="min-h-12 w-28 rounded-2xl border border-slate-300 bg-white px-4 py-3" type="number" name="quantity" value="1" min="1">
                </div>
              {% endif %}
              <div class="flex flex-wrap gap-3">
                <button class="button-primary" type="submit" name="add"{% unless product.available %} disabled="disabled"{% endunless %}>
                  {% if product.available %}Add to cart{% else %}Sold out{% endif %}
                </button>
                {% if settings.support_contact_url != blank %}
                  {% render 'button', label: 'Contact support', url: settings.support_contact_url, style: 'secondary' %}
                {% endif %}
              </div>
            </div>

            {% if section.settings.show_dynamic_checkout %}
              <div>
                {{ form | payment_button }}
              </div>
            {% endif %}
          </div>

          {% if section.settings.show_support_panel %}
            <div class="section-frame">
              <p class="section-kicker">{{ section.settings.support_eyebrow }}</p>
              <h2 class="mt-3 text-lg font-semibold tracking-tight text-slate-900">{{ support_heading }}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-600">{{ support_copy }}</p>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show selected variant SKU",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_type",
      "label": "Show product type",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_support_panel",
      "label": "Show support panel",
      "default": true
    },
    {
      "type": "text",
      "id": "support_eyebrow",
      "label": "Support panel eyebrow",
      "default": "Support continuity"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support panel heading",
      "default": "Implementation-ready buy box"
    },
    {
      "type": "textarea",
      "id": "support_copy",
      "label": "Support panel copy",
      "default": "Reserved for compatibility guidance, installation notes, or direct support handoff messaging."
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Highlight title"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Short product buying support point."
        }
      ]
    }
  ]
}
{% endschema %}
