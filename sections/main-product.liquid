{{ 'pdp.css' | asset_url | stylesheet_tag }}
<section class="section-shell main-product-section" id="pdp-overview" data-product-root data-product-id="{{ product.id }}" data-product-price="{{ product.selected_or_first_available_variant.price | money }}">
  <div class="container-shell">
    <div class="hidden lg:block">
      {% render 'breadcrumbs' %}
    </div>
    {%- liquid
      assign structured_highlights = blank
      assign has_structured_highlights = false
      assign lead_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
      assign support_summary_text = blank
      assign compatibility_summary_text = blank
      assign compatibility_summary_html = blank
      assign first_structured_highlight = blank
      assign product_description_excerpt = blank
      assign product_positioning_text = blank
      assign review_rating_value = blank
      assign review_rating_count = blank
      assign display_rating_value = blank
      assign display_rating_count = blank
      assign amazon_rating = product.metafields.custom.amazon_rating
      assign amazon_count  = product.metafields.custom.amazon_review_count | default: 0
      assign selected_variant = product.selected_or_first_available_variant
      assign product_form_id = 'ProductForm-' | append: section.id
      assign mobile_proof_line = blank
      assign proof_fallback_line = blank
      assign sticky_trust_line = blank
      assign variant_reinforcement_text = blank
      assign selected_option_summary = blank
      assign selected_option_label = 'Variant'
      assign role_decision_note = 'Clean connectivity.'
      assign ownership_heading = section.settings.support_heading | default: 'Support stays close'
      assign ownership_copy = section.settings.support_copy | default: 'Compatibility, manuals, downloads, and help.'
      assign setup_label = 'Everyday'
      assign setup_statement = 'Clean connectivity for everyday devices.'
      assign spec_count = 0
      assign product_spec_rows = blank
      assign manual_count = 0
      assign download_count = 0
      assign use_owned_product_gallery = false
      assign key_features = blank
      assign compatibility_support_url = '/pages/compatibility'
      assign manuals_support_url = '/pages/manuals'
      assign downloads_support_url = '/pages/downloads'
      assign support_center_url = '/pages/support'
      assign setup_guide_url = '/pages/help-me-choose'
      assign compare_products_url = '/pages/compare'
      assign amazon_url = product.metafields.ezquest.amazon_url.value
      assign back_collection = collection
      assign back_collection_url = blank
      assign back_collection_title = blank
      assign back_collection_label = 'product.back_to_products' | t

      if back_collection == blank and product.collections != blank
        for candidate_collection in product.collections
          if candidate_collection.handle == 'all' or candidate_collection.handle == 'frontpage'
            continue
          endif
          assign back_collection = candidate_collection
          break
        endfor
      endif

      if back_collection != blank
        assign back_collection_url = back_collection.url
        assign back_collection_title = back_collection.title
        assign back_collection_label = 'product.back_to' | t: collection: back_collection.title
      endif

      if product.metafields.ezquest.feature_highlights != blank
        assign structured_highlights = product.metafields.ezquest.feature_highlights.value
        if structured_highlights.count > 0
          assign has_structured_highlights = true
          assign first_structured_highlight = structured_highlights.first
        endif
      endif

      if section.settings.show_support_summary and product.metafields.ezquest.support_summary != blank
        assign support_summary_text = product.metafields.ezquest.support_summary | metafield_tag | strip_html | strip
      endif

      if product.metafields.ezquest.compatibility_summary != blank
        assign compatibility_summary_html = product.metafields.ezquest.compatibility_summary | metafield_tag
        assign compatibility_summary_text = compatibility_summary_html | strip_html | strip
      endif

      if product.metafields.custom.key_features != blank
        assign key_features = product.metafields.custom.key_features.value
      endif

      if product.description != blank
        assign product_description_excerpt = product.description | strip_html | strip
      endif

      if compatibility_summary_text != blank
        assign product_positioning_text = compatibility_summary_text
      elsif support_summary_text != blank
        assign product_positioning_text = support_summary_text
      elsif section.settings.show_description and product_description_excerpt != blank
        assign product_positioning_text = product_description_excerpt | truncatewords: 14
      endif

      if product.metafields.ezquest.spec_rows != blank
        assign product_spec_rows = product.metafields.ezquest.spec_rows.value
        for spec_row in product_spec_rows
          assign spec_count = spec_count | plus: 1
        endfor
      endif

      if product.metafields.ezquest.manuals != blank
        assign manual_count = product.metafields.ezquest.manuals.value.count
      endif

      if product.metafields.ezquest.downloads != blank
        assign download_count = product.metafields.ezquest.downloads.value.count
      endif

      if product.metafields.reviews.rating != blank and product.metafields.reviews.rating.value != blank
        assign review_rating_value = product.metafields.reviews.rating.value.rating
        assign review_rating_count = product.metafields.reviews.rating_count.value | default: blank
      endif

      if amazon_rating != blank and amazon_count > 0
        assign display_rating_value = amazon_rating | round: 1
        assign display_rating_count = amazon_count
      elsif review_rating_value != blank
        assign display_rating_value = review_rating_value
        assign display_rating_count = review_rating_count
      elsif section.settings.fallback_rating != blank
        assign display_rating_value = section.settings.fallback_rating
        assign display_rating_count = section.settings.fallback_rating_count
      endif

      if product.handle != blank
        assign compatibility_support_url = compatibility_support_url | append: '?product=' | append: product.handle
        assign manuals_support_url = manuals_support_url | append: '?product=' | append: product.handle
        assign downloads_support_url = downloads_support_url | append: '?product=' | append: product.handle
        assign support_center_url = support_center_url | append: '?product=' | append: product.handle
        assign compare_products_url = compare_products_url | append: '?product=' | append: product.handle
      endif

      case product.handle
        when 'usb-c-travel-hub'
          assign use_owned_product_gallery = true
          assign setup_label = 'Travel'
          assign setup_statement = 'Compact ports and power for work on the move.'
          assign role_decision_note = 'Made for work on the move.'
          assign ownership_heading = 'Support for the move'
        when 'usb-c-pro-dock'
          assign use_owned_product_gallery = true
          assign setup_label = 'Desk'
          assign setup_statement = 'Ports, power, and displays for the desk.'
          assign role_decision_note = 'Made for the desk.'
          assign ownership_heading = 'Support for the desk'
        when 'usb-c-multimedia-hub'
          assign use_owned_product_gallery = true
          assign setup_label = 'Everyday'
          assign setup_statement = 'Balanced ports and power for everyday desks.'
          assign role_decision_note = 'Made for everyday desks.'
          assign ownership_heading = 'Support for everyday desks'
      endcase

      if support_summary_text != blank
        assign ownership_copy = support_summary_text
      endif

      if display_rating_value != blank
        assign mobile_proof_line = display_rating_value | append: ' / 5 on Amazon'
        if display_rating_count != blank
          assign mobile_proof_line = mobile_proof_line | append: ' · ' | append: display_rating_count | append: ' reviews'
        endif
      endif

      assign compatibility_text_downcase = compatibility_summary_text | downcase
      assign description_text_downcase = product_description_excerpt | downcase
      assign title_text_downcase = product.title | downcase
      assign type_text_downcase = product.type | downcase

      if compatibility_text_downcase contains 'mac' and compatibility_text_downcase contains 'window'
        assign sticky_trust_line = 'Works with Mac & Windows'
      elsif description_text_downcase contains 'mac' and description_text_downcase contains 'window'
        assign sticky_trust_line = 'Works with Mac & Windows'
      elsif title_text_downcase contains 'usb-c' or type_text_downcase contains 'usb-c' or description_text_downcase contains 'usb-c'
        assign sticky_trust_line = 'Fits most USB-C laptops'
      else
        assign sticky_trust_line = 'Works with Mac & Windows'
      endif

      if review_rating_value == blank
        if manual_count > 0 and download_count > 0
          assign proof_fallback_line = 'Support, manuals, and downloads available'
        elsif manual_count > 0
          assign proof_fallback_line = 'Support and manuals available'
        elsif download_count > 0
          assign proof_fallback_line = 'Support and downloads available'
        elsif compatibility_summary_text != blank
          assign proof_fallback_line = 'Compatibility guidance available'
        else
          assign proof_fallback_line = 'EZQuest support available'
        endif

        assign mobile_proof_line = proof_fallback_line
      endif

      assign t_in_stock = 'product.in_stock' | t
      assign t_sold_out = 'product.sold_out' | t

      if product.has_only_default_variant == false and selected_variant != blank
        if product.options_with_values.first != blank
          assign selected_option_label = product.options_with_values.first.name
        endif
        assign selected_option_summary = selected_variant.options.first | default: selected_variant.title
        assign variant_reinforcement_text = 'Selected: ' | append: selected_variant.title
        if selected_variant.available
          assign variant_reinforcement_text = variant_reinforcement_text | append: ' · ' | append: t_in_stock
        else
          assign variant_reinforcement_text = variant_reinforcement_text | append: ' · ' | append: t_sold_out
        endif
      elsif selected_variant != blank
        assign selected_option_summary = selected_variant.title
      endif
    -%}

    <div class="lg:hidden">
      <nav class="mb-4" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
          <li><a href="{{ routes.root_url }}" class="hover:text-slate-900">Home</a></li>
          {% if back_collection_url != blank %}
            <li aria-hidden="true">/</li>
            <li><a href="{{ back_collection_url }}" class="hover:text-slate-900">{{ back_collection_title }}</a></li>
          {% endif %}
          <li aria-hidden="true">/</li>
          <li aria-current="page">{{ product.title }}</li>
        </ol>
      </nav>
      <div class="product-context-row">
        {% if back_collection_url != blank %}
          <a href="{{ back_collection_url }}" class="site-meta-link">{{ back_collection_label }}</a>
        {% endif %}
        <a href="{{ setup_guide_url }}" class="site-meta-link">Shop by setup</a>
      </div>
    </div>

    <div class="mt-4 grid gap-8 lg:mt-6 lg:grid-cols-2 lg:items-start lg:gap-10 product-layout-grid">
      <div class="space-y-5 min-w-0 pdp-col-left">
        <div class="product-gallery-stage product-gallery-stage-shell">
          <div class="product-gallery-layout">

            <div class="product-gallery-main-shell">

              <div
                class="product-gallery-main pdp-gallery-main"
                data-zoom-trigger
                data-pdp-main-image
                data-zoom-container
                aria-label="Open product image zoom"
                role="button"
                tabindex="0"
              >
                <span class="pdp-zoom-hint" aria-hidden="true" data-zoom-hint>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"/>
                    <path d="M9.5 9.5L12 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                    <path d="M4.5 6h3M6 4.5v3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                  <span data-zoom-hint-text>Zoom</span>
                </span>
                {% if lead_media != blank %}
                  {% render 'media', media: lead_media, aspect_ratio: 'aspect-card', class: 'hero-media-frame', object_fit: 'object-contain', loading: 'eager', fetchpriority: 'high', decoding: 'sync', max_width: 1200, sizes: '(max-width: 1023px) 100vw, 600px' %}
                {% elsif product.featured_image != blank %}
                  {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-card', class: 'hero-media-frame', object_fit: 'object-contain', loading: 'eager', fetchpriority: 'high', decoding: 'sync', max_width: 1200, sizes: '(max-width: 1023px) 100vw, 600px' %}
                {% elsif use_owned_product_gallery and lead_media == blank and product.featured_image == blank %}
                  <div class="hero-media-frame p-2 lg:p-3">
                    {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'hero', width: 1600, height: 1200, class: 'aspect-card w-full object-cover', loading: 'eager', fetchpriority: 'high' %}
                  </div>
                {% else %}
                  {% render 'placeholder-visual', kind: 'product', text: product.title, width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
                {% endif %}
              </div>
            </div>

            <div class="product-gallery-grid product-gallery-grid--rail">
              {% if lead_media != blank %}
                <button type="button" class="product-thumb-card" data-pdp-thumb aria-current="true">
                  {% render 'media', media: lead_media, aspect_ratio: 'aspect-square', class: 'bg-white p-1 shadow-none', object_fit: 'object-contain', loading: 'eager', fetchpriority: 'high', max_width: 200, widths: '100, 200', sizes: '80px' %}
                </button>
              {% elsif product.featured_image != blank %}
                <button type="button" class="product-thumb-card" data-pdp-thumb aria-current="true">
                  {% render 'media', image: product.featured_image, aspect_ratio: 'aspect-square', class: 'bg-white p-1 shadow-none', object_fit: 'object-contain', loading: 'eager', fetchpriority: 'high', max_width: 200, widths: '100, 200', sizes: '80px' %}
                </button>
              {% elsif use_owned_product_gallery and lead_media == blank and product.featured_image == blank %}
                <button type="button" class="product-thumb-card" data-pdp-thumb aria-current="true">
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'hero', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
              {% endif %}

              {% if product.media.size > 1 %}
                {% for media_item in product.media limit: 6 %}
                  {% unless lead_media != blank and media_item.id == lead_media.id %}
                    <button type="button" class="product-thumb-card" data-pdp-thumb>
                      {% render 'media', media: media_item, aspect_ratio: 'aspect-square', class: 'bg-white p-1 shadow-none', object_fit: 'object-contain', max_width: 200, widths: '100, 200', sizes: '80px' %}
                    </button>
                  {% endunless %}
                {% endfor %}
              {% elsif use_owned_product_gallery and lead_media == blank and product.featured_image == blank %}
                <button type="button" class="product-thumb-card" data-pdp-thumb>
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'setup', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
                <button type="button" class="product-thumb-card" data-pdp-thumb>
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'ports', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
                <button type="button" class="product-thumb-card" data-pdp-thumb>
                  {% render 'owned-product-visual', product_handle: product.handle, product_title: product.title, variant: 'scale', width: 320, height: 320, class: 'aspect-square w-full object-cover' %}
                </button>
              {% endif %}
            </div>

          </div>
        </div>


        <div
          id="pdp-zoom-modal"
          class="pdp-zoom-modal"
          hidden
          role="dialog"
          aria-label="Product image zoom"
          aria-modal="true"
        >
          <button type="button" class="pdp-zoom-modal__close" aria-label="Close zoom">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="pdp-zoom-modal__inner">
            <div class="pdp-zoom-modal__img-wrap" data-zoom-wrap>
              <img
                class="pdp-zoom-modal__img"
                id="pdp-zoom-img"
                alt=""
                width="2000"
                height="2000"
                draggable="false"
              >
            </div>
          </div>
          <div class="pdp-zoom-modal__hint" aria-live="polite">
            Drag to pan · Scroll to zoom · Esc to close
          </div>
        </div>
      </div>

      <div class="space-y-4 lg:space-y-5 min-w-0 buybox-sticky motion-fade-up reveal-tier-2 pdp-buy-box">

        <div class="product-buybox">

          {%- comment -%} ── Title block — direct child of card, above rating ── {%- endcomment -%}
            <header class="product-buybox__header mb-5 border-b border-slate-950/10 pb-5">
            {%- assign pdp_kicker = product.metafields.custom.kicker | default: product.type | default: product.collections.first.title -%}
            {%- if pdp_kicker != blank -%}
                <p class="product-buybox__kicker mb-3 text-caption-sm font-semibold uppercase text-slate-500">{{ pdp_kicker | upcase }}</p>
            {%- endif -%}
              <h1 class="product-buybox__title mb-3 text-heading font-bold leading-tight text-slate-950 md:text-heading-lg">{{ product.title }}</h1>
            {%- assign pdp_short_desc = product.metafields.custom.short_description | default: product.description | strip_html | strip -%}
            {%- if pdp_short_desc != blank -%}
              {%- assign pdp_truncated = pdp_short_desc | truncate: 120, '' -%}
                <p class="product-buybox__subtitle max-w-prose text-body-sm-plus text-slate-600 md:text-body-sm">
                {{- pdp_truncated -}}
                {%- if pdp_short_desc.size > 120 -%}
                  &hellip; <a href="#product-overview" class="product-buybox__full-detail">(full detail)</a>
                {%- endif -%}
              </p>
            {%- endif -%}
          </header>

          <div class="product-buybox-header space-y-4">

            <div class="product-buybox-headline-row flex flex-col gap-3">
              <div class="product-buybox-lead space-y-2.5">
                {% render 'amazon-reviews-widget', product: product, link_href: '#pdp-reviews' %}
              </div>

              <div class="product-buybox-price" data-product-price-block>
                {% render 'price', product: product, variant: product.selected_or_first_available_variant %}
              </div>

              {% comment %} ── Stock counter ─────────────────── {% endcomment %}
              {%- assign stock_counter_hidden = true -%}
              {%- assign stock_counter_class = 'stock-counter--ok' -%}
              {%- assign delivery_ts = 'now' | date: '%s' | plus: 432000 -%}
              {%- assign delivery_date_str = delivery_ts | date: '%A, %B %-d' -%}
              {%- assign stock_counter_text = 'In stock · Get it by ' | append: delivery_date_str -%}
              {%- if selected_variant.inventory_management == 'shopify' and selected_variant.inventory_policy == 'deny' -%}
                {%- assign stock = selected_variant.inventory_quantity -%}
                {%- if stock > 0 -%}
                  {%- assign stock_counter_hidden = false -%}
                  {%- if stock <= 3 -%}
                    {%- assign stock_counter_class = 'stock-counter--critical' -%}
                    {%- capture stock_counter_text -%}Only {{ stock }} left — order soon{%- endcapture -%}
                  {%- elsif stock <= 5 -%}
                    {%- assign stock_counter_class = 'stock-counter--low' -%}
                    {%- capture stock_counter_text -%}Only {{ stock }} left in stock{%- endcapture -%}
                  {%- elsif stock <= 10 -%}
                    {%- assign stock_counter_class = 'stock-counter--low' -%}
                    {%- capture stock_counter_text -%}{{ stock }} left in stock{%- endcapture -%}
                  {%- else -%}
                    {%- assign stock_counter_class = 'stock-counter--ok' -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endif -%}
              <div
                class="stock-counter {{ stock_counter_class }}{% if stock_counter_hidden %} stock-counter--hidden{% endif %}"
                id="stock-counter"
                data-inventory="{{ stock | default: 0 }}"
                aria-live="polite"
              >
                <span class="stock-counter__dot" aria-hidden="true"></span>
                <span class="stock-counter__text">{{ stock_counter_text }}</span>
              </div>
            </div>

            <div class="product-buybox-price-row flex flex-col gap-2">
              <p class="product-buybox-setup-statement text-sm leading-relaxed text-slate-700">{{ setup_statement }}</p>
            </div>

            {%- if product.description != blank -%}
              <div class="pdp-highlight" data-pdp-highlight>
                <div class="pdp-highlight__body richtext-content">{{ product.description }}</div>
                <button type="button" class="pdp-highlight__toggle" data-pdp-highlight-toggle aria-expanded="false">
                  <span data-pdp-highlight-label>Learn more</span>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3.5 5.5 7 9l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            {%- endif -%}
          </div>

          {% form 'product', product, id: product_form_id, class: 'mt-5 space-y-4 lg:mt-6 lg:space-y-5' %}
            <div class="product-form-panel product-form-panel--with-wishlist space-y-4 p-5 lg:space-y-5" data-main-buybox>
              <div class="product-wishlist-wrap">
                {% render 'wishlist-button', product: product %}
              </div>

              {% if product.has_only_default_variant == false %}
                <div class="product-buybox-option-shell grid gap-3">
                  <div class="product-buybox-option-head flex flex-wrap items-center justify-between gap-2">
                    <p class="product-buybox-option-label text-sm font-medium text-slate-500">{{ selected_option_label }}</p>
                    <p class="product-buybox-option-selected text-sm font-medium text-slate-950" data-product-selected-variant-label>{{ selected_option_summary }}</p>
                  </div>
                  <select id="ProductVariant-{{ section.id }}" name="id" class="sr-only" data-product-variant-select>
                    {% for variant in product.variants %}
                      <option value="{{ variant.id }}" data-variant-price="{{ variant.price | money | escape }}" data-variant-compare-price="{{ variant.compare_at_price | money | escape }}" data-variant-save-label="{% if variant.compare_at_price > variant.price %}Save {{ variant.compare_at_price | minus: variant.price | money | escape }}{% endif %}" data-variant-available="{% if variant.available %}true{% else %}false{% endif %}" data-variant-title="{{ variant.title | escape }}" data-variant-option-label="{{ variant.options.first | default: variant.title | escape }}" data-variant-inventory-quantity="{{ variant.inventory_quantity }}" data-variant-inventory-management="{{ variant.inventory_management }}" data-variant-inventory-policy="{{ variant.inventory_policy }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                        {{ variant.title }}{% unless variant.available %} - {{ 'product.sold_out' | t }}{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                  {%- assign first_opt_lower = product.options_with_values.first.name | downcase -%}
                  {%- assign is_color_option = false -%}
                  {%- if first_opt_lower contains 'color' or first_opt_lower contains 'colour' or first_opt_lower contains 'finish' -%}
                    {%- assign is_color_option = true -%}
                  {%- endif -%}
                  {% if is_color_option %}
                    <div class="product-swatch-row" role="list" aria-label="{{ selected_option_label }}">
                      {% for variant in product.variants %}
                        <button
                          type="button"
                          class="product-swatch{% if variant == product.selected_or_first_available_variant %} is-active{% endif %}"
                          data-product-variant-chip
                          data-variant-id="{{ variant.id }}"
                          aria-pressed="{% if variant == product.selected_or_first_available_variant %}true{% else %}false{% endif %}"
                          title="{{ variant.options.first | default: variant.title }}"
                          data-swatch="{{ variant.options.first | handleize }}"
                          {% unless variant.available %} data-unavailable="true"{% endunless %}
                        >
                          {% if variant.featured_image != blank %}
                            <img src="{{ variant.featured_image | image_url: width: 80, format: 'pjpg' }}" alt="{{ variant.options.first }}" width="40" height="40" loading="lazy">
                          {% endif %}
                          <span class="sr-only">{{ variant.options.first | default: variant.title }}</span>
                        </button>
                      {% endfor %}
                    </div>
                  {% else %}
                    <div class="product-variant-chip-row flex flex-wrap gap-2" role="list">
                      {% for variant in product.variants %}
                        <button type="button" class="product-variant-chip inline-flex min-h-12 items-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-left text-sm font-medium text-slate-700 shadow-sm shadow-slate-900/5 transition hover:-translate-y-px hover:border-slate-300 hover:text-slate-950 focus-visible:-translate-y-px focus-visible:border-slate-300 focus-visible:text-slate-950{% if variant == product.selected_or_first_available_variant %} is-active border-slate-950 bg-slate-50 text-slate-950 ring-1 ring-slate-950/10{% endif %}{% unless variant.available %} opacity-60{% endunless %}" data-product-variant-chip data-variant-id="{{ variant.id }}" aria-pressed="{% if variant == product.selected_or_first_available_variant %}true{% else %}false{% endif %}"{% unless variant.available %} data-unavailable="true"{% endunless %}>
                          <span class="product-variant-chip-title leading-none">{{ variant.options.first | default: variant.title }}</span>
                          {% unless variant.available %}
                            <span class="product-variant-chip-meta text-xs text-slate-400">{{ 'product.sold_out' | t }}</span>
                          {% endunless %}
                        </button>
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% if variant_reinforcement_text != blank %}
                    <p class="product-variant-reinforcement" data-product-variant-reinforcement>{{ variant_reinforcement_text }}</p>
                  {% endif %}
                </div>
              {% else %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {% endif %}

              {% if section.settings.show_accessories_row and section.settings.accessories_collection != blank %}
                <details class="product-accessories-row">
                  <summary class="product-accessories-summary">
                    <span class="product-accessories-icon" aria-hidden="true">{% render 'icon', name: 'layers' %}</span>
                    More accessories
                    <span class="product-accessories-chevron" aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
                  </summary>
                  <div class="product-accessories-body">
                    <a href="{{ section.settings.accessories_collection.url }}" class="product-accessories-link">{{ section.settings.accessories_collection.title }}</a>
                  </div>
                </details>
              {% endif %}

              {%- if key_features != blank -%}
                <ul class="pdp-key-features" aria-label="Key features">
                  {%- if key_features.size > 0 -%}
                    {%- for feat in key_features -%}
                      <li class="pdp-key-feature-item">{{ feat }}</li>
                    {%- endfor -%}
                  {%- else -%}
                    <li class="pdp-key-feature-item">{{ key_features }}</li>
                  {%- endif -%}
                </ul>
              {%- endif -%}

              <div class="product-purchase-row">
                {% if section.settings.show_quantity_selector %}
                  <div class="product-buybox-quantity-shell min-w-28">
                    <label class="mb-2 block text-sm font-medium text-slate-900" for="ProductQuantity-{{ section.id }}">{{ 'product.quantity' | t }}</label>
                    <input id="ProductQuantity-{{ section.id }}" class="product-buybox-quantity-input min-h-12 w-28 rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900" type="number" name="quantity" value="1" min="1">
                  </div>
                {% endif %}
                <div class="product-primary-action-wrap" data-product-primary-action-wrap>
                  <button class="btn btn--primary btn--block product-primary-action" type="submit" name="add" data-product-primary-button
                    data-label-add="{{ 'product.add_to_cart' | t | escape }}"
                    data-label-adding="{{ 'product.adding' | t | escape }}"
                    {% unless product.available %} disabled="disabled"{% endunless %}>
                    <span data-product-primary-button-label>{% if product.available %}{{ 'product.add_to_cart' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}</span>
                  </button>
                </div>
              </div>

              {% if section.settings.show_dynamic_checkout %}
                <div class="product-form-payment">
                  {{ form | payment_button }}
                </div>
              {% endif %}

              {%- comment -%} Installment messaging (Shop Pay / Klarna) — renders only when enabled in the store {%- endcomment -%}
              <div class="product-form-terms">{{ form | payment_terms }}</div>

            </div>
          {% endform %}

          <div class="pdp-trust-grid" role="list" aria-label="Purchase confidence">
            <div class="pdp-trust-item" role="listitem">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
                <path d="M9 2l6 2.5V9c0 3.5-2.5 5.5-6 7C3.5 14.5 3 12.5 3 9V4.5L9 2z" stroke="rgba(254, 211, 0, 0.96)" stroke-width="1.25" stroke-linejoin="round"/>
              </svg>
              <div>
                <p class="pdp-trust-label">{{ product.metafields.custom.warranty_years | default: '1' }}-yr warranty</p>
                <p class="pdp-trust-sub">Covered against defects</p>
              </div>
            </div>
            <div class="pdp-trust-item" role="listitem">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
                <path d="M9 13v3M6 3v4M12 3v4M5 7h8l-1 4H6L5 7z" stroke="rgba(254, 211, 0, 0.96)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <p class="pdp-trust-label">{{ 'trust.no_drivers' | t }}</p>
                <p class="pdp-trust-sub">Plug in and go</p>
              </div>
            </div>
            <div class="pdp-trust-item" role="listitem">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
                <circle cx="9" cy="9" r="6.5" stroke="rgba(254, 211, 0, 0.96)" stroke-width="1.25"/>
                <path d="M9 2.5C9 2.5 7 6 7 9s2 6.5 2 6.5M9 2.5C9 2.5 11 6 11 9s-2 6.5-2 6.5M2.5 9h13" stroke="rgba(254, 211, 0, 0.96)" stroke-width="1.25" stroke-linecap="round"/>
              </svg>
              <div>
                <p class="pdp-trust-label">{{ 'trust.mac_windows' | t }}</p>
                <p class="pdp-trust-sub">macOS &amp; Windows ready</p>
              </div>
            </div>
            <div class="pdp-trust-item" role="listitem">
              <svg width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
                <path d="M2 8h9M2 8l3-3M2 8l3 3M16 10H7M16 10l-3-3M16 10l-3 3" stroke="rgba(254, 211, 0, 0.96)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <p class="pdp-trust-label">30-day returns</p>
                <p class="pdp-trust-sub">Free, no-hassle returns</p>
              </div>
            </div>
          </div>

          {% comment %} ── Action row: Social share ── {% endcomment %}
          <div class="pdp-action-row">

            {% if amazon_url != blank %}
              <a href="{{ amazon_url }}"
                 class="pdp-amazon-btn"
                 target="_blank"
                 rel="noopener noreferrer"
                 aria-label="{{ 'product.buy_on_amazon' | t }} — {{ product.title | escape }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-amazon" viewBox="0 0 16 16">
  <path d="M10.813 11.968c.157.083.36.074.5-.05l.005.005a90 90 0 0 1 1.623-1.405c.173-.143.143-.372.006-.563l-.125-.17c-.345-.465-.673-.906-.673-1.791v-3.3l.001-.335c.008-1.265.014-2.421-.933-3.305C10.404.274 9.06 0 8.03 0 6.017 0 3.77.75 3.296 3.24c-.047.264.143.404.316.443l2.054.22c.19-.009.33-.196.366-.387.176-.857.896-1.271 1.703-1.271.435 0 .929.16 1.188.55.264.39.26.91.257 1.376v.432q-.3.033-.621.065c-1.113.114-2.397.246-3.36.67C3.873 5.91 2.94 7.08 2.94 8.798c0 2.2 1.387 3.298 3.168 3.298 1.506 0 2.328-.354 3.489-1.54l.167.246c.274.405.456.675 1.047 1.166ZM6.03 8.431C6.03 6.627 7.647 6.3 9.177 6.3v.57c.001.776.002 1.434-.396 2.133-.336.595-.87.961-1.465.961-.812 0-1.286-.619-1.286-1.533M.435 12.174c2.629 1.603 6.698 4.084 13.183.997.28-.116.475.078.199.431C13.538 13.96 11.312 16 7.57 16 3.832 16 .968 13.446.094 12.386c-.24-.275.036-.4.199-.299z"/>
  <path d="M13.828 11.943c.567-.07 1.468-.027 1.645.204.135.176-.004.966-.233 1.533-.23.563-.572.961-.762 1.115s-.333.094-.23-.137c.105-.23.684-1.663.455-1.963-.213-.278-1.177-.177-1.625-.13l-.09.009q-.142.013-.233.024c-.193.021-.245.027-.274-.032-.074-.209.779-.556 1.347-.623"/>
</svg>
                <span>{{ 'product.buy_on_amazon' | t }}</span>
              </a>
            {% endif %}

            <div class="pdp-share-strip">
              <span class="pdp-share-label">{{ 'product.share' | t }}</span>
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: product.url | url_encode }}"
                 class="pdp-share-btn pdp-share-btn--fb"
                 target="_blank" rel="noopener noreferrer"
                 aria-label="{{ 'social.share_on_facebook' | t }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                </svg>
              </a>
              <a href="https://twitter.com/intent/tweet?url={{ shop.url | append: product.url | url_encode }}&text={{ product.title | url_encode }}"
                 class="pdp-share-btn pdp-share-btn--tw"
                 target="_blank" rel="noopener noreferrer"
                 aria-label="{{ 'social.share_on_twitter' | t }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L2.25 2.25h6.988l4.27 5.646zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
              <a href="https://pinterest.com/pin/create/button/?url={{ shop.url | append: product.url | url_encode }}&media={{ product.featured_image | image_url: width: 600 | url_encode }}&description={{ product.title | url_encode }}"
                 class="pdp-share-btn pdp-share-btn--pin"
                 target="_blank" rel="noopener noreferrer"
                 aria-label="{{ 'social.save_to_pinterest' | t }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
                </svg>
              </a>
              <button class="pdp-share-btn pdp-share-btn--copy"
                      type="button"
                      aria-label="{{ 'social.copy_link' | t }}"
                      onclick="navigator.clipboard.writeText('{{ shop.url | append: product.url }}');this.setAttribute('data-copied','true');setTimeout(()=>this.removeAttribute('data-copied'),2000)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
                </svg>
              </button>
            </div>

          </div>

          {% unless product.available %}
            {% render 'notify-me-form', product: product %}
          {% endunless %}

          {% if section.settings.show_pickup_availability %}
            <div class="product-pickup-row">
              <span class="product-pickup-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false"><circle cx="8" cy="8" r="7" fill="rgba(220,38,38,0.12)"/><circle cx="8" cy="8" r="3" fill="rgb(220,38,38)"/></svg>
              </span>
              <span class="product-pickup-text">
                {% if product.available %}
                  Pickup currently unavailable at {{ section.settings.pickup_location | default: 'local store' }}
                {% else %}
                  Pickup unavailable for this item
                {% endif %}
              </span>
              {% if section.settings.pickup_check_url != blank %}
                <a href="{{ section.settings.pickup_check_url }}" class="product-pickup-link">Check availability at other stores</a>
              {% endif %}
            </div>
          {% endif %}




          {%- capture product_fit_content -%}
            <div class="product-mobile-detail-stack">
              <p class="product-mobile-detail-copy">{{ setup_statement }}</p>
              {% if compatibility_summary_html != blank %}
                <div class="product-mobile-detail-copy product-mobile-detail-copy--list">{{ compatibility_summary_html }}</div>
              {% elsif product_positioning_text != blank %}
                <p class="product-mobile-detail-copy">{{ product_positioning_text }}</p>
              {% else %}
                <p class="product-mobile-detail-copy">{{ role_decision_note }}</p>
              {% endif %}
              <div class="product-buybox-signal-grid product-buybox-signal-grid--mobile">
                <div class="product-buybox-signal">
                  <p class="product-buybox-signal-label">Fit</p>
                  <p class="product-buybox-signal-value">{{ setup_label }}</p>
                </div>
                {% if spec_count > 0 %}
                  <div class="product-buybox-signal">
                    <p class="product-buybox-signal-label">Specs</p>
                    <p class="product-buybox-signal-value">{{ spec_count }} key spec{% if spec_count != 1 %}s{% endif %}</p>
                  </div>
                {% endif %}
                {% if manual_count > 0 or download_count > 0 %}
                  <div class="product-buybox-signal">
                    <p class="product-buybox-signal-label">Support</p>
                    <p class="product-buybox-signal-value">
                      {% if manual_count > 0 %}{{ manual_count }} manual{% if manual_count != 1 %}s{% endif %}{% endif %}
                      {% if manual_count > 0 and download_count > 0 %} + {% endif %}
                      {% if download_count > 0 %}{{ download_count }} download{% if download_count != 1 %}s{% endif %}{% endif %}
                    </p>
                  </div>
                {% endif %}
              </div>
            </div>
          {%- endcapture -%}

          {%- capture product_support_content -%}
            <div class="product-mobile-detail-stack">
              <div class="product-assurance-grid product-assurance-grid--mobile">
                <div class="product-confidence-item">
                  <p class="product-confidence-title">Fit</p>
                  <p class="mt-2">
                    {% if compatibility_summary_text != blank %}
                      {{ compatibility_summary_text | truncatewords: 10 }}
                    {% else %}
                      Mac and Windows ready
                    {% endif %}
                  </p>
                </div>
                <div class="product-confidence-item">
                  <p class="product-confidence-title">Why it stands out</p>
                  <p class="mt-2">
                    {% if first_structured_highlight != blank %}
                      {{ first_structured_highlight | truncatewords: 10 }}
                    {% else %}
                      Clean, plug-in setup
                    {% endif %}
                  </p>
                </div>
                <div class="product-confidence-item">
                  <p class="product-confidence-title">Support</p>
                  <p class="mt-2">
                    {% if support_summary_text != blank %}
                      {{ support_summary_text | truncatewords: 10 }}
                    {% else %}
                      Manuals, downloads, help
                    {% endif %}
                  </p>
                </div>
              </div>

              {% if section.settings.show_support_panel %}
                <div class="product-buybox-confidence mt-0">
                  <p class="product-buybox-confidence-kicker">{{ section.settings.support_eyebrow | default: 'Support' }}</p>
                  <p class="product-buybox-confidence-heading">{{ ownership_heading }}</p>
                  <div class="product-buybox-confidence-copy">
                    {{ ownership_copy | truncatewords: 22 }}
                  </div>
                </div>
              {% endif %}
            </div>
          {%- endcapture -%}

          {%- capture product_features_content -%}
            {% if has_structured_highlights or section.blocks.size > 0 %}
              {%- assign mobile_rendered_highlights = 0 -%}
              <div class="product-highlight-shell product-highlight-shell--mobile">
                <div class="product-highlights">
                  {% if has_structured_highlights %}
                    {% for highlight in structured_highlights limit: section.settings.highlight_limit %}
                      {% if mobile_rendered_highlights < 3 %}
                        <div class="product-highlight-card">
                          <p class="product-highlight-index">0{{ forloop.index }}</p>
                          <div class="product-highlight-copy">{{ highlight }}</div>
                        </div>
                        {%- assign mobile_rendered_highlights = mobile_rendered_highlights | plus: 1 -%}
                      {% endif %}
                    {% endfor %}
                  {% elsif section.blocks.size > 0 %}
                    {% for block in section.blocks %}
                      {% if mobile_rendered_highlights < 3 and block.settings.title != blank %}
                        <div class="product-highlight-card" {{ block.shopify_attributes }}>
                          <p class="product-highlight-index">0{{ mobile_rendered_highlights | plus: 1 }}</p>
                          <div class="product-highlight-copy">{{ block.settings.title }}</div>
                        </div>
                        {%- assign mobile_rendered_highlights = mobile_rendered_highlights | plus: 1 -%}
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            {% endif %}
	          {%- endcapture -%}

            {%- assign product_features_content_stripped = product_features_content | strip -%}
            {%- assign product_support_content_stripped = product_support_content | strip -%}

	          <div class="product-mobile-accordions hidden lg:block">
	            {% if product_features_content_stripped != blank %}
	              {% render 'accordion-item', title: 'Features', content: product_features_content %}
	            {% endif %}
	          </div>


        </div>
      </div>
    </div>

  </div>

  <div class="product-sticky-atc" aria-hidden="true" data-sticky-atc>
    <div class="product-sticky-atc-shell">
      <div class="product-sticky-atc-main">
        <div class="product-sticky-atc-copy">
          <p class="product-sticky-atc-title">{{ product.title | truncate: 28 }}</p>
          <div class="product-sticky-atc-meta">
            <p class="product-sticky-atc-availability" data-sticky-atc-availability>
              {% if product.available %}{{ 'product.in_stock' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}
            </p>
            <p class="product-sticky-atc-price" data-sticky-atc-price>{{ product.selected_or_first_available_variant.price | money }}</p>
          </div>
          <p class="product-sticky-atc-trust">{{ sticky_trust_line }}</p>
        </div>
        <button class="btn btn--primary product-sticky-atc-button" type="submit" name="add" form="{{ product_form_id }}" data-sticky-atc-button{% unless product.available %} disabled="disabled"{% endunless %}>
          <span data-sticky-atc-button-label>{% if product.available %}{{ 'product.add_to_cart' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}</span>
          <span class="product-primary-action-divider" aria-hidden="true" data-sticky-atc-button-divider>·</span>
          <span data-sticky-atc-button-price>{{ product.selected_or_first_available_variant.price | money }}</span>
        </button>
      </div>
    </div>
  </div>
</section>

{%- liquid
  assign show_features_tab = false
  assign metafield_video_url = product.metafields.custom.product_video_url | strip
  if section.settings.youtube_url != blank or metafield_video_url != blank
    assign show_features_tab = true
  endif
  for block in section.blocks
    if block.type == 'feature' and block.settings.image != blank
      assign show_features_tab = true
      break
    endif
  endfor
-%}

{% comment %}──────────────────────────────────────────────────────────────
  ZONE 3 — FEATURES
  Guard: requires youtube_url setting OR at least one feature block
         with an image. Renders nothing if neither is set.
──────────────────────────────────────────────────────────────{% endcomment %}
{% if show_features_tab %}
<section class="section-shell pdp-section pdp-section--features" id="pdp-features">
  <div class="container-shell">
    <div class="section-intro">
      <div class="max-w-2xl">
        <p class="section-kicker">Product features</p>
        <h2 class="section-heading mt-4">{{ product.title | split: '—' | first | strip }}</h2>
      </div>
    </div>

    {%- assign feature_video_url = section.settings.youtube_url | strip | default: metafield_video_url -%}
    {%- if feature_video_url != blank -%}
      {%- render 'product-video-embed', url: feature_video_url, title: product.title -%}
    {%- endif -%}

    {%- assign feature_block_count = 0 -%}
    {% for block in section.blocks %}
      {% if block.type == 'feature' and block.settings.image != blank %}
        {%- assign feature_block_count = feature_block_count | plus: 1 -%}
      {% endif %}
    {% endfor %}
    {% if feature_block_count > 0 %}
      <div class="pdp-feature-grid mt-8">
        {% for block in section.blocks %}
          {% if block.type == 'feature' and block.settings.image != blank %}
            <div class="pdp-feature-panel{% if block.settings.span == '2' %} pdp-feature-panel--wide{% endif %}" {{ block.shopify_attributes }}>
              {% render 'media', image: block.settings.image, aspect_ratio: 'aspect-video', class: 'pdp-feature-panel-img', object_fit: 'object-cover', sizes: '(max-width: 1023px) 100vw, 50vw' %}
              {% if block.settings.caption != blank %}
                <p class="pdp-feature-panel-caption">{{ block.settings.caption }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% comment %}──────────────────────────────────────────────────────────────
  ZONE 4 — CONTENT TABS
  Default (tab_set = "default"): Overview / Specifications / Recommended
  Flagship (tab_set = "flagship"): Overview / Specifications / Comparisons / Reviews
  Legacy tabs (Highlight / Compatibility / Downloads) are OFF by default;
  merchant enables per-product via section settings.
──────────────────────────────────────────────────────────────{% endcomment %}
{%- liquid
  assign features_html  = product.metafields.custom.product_features.value
  assign specs_html     = product.metafields.custom.product_specifications.value
  assign highlight_html = product.metafields.custom.product_highlight.value
  assign compat_html    = product.metafields.custom.product_compatibility_html.value
  assign has_features   = false
  assign has_specs      = false
  assign has_highlight  = false
  assign has_compat     = false
  if features_html and features_html != ''
    assign has_features = true
  endif
  if specs_html and specs_html != ''
    assign has_specs = true
  endif
  if highlight_html and highlight_html != ''
    assign has_highlight = true
  endif
  if compat_html and compat_html != ''
    assign has_compat = true
  endif

  assign tab_set = section.settings.tab_set | default: 'default'

  assign show_overview_tab    = false
  assign show_specs_tab       = false
  assign show_highlight_tab   = false
  assign show_compat_tab      = false
  assign show_downloads_tab   = false
  assign show_recommended_tab = false
  assign show_comparisons_tab = false
  assign show_reviews_tab     = false

  if has_features and section.settings.show_overview != false
    assign show_overview_tab = true
  endif
  if has_specs and section.settings.show_specifications != false
    assign show_specs_tab = true
  endif
  if section.settings.show_recommended != false
    assign show_recommended_tab = true
  endif
  if section.settings.show_comparisons or tab_set == 'flagship'
    assign show_comparisons_tab = true
  endif
  if section.settings.show_reviews or tab_set == 'flagship'
    assign show_reviews_tab = true
  endif
  if has_highlight and section.settings.show_highlight
    assign show_highlight_tab = true
  endif
  if has_compat and section.settings.show_compatibility
    assign show_compat_tab = true
  endif
  if section.settings.show_downloads
    assign show_downloads_tab = true
  endif

  assign first_tab = ''
  if show_overview_tab
    assign first_tab = 'features'
  elsif show_specs_tab
    assign first_tab = 'specs'
  elsif show_comparisons_tab
    assign first_tab = 'comparisons'
  elsif show_reviews_tab
    assign first_tab = 'reviews'
  elsif show_recommended_tab
    assign first_tab = 'recommended'
  elsif show_highlight_tab
    assign first_tab = 'highlight'
  elsif show_compat_tab
    assign first_tab = 'compat'
  elsif show_downloads_tab
    assign first_tab = 'downloads'
  endif
-%}

