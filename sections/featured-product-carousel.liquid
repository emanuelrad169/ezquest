{%- liquid
  assign products_limit = section.settings.products_limit | default: 8

  assign has_tabs = false
  assign tab_count = 0
  for i in (1..4)
    assign tl = 'tab_' | append: i | append: '_label'
    assign tc = 'tab_' | append: i | append: '_collection'
    if section.settings[tl] != blank and section.settings[tc] != blank
      assign tab_count = tab_count | plus: 1
    endif
  endfor
  if tab_count > 0
    assign has_tabs = true
  endif

  assign source_collection = section.settings.collection
  assign featured_products = blank
  if source_collection != blank
    assign featured_products = source_collection.products
  elsif collections['all'] != blank
    assign featured_products = collections['all'].products
  endif
-%}

<section class="section-shell section--grey featured-products-section">
  <div class="container-shell">

    <div class="featured-products-header-v2 motion-fade-up reveal-tier-2">
      <div class="featured-products-header-left">
        <h2 class="featured-products-title-v2">{{ section.settings.heading | default: 'Best Sellers' }}</h2>

        {% if has_tabs %}
          <div class="featured-products-tabs" data-product-tabs role="tablist">
            {%- assign tab_rendered = 0 -%}
            {% for i in (1..4) %}
              {%- assign tl = 'tab_' | append: i | append: '_label' -%}
              {%- assign tc = 'tab_' | append: i | append: '_collection' -%}
              {%- assign tab_label = section.settings[tl] -%}
              {%- assign tab_col   = section.settings[tc] -%}
              {% if tab_label != blank and tab_col != blank %}
                <button
                  class="featured-products-tab{% if tab_rendered == 0 %} is-active{% endif %}"
                  type="button"
                  data-tab="{{ tab_rendered }}"
                  role="tab"
                  aria-selected="{% if tab_rendered == 0 %}true{% else %}false{% endif %}"
                >{{ tab_label }}</button>
                {%- assign tab_rendered = tab_rendered | plus: 1 -%}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="featured-products-header-right" style="--reveal-delay: 100ms">
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <a href="{{ section.settings.link_url }}" class="featured-products-link">{{ section.settings.link_label }}</a>
        {% endif %}
        <div class="featured-products-controls" aria-label="Carousel controls">
          <button class="featured-products-arrow" type="button" data-carousel-prev aria-label="Previous">
            {% render 'icon', name: 'chevron-left' %}
          </button>
          <span class="featured-products-controls-divider" aria-hidden="true"></span>
          <button class="featured-products-arrow" type="button" data-carousel-next aria-label="Next">
            {% render 'icon', name: 'chevron-right' %}
          </button>
        </div>
      </div>
    </div>

    <div class="featured-products-carousel" data-scroll-carousel aria-label="{{ section.settings.heading | default: 'Best Sellers' }}">
      <div class="featured-products-track" data-carousel-track>

        {% if has_tabs %}
          {%- assign tab_rendered = 0 -%}
          {% for i in (1..4) %}
            {%- assign tl = 'tab_' | append: i | append: '_label' -%}
            {%- assign tc = 'tab_' | append: i | append: '_collection' -%}
            {%- assign tab_label = section.settings[tl] -%}
            {%- assign tab_col   = section.settings[tc] -%}
            {% if tab_label != blank and tab_col != blank %}
              {% for product in tab_col.products limit: products_limit %}
                <div
                  class="featured-products-slide{% if forloop.first and tab_rendered == 0 %} is-featured{% endif %}"
                  data-tab-group="{{ tab_rendered }}"
                  {% if tab_rendered > 0 %}style="display:none"{% endif %}
                >
                  {% render 'card-product', product: product, card_style: 'featured-strip', card_context: 'featured', card_index: forloop.index0 %}
                </div>
              {% endfor %}
              {%- assign tab_rendered = tab_rendered | plus: 1 -%}
            {% endif %}
          {% endfor %}

        {% elsif featured_products != blank and featured_products.size > 0 %}
          {% for product in featured_products limit: products_limit %}
            <div class="featured-products-slide{% if forloop.first %} is-featured{% endif %}">
              {% render 'card-product', product: product, card_style: 'featured-strip', card_context: 'featured', card_index: forloop.index0 %}
            </div>
          {% endfor %}

        {% else %}
          {% for i in (1..5) %}
            <div class="featured-products-slide">
              <article class="product-card-tile product-card-tile--featured-strip card-elevated card-interactive motion-fade-up" data-card-index="{{ forloop.index0 }}">
                <div class="product-card-featured-media-shell relative">
                  <div class="product-card-featured-media">
                    {% render 'placeholder-visual',
                      kind: 'product',
                      text: 'EZQuest Product',
                      width: 900,
                      height: 700,
                      class: 'product-card-image product-card-featured-image aspect-card w-full object-contain'
                    %}
                    <span class="product-card-featured-badge">New</span>
                  </div>
                </div>
                <div class="product-card-featured-body flex flex-1 flex-col gap-3 px-4 pb-4 pt-3 lg:px-5">
                  <div class="product-card-featured-copy grid gap-1.5">
                    <p class="product-card-featured-vendor">Cable</p>
                    <div class="product-card-featured-title-price-row">
                      <h3 class="card-title product-card-featured-title">EZQuest USB-C Hub</h3>
                      <div class="product-card-featured-price">
                        <div class="price-block">
                          <div class="flex flex-wrap items-end gap-3">
                            <span class="price-amount text-3xl font-medium tracking-heading text-slate-950">$24.99</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            </div>
          {% endfor %}
        {% endif %}

      </div>
    </div>

    <div class="featured-products-progress-track" aria-hidden="true">
      <div class="featured-products-progress-bar" data-carousel-progress></div>
    </div>

    <div class="featured-products-support-row">
      <p class="featured-products-support-copy">Need a quicker way to narrow it down? Compare the core setups or get help choosing.</p>
      <div class="featured-products-support-links">
        <a href="/pages/compare" class="support-inline-link">Compare setups</a>
        <a href="/pages/support" class="support-inline-link">Get help choosing</a>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured carousel",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "collection", "id": "collection", "label": "Collection (used when no tabs are set)" },
    { "type": "header", "content": "Tab 1" },
    { "type": "text", "id": "tab_1_label", "label": "Label", "default": "Cables" },
    { "type": "collection", "id": "tab_1_collection", "label": "Collection" },
    { "type": "header", "content": "Tab 2" },
    { "type": "text", "id": "tab_2_label", "label": "Label", "default": "Hubs" },
    { "type": "collection", "id": "tab_2_collection", "label": "Collection" },
    { "type": "header", "content": "Tab 3" },
    { "type": "text", "id": "tab_3_label", "label": "Label" },
    { "type": "collection", "id": "tab_3_collection", "label": "Collection" },
    { "type": "header", "content": "Tab 4" },
    { "type": "text", "id": "tab_4_label", "label": "Label" },
    { "type": "collection", "id": "tab_4_collection", "label": "Collection" },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products per tab",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    { "name": "Featured carousel" }
  ]
}
{% endschema %}
