{{ 'pages.css' | asset_url | stylesheet_tag }}

<section class="page-cta">
  <div class="page-cta__inner">
    <div class="page-cta__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="page-cta__kicker">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      <p class="page-cta__heading">{{ section.settings.heading | default: 'Take the next step.' | escape }}</p>
      {% if section.settings.copy != blank %}
        <p class="page-cta__sub">{{ section.settings.copy | escape }}</p>
      {% endif %}
    </div>
    <div class="page-cta__actions">
      {% if section.settings.link_label != blank %}
        <a href="{{ section.settings.link_url | default: '#' }}" class="page-cta__btn">
          {{ section.settings.link_label | escape }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
      {% if section.settings.secondary_label != blank and section.settings.secondary_url != blank %}
        <a href="{{ section.settings.secondary_url }}" class="page-cta__btn" style="background:transparent;border:1.5px solid rgba(0,0,0,0.15);color:#1d1d1f;box-shadow:none;">
          {{ section.settings.secondary_label | escape }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    { "type": "text",     "id": "eyebrow",         "label": "Kicker",           "default": "Next step" },
    { "type": "text",     "id": "heading",          "label": "Heading",          "default": "Take the next step." },
    { "type": "textarea", "id": "copy",             "label": "Subheading" },
    { "type": "text",     "id": "link_label",       "label": "Button label",     "default": "Learn more" },
    { "type": "url",      "id": "link_url",         "label": "Button URL" },
    { "type": "text",     "id": "secondary_label",  "label": "Secondary button label" },
    { "type": "url",      "id": "secondary_url",    "label": "Secondary button URL" }
  ],
  "presets": [
    { "name": "CTA banner" }
  ]
}
{% endschema %}
