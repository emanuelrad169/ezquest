{% render 'page-cta',
  kicker: section.settings.eyebrow,
  heading: section.settings.heading,
  subhead: section.settings.copy,
  primary_label: section.settings.link_label,
  primary_url: section.settings.link_url,
  secondary_label: section.settings.secondary_label,
  secondary_url: section.settings.secondary_url,
  variant: section.settings.variant
%}

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Style",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark",  "label": "Dark" },
        { "value": "amber", "label": "Amber" }
      ],
      "default": "light"
    },
    { "type": "text",     "id": "eyebrow",         "label": "Kicker",           "default": "Next step" },
    { "type": "text",     "id": "heading",          "label": "Heading",          "default": "Take the next step." },
    { "type": "textarea", "id": "copy",             "label": "Subheading" },
    { "type": "text",     "id": "link_label",       "label": "Button label",     "default": "Learn more" },
    { "type": "url",      "id": "link_url",         "label": "Button URL" },
    { "type": "text",     "id": "secondary_label",  "label": "Secondary button label" },
    { "type": "url",      "id": "secondary_url",    "label": "Secondary button URL" }
  ],
  "presets": [
    { "name": "CTA banner" }
  ]
}
{% endschema %}
