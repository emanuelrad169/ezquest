{%- liquid
  assign use_global_faqs = false
  assign sorted_global_faq_keys = '' | split: ''
  assign has_group_blocks = false

  if metaobjects.ezquest_faq_item != blank
    assign use_global_faqs = true
    capture sorted_faqs_raw
      for faq_item in metaobjects.ezquest_faq_item.values
        capture order_token_raw
          echo '000000'
          echo faq_item.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo faq_item.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_global_faq_keys = sorted_faqs_raw | split: '||' | sort_natural
  endif

  for block in section.blocks
    if block.type == 'group'
      assign has_group_blocks = true
      break
    endif
  endfor
-%}

<section class="faq-accordion-section section-shell" id="faq-section-{{ section.id }}">
  <div class="container-shell faq-accordion-shell">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.header_copy != blank %}
      <div class="faq-accordion-intro">
        {% if section.settings.eyebrow != blank %}
          <p class="faq-accordion-intro__kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="faq-accordion-intro__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.header_copy != blank %}
          <p class="faq-accordion-intro__copy">{{ section.settings.header_copy }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="faq-accordion-groups">
      {% if has_group_blocks %}
        {%- assign item_index = 0 -%}
        {% for block in section.blocks %}
          {% if block.type == 'group' %}
            {%- assign group_filter = block.settings.group_handle | downcase -%}
            {%- assign group_faq_count = 0 -%}
            <section class="faq-group" {{ block.shopify_attributes }}>
              <div class="faq-group__header faq-blur-in" data-reveal-delay="{{ item_index | times: 40 }}">
                <h3 class="faq-group__title">{{ block.settings.title }}</h3>
                {% if block.settings.subtitle != blank %}
                  <p class="faq-group__subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
              </div>

              <div class="faq-group__items">
                {% if use_global_faqs and group_filter != blank %}
                  {% for faq_key in sorted_global_faq_keys %}
                    {% if faq_key == blank %}{% continue %}{% endif %}
                    {% assign faq_handle = faq_key | split: '::' | last %}
                    {% assign faq_item = metaobjects.ezquest_faq_item[faq_handle] %}
                    {%- assign item_group = faq_item.faq_group.value | downcase | default: '' -%}
                    {% if item_group == group_filter %}
                      {%- assign item_number = item_index | plus: 1 -%}
                      {%- capture faq_number_raw -%}00{{ item_number }}{%- endcapture -%}
                      {%- assign faq_number = faq_number_raw | slice: -2, 2 -%}
                      <details class="faq-card faq-blur-in" data-reveal-delay="{{ item_index | times: 40 }}" id="faq-{{ faq_handle }}">
                        <summary class="faq-card__summary">
                          <span class="faq-card__number">{{ faq_number }}</span>
                          <span class="faq-card__question">{{ faq_item.question.value }}</span>
                          <span class="faq-card__toggle" aria-hidden="true"></span>
                        </summary>
                        <div class="faq-card__body">
                          <div class="faq-card__body-inner">{{ faq_item.answer.value | newline_to_br }}</div>
                        </div>
                      </details>
                      {%- assign group_faq_count = group_faq_count | plus: 1 -%}
                      {%- assign item_index = item_index | plus: 1 -%}
                    {% endif %}
                  {% endfor %}
                {% endif %}

                {%- assign block_faq_count = 0 -%}
                {% if group_faq_count == 0 %}
                  {% for item_block in section.blocks %}
                    {% if item_block.type == 'faq' and item_block.settings.group == block.settings.group_handle %}
                      {%- assign item_number = item_index | plus: 1 -%}
                      {%- capture faq_number_raw -%}00{{ item_number }}{%- endcapture -%}
                      {%- assign faq_number = faq_number_raw | slice: -2, 2 -%}
                      <details class="faq-card faq-blur-in" data-reveal-delay="{{ item_index | times: 40 }}" id="faq-block-{{ item_block.id }}">
                        <summary class="faq-card__summary">
                          <span class="faq-card__number">{{ faq_number }}</span>
                          <span class="faq-card__question">{{ item_block.settings.question }}</span>
                          <span class="faq-card__toggle" aria-hidden="true"></span>
                        </summary>
                        <div class="faq-card__body">
                          <div class="faq-card__body-inner">{{ item_block.settings.answer | newline_to_br }}</div>
                        </div>
                      </details>
                      {%- assign block_faq_count = block_faq_count | plus: 1 -%}
                      {%- assign item_index = item_index | plus: 1 -%}
                    {% endif %}
                  {% endfor %}
                {% endif %}

                {% if group_faq_count == 0 and block_faq_count == 0 %}
                  <p class="faq-empty">No FAQs added to this group yet.</p>
                {% endif %}
              </div>
            </section>
          {% endif %}
        {% endfor %}
      {% else %}
        <section class="faq-group">
          <div class="faq-group__header faq-blur-in" data-reveal-delay="0">
            <h3 class="faq-group__title">{{ section.settings.heading | default: 'Frequently asked questions' }}</h3>
          </div>

          <div class="faq-group__items">
            {%- assign item_index = 0 -%}
            {% if use_global_faqs %}
              {% for faq_key in sorted_global_faq_keys %}
                {% if faq_key == blank %}{% continue %}{% endif %}
                {% assign faq_handle = faq_key | split: '::' | last %}
                {% assign faq_item = metaobjects.ezquest_faq_item[faq_handle] %}
                {%- assign item_number = item_index | plus: 1 -%}
                {%- capture faq_number_raw -%}00{{ item_number }}{%- endcapture -%}
                {%- assign faq_number = faq_number_raw | slice: -2, 2 -%}
                <details class="faq-card faq-blur-in" data-reveal-delay="{{ item_index | times: 40 }}" id="faq-{{ faq_handle }}">
                  <summary class="faq-card__summary">
                    <span class="faq-card__number">{{ faq_number }}</span>
                    <span class="faq-card__question">{{ faq_item.question.value }}</span>
                    <span class="faq-card__toggle" aria-hidden="true"></span>
                  </summary>
                  <div class="faq-card__body">
                    <div class="faq-card__body-inner">{{ faq_item.answer.value | newline_to_br }}</div>
                  </div>
                </details>
                {%- assign item_index = item_index | plus: 1 -%}
              {% endfor %}
            {% endif %}

            {% for block in section.blocks %}
              {% if block.type == 'faq' %}
                {%- assign item_number = item_index | plus: 1 -%}
                {%- capture faq_number_raw -%}00{{ item_number }}{%- endcapture -%}
                {%- assign faq_number = faq_number_raw | slice: -2, 2 -%}
                <details class="faq-card faq-blur-in" data-reveal-delay="{{ item_index | times: 40 }}" id="faq-block-{{ block.id }}">
                  <summary class="faq-card__summary">
                    <span class="faq-card__number">{{ faq_number }}</span>
                    <span class="faq-card__question">{{ block.settings.question }}</span>
                    <span class="faq-card__toggle" aria-hidden="true"></span>
                  </summary>
                  <div class="faq-card__body">
                    <div class="faq-card__body-inner">{{ block.settings.answer | newline_to_br }}</div>
                  </div>
                </details>
                {%- assign item_index = item_index | plus: 1 -%}
              {% endif %}
            {% endfor %}

            {% if item_index == 0 %}
              <p class="faq-empty">No FAQ entries configured yet. <a href="/pages/contact">Contact support</a></p>
            {% endif %}
          </div>
        </section>
      {% endif %}
    </div>

    <div class="faq-support-footer">
      <div class="faq-support-footer__copy">
        <p class="faq-support-footer__eyebrow">Still need help?</p>
        <h3 class="faq-support-footer__title">{{ section.settings.contact_heading | default: 'Still need help?' }}</h3>
        {% if section.settings.contact_sub != blank %}
          <p class="faq-support-footer__text">{{ section.settings.contact_sub }}</p>
        {% endif %}
      </div>
      <div class="faq-support-footer__action">
        <a href="/pages/contact" class="button-secondary">Message</a>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  var section = document.getElementById('faq-section-{{ section.id }}');
  if (!section) return;

  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var items = section.querySelectorAll('.faq-blur-in');
  var cards = section.querySelectorAll('.faq-card');

  cards.forEach(function (card) {
    card.addEventListener('toggle', function () {
      if (!card.open) return;
      cards.forEach(function (other) {
        if (other !== card) other.open = false;
      });
    });
  });

  if (!prefersReduced) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var delay = parseInt(el.dataset.revealDelay || '0', 10) || 0;
        setTimeout(function () {
          el.classList.add('is-visible');
        }, delay);
        io.unobserve(el);
      });
    }, { threshold: 0.08 });

    items.forEach(function (el) { io.observe(el); });
  } else {
    items.forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "textarea", "id": "header_copy", "label": "Header copy", "default": "Find quick answers to the most common questions about orders, products, and support." },
    { "type": "text", "id": "contact_heading", "label": "Contact card heading", "default": "Still need help?" },
    { "type": "textarea", "id": "contact_sub", "label": "Contact card subtext", "default": "Send us your question and our team will help you find the right answer." }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "FAQ group",
      "settings": [
        { "type": "text", "id": "title", "label": "Group title", "default": "Shipping & Returns" },
        { "type": "text", "id": "subtitle", "label": "Group subtitle" },
        { "type": "text", "id": "group_handle", "label": "Group handle (matches FAQ metaobject group field)", "default": "shipping" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item (manual)",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your return policy?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "We accept returns within 30 days of purchase." },
        { "type": "text", "id": "group", "label": "Group handle (to assign to a group block)", "default": "shipping" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion"
    }
  ]
}
{% endschema %}
