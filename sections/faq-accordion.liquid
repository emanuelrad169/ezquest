<script src="{{ 'component-accordion.js' | asset_url }}" defer="defer"></script>

<section class="section-shell">
  <div class="container-shell max-w-4xl">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <div class="mt-8 space-y-4">
      {% for block in section.blocks %}
        {% capture answer %}
          <p>{{ block.settings.answer }}</p>
        {% endcapture %}
        {% render 'accordion-item', title: block.settings.question, content: answer %}
      {% else %}
        {% for i in (1..3) %}
          {% capture answer %}
            <p>Add FAQ blocks in the theme editor to populate this section.</p>
          {% endcapture %}
          {% render 'accordion-item', title: 'FAQ item', content: answer %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion",
      "blocks": [{ "type": "faq" }, { "type": "faq" }, { "type": "faq" }]
    }
  ]
}
{% endschema %}
