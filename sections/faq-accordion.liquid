<script src="{{ 'component-accordion.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign faq_heading = section.settings.heading | default: 'Frequently asked questions'
  assign current_product = blank
  assign structured_product_faqs = blank
  assign has_product_faqs = false
  assign use_product_faqs = false
  assign use_global_faqs = false
  assign faq_group_filter = section.settings.faq_group | downcase
  assign faq_collection = section.settings.source_collection

  if product != blank
    assign current_product = product
  elsif section.settings.source_product != blank
    assign current_product = section.settings.source_product
  endif

  if current_product != blank and current_product.metafields.ezquest.faq_items != blank
    assign structured_product_faqs = current_product.metafields.ezquest.faq_items.value
    if structured_product_faqs.count > 0
      assign has_product_faqs = true
    endif
  endif

  case section.settings.structured_source
    when 'product'
      if has_product_faqs
        assign use_product_faqs = true
      endif
    when 'global'
      assign use_global_faqs = true
    when 'auto'
      if has_product_faqs
        assign use_product_faqs = true
      else
        assign use_global_faqs = true
      endif
  endcase
-%}

<section class="section-shell home-faq-section">
  <div class="container-shell max-w-7xl">
    <div class="home-faq-shell">
      <div class="home-faq-main">
        <div class="home-faq-intro">
          {% if section.settings.eyebrow != blank %}
            <p class="section-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <h2 class="home-faq-heading{% if section.settings.eyebrow != blank %} mt-4{% endif %}">{{ faq_heading }}</h2>
          {% if section.settings.copy != blank %}
            <p class="section-copy mt-4">{{ section.settings.copy }}</p>
          {% endif %}
        </div>

        <div class="faq-list home-faq-list">
        {% if use_product_faqs %}
          {% for faq_item in structured_product_faqs limit: section.settings.faq_limit %}
            {% capture answer %}
              <p>{{ faq_item.answer.value | newline_to_br }}</p>
            {% endcapture %}
            {% render 'accordion-item', title: faq_item.question.value, content: answer %}
          {% endfor %}
        {% elsif use_global_faqs %}
          {%- assign rendered_faqs = 0 -%}
          {% for faq_item in metaobjects.ezquest_faq_item.values %}
            {%- liquid
              assign matches_group = true
              assign matches_collection = true

              if faq_group_filter != blank
                assign faq_group_value = blank
                if faq_item.faq_group != blank and faq_item.faq_group.value != blank
                  assign faq_group_value = faq_item.faq_group.value | downcase
                endif
                if faq_group_value != faq_group_filter
                  assign matches_group = false
                endif
              endif

              if faq_collection != blank
                assign matches_collection = false
                if faq_item.collections != blank and faq_item.collections.value.count > 0
                  for linked_collection in faq_item.collections.value
                    if linked_collection.id == faq_collection.id
                      assign matches_collection = true
                      break
                    endif
                  endfor
                endif
              endif
            -%}
            {% if matches_group and matches_collection and rendered_faqs < section.settings.faq_limit %}
              {% capture answer %}
                <p>{{ faq_item.answer.value | newline_to_br }}</p>
              {% endcapture %}
              {% render 'accordion-item', title: faq_item.question.value, content: answer %}
              {%- assign rendered_faqs = rendered_faqs | plus: 1 -%}
            {% endif %}
          {% endfor %}
          {% if rendered_faqs == 0 %}
            {% for i in (1..3) %}
              {%- liquid
                assign fallback_question = 'How do I confirm compatibility before I buy?'

                if forloop.index == 2
                  assign fallback_question = 'Where do I find setup guides and manuals?'
                elsif forloop.index == 3
                  assign fallback_question = 'When should I contact support directly?'
                endif
              -%}
              {% capture answer %}
                <p>Start here for compatibility checks, setup basics, and ownership guidance, then move into troubleshooting or direct support only when your setup needs a deeper answer.</p>
              {% endcapture %}
              {% render 'accordion-item', title: fallback_question, content: answer %}
            {% endfor %}
          {% endif %}
        {% else %}
          {% for block in section.blocks %}
            {% capture answer %}
              <p>{{ block.settings.answer }}</p>
            {% endcapture %}
            {% render 'accordion-item', title: block.settings.question, content: answer %}
          {% else %}
            {% for i in (1..3) %}
              {%- liquid
                assign fallback_question = 'How do I confirm compatibility before I buy?'

                if forloop.index == 2
                  assign fallback_question = 'Where do I find setup guides and manuals?'
                elsif forloop.index == 3
                  assign fallback_question = 'When should I contact support directly?'
                endif
              -%}
              {% capture answer %}
                <p>Keep the answer focused on product fit, setup guidance, or ownership clarity so the customer can move forward with confidence and know the next step.</p>
              {% endcapture %}
              {% render 'accordion-item', title: fallback_question, content: answer %}
            {% endfor %}
          {% endfor %}
        {% endif %}
        </div>
      </div>

      <aside class="home-faq-help-card">
        <h3>Need setup help?</h3>
        <p>Move into support when the question depends on your exact product, connection path, or order details.</p>
        <a href="/pages/contact" class="home-faq-help-button" aria-label="Contact EZQuest support">Contact support</a>
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Answer recurring questions clearly, then route into troubleshooting, manuals, or direct support when needed." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "product", "label": "Product-linked FAQ" },
        { "value": "global", "label": "Global FAQ metaobjects" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    { "type": "product", "id": "source_product", "label": "Source product" },
    { "type": "collection", "id": "source_collection", "label": "Global FAQ collection filter" },
    { "type": "text", "id": "faq_group", "label": "Global FAQ group filter" },
    {
      "type": "range",
      "id": "faq_limit",
      "label": "FAQ limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How do I confirm compatibility before I buy?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Start with compatibility guidance on the product page, then move into manuals, downloads, or direct support only if your setup needs a deeper check." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion",
      "blocks": [{ "type": "faq" }, { "type": "faq" }, { "type": "faq" }]
    }
  ]
}
{% endschema %}
