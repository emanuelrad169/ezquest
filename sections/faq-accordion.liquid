{%- liquid
  assign use_global_faqs = false
  assign sorted_global_faq_keys = '' | split: ''

  if metaobjects.ezquest_faq_item != blank
    assign use_global_faqs = true
    capture sorted_faqs_raw
      for faq_item in metaobjects.ezquest_faq_item.values
        capture order_token_raw
          echo '000000'
          echo faq_item.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo faq_item.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_global_faq_keys = sorted_faqs_raw | split: '||' | sort_natural
  endif
-%}

<section class="faq-page-section section-shell">
  <div class="container-shell">
    <div class="faq-page-shell">

      <!-- FAQ groups -->
      <div class="faq-page-main">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'group' %}
              {%- assign group_filter = block.settings.group_handle | downcase -%}
              {%- assign group_faq_count = 0 -%}

              <div class="faq-group-card" {{ block.shopify_attributes }}>
                <div class="faq-group-header">
                  <h2 class="faq-group-title">{{ block.settings.title }}</h2>
                  {% if block.settings.subtitle != blank %}
                    <p class="faq-group-subtitle">{{ block.settings.subtitle }}</p>
                  {% endif %}
                </div>

                <div class="faq-list faq-group-list">
                  {% if use_global_faqs and group_filter != blank %}
                    {% for faq_key in sorted_global_faq_keys %}
                      {% if faq_key == blank %}{% continue %}{% endif %}
                      {% assign faq_handle = faq_key | split: '::' | last %}
                      {% assign faq_item = metaobjects.ezquest_faq_item[faq_handle] %}
                      {%- assign item_group = faq_item.faq_group.value | downcase | default: '' -%}
                      {% if item_group == group_filter %}
                        {% capture answer %}<p>{{ faq_item.answer.value | newline_to_br }}</p>{% endcapture %}
                        {% render 'accordion-item', title: faq_item.question.value, content: answer %}
                        {%- assign group_faq_count = group_faq_count | plus: 1 -%}
                      {% endif %}
                    {% endfor %}
                  {% endif %}

                  {% if group_faq_count == 0 %}
                    {% for item_block in section.blocks %}
                      {% if item_block.type == 'faq' and item_block.settings.group == block.settings.group_handle %}
                        {% capture answer %}<p>{{ item_block.settings.answer }}</p>{% endcapture %}
                        {% render 'accordion-item', title: item_block.settings.question, content: answer %}
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          <!-- Flat list fallback (no groups defined) -->
          <div class="faq-group-card">
            <div class="faq-group-header">
              <h2 class="faq-group-title">{{ section.settings.heading | default: 'Frequently asked questions' }}</h2>
            </div>
            <div class="faq-list faq-group-list">
              {% if use_global_faqs %}
                {% for faq_key in sorted_global_faq_keys %}
                  {% if faq_key == blank %}{% continue %}{% endif %}
                  {% assign faq_handle = faq_key | split: '::' | last %}
                  {% assign faq_item = metaobjects.ezquest_faq_item[faq_handle] %}
                  {% capture answer %}<p>{{ faq_item.answer.value | newline_to_br }}</p>{% endcapture %}
                  {% render 'accordion-item', title: faq_item.question.value, content: answer %}
                {% endfor %}
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>

      <!-- Contact form sidebar -->
      <aside class="faq-page-aside">
        <div class="faq-contact-card">
          <h3 class="faq-contact-heading">{{ section.settings.contact_heading | default: "Still need help?" }}</h3>
          <p class="faq-contact-sub">{{ section.settings.contact_sub | default: "Send us your question and our team will help you find the right answer." }}</p>

          {%- form 'contact', id: 'faq-contact-form' -%}
            {% if form.posted_successfully? %}
              <p class="faq-contact-success">Thanks! We'll get back to you soon.</p>
            {% else %}
              <div class="faq-contact-fields">
                <input class="faq-contact-input" type="text" name="contact[name]" placeholder="Name" autocomplete="name" required>
                <input class="faq-contact-input" type="email" name="contact[email]" placeholder="Email" autocomplete="email" required>
                <textarea class="faq-contact-input faq-contact-textarea" name="contact[body]" placeholder="Message" rows="4"></textarea>
                <button class="faq-contact-btn" type="submit">Send message</button>
              </div>
            {% endif %}
          {%- endform -%}
        </div>
      </aside>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "text", "id": "contact_heading", "label": "Contact card heading", "default": "Still need help?" },
    { "type": "textarea", "id": "contact_sub", "label": "Contact card subtext", "default": "Send us your question and our team will help you find the right answer." }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "FAQ group",
      "settings": [
        { "type": "text", "id": "title", "label": "Group title", "default": "Shipping & Returns" },
        { "type": "text", "id": "subtitle", "label": "Group subtitle" },
        { "type": "text", "id": "group_handle", "label": "Group handle (matches FAQ metaobject group field)", "default": "shipping" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item (manual)",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What is your return policy?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "We accept returns within 30 days of purchase." },
        { "type": "text", "id": "group", "label": "Group handle (to assign to a group block)", "default": "shipping" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion"
    }
  ]
}
{% endschema %}
