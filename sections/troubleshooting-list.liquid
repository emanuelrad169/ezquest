<section class="section-shell surface-muted">
  <div class="container-shell">
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    {%- liquid
      assign use_structured_entries = false
      assign sorted_entry_keys = '' | split: ''
      if section.settings.structured_source != 'blocks' and metaobjects.ezquest_troubleshooting_item != blank
        assign use_structured_entries = true
        capture sorted_entries_raw
          for entry in metaobjects.ezquest_troubleshooting_item.values
            capture order_token_raw
              echo '000000'
              echo entry.sort_order.value | default: 999999 | plus: 0
            endcapture
            assign order_token = order_token_raw | strip | slice: -6, 6
            echo order_token
            echo '::'
            echo entry.system.handle
            echo '||'
          endfor
        endcapture
        assign sorted_entry_keys = sorted_entries_raw | split: '||' | sort_natural
      endif
    -%}

    <div class="troubleshooting-grid">
      {% if use_structured_entries %}
        {%- assign rendered_entries = 0 -%}
        {% for entry_key in sorted_entry_keys %}
          {% if entry_key == blank %}
            {% continue %}
          {% endif %}
          {% assign entry_handle = entry_key | split: '::' | last %}
          {% assign entry = metaobjects.ezquest_troubleshooting_item[entry_handle] %}
          {%- liquid
            assign entry_issue = entry.issue_type.value | default: 'Issue'
            assign entry_title = entry.title.value
            assign entry_copy = entry.summary.value
            assign entry_label = entry.primary_label.value | default: 'Open support path'
            assign entry_url = entry.primary_url.value
          -%}
          {% if rendered_entries < section.settings.entry_limit %}
            <article class="troubleshooting-card">
              <div class="troubleshooting-card-top">
                <div>
                  <p class="section-kicker">{{ entry_issue }}</p>
                  <h3 class="troubleshooting-card-title">{{ entry_title }}</h3>
                </div>
                <span class="troubleshooting-card-index">{{ rendered_entries | plus: 1 | prepend: '0' }}</span>
              </div>
              {% if entry_copy != blank %}
                <p class="troubleshooting-card-copy">{{ entry_copy }}</p>
              {% endif %}
              <div class="troubleshooting-card-footer">
                <p class="troubleshooting-card-meta">Start with the visible symptom, then move into the shortest fix.</p>
                {% if entry_url != blank %}
                  {% render 'button', label: entry_label, url: entry_url, style: 'secondary' %}
                {% endif %}
              </div>
            </article>
            {%- assign rendered_entries = rendered_entries | plus: 1 -%}
          {% endif %}
        {% endfor %}

        {% if rendered_entries == 0 %}
          <article class="troubleshooting-card structured-empty-state">
            <div class="troubleshooting-card-top">
              <div>
                <p class="section-kicker">Issue</p>
                <h3 class="troubleshooting-card-title">No troubleshooting entries yet</h3>
              </div>
              <span class="troubleshooting-card-index">00</span>
            </div>
            <p class="troubleshooting-card-copy">Troubleshooting entries will appear here when they are added to the EZQuest support metaobjects.</p>
            <div class="support-next-step-list mt-6">
              <a href="/pages/manuals" class="support-inline-link">Find manuals</a>
              <a href="/pages/downloads" class="support-inline-link">Find downloads</a>
              <a href="/pages/contact" class="support-inline-link">Get help now</a>
            </div>
          </article>
        {% endif %}
      {% else %}
        {% for block in section.blocks %}
          <article class="troubleshooting-card" {{ block.shopify_attributes }}>
            <div class="troubleshooting-card-top">
              <div>
                <p class="section-kicker">{{ block.settings.eyebrow | default: 'Issue' }}</p>
                <h3 class="troubleshooting-card-title">{{ block.settings.title }}</h3>
              </div>
              <span class="troubleshooting-card-index">{{ forloop.index | prepend: '0' }}</span>
            </div>
            <p class="troubleshooting-card-copy">{{ block.settings.copy }}</p>
            <div class="troubleshooting-card-footer">
              <p class="troubleshooting-card-meta">Start with the visible symptom, then move into the shortest fix.</p>
              {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
              {% endif %}
            </div>
          </article>
          {% else %}
            {% for i in (1..4) %}
              <article class="troubleshooting-card">
              <div class="troubleshooting-card-top">
                <div>
                <p class="section-kicker">Issue</p>
              <h3 class="troubleshooting-card-title">
                {% if forloop.index == 1 %}
                  Display not detected
                {% elsif forloop.index == 2 %}
                  Device not charging as expected
                {% elsif forloop.index == 3 %}
                  Accessory or drive not appearing
                {% else %}
                  Setup still not working
                {% endif %}
              </h3>
                </div>
                <span class="troubleshooting-card-index">{{ i | prepend: '0' }}</span>
              </div>
              <p class="troubleshooting-card-copy">
                {% if forloop.index == 1 %}
                  Start with cable path, display support, and host compatibility before moving into deeper troubleshooting.
                {% elsif forloop.index == 2 %}
                  Confirm charger wattage, power-delivery support, and the exact device connection path first.
                {% elsif forloop.index == 3 %}
                  Review port type, adapter chain, and platform support before moving into direct help.
                {% else %}
                  Move from symptom checks into manuals, downloads, or direct support when the faster option is no longer enough.
                {% endif %}
              </p>
              <div class="troubleshooting-card-footer">
                <p class="troubleshooting-card-meta">Follow the clearest next action instead of bouncing between support pages.</p>
              </div>
            </article>
          {% endfor %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Troubleshooting list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Troubleshooting" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Troubleshooting by symptom" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Start with the symptom you are seeing, then move into the clearest next support step." },
    {
      "type": "select",
      "id": "structured_source",
      "label": "Structured source",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "global", "label": "Global metaobject list" },
        { "value": "blocks", "label": "Blocks only" }
      ]
    },
    {
      "type": "range",
      "id": "entry_limit",
      "label": "Entry limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "issue",
      "name": "Issue item",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Issue" },
        { "type": "text", "id": "title", "label": "Title", "default": "Issue title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Explain the symptom, likely cause, and the next recommended action." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Open support path" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Troubleshooting list",
      "blocks": [{ "type": "issue" }, { "type": "issue" }, { "type": "issue" }, { "type": "issue" }]
    }
  ]
}
{% endschema %}
