<section class="section-shell surface-muted">
  <div class="container-shell">
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        <p class="section-copy mt-4">{{ section.settings.copy }}</p>
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    <div class="troubleshooting-grid">
      {% for block in section.blocks %}
        <article class="troubleshooting-card" {{ block.shopify_attributes }}>
          <div class="troubleshooting-card-top">
            <div>
              <p class="section-kicker">{{ block.settings.eyebrow | default: 'Issue' }}</p>
              <h3 class="troubleshooting-card-title">{{ block.settings.title }}</h3>
            </div>
            <span class="troubleshooting-card-index">{{ forloop.index | prepend: '0' }}</span>
          </div>
          <p class="troubleshooting-card-copy">{{ block.settings.copy }}</p>
          <div class="troubleshooting-card-footer">
            <p class="troubleshooting-card-meta">Confirm the symptom first, then move into the best next action.</p>
            {% if block.settings.link_label != blank and block.settings.link_url != blank %}
              {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
            {% endif %}
          </div>
        </article>
        {% else %}
          {% for i in (1..4) %}
            <article class="troubleshooting-card">
            <div class="troubleshooting-card-top">
              <div>
              <p class="section-kicker">Issue</p>
            <h3 class="troubleshooting-card-title">
              {% if forloop.index == 1 %}
                Display not detected
              {% elsif forloop.index == 2 %}
                Device not charging as expected
              {% elsif forloop.index == 3 %}
                Accessory or drive not appearing
              {% else %}
                Setup still not working
              {% endif %}
            </h3>
              </div>
              <span class="troubleshooting-card-index">{{ i | prepend: '0' }}</span>
            </div>
            <p class="troubleshooting-card-copy">
              {% if forloop.index == 1 %}
                Start with cable path, display support, and host compatibility before moving into deeper troubleshooting.
              {% elsif forloop.index == 2 %}
                Confirm charger wattage, power-delivery support, and the exact device connection path first.
              {% elsif forloop.index == 3 %}
                Review port type, adapter chain, and platform support before escalating the issue.
              {% else %}
                Move from symptom checks into manuals, downloads, or direct support when the faster path is no longer enough.
              {% endif %}
            </p>
            <div class="troubleshooting-card-footer">
              <p class="troubleshooting-card-meta">Follow the clearest next action instead of guessing between support pages.</p>
            </div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Troubleshooting list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Troubleshooting" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Troubleshooting by symptom" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Start with the symptom you are seeing, then move into the clearest next support step." },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "issue",
      "name": "Issue item",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Issue" },
        { "type": "text", "id": "title", "label": "Title", "default": "Issue title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Explain the symptom, likely cause, and the next recommended action." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Open support path" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Troubleshooting list",
      "blocks": [{ "type": "issue" }, { "type": "issue" }, { "type": "issue" }, { "type": "issue" }]
    }
  ]
}
{% endschema %}
