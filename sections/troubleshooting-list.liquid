<section class="section-shell bg-slate-50">
  <div class="container-shell">
    <div class="max-w-3xl">
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <p class="section-copy mt-4">{{ section.settings.copy }}</p>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {% for block in section.blocks %}
        <div class="card-shell" {{ block.shopify_attributes }}>
          <h3 class="text-lg font-semibold">{{ block.settings.title }}</h3>
          <p class="mt-3 text-sm text-slate-600">{{ block.settings.copy }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Troubleshooting list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Troubleshooting framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for issue categories, symptoms, and next steps." }
  ],
  "blocks": [
    {
      "type": "issue",
      "name": "Issue item",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Issue title" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Issue guidance" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Troubleshooting list",
      "blocks": [{ "type": "issue" }, { "type": "issue" }, { "type": "issue" }, { "type": "issue" }]
    }
  ]
}
{% endschema %}
