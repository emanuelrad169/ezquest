<section class="section-shell">
  <div class="container-shell max-w-6xl">
    {% if section.settings.show_breadcrumbs %}
      {% render 'breadcrumbs' %}
    {% endif %}

    <div class="content-page-shell{% if section.settings.show_breadcrumbs %} mt-6{% endif %}">
      <aside class="content-page-sidebar">
        {% if section.settings.show_title %}
          <p class="section-kicker">{{ section.settings.sidebar_eyebrow | default: 'Page' }}</p>
          <h2 class="mt-4 text-3xl font-medium tracking-heading text-slate-950">{{ page.title }}</h2>
        {% endif %}

        {% if section.settings.intro_copy != blank %}
          <p class="mt-4 text-sm leading-7 text-slate-600">{{ section.settings.intro_copy }}</p>
        {% endif %}

        {% if section.settings.side_heading != blank or section.settings.side_copy != blank %}
          <div class="product-support-panel mt-6">
            {% if section.settings.side_eyebrow != blank %}
              <p class="section-kicker">{{ section.settings.side_eyebrow }}</p>
            {% endif %}
            {% if section.settings.side_heading != blank %}
              <h3 class="mt-3 text-xl font-medium tracking-tight text-slate-950">{{ section.settings.side_heading }}</h3>
            {% endif %}
            {% if section.settings.side_copy != blank %}
              <p class="mt-3 text-sm leading-7 text-slate-600">{{ section.settings.side_copy }}</p>
            {% endif %}
            {% if section.settings.side_link_label != blank and section.settings.side_link_url != blank %}
              <div class="mt-5">
                {% render 'button', label: section.settings.side_link_label, url: section.settings.side_link_url, style: 'secondary' %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </aside>

      <div class="content-page-body">
        {% unless section.settings.show_title %}
          <h2 class="section-heading">{{ page.title }}</h2>
        {% endunless %}
        <div class="richtext-content{% unless section.settings.show_title %} mt-8{% endunless %} max-w-none">
          {{ page.content }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": [
    { "type": "checkbox", "id": "show_breadcrumbs", "label": "Show breadcrumbs", "default": false },
    { "type": "checkbox", "id": "show_title", "label": "Show page title in sidebar", "default": true },
    { "type": "textarea", "id": "intro_copy", "label": "Intro copy" },
    { "type": "text", "id": "sidebar_eyebrow", "label": "Sidebar eyebrow", "default": "Page" },
    { "type": "text", "id": "side_eyebrow", "label": "Side card eyebrow", "default": "Need help" },
    { "type": "text", "id": "side_heading", "label": "Side card heading" },
    { "type": "textarea", "id": "side_copy", "label": "Side card copy" },
    { "type": "text", "id": "side_link_label", "label": "Side card link label" },
    { "type": "url", "id": "side_link_url", "label": "Side card link URL" }
  ]
}
{% endschema %}
