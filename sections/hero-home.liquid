{%- liquid
  assign slide_blocks = section.blocks | where: 'type', 'slide'
  assign hero_heading = section.settings.heading | default: 'USB-C hubs, docks, chargers, and cables built for modern-device workflows.'
  assign hero_copy = section.settings.copy | default: 'EZQuest helps Mac, PC, tablet, and mobile users expand ports, power displays, and keep everyday setups cleaner from desk to travel.'
  assign fallback_image = section.settings.image
  assign fallback_mobile_image = section.settings.image_mobile
  assign owned_hero_desktop_asset = 'hero-home-desktop.svg'
  assign owned_hero_mobile_asset = 'hero-home-mobile.svg'

  if fallback_image == blank and all_products['usb-c-pro-dock'] != blank
    assign fallback_image = all_products['usb-c-pro-dock'].featured_image
  elsif fallback_image == blank and all_products['usb-c-multimedia-hub'] != blank
    assign fallback_image = all_products['usb-c-multimedia-hub'].featured_image
  endif
-%}

<section class="home-hero" data-hero>
  <div class="container-shell">
    <div class="home-hero-shell">
      <div class="home-hero-slider-shell" data-hero-slider{% if slide_blocks.size > 1 %} data-hero-autoplay="true"{% endif %}>
        <div class="home-hero-slider-track">
          {% if slide_blocks.size > 0 %}
            {% for block in slide_blocks %}
              {%- liquid
                assign slide_image = block.settings.image | default: fallback_image
                assign slide_mobile_image = block.settings.image_mobile | default: fallback_mobile_image
                assign slide_desktop_image = slide_image | default: slide_mobile_image
                assign slide_heading = block.settings.heading | default: hero_heading
                assign slide_copy = block.settings.copy | default: hero_copy
                assign slide_primary_label = block.settings.primary_label | default: section.settings.primary_label
                assign slide_primary_url = block.settings.primary_url | default: section.settings.primary_url
                assign slide_secondary_label = block.settings.secondary_label | default: section.settings.secondary_label
                assign slide_secondary_url = block.settings.secondary_url | default: section.settings.secondary_url
                assign uses_owned_hero_asset = false

                if slide_image == blank and slide_mobile_image == blank
                  assign uses_owned_hero_asset = true
                endif
              -%}
              <article
                class="home-hero-slide{% if forloop.first %} is-active{% endif %}"
                data-hero-slide
                {% unless forloop.first %}hidden{% endunless %}
                aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                {{ block.shopify_attributes }}
              >
                <div class="home-hero-media-panel{% if uses_owned_hero_asset %} home-hero-media-panel--owned{% endif %}" data-hero-media>
                  {% if slide_desktop_image != blank or slide_mobile_image != blank %}
                    <picture class="home-hero-media-picture">
                      {% if slide_mobile_image != blank %}
                        <source media="(max-width: 767px)" srcset="{{ slide_mobile_image | image_url: width: 1800 }}">
                      {% endif %}
                      {% if slide_desktop_image != blank %}
                        {{ slide_desktop_image | image_url: width: 2400 | image_tag: loading: 'lazy', class: 'home-hero-media-image', widths: '1200, 1600, 2000, 2400', sizes: '100vw' }}
                      {% else %}
                        <img
                          src="{{ owned_hero_desktop_asset | asset_url }}"
                          alt="{{ slide_heading | escape }}"
                          class="home-hero-media-image"
                          loading="lazy"
                          width="3600"
                          height="2250"
                        >
                      {% endif %}
                    </picture>
                  {% else %}
                    <picture class="home-hero-media-picture">
                      <source media="(max-width: 767px)" srcset="{{ owned_hero_mobile_asset | asset_url }}">
                      <img
                        src="{{ owned_hero_desktop_asset | asset_url }}"
                        alt="{{ slide_heading | escape }}"
                        class="home-hero-media-image"
                        loading="lazy"
                        width="3600"
                        height="2250"
                      >
                    </picture>
                  {% endif %}
                  <div class="home-hero-media-overlay"></div>
                </div>

                <div class="home-hero-copy-panel">
                  <div class="home-hero-copy-meta">
                    <span class="home-hero-copy-series">{{ shop.name }}</span>
                    {% if slide_blocks.size > 1 %}
                      <span class="home-hero-copy-meta-rule" aria-hidden="true"></span>
                      <span class="home-hero-copy-index">0{{ forloop.index }} / 0{{ slide_blocks.size }}</span>
                    {% endif %}
                  </div>
                  {% if block.settings.eyebrow != blank %}
                    <p class="home-hero-copy-kicker" data-hero-kicker>{{ block.settings.eyebrow }}</p>
                  {% endif %}
                  <h1 class="display-heading home-hero-copy-heading" data-hero-heading>{{ slide_heading }}</h1>
                  <p class="home-hero-copy-text" data-hero-copy>{{ slide_copy }}</p>

                  <div class="home-hero-actions" data-hero-actions>
                    {% if slide_primary_label != blank %}
                      <a href="{{ slide_primary_url | default: routes.all_products_collection_url }}" class="home-hero-primary-button">{{ slide_primary_label }}</a>
                    {% endif %}
                    {% if slide_secondary_label != blank %}
                      <a href="{{ slide_secondary_url | default: '/pages/compare' }}" class="home-hero-secondary-link">{{ slide_secondary_label }}</a>
                    {% endif %}
                  </div>

                  <div class="home-hero-trust-rail" data-hero-trust>
                    <span class="home-hero-trust-chip">
                      {% render 'icon', name: 'check' %}
                      <span>Mac + PC confidence</span>
                    </span>
                    <a href="/pages/compare" class="home-hero-trust-link">
                      {% render 'icon', name: 'layers' %}
                      <span>Compare setups</span>
                    </a>
                    <a href="/pages/support" class="home-hero-trust-link">
                      {% render 'icon', name: 'support' %}
                      <span>Support stays close</span>
                    </a>
                  </div>
                </div>

                <div class="home-hero-scene-note" aria-hidden="true">
                  <span>Travel</span>
                  <span>Desk</span>
                  <span>Support</span>
                </div>
              </article>
            {% endfor %}
          {% else %}
            {%- liquid
              assign fallback_desktop_image = fallback_image | default: fallback_mobile_image
              assign uses_owned_hero_asset = false
              if fallback_image == blank and fallback_mobile_image == blank
                assign uses_owned_hero_asset = true
              endif
            -%}
            <article class="home-hero-slide is-active" data-hero-slide aria-hidden="false">
              <div class="home-hero-media-panel{% if uses_owned_hero_asset %} home-hero-media-panel--owned{% endif %}" data-hero-media>
                {% if fallback_desktop_image != blank or fallback_mobile_image != blank %}
                  <picture class="home-hero-media-picture">
                    {% if fallback_mobile_image != blank %}
                      <source media="(max-width: 767px)" srcset="{{ fallback_mobile_image | image_url: width: 1800 }}">
                    {% endif %}
                    {% if fallback_desktop_image != blank %}
                      {{ fallback_desktop_image | image_url: width: 2400 | image_tag: loading: 'lazy', class: 'home-hero-media-image', widths: '1200, 1600, 2000, 2400', sizes: '100vw' }}
                    {% else %}
                      <img
                        src="{{ owned_hero_desktop_asset | asset_url }}"
                        alt="{{ hero_heading | escape }}"
                        class="home-hero-media-image"
                        loading="lazy"
                        width="3600"
                        height="2250"
                      >
                    {% endif %}
                  </picture>
                {% else %}
                  <picture class="home-hero-media-picture">
                    <source media="(max-width: 767px)" srcset="{{ owned_hero_mobile_asset | asset_url }}">
                    <img
                      src="{{ owned_hero_desktop_asset | asset_url }}"
                      alt="{{ hero_heading | escape }}"
                      class="home-hero-media-image"
                      loading="lazy"
                      width="3600"
                      height="2250"
                    >
                  </picture>
                {% endif %}
                <div class="home-hero-media-overlay"></div>
              </div>

              <div class="home-hero-copy-panel">
                <div class="home-hero-copy-meta">
                  <span class="home-hero-copy-series">{{ shop.name }}</span>
                </div>
                {% if section.settings.eyebrow != blank %}
                  <p class="home-hero-copy-kicker" data-hero-kicker>{{ section.settings.eyebrow }}</p>
                {% endif %}
                <h1 class="display-heading home-hero-copy-heading" data-hero-heading>{{ hero_heading }}</h1>
                <p class="home-hero-copy-text" data-hero-copy>{{ hero_copy }}</p>
                <div class="home-hero-actions" data-hero-actions>
                  {% if section.settings.primary_label != blank %}
                    <a href="{{ section.settings.primary_url | default: routes.all_products_collection_url }}" class="home-hero-primary-button">{{ section.settings.primary_label }}</a>
                  {% endif %}
                  {% if section.settings.secondary_label != blank %}
                    <a href="{{ section.settings.secondary_url | default: '/pages/compare' }}" class="home-hero-secondary-link">{{ section.settings.secondary_label }}</a>
                  {% endif %}
                </div>
                <div class="home-hero-trust-rail" data-hero-trust>
                  <span class="home-hero-trust-chip">
                    {% render 'icon', name: 'check' %}
                    <span>Mac + PC confidence</span>
                  </span>
                  <a href="/pages/compare" class="home-hero-trust-link">
                    {% render 'icon', name: 'layers' %}
                    <span>Compare setups</span>
                  </a>
                  <a href="/pages/support" class="home-hero-trust-link">
                    {% render 'icon', name: 'support' %}
                    <span>Support stays close</span>
                  </a>
                </div>
              </div>

              <div class="home-hero-scene-note" aria-hidden="true">
                <span>Travel</span>
                <span>Desk</span>
                <span>Support</span>
              </div>
            </article>
          {% endif %}
        </div>

        {% if slide_blocks.size > 1 %}
          <div class="home-hero-slider-controls" aria-label="Hero slider controls">
            <button class="home-hero-slider-arrow" type="button" data-hero-prev aria-label="Previous slide">
              <span aria-hidden="true">&lsaquo;</span>
            </button>
            <div class="home-hero-slider-dots" role="tablist" aria-label="Hero slides">
              {% for inner_block in slide_blocks %}
                <button
                  class="home-hero-slider-dot{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-hero-dot
                  data-hero-index="{{ forloop.index0 }}"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="Go to slide {{ forloop.index }}"
                ></button>
              {% endfor %}
            </div>
            <button class="home-hero-slider-arrow" type="button" data-hero-next aria-label="Next slide">
              <span aria-hidden="true">&rsaquo;</span>
            </button>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium connectivity" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "USB-C hubs, docks, chargers, and cables built for modern-device workflows." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "EZQuest helps Mac, PC, tablet, and mobile users expand ports, power displays, and keep everyday setups cleaner from desk to travel." },
    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Now" },
    { "type": "url", "id": "primary_url", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label" },
    { "type": "url", "id": "secondary_url", "label": "Secondary CTA link" },
    { "type": "image_picker", "id": "image", "label": "Desktop fallback image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile fallback image" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium connectivity" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "USB-C hubs, docks, chargers, and cables built for modern-device workflows." },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "EZQuest helps Mac, PC, tablet, and mobile users expand ports, power displays, and keep everyday setups cleaner from desk to travel." },
        { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Now" },
        { "type": "url", "id": "primary_url", "label": "Primary CTA link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary CTA label" },
        { "type": "url", "id": "secondary_url", "label": "Secondary CTA link" },
        { "type": "image_picker", "id": "image", "label": "Desktop slide image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile slide image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home hero",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
