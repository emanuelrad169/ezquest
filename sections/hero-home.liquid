{%- liquid
  assign slide_blocks = section.blocks | where: 'type', 'slide'
  assign hero_heading = section.settings.heading | default: 'USB-C hubs, docks, chargers, and cables built for modern-device workflows.'
  assign hero_copy = section.settings.copy | default: 'EZQuest helps Mac, PC, tablet, and mobile users expand ports, power displays, and keep everyday setups cleaner from desk to travel.'
  assign fallback_image = section.settings.image
  assign fallback_mobile_image = section.settings.image_mobile
  assign owned_hero_desktop_asset = 'hero-home-desktop.svg'
  assign owned_hero_mobile_asset = 'hero-home-mobile.svg'
  assign flagship_product = all_products['usb-c-multimedia-hub']
  assign flagship_hero_image = blank
  assign flagship_hero_mobile_image = blank

  if flagship_product != blank and flagship_product.images.size > 0
    assign flagship_hero_image = flagship_product.featured_image | default: flagship_product.images.first
    assign flagship_hero_mobile_image = flagship_hero_image

    if flagship_product.images.size > 1
      assign flagship_desktop_candidate = blank
      assign flagship_mobile_candidate = blank
      assign flagship_non_technical_candidate = blank

      for flagship_image in flagship_product.images
        assign flagship_alt = flagship_image.alt | downcase
        assign flagship_is_technical = false

        if flagship_alt contains 'illustration'
          assign flagship_is_technical = true
        elsif flagship_alt contains 'diagram'
          assign flagship_is_technical = true
        elsif flagship_alt contains 'schematic'
          assign flagship_is_technical = true
        elsif flagship_alt contains 'placeholder'
          assign flagship_is_technical = true
        elsif flagship_alt contains 'port'
          assign flagship_is_technical = true
        elsif flagship_alt contains 'icon'
          assign flagship_is_technical = true
        endif

        if flagship_desktop_candidate == blank and flagship_is_technical == false and flagship_image.aspect_ratio >= 1.1 and flagship_image.aspect_ratio <= 2.4
          assign flagship_desktop_candidate = flagship_image
        endif

        if flagship_mobile_candidate == blank and flagship_is_technical == false and flagship_image.aspect_ratio >= 0.9 and flagship_image.aspect_ratio <= 1.5
          assign flagship_mobile_candidate = flagship_image
        endif

        if flagship_non_technical_candidate == blank and flagship_is_technical == false
          assign flagship_non_technical_candidate = flagship_image
        endif
      endfor

      assign flagship_hero_image = flagship_desktop_candidate | default: flagship_non_technical_candidate | default: flagship_hero_image
      assign flagship_hero_mobile_image = flagship_mobile_candidate | default: flagship_desktop_candidate | default: flagship_non_technical_candidate | default: flagship_hero_mobile_image
    endif
  endif

-%}

<section class="home-hero home-hero--fullbleed pt-0" data-hero>
  <div class="w-full">
    <div class="home-hero-shell w-full bg-transparent">
      <div class="home-hero-slider-shell relative overflow-hidden bg-slate-950" data-hero-slider>
        <div class="home-hero-slider-track">
          {% if slide_blocks.size > 0 %}
            {% for block in slide_blocks %}
              {%- liquid
                assign slide_image = block.settings.image | default: fallback_image
                assign slide_mobile_image = block.settings.image_mobile | default: fallback_mobile_image
                assign slide_desktop_image = slide_image | default: slide_mobile_image
                assign slide_heading = block.settings.heading | default: hero_heading
                assign slide_copy = block.settings.copy | default: hero_copy
                assign slide_primary_label = block.settings.primary_label | default: section.settings.primary_label
                assign slide_secondary_label = block.settings.secondary_label | default: section.settings.secondary_label
                assign slide_secondary_url = block.settings.secondary_url | default: section.settings.secondary_url
                assign uses_owned_hero_asset = false
                assign slide_image_loading = 'lazy'
                assign slide_image_fetchpriority = 'auto'

                if forloop.first
                  assign slide_image_loading = 'eager'
                  assign slide_image_fetchpriority = 'high'
                endif

                if slide_image == blank and slide_mobile_image == blank and flagship_hero_image != blank
                  assign slide_desktop_image = flagship_hero_image
                  assign slide_mobile_image = flagship_hero_mobile_image | default: flagship_hero_image
                endif

                if slide_desktop_image == blank
                  assign slide_desktop_image = slide_mobile_image
                endif

                if slide_desktop_image == blank and slide_mobile_image == blank
                  assign uses_owned_hero_asset = true
                endif
              -%}
              <article
                class="home-hero-slide relative block min-h-hero xl:min-h-feature-lg{% if forloop.first %} is-active{% endif %}"
                data-hero-slide
                {% unless forloop.first %}hidden{% endunless %}
                aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                {{ block.shopify_attributes }}
              >
                <div class="home-hero-media-panel{% if uses_owned_hero_asset %} home-hero-media-panel--owned{% endif %}" data-hero-media>
                  {% if slide_desktop_image != blank or slide_mobile_image != blank %}
                    <picture class="home-hero-media-picture">
                      {% if slide_mobile_image != blank %}
                        <source media="(max-width: 767px)" srcset="{{ slide_mobile_image | image_url: width: 1800 }}">
                      {% endif %}
                      {% if slide_desktop_image != blank %}
                        {{ slide_desktop_image | image_url: width: 2400 | image_tag: loading: slide_image_loading, fetchpriority: slide_image_fetchpriority, class: 'home-hero-media-image', widths: '1200, 1600, 2000, 2400', sizes: '100vw' }}
                      {% else %}
                        <img
                          src="{{ owned_hero_desktop_asset | asset_url }}"
                          alt="{{ slide_heading | escape }}"
                          class="home-hero-media-image"
                          loading="{{ slide_image_loading }}"
                          fetchpriority="{{ slide_image_fetchpriority }}"
                          width="3600"
                          height="2250"
                        >
                      {% endif %}
                    </picture>
                  {% else %}
                    <picture class="home-hero-media-picture">
                      <source media="(max-width: 767px)" srcset="{{ owned_hero_mobile_asset | asset_url }}">
                      <img
                        src="{{ owned_hero_desktop_asset | asset_url }}"
                        alt="{{ slide_heading | escape }}"
                        class="home-hero-media-image"
                        loading="{{ slide_image_loading }}"
                        fetchpriority="{{ slide_image_fetchpriority }}"
                        width="3600"
                        height="2250"
                      >
                    </picture>
                  {% endif %}
                  <div class="home-hero-media-overlay"></div>
                </div>

                <div class="pointer-events-none absolute inset-0 z-10">
                  <div class="container-shell relative flex h-full flex-col justify-end md:block">
                    <div class="home-hero-copy-panel pointer-events-auto absolute bottom-23 left-0 right-auto z-10 flex max-w-none translate-y-0 flex-col items-start justify-center pl-4 text-left md:max-w-copy-row md:pl-4 lg:top-1/2 lg:bottom-auto lg:max-w-prose lg:-translate-y-1/2 lg:pl-4 xl:max-w-hero-panel xl:pl-4">
                      {% if block.settings.eyebrow != blank %}
                        <p class="home-hero-copy-kicker" data-hero-kicker>{{ block.settings.eyebrow }}</p>
                      {% endif %}
                      <h1 class="display-heading home-hero-copy-heading mt-5 max-w-prose text-display-3xl text-white md:max-w-copy-row lg:mt-6 lg:text-display-4xl xl:mt-7 xl:max-w-hero xl:text-display-5xl" data-hero-heading>{{ slide_heading }}</h1>
                      <p class="home-hero-copy-text mt-4 max-w-copy text-body-sm text-white/80 md:max-w-copy-row md:text-body lg:mt-5 lg:max-w-copy-md lg:text-body-lg xl:max-w-prose" data-hero-copy>{{ slide_copy }}</p>

                      <div class="home-hero-actions mt-6 flex flex-wrap items-center gap-4 lg:mt-8" data-hero-actions>
                        {% if slide_primary_label != blank %}
                          {% render 'button', label: slide_primary_label, url: block.settings.primary_url | default: section.settings.primary_url | default: routes.all_products_collection_url, style: 'primary', class: 'button-context-hero-primary' %}
                        {% endif %}
                        {% if slide_secondary_label != blank %}
                          <a href="{{ slide_secondary_url | default: '/pages/compare' }}" class="home-hero-secondary-link">{{ slide_secondary_label }}</a>
                        {% endif %}
                      </div>
                    </div>

                  </div>
                </div>
              </article>
            {% endfor %}
          {% else %}
            {%- liquid
              assign fallback_desktop_image = fallback_image | default: fallback_mobile_image
              assign uses_owned_hero_asset = false
              assign fallback_image_loading = 'eager'
              assign fallback_image_fetchpriority = 'high'
              if fallback_desktop_image == blank and flagship_hero_image != blank
                assign fallback_desktop_image = flagship_hero_image
              endif
              if fallback_mobile_image == blank and flagship_hero_mobile_image != blank
                assign fallback_mobile_image = flagship_hero_mobile_image
              endif
              if fallback_desktop_image == blank
                assign fallback_desktop_image = fallback_mobile_image
              endif
              if fallback_desktop_image == blank and fallback_mobile_image == blank
                assign uses_owned_hero_asset = true
              endif
            -%}
            <article class="home-hero-slide relative block min-h-hero xl:min-h-feature-lg is-active" data-hero-slide aria-hidden="false">
              <div class="home-hero-media-panel{% if uses_owned_hero_asset %} home-hero-media-panel--owned{% endif %}" data-hero-media>
                {% if fallback_desktop_image != blank or fallback_mobile_image != blank %}
                  <picture class="home-hero-media-picture">
                    {% if fallback_mobile_image != blank %}
                      <source media="(max-width: 767px)" srcset="{{ fallback_mobile_image | image_url: width: 1800 }}">
                    {% endif %}
                    {% if fallback_desktop_image != blank %}
                      {{ fallback_desktop_image | image_url: width: 2400 | image_tag: loading: fallback_image_loading, fetchpriority: fallback_image_fetchpriority, class: 'home-hero-media-image', widths: '1200, 1600, 2000, 2400', sizes: '100vw' }}
                    {% else %}
                      <img
                        src="{{ owned_hero_desktop_asset | asset_url }}"
                        alt="{{ hero_heading | escape }}"
                        class="home-hero-media-image"
                        loading="{{ fallback_image_loading }}"
                        fetchpriority="{{ fallback_image_fetchpriority }}"
                        width="3600"
                        height="2250"
                      >
                    {% endif %}
                  </picture>
                {% else %}
                  <picture class="home-hero-media-picture">
                    <source media="(max-width: 767px)" srcset="{{ owned_hero_mobile_asset | asset_url }}">
                    <img
                      src="{{ owned_hero_desktop_asset | asset_url }}"
                      alt="{{ hero_heading | escape }}"
                      class="home-hero-media-image"
                      loading="{{ fallback_image_loading }}"
                      fetchpriority="{{ fallback_image_fetchpriority }}"
                      width="3600"
                      height="2250"
                    >
                  </picture>
                {% endif %}
                <div class="home-hero-media-overlay"></div>
              </div>

              <div class="pointer-events-none absolute inset-0 z-10">
                <div class="container-shell relative flex h-full flex-col justify-end md:block">
                  <div class="home-hero-copy-panel pointer-events-auto absolute bottom-23 left-0 right-auto z-10 flex max-w-none translate-y-0 flex-col items-start justify-center pl-4 text-left md:max-w-copy-row md:pl-4 lg:top-1/2 lg:bottom-auto lg:max-w-prose lg:-translate-y-1/2 lg:pl-4 xl:max-w-hero-panel xl:pl-4">
                    {% if section.settings.eyebrow != blank %}
                      <p class="home-hero-copy-kicker" data-hero-kicker>{{ section.settings.eyebrow }}</p>
                    {% endif %}
                    <h1 class="display-heading home-hero-copy-heading mt-5 max-w-prose text-display-3xl text-white md:max-w-copy-row lg:mt-6 lg:text-display-4xl xl:mt-7 xl:max-w-hero xl:text-display-5xl" data-hero-heading>{{ hero_heading }}</h1>
                    <p class="home-hero-copy-text mt-4 max-w-copy text-body-sm text-white/80 md:max-w-copy-row md:text-body lg:mt-5 lg:max-w-copy-md lg:text-body-lg xl:max-w-prose" data-hero-copy>{{ hero_copy }}</p>
                    <div class="home-hero-actions mt-6 flex flex-wrap items-center gap-4 lg:mt-8" data-hero-actions>
                      {% if section.settings.primary_label != blank %}
                        {% render 'button', label: section.settings.primary_label, url: section.settings.primary_url | default: routes.all_products_collection_url, style: 'primary', class: 'button-context-hero-primary' %}
                      {% endif %}
                      {% if section.settings.secondary_label != blank %}
                        <a href="{{ section.settings.secondary_url | default: '/pages/compare' }}" class="home-hero-secondary-link">{{ section.settings.secondary_label }}</a>
                      {% endif %}
                    </div>
                  </div>

                </div>
              </div>
            </article>
          {% endif %}
        </div>

        {% if slide_blocks.size > 1 %}
          <div class="home-hero-slider-controls absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 items-center gap-4 bg-transparent px-3 py-2.5 shadow-none lg:bottom-6 lg:px-4 lg:py-3" aria-label="Hero slider controls">
            <button class="home-hero-slider-arrow" type="button" data-hero-prev aria-label="Previous slide">
              <span aria-hidden="true">&lsaquo;</span>
            </button>
            <div class="home-hero-slider-dots" role="tablist" aria-label="Hero slides">
              {% for inner_block in slide_blocks %}
                <button
                  class="home-hero-slider-dot{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-hero-dot
                  data-hero-index="{{ forloop.index0 }}"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="Go to slide {{ forloop.index }}"
                ></button>
              {% endfor %}
            </div>
            <button class="home-hero-slider-arrow" type="button" data-hero-next aria-label="Next slide">
              <span aria-hidden="true">&rsaquo;</span>
            </button>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium connectivity" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "USB-C hubs, docks, chargers, and cables built for modern-device workflows." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "EZQuest helps Mac, PC, tablet, and mobile users expand ports, power displays, and keep everyday setups cleaner from desk to travel." },
    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Now" },
    { "type": "url", "id": "primary_url", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label" },
    { "type": "url", "id": "secondary_url", "label": "Secondary CTA link" },
    { "type": "image_picker", "id": "image", "label": "Desktop fallback image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile fallback image" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium connectivity" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "USB-C hubs, docks, chargers, and cables built for modern-device workflows." },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "EZQuest helps Mac, PC, tablet, and mobile users expand ports, power displays, and keep everyday setups cleaner from desk to travel." },
        { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Now" },
        { "type": "url", "id": "primary_url", "label": "Primary CTA link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary CTA label" },
        { "type": "url", "id": "secondary_url", "label": "Secondary CTA link" },
        { "type": "image_picker", "id": "image", "label": "Desktop slide image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile slide image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home hero",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
