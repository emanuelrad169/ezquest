{%- liquid
  assign media_first = false
  assign hero_heading = section.settings.heading | default: 'Homepage hero framework'
  assign hero_copy = section.settings.copy | default: 'Reserved for homepage value proposition, support orientation, and merchandising hierarchy.'
  assign panel_eyebrow = section.settings.panel_eyebrow | default: 'Framework note'
  assign panel_heading = section.settings.panel_heading | default: 'Implementation direction'
  assign panel_copy = section.settings.panel_copy | default: 'Reserved for structural guidance, merchandising priorities, or support handoff messaging.'
  if section.settings.layout == 'media_first'
    assign media_first = true
  endif
-%}
<section class="section-shell pt-8 lg:pt-10">
  <div class="container-shell">
    <div class="hero-surface">
      <div class="hero-layout">
        <div class="hero-copy-stack{% if media_first %} order-2 lg:order-2{% endif %}">
          {% if section.settings.eyebrow != blank %}
            <p class="section-kicker">{{ section.settings.eyebrow }}</p>
          {% endif %}
          <h1 class="section-heading mt-5">{{ hero_heading }}</h1>
          <p class="section-copy mt-5">{{ hero_copy }}</p>

          <div class="hero-chip-row">
            <span class="hero-chip">Premium electronics</span>
            <span class="hero-chip">Support-aware storefront</span>
            <span class="hero-chip">Structured-ready foundation</span>
          </div>

          <div class="action-cluster mt-8">
            {% if section.settings.primary_label != blank %}
              {% render 'button', label: section.settings.primary_label, url: section.settings.primary_url %}
            {% endif %}
            {% if section.settings.secondary_label != blank %}
              {% render 'button', label: section.settings.secondary_label, url: section.settings.secondary_url, style: 'secondary' %}
            {% endif %}
            {% if section.settings.show_support_link and settings.support_contact_url != blank %}
              <a href="{{ settings.support_contact_url }}" class="site-meta-link">
                Contact support
              </a>
            {% endif %}
          </div>

          <div class="hero-quick-links">
            <a href="/pages/compare" class="hero-quick-link">
              <div class="section-kicker">Compare</div>
              <div class="mt-2 text-base font-semibold tracking-[-0.02em] text-slate-950">Compare product families</div>
            </a>
            <a href="/pages/downloads" class="hero-quick-link">
              <div class="section-kicker">Resources</div>
              <div class="mt-2 text-base font-semibold tracking-[-0.02em] text-slate-950">Open downloads and manuals</div>
            </a>
          </div>

          <div class="hero-metrics">
            {% if section.blocks.size > 0 %}
              {% for block in section.blocks %}
                <div class="hero-metric" {{ block.shopify_attributes }}>
                  <p class="text-2xl font-semibold tracking-[-0.04em] text-slate-950">{{ block.settings.value }}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{{ block.settings.label }}</p>
                </div>
              {% endfor %}
            {% else %}
              {% for i in (1..3) %}
                <div class="hero-metric">
                  <p class="text-2xl font-semibold tracking-[-0.04em] text-slate-950">0{{ i }}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">Add hero metric blocks in the theme editor to reinforce priorities here.</p>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>

        <div class="space-y-5{% unless media_first %} lg:justify-self-end{% endunless %}">
          <div class="hero-media-frame">
            {% render 'media', image: section.settings.image, aspect_ratio: 'aspect-[4/3]', class: 'w-full bg-transparent p-0 shadow-none', object_fit: 'object-contain' %}
          </div>

          {% if section.settings.show_panel %}
            <div class="hero-panel">
              <p class="section-kicker">{{ panel_eyebrow }}</p>
              <h2 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-slate-950">{{ panel_heading }}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{{ panel_copy }}</p>
              <div class="support-crosslink-list">
                <a href="{{ routes.all_products_collection_url }}" class="support-crosslink">
                  <span>Shop all products</span>
                  <span class="text-slate-400">Browse</span>
                </a>
                <a href="/pages/support" class="support-crosslink">
                  <span>Open support center</span>
                  <span class="text-slate-400">Help</span>
                </a>
              </div>
              {% if section.settings.panel_link_label != blank and section.settings.panel_link_url != blank %}
                <div class="mt-6">
                  {% render 'button', label: section.settings.panel_link_label, url: section.settings.panel_link_url, style: 'secondary' %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Homepage" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Homepage hero framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for homepage value proposition, support orientation, and merchandising hierarchy." },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "split",
      "options": [
        { "value": "split", "label": "Content left, media right" },
        { "value": "media_first", "label": "Media left, content right" }
      ]
    },
    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop collection" },
    { "type": "url", "id": "primary_url", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label", "default": "Explore support" },
    { "type": "url", "id": "secondary_url", "label": "Secondary CTA link" },
    { "type": "checkbox", "id": "show_support_link", "label": "Show support text link", "default": true },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "show_panel", "label": "Show framework panel", "default": true },
    { "type": "text", "id": "panel_eyebrow", "label": "Framework panel eyebrow", "default": "Framework note" },
    { "type": "text", "id": "panel_heading", "label": "Framework panel heading", "default": "Implementation direction" },
    { "type": "textarea", "id": "panel_copy", "label": "Framework panel copy", "default": "Reserved for structural guidance, merchandising priorities, or support handoff messaging." },
    { "type": "text", "id": "panel_link_label", "label": "Framework panel link label", "default": "Learn more" },
    { "type": "url", "id": "panel_link_url", "label": "Framework panel link" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "Value" },
        { "type": "text", "id": "label", "label": "Label", "default": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home hero",
      "blocks": [{ "type": "stat" }, { "type": "stat" }, { "type": "stat" }]
    }
  ]
}
{% endschema %}
