<section class="section-shell home-testimonials-section">
  <div class="container-shell">

    <div class="home-testimonials-header">
      <div class="home-testimonials-header-copy">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading{% if section.settings.eyebrow != blank %} mt-4{% endif %}">{{ section.settings.heading }}</h2>
      </div>
      <div class="home-testimonials-controls" aria-label="Carousel controls">
        <button class="home-testimonials-arrow" type="button" data-carousel-prev aria-label="Previous">
          {% render 'icon', name: 'chevron-left' %}
        </button>
        <button class="home-testimonials-arrow" type="button" data-carousel-next aria-label="Next">
          {% render 'icon', name: 'chevron-right' %}
        </button>
      </div>
    </div>

    <div class="home-testimonials-carousel" data-scroll-carousel aria-label="{{ section.settings.heading }}">
      <div class="home-testimonials-track" data-carousel-track>
        {% for block in section.blocks %}
          {%- liquid
            assign reviewer = block.settings.reviewer_name | default: 'Customer'
            assign rating = block.settings.rating | default: 5
            assign review = block.settings.review_text
            assign product_obj = block.settings.product
            assign avatar = block.settings.avatar
          -%}
          <article class="home-testimonials-card" {{ block.shopify_attributes }}>
            <div class="home-testimonials-card-top">
              <div class="home-testimonials-reviewer">
                <div class="home-testimonials-avatar">
                  {% if avatar != blank %}
                    {{ avatar | image_url: width: 80 | image_tag: loading: 'lazy', alt: reviewer, class: 'home-testimonials-avatar-img' }}
                  {% else %}
                    <span class="home-testimonials-avatar-fallback">{{ reviewer | slice: 0 }}</span>
                  {% endif %}
                </div>
                <div>
                  <p class="home-testimonials-name">{{ reviewer }}</p>
                  <div class="home-testimonials-stars" aria-label="{{ rating }} out of 5 stars">
                    {%- for i in (1..5) -%}
                      <svg class="home-testimonials-star{% if i <= rating %} is-filled{% endif %}" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M7 1.5l1.55 3.14 3.47.5-2.51 2.45.59 3.45L7 9.27l-3.1 1.77.59-3.45L2 5.14l3.47-.5L7 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            </div>
            {% if review != blank %}
              <p class="home-testimonials-text">{{ review }}</p>
            {% endif %}
            {% if product_obj != blank %}
              <div class="home-testimonials-product">
                {% if product_obj.featured_image != blank %}
                  {{ product_obj.featured_image | image_url: width: 80 | image_tag: loading: 'lazy', class: 'home-testimonials-product-img', alt: product_obj.title }}
                {% endif %}
                <span class="home-testimonials-product-name">{{ product_obj.title | truncate: 40 }}</span>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Home testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by Over 200+ Million Users Worldwide" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "reviewer_name", "label": "Reviewer name", "default": "Customer" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar image" },
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "review_text", "label": "Review text" },
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
