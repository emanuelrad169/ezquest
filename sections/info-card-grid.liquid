<section class="section-shell">
  <div class="container-shell">
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}
          <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% endif %}
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    {%- liquid
      assign columns_class = 'xl:grid-cols-3'
      if section.settings.columns_desktop == 2
        assign columns_class = 'xl:grid-cols-2'
      elsif section.settings.columns_desktop == 4
        assign columns_class = 'xl:grid-cols-4'
      endif
    -%}

    <div class="mt-10 grid gap-6 md:grid-cols-2 {{ columns_class }}">
      {% for block in section.blocks %}
        <article class="feature-card bg-gradient-to-br from-white to-slate-50" {{ block.shopify_attributes }}>
          <div class="flex items-center justify-between gap-4">
            <p class="section-kicker">{{ block.settings.eyebrow | default: 'Detail' }}</p>
            <span class="text-xs uppercase tracking-[0.18em] text-slate-300">{{ forloop.index | prepend: '0' }}</span>
          </div>
          <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">{{ block.settings.title | default: 'Information card' }}</h3>
          {% if block.settings.copy != blank %}
            <p class="mt-3 text-sm leading-7 text-slate-600">{{ block.settings.copy }}</p>
          {% endif %}
          {% if block.settings.link_url != blank %}
            <div class="mt-6">
              {% render 'button', label: block.settings.link_label, url: block.settings.link_url, style: 'secondary' %}
            </div>
          {% endif %}
        </article>
      {% else %}
        {% for i in (1..3) %}
          <article class="feature-card bg-gradient-to-br from-white to-slate-50">
            <div class="flex items-center justify-between gap-4">
              <p class="section-kicker">Detail</p>
              <span class="text-xs uppercase tracking-[0.18em] text-slate-300">{{ i | prepend: '0' }}</span>
            </div>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">Information card</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">Add cards in the theme editor to populate this section.</p>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Info card grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Information" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Supporting details" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Use this section for company details, process summaries, contact pathways, or policy highlights." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Info card",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Detail" },
        { "type": "text", "id": "title", "label": "Title", "default": "Information card" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Summary text" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Info card grid",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
