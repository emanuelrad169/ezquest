<section class="section-shell product-specs-section">
  <div class="container-shell max-w-6xl">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Technical sheet'
      assign section_copy = section.settings.copy | default: 'Review the key ports, charging, display, and host details that matter most before you commit.'
      assign section_note = section.settings.source_note | default: 'Review the key specs here, then open compatibility or manuals if you need one last detail.'
      assign structured_spec_rows = blank
      assign has_structured_rows = false

      if product != blank and product.metafields.ezquest.spec_rows != blank
        assign structured_spec_rows = product.metafields.ezquest.spec_rows.value
        if structured_spec_rows.count > 0
          assign has_structured_rows = true
        endif
      endif

      case product.handle
        when 'usb-c-travel-hub'
          assign section_heading = 'Specifications for mobile setups'
          assign section_copy = 'Review the core ports, charging path, and display support that matter when the setup needs to stay light and mobile.'
          assign section_note = 'Check the essentials here, then open compatibility if you need to confirm a display or host detail.'
        when 'usb-c-pro-dock'
          assign section_heading = 'Specifications for desk setups'
          assign section_copy = 'Review the broader connectivity, display support, charging path, and host details that matter before you commit to a permanent desk setup.'
          assign section_note = 'Check the desk-critical specs here, then open compatibility or manuals if you need a deeper detail.'
        when 'usb-c-multimedia-hub'
          assign section_heading = 'Specifications for everyday desks'
          assign section_copy = 'Review the ports, charging support, display path, and host details that make this a strong everyday choice.'
          assign section_note = 'Check the everyday essentials here, then open compatibility or manuals if one detail still needs confirmation.'
      endcase
    -%}

    <div class="grid gap-8 lg:grid-cols-article-aside lg:items-start">
      <div class="product-technical-intro">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        <p class="product-technical-note">{{ section_note }}</p>
      </div>

      <div class="spec-table-shell">
        <div class="spec-table-head">
          <p class="section-kicker">Technical profile</p>
        </div>

        <div class="spec-table-body">
          {% if has_structured_rows %}
            {% for spec_row in structured_spec_rows %}
              {% render 'spec-row', label: spec_row.label.value, value: spec_row.spec_value.value, first: forloop.first %}
            {% endfor %}
          {% else %}
            {% for block in section.blocks %}
              {% render 'spec-row', label: block.settings.label, value: block.settings.value, first: forloop.first %}
            {% else %}
              {% render 'spec-row', label: section.settings.empty_state_label, value: section.settings.empty_state_value, first: true %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product spec table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Technical sheet" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Technical sheet" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Review the key ports, charging, display, and host details that matter most before you commit." },
    { "type": "textarea", "id": "source_note", "label": "Source note", "default": "Review the key specs here, then open compatibility or manuals if you need one last detail." },
    { "type": "text", "id": "empty_state_label", "label": "Empty-state label", "default": "Connection type" },
    { "type": "text", "id": "empty_state_value", "label": "Empty-state value", "default": "USB-C host connection" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Specification row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Connection type" },
        { "type": "text", "id": "value", "label": "Value", "default": "USB-C host connection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product spec table",
      "blocks": [{ "type": "row" }, { "type": "row" }, { "type": "row" }]
    }
  ]
}
{% endschema %}
