{{ 'support-cluster.css' | asset_url | stylesheet_tag }}

<section class="support-hero relative overflow-hidden">
  <div class="support-hero__wrap w-full">
    <p class="support-hero__kicker">Firmware</p>
    <h1 class="support-hero__heading">
      Firmware updates
    </h1>
    <p class="support-hero__sub">
      Keep your EZQuest device running the latest verified firmware.
      Always download the version matched to your OS.
    </p>
  </div>
</section>

{% render 'support-nav', current: 'firmware' %}

<div class="support-body">

  <div class="info-card info-card--amber bg-[var(--ez-amber-04)] border-[var(--ez-amber-25)]" style="margin-bottom:2rem">
    <div class="info-card__icon info-card__icon--amber">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2l7 13H2L9 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 7v4M9 13v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div>
      <p class="info-card__title">Before updating</p>
      <p class="info-card__body">
        Connect your device to a power source and ensure a stable connection.
        Do not disconnect during the update. Firmware updates are not reversible.
      </p>
    </div>
  </div>

  {% for block in section.blocks %}
    {% if block.type == 'firmware_entry' %}
      <div class="fw-card hover:border-[var(--ez-amber-30)]" {{ block.shopify_attributes }}>
        <div class="fw-card__header mb-5">
          <div class="fw-card__meta">
            <span class="fw-card__version">{{ block.settings.version }}</span>
            {% if block.settings.is_latest %}
              <span class="fw-card__latest-badge">Latest</span>
            {% endif %}
          </div>
          <p class="fw-card__product">{{ block.settings.product_name }}</p>
          <p class="fw-card__date">Released {{ block.settings.release_date }} · Compatible with {{ block.settings.os_compat }}</p>
        </div>

        {% if block.settings.changelog != blank %}
          <details class="fw-changelog">
            <summary class="fw-changelog__trigger hover:text-[var(--ez-black)]">
              What's changed in this version
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="fw-changelog__icon transition-transform duration-200 shrink-0" aria-hidden="true"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="fw-changelog__body">{{ block.settings.changelog }}</div>
          </details>
        {% endif %}

        <div class="fw-card__actions">
          {% if block.settings.mac_url != blank and block.settings.mac_url != '#' %}
            <a href="{{ block.settings.mac_url }}" class="btn-download hover:bg-[var(--ez-amber)]" download>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 2v7m0 0L4.5 6.5M7 9l2.5-2.5M2 11h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              macOS
            </a>
          {% endif %}
          {% if block.settings.win_url != blank and block.settings.win_url != '#' %}
            <a href="{{ block.settings.win_url }}" class="btn-download hover:bg-[var(--ez-amber)]" download style="background:var(--ez-black)">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 2v7m0 0L4.5 6.5M7 9l2.5-2.5M2 11h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Windows
            </a>
          {% endif %}
          {% if block.settings.mac_url == blank and block.settings.win_url == blank %}
            <span style="font-size:13px;color:var(--ez-grey)">Files uploading</span>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}

  {% if section.blocks.size == 0 %}
    <div class="empty-state">
      <p class="empty-state__heading">Firmware files are being prepared</p>
      <p class="empty-state__body">Check back shortly or contact us for direct access.</p>
      <a href="/pages/contact" class="btn btn--primary">Contact support</a>
    </div>
  {% endif %}


</div>

{%- render 'page-cta',
  variant: 'dark',
  kicker: 'Firmware',
  heading: 'Need help with an update?',
  subhead: 'Our team can walk you through the process.',
  primary_label: 'Get help',
  primary_url: '/pages/contact'
-%}

{% schema %}
{
  "name": "Firmware",
  "tag": "section",
  "blocks": [
    {
      "type": "firmware_entry",
      "name": "Firmware version",
      "settings": [
        {"type":"text","id":"product_name","label":"Product name"},
        {"type":"text","id":"version","label":"Version number","placeholder":"v2.1.0"},
        {"type":"checkbox","id":"is_latest","label":"Mark as latest","default":true},
        {"type":"text","id":"release_date","label":"Release date","placeholder":"April 2025"},
        {"type":"text","id":"os_compat","label":"Compatible with","default":"macOS 12+ · Windows 10/11"},
        {"type":"richtext","id":"changelog","label":"Changelog (optional)"},
        {"type":"url","id":"mac_url","label":"macOS download URL"},
        {"type":"url","id":"win_url","label":"Windows download URL"}
      ]
    }
  ],
  "presets":[{"name":"Firmware"}]
}
{% endschema %}
