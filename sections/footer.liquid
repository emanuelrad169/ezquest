{{ 'pages.css' | asset_url | stylesheet_tag }}
{% render 'site-footer', section: section %}

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "shopify-section-footer",
  "settings": [
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Support menu"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "Company menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal menu"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support heading",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "company_heading",
      "label": "Company heading",
      "default": "Company"
    },
    {
      "type": "text",
      "id": "legal_heading",
      "label": "Legal heading",
      "default": "Legal"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay connected"
    },
    {
      "type": "textarea",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "Browse products, find support, and review policy details without losing the path back into your setup."
    }
  ]
}
{% endschema %}
