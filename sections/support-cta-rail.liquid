{% render 'page-cta',
  kicker: section.settings.kicker,
  heading: section.settings.heading,
  subhead: section.settings.body,
  primary_label: section.settings.cta_label,
  primary_url: section.settings.cta_url,
  secondary_label: section.settings.cta2_label,
  secondary_url: section.settings.cta2_url,
  variant: section.settings.variant,
  aria_label: section.settings.heading
%}

{% schema %}
{
  "name": "Support CTA rail",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Style",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark",  "label": "Dark" },
        { "value": "amber", "label": "Amber" }
      ],
      "default": "light"
    },
    { "type": "text",     "id": "kicker",     "label": "Kicker",     "default": "Support" },
    { "type": "text",     "id": "heading",    "label": "Heading" },
    { "type": "textarea", "id": "body",       "label": "Subheading" },
    { "type": "text",     "id": "cta_label",  "label": "Primary button label" },
    { "type": "url",      "id": "cta_url",    "label": "Primary button URL" },
    { "type": "text",     "id": "cta2_label", "label": "Secondary button label" },
    { "type": "url",      "id": "cta2_url",   "label": "Secondary button URL" }
  ],
  "presets": [
    { "name": "Support CTA rail" }
  ]
}
{% endschema %}
