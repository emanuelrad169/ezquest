  left: 0;
  color: #c9a800;
  font-weight: 700;
}
.rp-highlights__note {
  font-size: 12px;
  color: var(--ez-grey);
  margin: 0;
  font-style: italic;
}
.rp-bottom-cta {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1.75rem 0 0;
  margin-top: 2.5rem;
  border-top: 1px solid rgba(0, 0, 0, .07);
}
.rp-bottom-cta p {
  font-size: 15px;
  font-weight: 500;
  color: var(--ez-black);
  margin: 0;
}
</style>

