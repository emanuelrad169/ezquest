  list-style: none;
  padding: 0;
  margin: 0 0 .875rem;
  display: flex;
  flex-direction: column;
  gap: .5rem;
}
.rp-highlights__list li {
  font-size: 14px;
  color: var(--ez-black);
  font-weight: 500;
