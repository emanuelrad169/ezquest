{{ 'policy-page.css' | asset_url | stylesheet_tag }}

{% assign doc_title = page.title %}
{% assign doc_body  = page.content %}
{% assign doc_handle = page.handle %}

<div class="policy-page">

  <div class="policy-hero">
    <p class="policy-hero__kicker">Legal</p>
    <h1 class="policy-hero__heading">{{ doc_title }}</h1>
    <p class="policy-hero__meta">Last updated: 2026</p>
  </div>

  <div class="policy-layout">

    <div class="policy-prose">
      {{ doc_body }}
    </div>

    <aside class="policy-sidebar">

      <div class="policy-sidebar__card">
        <p class="policy-sidebar__label">Legal documents</p>
        <nav class="policy-sidebar__nav">
          <a href="/policies/privacy-policy"
             class="policy-sidebar__link{% if doc_handle == 'privacy-policy' %} is-active{% endif %}">
            Privacy Policy
          </a>
          <a href="/policies/terms-of-service"
             class="policy-sidebar__link{% if doc_handle == 'terms-of-service' %} is-active{% endif %}">
            Terms of Service
          </a>
          <a href="/policies/refund-policy"
             class="policy-sidebar__link{% if doc_handle == 'refund-policy' %} is-active{% endif %}">
            Refund Policy
          </a>
          <a href="/pages/shipping-returns"
             class="policy-sidebar__link{% if doc_handle == 'shipping-returns' %} is-active{% endif %}">
            Shipping &amp; Returns
          </a>
          <a href="/pages/cookie-policy"
             class="policy-sidebar__link{% if doc_handle == 'cookie-policy' %} is-active{% endif %}">
            Cookie Policy
          </a>
          <a href="/pages/warranty"
             class="policy-sidebar__link{% if doc_handle == 'warranty' %} is-active{% endif %}">
            Warranty
          </a>
        </nav>
      </div>

      <div class="policy-sidebar__card policy-sidebar__card--help">
        <p class="policy-sidebar__help-title">Questions?</p>
        <p class="policy-sidebar__help-body">
          We respond within 1 business day.
        </p>
        <a href="/pages/contact"
           class="btn btn--primary"
           style="display:block;text-align:center;margin-top:1rem;border-radius:100px">
          Contact us
        </a>
      </div>

    </aside>
  </div>
</div>

{% schema %}
{
  "name": "Policy page",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Policy page" }]
}
{% endschema %}
