{%- liquid
  assign feature_image = section.settings.image
  assign use_owned_support_visual = false

  if feature_image == blank and all_products['usb-c-pro-dock'] != blank
    assign feature_image = all_products['usb-c-pro-dock'].featured_image
  elsif feature_image == blank and all_products['usb-c-multimedia-hub'] != blank
    assign feature_image = all_products['usb-c-multimedia-hub'].featured_image
  endif

  if feature_image == blank
    assign use_owned_support_visual = true
  endif
-%}

<section class="section-shell home-feature-band-section">
  <div class="container-shell">
    <div class="home-feature-band">
      <div class="home-feature-band-copy">
        {% if section.settings.eyebrow != blank %}
          <p class="home-feature-band-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="home-feature-band-heading">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}
          <p class="home-feature-band-text">{{ section.settings.copy }}</p>
        {% endif %}
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <a href="{{ section.settings.link_url }}" class="home-feature-band-button">{{ section.settings.link_label }}</a>
        {% endif %}
        <div class="home-feature-band-note">
          <p class="home-feature-band-note-kicker">Support stays in the buying path</p>
          <p class="home-feature-band-note-copy">Check fit before you order, then move into manuals, downloads, and help without leaving the EZQuest flow.</p>
        </div>
        <div class="home-feature-band-links">
          <a href="/pages/compatibility" class="support-inline-link">Check compatibility</a>
          <a href="/pages/manuals" class="support-inline-link">Manuals</a>
          <a href="/pages/downloads" class="support-inline-link">Downloads</a>
        </div>
      </div>

      <div class="home-feature-band-media">
        {% if feature_image != blank %}
          {{ feature_image | image_url: width: 1800 | image_tag: loading: 'lazy', class: 'home-feature-band-image' }}
        {% elsif use_owned_support_visual %}
          {% render 'owned-support-visual', context: 'support', alt: 'EZQuest ownership support', width: 1800, height: 1400, class: 'home-feature-band-image' %}
        {% else %}
          {% render 'placeholder-visual', kind: 'support', text: 'EZQuest lifestyle', width: 1800, height: 1400, class: 'home-feature-band-image' %}
        {% endif %}
        <div class="home-feature-band-dots" aria-hidden="true">
          <span></span>
          <span></span>
          <span class="is-active"></span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support card grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support-aware commerce" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From compatibility before purchase to setup after delivery, support stays close." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Keep compatibility, manuals, downloads, and direct help close to the buying path so the EZQuest experience feels complete before and after purchase." },
    { "type": "text", "id": "link_label", "label": "Section link label", "default": "Open support center" },
    { "type": "url", "id": "link_url", "label": "Section link URL" },
    { "type": "image_picker", "id": "image", "label": "Feature image" }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Support card grid"
    }
  ]
}
{% endschema %}
