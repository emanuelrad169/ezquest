<section class="section-shell">
  <div class="container-shell">
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}
          <p class="section-copy mt-4">{{ section.settings.copy }}</p>
        {% endif %}
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>
    {%- liquid
      assign columns_class = 'xl:grid-cols-3'
      if section.settings.columns_desktop == 2
        assign columns_class = 'xl:grid-cols-2'
      elsif section.settings.columns_desktop == 4
        assign columns_class = 'xl:grid-cols-4'
      endif
    -%}
    <div class="mt-10 grid gap-6 md:grid-cols-2 {{ columns_class }}">
      {% for block in section.blocks %}
        {% render 'card-support', title: block.settings.title, copy: block.settings.copy, link_label: block.settings.link_label, link_url: block.settings.link_url %}
      {% else %}
        {% for i in (1..3) %}
          {% render 'card-support', title: 'Support item', copy: 'Add support cards in the theme editor to populate this grid.', link_label: 'View page', link_url: '#' %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support card grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Support pathways" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for key support tasks and escalation paths." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Support card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Support item" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Support task summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "View page" },
        { "type": "url", "id": "link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support card grid",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
