{%- liquid
  assign source_blog = blogs[section.settings.blog_handle]
  assign article_limit = section.settings.article_limit | default: 6
-%}

<section class="section-shell resources-featured-section">
  <div class="container-shell">
    <div class="section-intro">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section.settings.heading | default: 'Featured guides' }}</h2>
      </div>
      {% if source_blog != blank %}
        <a href="{{ source_blog.url }}" class="resources-featured-all section-intro-action">View all guides →</a>
      {% endif %}
    </div>

    <div class="resources-articles-grid mt-10">
      {% if source_blog != blank and source_blog.articles.size > 0 %}
        {% for article in source_blog.articles limit: article_limit %}
          <a href="{{ article.url }}" class="resources-article-card">
            <div class="resources-article-media">
              {% if article.image != blank %}
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: article.title, class: 'resources-article-img' }}
              {% else %}
                {%- assign editorial_visual = 'guide' -%}
                {%- if forloop.index == 2 -%}{%- assign editorial_visual = 'travel' -%}{%- endif -%}
                {%- if forloop.index == 3 or forloop.index == 6 -%}{%- assign editorial_visual = 'compatibility' -%}{%- endif -%}
                {% render 'owned-editorial-visual',
                  visual: editorial_visual,
                  title: article.title,
                  class: 'resources-article-img',
                  loading: 'lazy'
                %}
              {% endif %}
            </div>
            <div class="resources-article-body">
              <p class="resources-article-meta">{{ article.published_at | date: '%b %Y' }}</p>
              <h3 class="resources-article-title">{{ article.title }}</h3>
              {% if article.excerpt != blank %}
                <p class="resources-article-excerpt">{{ article.excerpt | strip_html | truncatewords: 18 }}</p>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <div class="resources-article-card resources-article-card--placeholder">
            <div class="resources-article-media">
              {%- assign ph_visual = 'guide' -%}
              {%- if i == 2 -%}{%- assign ph_visual = 'travel' -%}{%- endif -%}
              {%- if i == 3 -%}{%- assign ph_visual = 'compatibility' -%}{%- endif -%}
              {% render 'owned-editorial-visual', visual: ph_visual, title: 'EZQuest guide', width: 800, height: 600, class: 'resources-article-img', loading: 'lazy' %}
            </div>
            <div class="resources-article-body">
              <p class="resources-article-meta">Guide</p>
              <h3 class="resources-article-title">
                {%- case i -%}
                  {%- when 1 -%}How to choose the right hub for your laptop
                  {%- when 2 -%}Setting up a clean dual-display desk
                  {%- when 3 -%}USB-C vs Thunderbolt — what actually matters
                {%- endcase -%}
              </h3>
              <p class="resources-article-excerpt">Practical guidance to help you get the most from your EZQuest product.</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured resources",
  "settings": [
    { "type": "text",   "id": "eyebrow",       "label": "Eyebrow",      "default": "Featured guides" },
    { "type": "text",   "id": "heading",       "label": "Heading",      "default": "Featured guides" },
    { "type": "text",   "id": "blog_handle",   "label": "Blog handle",  "default": "resources" },
    { "type": "range",  "id": "article_limit", "label": "Article limit","min": 3, "max": 6, "step": 1, "default": 6 }
  ],
  "presets": [
    { "name": "Featured resources" }
  ]
}
{% endschema %}
