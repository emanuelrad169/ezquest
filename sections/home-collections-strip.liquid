<section class="section-shell section--grey home-collections-strip-section">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Collections'
      assign section_copy = section.settings.copy
    -%}

    <div class="home-collections-strip-header flex flex-col gap-4 reveal-on-scroll">
      <div class="home-collections-strip-header-copy min-w-0">
        <p class="section-kicker">Product families</p>
        <div class="home-collections-strip-heading-row flex items-center gap-5 mt-3">
          <h2 class="section-heading home-strip-heading">{{ section_heading }}</h2>
          <span class="home-strip-rule max-w-28 sm:max-w-36 lg:max-w-44 xl:max-w-56" aria-hidden="true"></span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between content-start lg:gap-6">
      {% if section_copy != blank %}
        <p class="section-copy home-strip-copy max-w-2xl">{{ section_copy }}</p>
      {% endif %}
      <a href="{{ routes.collections_url }}" class="site-meta-link shrink-0 lg:mt-1">View all categories</a>
    </div>

    <div class="home-collections-strip-grid reveal-stagger">
      {% for block in section.blocks %}
        {%- liquid
          assign collection_object = block.settings.collection
          assign card_title = block.settings.title
          assign card_url = block.settings.link
          assign card_image = block.settings.image
          assign card_eyebrow = blank
          assign card_cta_label = 'Shop this family'

          if collection_object != blank
            assign card_title = collection_object.title
            assign card_url = collection_object.url

            if card_image == blank and collection_object.featured_image != blank
              assign card_image = collection_object.featured_image
            elsif card_image == blank and collection_object.products_count > 0 and collection_object.products.first.featured_image != blank
              assign card_image = collection_object.products.first.featured_image
            endif
          endif

          if card_title == blank
            assign card_title = 'EZQuest Collection'
          endif

          if collection_object != blank
            case collection_object.handle
              when 'hubs-adapters'
                assign card_eyebrow = 'Hybrid + travel'
                assign card_cta_label = 'Shop hubs & adapters'
              when 'docking-stations'
                assign card_eyebrow = 'Desk command'
                assign card_cta_label = 'See desk-ready docks'
              when 'chargers-power'
                assign card_eyebrow = 'Power layer'
                assign card_cta_label = 'Shop chargers & power'
              when 'accessories'
                assign card_eyebrow = 'Finish the setup'
                assign card_cta_label = 'Browse cables & accessories'
            endcase
          elsif card_url contains '/collections/hubs-adapters'
            assign card_eyebrow = 'Hybrid + travel'
            assign card_cta_label = 'Shop hubs & adapters'
          elsif card_url contains '/collections/docking-stations'
            assign card_eyebrow = 'Desk command'
            assign card_cta_label = 'See desk-ready docks'
          elsif card_url contains '/collections/chargers-power'
            assign card_eyebrow = 'Power layer'
            assign card_cta_label = 'Shop chargers & power'
          elsif card_url contains '/collections/accessories'
            assign card_eyebrow = 'Finish the setup'
            assign card_cta_label = 'Browse cables & accessories'
          endif
        -%}

        <a href="{{ card_url | default: '/collections/all' }}" class="home-collections-strip-card" {{ block.shopify_attributes }}>
          <div class="home-collections-strip-media">
            {% if card_image != blank %}
              {{ card_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: card_title, class: 'home-collections-strip-image' }}
            {% elsif collection_object != blank and collection_object.handle != blank %}
              {% render 'owned-collection-visual',
                collection_handle: collection_object.handle,
                collection_title: card_title,
                width: 1200,
                height: 900,
                class: 'home-collections-strip-image'
              %}
            {% else %}
              {% render 'owned-collection-visual',
                collection_handle: collection_object.handle,
                collection_title: card_title,
                width: 1200,
                height: 900,
                class: 'home-collections-strip-image'
              %}
            {% endif %}
          </div>
          <div class="home-collections-strip-overlay"></div>
          <div class="home-collections-strip-content">
            {% if card_eyebrow != blank %}
              <p class="home-collections-strip-eyebrow">{{ card_eyebrow }}</p>
            {% endif %}
            <h3 class="home-collections-strip-title">{{ card_title }}</h3>
            {%- if collection_object != blank -%}
              <p class="home-collections-strip-count">{{ collection_object.products_count }} products</p>
            {%- endif -%}
            <span class="home-collections-strip-cta">{{ card_cta_label }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home collections strip",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" },
    { "type": "textarea", "id": "copy", "label": "Copy" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "limit": 4,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "url", "id": "link", "label": "Link override" },
        { "type": "number", "id": "product_count", "label": "Product count override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home collections strip",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ]
}
{% endschema %}
