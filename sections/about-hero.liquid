<section class="about-hero-section" aria-label="{{ section.settings.eyebrow | default: 'About EZQuest' | escape }}">
  <div class="about-hero-inner container-shell">

    {% if section.settings.eyebrow != blank %}
      <p class="about-hero-eyebrow section-kicker">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    <h1 class="about-hero-heading">
      {{ section.settings.heading | default: page.title | escape }}
    </h1>

    {% if section.settings.copy != blank %}
      <p class="about-hero-subheading">{{ section.settings.copy | escape }}</p>
    {% endif %}

    {% if section.settings.cta_label != blank %}
      <div class="about-hero-cta">
        {% render 'button',
          label: section.settings.cta_label,
          url: section.settings.cta_url,
          style: 'primary',
          size: 'lg'
        %}
      </div>
    {% endif %}

  </div>
  <div class="about-hero-divider" aria-hidden="true"></div>
</section>

{% schema %}
{
  "name": "About hero",
  "settings": [
    { "type": "text",     "id": "eyebrow",   "label": "Eyebrow",     "default": "About EZQuest" },
    { "type": "text",     "id": "heading",   "label": "Heading",     "default": "Connectivity built for real setups." },
    { "type": "textarea", "id": "copy",      "label": "Subheading",  "default": "We make hubs, docks, cables, and chargers for people who need their gear to simply work." },
    { "type": "text",     "id": "cta_label", "label": "CTA label" },
    { "type": "url",      "id": "cta_url",   "label": "CTA URL" }
  ],
  "presets": [
    { "name": "About hero" }
  ]
}
{% endschema %}
