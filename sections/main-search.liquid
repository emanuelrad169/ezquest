<section class="section-shell" {% if search.performed %}data-site-search-results="{{ search.results_count }}"{% endif %}>
  <div class="container-shell">
    <div class="editorial-shell">
      <div class="grid gap-8 lg:grid-cols-editorial lg:items-end">
        <div class="max-w-3xl">
          <p class="section-kicker">Search</p>
          <h1 class="section-heading mt-5">
            {% if search.performed %}
              {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }} for “{{ search.terms | escape }}”
            {% else %}
              Find products, resources, and support faster
            {% endif %}
          </h1>
          {% if search.performed %}
            <p class="section-copy mt-5">Search across products, manuals, downloads, support pages, and resources from one focused grid.</p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <span class="product-meta-pill">{{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }}</span>
              <span class="product-meta-pill">Unified discovery</span>
            </div>
          {% else %}
            <p class="section-copy mt-5">Search by product name, port type, compatibility keyword, or support topic from one clear starting point.</p>
          {% endif %}
        </div>
        <div class="hero-side-panel">
          {% render 'support-search-form' %}
        </div>
      </div>
    </div>

    {% if search.performed and search.results_count > 0 %}
      <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
        <p class="text-sm font-medium text-slate-600">
          {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }} for “{{ search.terms | escape }}”
        </p>
        <a href="{{ routes.search_url }}" class="site-meta-link">Reset search</a>
      </div>
    {% endif %}

    <div class="search-grid-shell">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          {% render 'card-product', product: item, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
        {% else %}
          <div class="search-result-card search-result-card--{{ item.object_type | default: 'result' }}">
            <p class="section-kicker">
              {% if item.object_type == 'article' %}
                Article
              {% elsif item.object_type == 'page' %}
                Page
              {% else %}
                {{ item.object_type | default: 'Result' }}
              {% endif %}
            </p>
            <a href="{{ item.url }}" class="mt-4 block text-2xl font-medium tracking-tight text-slate-950">{{ item.title }}</a>
            <p class="mt-3 text-sm leading-7 text-slate-600">{{ item.content | strip_html | truncatewords: 24 }}</p>
            <div class="mt-6 border-t border-slate-200/80 pt-5">
              {% render 'button', label: 'Open result', url: item.url, style: 'tertiary' %}
            </div>
          </div>
        {% endif %}
      {% else %}
        <div class="search-empty-shell">
          {% if search.performed %}
            <p class="section-kicker">No results yet</p>
            <h2 class="mt-4 text-2xl font-medium tracking-tight text-slate-950">No matches for “{{ search.terms | escape }}”</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">Try a product name, connection type, compatibility keyword, or support topic. If nothing matches yet, browse the product families, compare the core lineup, or open support.</p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <a href="{{ routes.collections_url }}" class="button-secondary">Shop by Collections</a>
              <a href="/pages/compare" class="site-meta-link">Compare core products</a>
              <a href="/pages/support" class="site-meta-link">Open support center</a>
            </div>
          {% else %}
            <p class="section-kicker">Search the storefront</p>
            <h2 class="mt-4 text-2xl font-medium tracking-tight text-slate-950">Start with a product name, resource type, or support topic</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">Use search as the fastest bridge between shopping, setup guidance, downloads, and support.</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
