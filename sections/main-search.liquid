<section class="section-shell" {% if search.performed %}data-site-search-results="{{ search.results_count }}"{% endif %}>
  <div class="container-shell">

    {%- comment -%} Search box ── {%- endcomment -%}
    <div class="mb-8 lg:mb-10 max-w-xl ml-auto">
      {% render 'support-search-form' %}
    </div>

    {%- if search.performed -%}

      {%- comment -%} Partition results by type ── {%- endcomment -%}
      {%- assign result_products = search.results | where: 'object_type', 'product' -%}
      {%- assign result_articles = search.results | where: 'object_type', 'article' -%}
      {%- assign result_pages    = search.results | where: 'object_type', 'page'    -%}

      {%- if search.results_count > 0 -%}

        {%- comment -%} Count bar + tabs ── {%- endcomment -%}
        <div class="search-results-bar">
          <p class="search-results-bar__count">
            {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }}
            for &ldquo;{{ search.terms | escape }}&rdquo;
          </p>
          <a href="{{ routes.search_url }}" class="search-results-bar__reset">Reset</a>
        </div>

        <div class="search-tabs" role="tablist" aria-label="Filter search results">
          <button type="button" class="search-tab is-active" role="tab" aria-selected="true"
                  aria-controls="search-panel-all" data-tab="all">
            All <span class="search-tab__count">{{ search.results_count }}</span>
          </button>
          {%- if result_products.size > 0 -%}
            <button type="button" class="search-tab" role="tab" aria-selected="false"
                    aria-controls="search-panel-products" data-tab="products">
              Products <span class="search-tab__count">{{ result_products.size }}</span>
            </button>
          {%- endif -%}
          {%- if result_articles.size > 0 -%}
            <button type="button" class="search-tab" role="tab" aria-selected="false"
                    aria-controls="search-panel-articles" data-tab="articles">
              Articles <span class="search-tab__count">{{ result_articles.size }}</span>
            </button>
          {%- endif -%}
          {%- if result_pages.size > 0 -%}
            <button type="button" class="search-tab" role="tab" aria-selected="false"
                    aria-controls="search-panel-pages" data-tab="pages">
              Pages <span class="search-tab__count">{{ result_pages.size }}</span>
            </button>
          {%- endif -%}
        </div>

        {%- comment -%} ── Tab panel: All ── {%- endcomment -%}
        <div id="search-panel-all" class="search-tab-panel search-grid-shell is-active" role="tabpanel" data-tab-panel="all">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {% render 'card-product', product: item, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
            {% else %}
              <div class="search-result-card search-result-card--{{ item.object_type }}">
                <p class="section-kicker">
                  {% if item.object_type == 'article' %}Article
                  {% elsif item.object_type == 'page' %}Page
                  {% else %}{{ item.object_type }}{% endif %}
                </p>
                <a href="{{ item.url }}" class="mt-4 block text-2xl font-medium tracking-tight text-slate-950">{{ item.title }}</a>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ item.content | strip_html | truncatewords: 24 }}</p>
                <div class="mt-6 border-t border-slate-200/80 pt-5">
                  {% render 'button', label: 'Open result', url: item.url, style: 'tertiary' %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {%- comment -%} ── Tab panel: Products ── {%- endcomment -%}
        {%- if result_products.size > 0 -%}
          <div id="search-panel-products" class="search-tab-panel search-grid-shell" role="tabpanel" data-tab-panel="products" hidden>
            {% for item in result_products %}
              {% render 'card-product', product: item, card_style: 'featured-strip', card_context: 'collection', card_index: forloop.index0 %}
            {% endfor %}
          </div>
        {%- endif -%}

        {%- comment -%} ── Tab panel: Articles ── {%- endcomment -%}
        {%- if result_articles.size > 0 -%}
          <div id="search-panel-articles" class="search-tab-panel search-grid-shell" role="tabpanel" data-tab-panel="articles" hidden>
            {% for item in result_articles %}
              <div class="search-result-card search-result-card--article">
                <p class="section-kicker">Article</p>
                <a href="{{ item.url }}" class="mt-4 block text-2xl font-medium tracking-tight text-slate-950">{{ item.title }}</a>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ item.content | strip_html | truncatewords: 24 }}</p>
                <div class="mt-6 border-t border-slate-200/80 pt-5">
                  {% render 'button', label: 'Read article', url: item.url, style: 'tertiary' %}
                </div>
              </div>
            {% endfor %}
          </div>
        {%- endif -%}

        {%- comment -%} ── Tab panel: Pages ── {%- endcomment -%}
        {%- if result_pages.size > 0 -%}
          <div id="search-panel-pages" class="search-tab-panel search-grid-shell" role="tabpanel" data-tab-panel="pages" hidden>
            {% for item in result_pages %}
              <div class="search-result-card search-result-card--page">
                <p class="section-kicker">Page</p>
                <a href="{{ item.url }}" class="mt-4 block text-2xl font-medium tracking-tight text-slate-950">{{ item.title }}</a>
                <p class="mt-3 text-sm leading-7 text-slate-600">{{ item.content | strip_html | truncatewords: 24 }}</p>
                <div class="mt-6 border-t border-slate-200/80 pt-5">
                  {% render 'button', label: 'Open page', url: item.url, style: 'tertiary' %}
                </div>
              </div>
            {% endfor %}
          </div>
        {%- endif -%}

      {%- else -%}

        {%- comment -%} ── No results ── {%- endcomment -%}
        <div class="search-empty">
          <p class="section-kicker">No results</p>
          <h2 class="search-empty__heading">No matches for &ldquo;{{ search.terms | escape }}&rdquo;</h2>
          <p class="search-empty__body">Try a product name, connection type, compatibility keyword, or support topic.</p>

          <div class="search-empty__suggestions">
            <h3 class="search-empty__sub">Popular searches</h3>
            <div class="search-empty__chips">
              <a href="{{ routes.search_url }}?q=usb-c+hub&type=product,article,page" class="search-empty__chip">USB-C Hub</a>
              <a href="{{ routes.search_url }}?q=charger&type=product,article,page" class="search-empty__chip">Charger</a>
              <a href="{{ routes.search_url }}?q=docking+station&type=product,article,page" class="search-empty__chip">Docking Station</a>
              <a href="{{ routes.search_url }}?q=cable&type=product,article,page" class="search-empty__chip">Cable</a>
              <a href="{{ routes.search_url }}?q=compatibility&type=product,article,page" class="search-empty__chip">Compatibility</a>
              <a href="{{ routes.search_url }}?q=manual&type=product,article,page" class="search-empty__chip">Manuals</a>
            </div>
          </div>

          <div class="search-empty__categories">
            <h3 class="search-empty__sub">Browse by category</h3>
            <div class="search-empty__cat-grid">
              <a href="/collections/hubs-adapters" class="search-empty__cat">Hubs &amp; Adapters</a>
              <a href="/collections/chargers" class="search-empty__cat">Chargers</a>
              <a href="/collections/cables" class="search-empty__cat">Cables</a>
              <a href="{{ routes.collections_url }}" class="search-empty__cat">All products</a>
            </div>
          </div>

          <div class="search-empty__actions">
            <a href="/pages/support" class="button-secondary">Open support center</a>
            <a href="/pages/compare" class="site-meta-link">Compare products</a>
          </div>
        </div>

        {%- comment -%} GA4: no-results event ── {%- endcomment -%}
        <script>
        (function() {
          if (!window.gtag) return;
          gtag('event', 'search_no_results', { search_term: {{ search.terms | json }} });
        })();
        </script>

      {%- endif -%}

    {%- else -%}

      {%- comment -%} ── Pre-search state ── {%- endcomment -%}
      <div class="search-empty-shell">
        <p class="section-kicker">Search the storefront</p>
        <h2 class="mt-4 text-2xl font-medium tracking-tight text-slate-950">
          Start with a product name, resource type, or support topic
        </h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Use search as the fastest bridge between shopping, setup guidance, downloads, and support.
        </p>
      </div>

    {%- endif -%}

  </div>
</section>

{%- comment -%} Tab switching ── {%- endcomment -%}
<script>
(function () {
  var tabs   = document.querySelectorAll('.search-tab');
  var panels = document.querySelectorAll('.search-tab-panel');
  if (!tabs.length) return;

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      var target = tab.dataset.tab;

      tabs.forEach(function (t) {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(function (p) {
        p.classList.remove('is-active');
        p.hidden = true;
      });

      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      var panel = document.querySelector('[data-tab-panel="' + target + '"]');
      if (panel) { panel.classList.add('is-active'); panel.hidden = false; }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
