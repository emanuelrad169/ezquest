<section class="home-feature-banner-section relative flex items-center overflow-hidden bg-slate-900" data-parallax-banner>

  <div class="home-feature-banner-media absolute -inset-y-10 inset-x-0 will-change-transform" data-parallax-media>
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', class: 'home-feature-banner-img h-full w-full object-cover', alt: section.settings.heading }}
    {% else %}
      <div class="home-feature-banner-placeholder flex h-full w-full flex-col items-center justify-center gap-3 text-xs font-medium uppercase tracking-widest text-white/30">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
          <rect width="64" height="64" rx="16" fill="currentColor" fill-opacity="0.06"/>
          <rect x="12" y="12" width="40" height="28" rx="4" fill="currentColor" fill-opacity="0.1"/>
          <circle cx="22" cy="22" r="5" fill="currentColor" fill-opacity="0.2"/>
          <path d="M12 34l12-10 10 8 7-6 11 8v2H12v-2Z" fill="currentColor" fill-opacity="0.12"/>
          <rect x="12" y="46" width="26" height="4" rx="2" fill="currentColor" fill-opacity="0.1"/>
          <rect x="12" y="54" width="16" height="3" rx="1.5" fill="currentColor" fill-opacity="0.07"/>
        </svg>
        <span>Add background image</span>
      </div>
    {% endif %}
  </div>

  <div class="home-feature-banner-overlay absolute inset-0 bg-gradient-to-r from-slate-900/20 via-slate-900/65 to-slate-900/85"></div>

  <div class="container-shell home-feature-banner-inner relative z-10 w-full py-20">
    <div class="home-feature-banner-content flex max-w-3xl flex-col gap-3{% if section.settings.text_position == 'left' %}{% else %} ml-auto{% endif %}">
      {% if section.settings.eyebrow != blank %}
        <p class="section-kicker home-feature-banner-eyebrow text-white/55">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="section-heading home-feature-banner-heading mt-0 text-white">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="type-heading home-feature-banner-subheading mt-0 text-white">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.copy != blank %}
        <p class="section-copy home-feature-banner-copy mt-0 max-w-2xl text-white/65">{{ section.settings.copy }}</p>
      {% endif %}
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary', class: 'button-context-hero-secondary home-feature-banner-link mt-4 w-fit' %}
      {% endif %}
    </div>
  </div>

</section>

<script>
(function () {
  var section = document.currentScript.closest('[data-parallax-banner]') || document.querySelector('[data-parallax-banner]');
  if (!section) return;
  var media = section.querySelector('[data-parallax-media]');
  if (!media || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  function onScroll() {
    var rect = section.getBoundingClientRect();
    var vh = window.innerHeight;
    if (rect.bottom < 0 || rect.top > vh) return;
    var progress = (vh - rect.top) / (vh + rect.height);
    var offset = (progress - 0.5) * 80;
    media.style.transform = 'translateY(' + offset + 'px)';
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
}());
</script>

{% schema %}
{
  "name": "Home feature banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose the right mix of ports, power, and displays." },
    { "type": "text", "id": "subheading", "label": "Subheading (bold)", "default": "Desk-ready docks, travel hubs, and chargers built for modern devices." },
    { "type": "textarea", "id": "copy", "label": "Body copy" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "presets": [
    {
      "name": "Home feature banner",
      "settings": {
        "eyebrow": "Desk and travel coverage",
        "heading": "Choose the right mix of ports, power, and displays.",
        "copy": "From compact travel hubs to desk-ready docks and multi-device chargers, EZQuest keeps modern-device setups cleaner and easier to manage.",
        "text_position": "right"
      }
    }
  ]
}
{% endschema %}
