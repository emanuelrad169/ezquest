<section class="section-shell">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Story grid framework'
      assign section_copy = section.settings.copy | default: 'Reserved for timeline, value proposition, or brand narrative content.'
      assign grid_class = 'lg:grid-cols-2'
      assign wrapper_class = ''
      if section.settings.columns_desktop == '3'
        assign grid_class = 'lg:grid-cols-3'
        assign wrapper_class = ' story-grid--editorial'
      endif
    -%}
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="product-meta-pill">Storytelling layer</span>
          <span class="product-meta-pill">Conversion support</span>
        </div>
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    <div class="mt-10 grid gap-6 {{ grid_class }}{{ wrapper_class }}">
      {% for block in section.blocks %}
        {%- liquid
          assign story_eyebrow = block.settings.eyebrow
          if story_eyebrow == blank and section.settings.show_sequence
            assign story_eyebrow = 'Module'
          endif
        -%}
        <article class="feature-card flex h-full flex-col bg-gradient-to-br from-white to-slate-50" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'mb-6 aspect-[4/3] w-full rounded-[1.5rem] border border-slate-200/80 object-cover' }}
          {% else %}
            <div class="mb-6 aspect-[4/3] rounded-[1.5rem] border border-slate-200/80 bg-slate-100"></div>
          {% endif %}
          <div class="flex items-center justify-between gap-4">
            {% if story_eyebrow != blank %}
              <p class="section-kicker">{{ story_eyebrow }}</p>
            {% endif %}
            {% if section.settings.show_sequence %}
              <span class="text-sm font-medium text-slate-400">{{ forloop.index | prepend: '0' }}</span>
            {% endif %}
          </div>
          <h3 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-slate-950">{{ block.settings.title | default: 'Story item' }}</h3>
          {% if block.settings.copy != blank %}
            <p class="mt-4 text-sm leading-7 text-slate-600">{{ block.settings.copy }}</p>
          {% endif %}
          <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200/80 pt-5">
            <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Move from explanation into action</p>
            {% if block.settings.link != blank %}
              {% render 'button', label: block.settings.link_label, url: block.settings.link, style: 'secondary' %}
            {% endif %}
          </div>
        </article>
      {% else %}
        {% assign fallback_columns = section.settings.columns_desktop | plus: 0 %}
        {% for i in (1..fallback_columns) %}
          <article class="feature-card flex h-full flex-col bg-gradient-to-br from-white to-slate-50">
            <div class="mb-6 aspect-[4/3] rounded-[1.5rem] border border-slate-200/80 bg-slate-100"></div>
            <div class="flex items-center justify-between gap-4">
              <p class="section-kicker">Module</p>
              {% if section.settings.show_sequence %}
                <span class="text-sm font-medium text-slate-400">{{ i | prepend: '0' }}</span>
              {% endif %}
            </div>
            <h3 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-slate-950">Story item</h3>
            <p class="mt-4 text-sm leading-7 text-slate-600">Add story blocks in the theme editor to preview this section with real content.</p>
            <div class="mt-6 border-t border-slate-200/80 pt-5 text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Move from explanation into action</div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product story grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Story grid framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for timeline, value proposition, or brand narrative content." },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "default": "2",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ]
    },
    { "type": "checkbox", "id": "show_sequence", "label": "Show sequence labels", "default": true },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Module" },
        { "type": "text", "id": "title", "label": "Title", "default": "Story item" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Narrative summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product story grid",
      "blocks": [{ "type": "story" }, { "type": "story" }]
    }
  ]
}
{% endschema %}
