<section class="section-shell section--dark home-story-section">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Why EZQuest feels easier to own'
      assign section_copy = section.settings.copy | default: 'Show how product design, setup clarity, and support work together across the line.'
    -%}
    <div class="home-story-shell">
      <div class="home-story-intro">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
        {% if section.settings.link_label != blank and section.settings.link_url != blank %}
          <div class="mt-8">
            {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
          </div>
        {% endif %}
      </div>

      {% for block in section.blocks %}
        {%- liquid
          assign story_eyebrow = block.settings.eyebrow
          assign story_image = block.settings.image
          if story_eyebrow == blank and section.settings.show_sequence
            if forloop.index == 1
              assign story_eyebrow = 'Design'
            elsif forloop.index == 2
              assign story_eyebrow = 'Workflow'
            else
              assign story_eyebrow = 'Support'
            endif
          endif

          assign story_class = 'home-story-card'
          if forloop.index == 1
            assign story_class = story_class | append: ' home-story-card--feature'
          elsif forloop.index == 2
            assign story_class = story_class | append: ' home-story-card--detail'
          else
            assign story_class = story_class | append: ' home-story-card--support'
          endif

          if story_image == blank
            if forloop.index == 1 and all_products['usb-c-multimedia-hub'] != blank
              assign story_image = all_products['usb-c-multimedia-hub'].featured_image
            elsif forloop.index == 2 and all_products['usb-c-pro-dock'] != blank
              assign story_image = all_products['usb-c-pro-dock'].featured_image
            elsif all_products['usb-c-travel-hub'] != blank
              assign story_image = all_products['usb-c-travel-hub'].featured_image
            endif
          endif
        -%}
        <article class="{{ story_class }}" {{ block.shopify_attributes }}>
          {% if story_image != blank %}
            <div class="home-story-media">
              {{ story_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: '', class: 'home-story-image aspect-card w-full object-cover' }}
            </div>
          {% else %}
            <div class="home-story-media">
              {% render 'placeholder-visual',
                kind: 'story',
                text: block.settings.title | default: 'EZQuest Story',
                width: 1200,
                height: 900,
                bg: '1D2736',
                fg: 'F8FAFC',
                class: 'home-story-image aspect-card w-full object-cover'
              %}
            </div>
          {% endif %}
          <div class="home-story-content">
            <div class="flex items-center justify-between gap-4">
              {% if story_eyebrow != blank %}
                <p class="section-kicker">{{ story_eyebrow }}</p>
              {% endif %}
              {% if section.settings.show_sequence %}
                <span class="text-sm font-medium text-slate-400">{{ forloop.index | prepend: '0' }}</span>
              {% endif %}
            </div>
            <h3 class="card-title mt-4">{{ block.settings.title | default: 'Built for cleaner device setups' }}</h3>
            {% if block.settings.copy != blank %}
              <p class="mt-4 text-sm leading-7 text-slate-600">{{ block.settings.copy }}</p>
            {% else %}
              <p class="mt-4 text-sm leading-7 text-slate-600">See how the port mix, charging path, and support model work together in a setup customers can understand quickly.</p>
            {% endif %}
          </div>
          <div class="home-story-footer">
            {% if block.settings.link != blank %}
              {% render 'button', label: block.settings.link_label, url: block.settings.link, style: 'secondary' %}
            {% endif %}
          </div>
        </article>
      {% else %}
        {% assign fallback_columns = section.settings.columns_desktop | plus: 0 %}
        {% for i in (1..fallback_columns) %}
          {%- liquid
            assign fallback_story_image = blank
            if forloop.index == 1 and all_products['usb-c-multimedia-hub'] != blank
              assign fallback_story_image = all_products['usb-c-multimedia-hub'].featured_image
            elsif forloop.index == 2 and all_products['usb-c-pro-dock'] != blank
              assign fallback_story_image = all_products['usb-c-pro-dock'].featured_image
            elsif all_products['usb-c-travel-hub'] != blank
              assign fallback_story_image = all_products['usb-c-travel-hub'].featured_image
            endif
          -%}
          <article class="home-story-card home-story-card--support">
            <div class="home-story-media">
              {% if fallback_story_image != blank %}
                {{ fallback_story_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: '', class: 'home-story-image aspect-card w-full object-cover' }}
              {% else %}
                {% render 'placeholder-visual',
                  kind: 'story',
                  text: 'EZQuest Story',
                  width: 1200,
                  height: 900,
                  bg: '1D2736',
                  fg: 'F8FAFC',
                  class: 'home-story-image aspect-card w-full object-cover'
                %}
              {% endif %}
            </div>
            <div class="home-story-content">
              <div class="flex items-center justify-between gap-4">
                <p class="section-kicker">
                  {% if forloop.index == 1 %}
                    Design
                  {% elsif forloop.index == 2 %}
                    Workflow
                  {% else %}
                    Support
                  {% endif %}
                </p>
                {% if section.settings.show_sequence %}
                  <span class="text-sm font-medium text-slate-400">{{ i | prepend: '0' }}</span>
                {% endif %}
              </div>
              <h3 class="card-title mt-4">
                {% if forloop.index == 1 %}
                  Premium connectivity without setup clutter
                {% elsif forloop.index == 2 %}
                  A stronger match for the devices you use every day
                {% else %}
                  Support that stays close after purchase
                {% endif %}
              </h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">
                {% if forloop.index == 1 %}
                  Frame the lead product benefit around cleaner desks, better port access, and fewer setup compromises.
                {% elsif forloop.index == 2 %}
                  Show how charging, display, and connection paths make the right model easier to choose.
                {% else %}
                  Keep manuals, downloads, and compatibility within reach so ownership feels considered from the start.
                {% endif %}
              </p>
            </div>
            <div class="home-story-footer"></div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product story grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why EZQuest feels easier to own" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Show how product design, setup clarity, and support work together across the line." },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "default": "2",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ]
    },
    { "type": "checkbox", "id": "show_sequence", "label": "Show sequence labels", "default": true },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Design" },
        { "type": "text", "id": "title", "label": "Title", "default": "Built for cleaner device setups" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Explain how the product design, compatibility, or support path makes ownership easier." },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product story grid",
      "blocks": [{ "type": "story" }, { "type": "story" }]
    }
  ]
}
{% endschema %}
