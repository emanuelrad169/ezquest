<section class="section-shell">
  <div class="container-shell">
    {%- liquid
      assign section_heading = section.settings.heading | default: 'Story grid framework'
      assign section_copy = section.settings.copy | default: 'Reserved for timeline, value proposition, or brand narrative content.'
    -%}
    <div class="section-intro">
      <div class="max-w-3xl">
        {% if section.settings.eyebrow != blank %}
          <p class="section-kicker">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 class="section-heading mt-4">{{ section_heading }}</h2>
        <p class="section-copy mt-4">{{ section_copy }}</p>
      </div>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <div class="section-intro-action">
          {% render 'button', label: section.settings.link_label, url: section.settings.link_url, style: 'secondary' %}
        </div>
      {% endif %}
    </div>

    {%- liquid
      assign columns_class = 'lg:grid-cols-2'
      if section.settings.columns_desktop == 3
        assign columns_class = 'lg:grid-cols-3'
      endif
    -%}

    <div class="mt-10 grid gap-6 {{ columns_class }}">
      {% for block in section.blocks %}
        {%- liquid
          assign story_eyebrow = block.settings.eyebrow
          if story_eyebrow == blank and section.settings.show_sequence
            assign story_eyebrow = 'Module'
          endif
        -%}
        <article class="feature-card flex h-full flex-col" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'mb-5 aspect-[4/3] w-full rounded-2xl object-cover' }}
          {% else %}
            <div class="mb-5 aspect-[4/3] rounded-2xl bg-slate-100"></div>
          {% endif %}
          <div class="flex items-center justify-between gap-4">
            {% if story_eyebrow != blank %}
              <p class="section-kicker">{{ story_eyebrow }}</p>
            {% endif %}
            {% if section.settings.show_sequence %}
              <span class="text-sm font-medium text-slate-400">{{ forloop.index | prepend: '0' }}</span>
            {% endif %}
          </div>
          <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">{{ block.settings.title | default: 'Story item' }}</h3>
          {% if block.settings.copy != blank %}
            <p class="mt-3 text-sm leading-6 text-slate-600">{{ block.settings.copy }}</p>
          {% endif %}
          {% if block.settings.link != blank %}
            <div class="mt-6">
              {% render 'button', label: block.settings.link_label, url: block.settings.link, style: 'secondary' %}
            </div>
          {% endif %}
        </article>
      {% else %}
        {% for i in (1..section.settings.columns_desktop) %}
          <article class="feature-card flex h-full flex-col">
            <div class="mb-5 aspect-[4/3] rounded-2xl bg-slate-100"></div>
            <div class="flex items-center justify-between gap-4">
              <p class="section-kicker">Module</p>
              {% if section.settings.show_sequence %}
                <span class="text-sm font-medium text-slate-400">{{ i | prepend: '0' }}</span>
              {% endif %}
            </div>
            <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">Story item</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">Add story blocks in the theme editor to preview this section with real content.</p>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product story grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Story grid framework" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Reserved for timeline, value proposition, or brand narrative content." },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 3,
      "step": 1,
      "default": 2
    },
    { "type": "checkbox", "id": "show_sequence", "label": "Show sequence labels", "default": true },
    { "type": "text", "id": "link_label", "label": "Section link label" },
    { "type": "url", "id": "link_url", "label": "Section link URL" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Module" },
        { "type": "text", "id": "title", "label": "Title", "default": "Story item" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Narrative summary" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn more" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product story grid",
      "blocks": [{ "type": "story" }, { "type": "story" }]
    }
  ]
}
{% endschema %}
