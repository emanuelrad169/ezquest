{%- liquid
  assign col_usbc   = collections['usb-c-hubs']
  assign col_cables = collections['hdmi-cables-adapters']
  assign col_power  = collections['wall-chargers']
  assign fp         = section.settings.mega_menu_featured_product
  assign fp_label   = section.settings.mega_menu_featured_label | default: 'NEW'

  for block in section.blocks
    if block.type == 'menu_column'
      case block.settings.title
        when 'USB-C'
          assign tile_img_usbc = all_products[block.settings.hero_product_handle]
        when 'Cables/Adapters'
          assign tile_img_cables = all_products[block.settings.hero_product_handle]
        when 'Power'
          assign tile_img_power = all_products[block.settings.hero_product_handle]
      endcase
    endif
  endfor
-%}
<div class="ez-mega ez-mega--shop nav-panel" id="nav-panel-shop"
     role="region" aria-label="Shop menu" hidden>
  <div class="ez-mega__spotlight" aria-hidden="true"></div>

  <div class="ez-mega__shell ez-mega__shell--shop">

    {% comment %} ── Header row ───────────────────────────── {% endcomment %}
    <div class="ez-mega-shop__header">
      <span class="ez-mega-shop__header-label">EZQuest Products</span>
      <a href="{{ routes.all_products_collection_url }}" class="ez-mega-shop__header-pill">View all →</a>
    </div>

    <hr class="ez-mega-shop__divider" aria-hidden="true">

    {% comment %} ── Category tiles — 3 gradient cards ─────── {% endcomment %}
    <div class="ez-mega-shop__tiles">

      <a href="{{ col_usbc.url | default: '/collections/usb-c-hubs' }}"
         class="ez-mega-shop__tile ez-mega-shop__tile--hubs"
         aria-label="{{ col_usbc.title | default: 'USB-C' }}">
        <div class="ez-mega-shop__tile-media" aria-hidden="true">
          {%- if tile_img_usbc.featured_image -%}
            <img src="{{ tile_img_usbc.featured_image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- elsif col_usbc.image -%}
            <img src="{{ col_usbc.image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <rect x="4" y="10" width="28" height="16" rx="3" stroke="currentColor" stroke-width="2"/>
              <path d="M10 10V8M16 10V8M22 10V8M28 10V8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 18h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__tile-body">
          <p class="ez-mega-shop__tile-name">USB-C</p>
          <p class="ez-mega-shop__tile-meta">Hubs · Cables · Adapters</p>
        </div>
      </a>

      <a href="{{ col_cables.url | default: '/collections/hdmi-cables-adapters' }}"
         class="ez-mega-shop__tile ez-mega-shop__tile--chargers"
         aria-label="{{ col_cables.title | default: 'Cables/Adapters' }}">
        <div class="ez-mega-shop__tile-media" aria-hidden="true">
          {%- if tile_img_cables.featured_image -%}
            <img src="{{ tile_img_cables.featured_image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- elsif col_cables.image -%}
            <img src="{{ col_cables.image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <path d="M6 18h24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <circle cx="18" cy="18" r="3.5" fill="currentColor"/>
              <path d="M6 18a5 5 0 01-5-5v-5M30 18a5 5 0 005-5v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__tile-body">
          <p class="ez-mega-shop__tile-name">Cables/Adapters</p>
          <p class="ez-mega-shop__tile-meta">HDMI · DisplayPort · Audio</p>
        </div>
      </a>

      <a href="{{ col_power.url | default: '/collections/wall-chargers' }}"
         class="ez-mega-shop__tile ez-mega-shop__tile--cables"
         aria-label="{{ col_power.title | default: 'Power' }}">
        <div class="ez-mega-shop__tile-media" aria-hidden="true">
          {%- if tile_img_power.featured_image -%}
            <img src="{{ tile_img_power.featured_image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- elsif col_power.image -%}
            <img src="{{ col_power.image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <path d="M18 4v10l6 2L18 32V22l-6-2 6-16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__tile-body">
          <p class="ez-mega-shop__tile-name">Power</p>
          <p class="ez-mega-shop__tile-meta">Wall · Car · GaN</p>
        </div>
      </a>

    </div>

    {% comment %} ── Subcategory columns — 3 columns with icons ── {% endcomment %}
    <div class="ez-mega-shop__subcats">

      <div class="ez-mega-shop__subcat-col">
        <p class="ez-mega-shop__subcat-head">USB-C</p>
        <ul class="nav-dd__links" role="list">
          <li>
            <a href="{{ routes.collections_url }}/usb-c-hubs" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Hubs</span>
                <span class="nav-dd__link-sub">Multi-port connectivity</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/usb-c-cables-collection" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Cables</span>
                <span class="nav-dd__link-sub">USB-C cables</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/usb-c-adapters" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Adapters</span>
                <span class="nav-dd__link-sub">Port converters</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/usb-c-card-readers" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Card Readers</span>
                <span class="nav-dd__link-sub">SD &amp; microSD</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/usb-c-enclosures" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Enclosures</span>
                <span class="nav-dd__link-sub">M.2 NVMe storage</span>
              </span>
            </a>
          </li>
        </ul>
        <a href="{{ routes.collections_url }}/usb-c-hubs" class="ez-mega-shop__subcat-seeall">All USB-C →</a>
      </div>

      <div class="ez-mega-shop__subcat-col">
        <p class="ez-mega-shop__subcat-head">Cables &amp; Adapters</p>
        <ul class="nav-dd__links" role="list">
          <li>
            <a href="{{ routes.collections_url }}/hdmi-cables-adapters" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">HDMI</span>
                <span class="nav-dd__link-sub">4K &amp; 8K displays</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/displayport-cables-adapters" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">DisplayPort</span>
                <span class="nav-dd__link-sub">Monitor connection</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/mini-displayport-cables" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Mini DisplayPort</span>
                <span class="nav-dd__link-sub">mDP adapters</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/audio-cables" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Audio</span>
                <span class="nav-dd__link-sub">3.5mm &amp; converters</span>
              </span>
            </a>
          </li>
        </ul>
        <a href="{{ routes.collections_url }}/hdmi-cables-adapters" class="ez-mega-shop__subcat-seeall">All cables →</a>
      </div>

      <div class="ez-mega-shop__subcat-col">
        <p class="ez-mega-shop__subcat-head">Power</p>
        <ul class="nav-dd__links" role="list">
          <li>
            <a href="{{ routes.collections_url }}/wall-chargers" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Wall Chargers</span>
                <span class="nav-dd__link-sub">GaN fast charging</span>
              </span>
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/car-chargers" class="nav-dd__link">
              <span class="nav-dd__link-text">
                <span class="nav-dd__link-title">Car Chargers</span>
                <span class="nav-dd__link-sub">In-vehicle power</span>
              </span>
            </a>
          </li>
        </ul>
        <a href="{{ routes.collections_url }}/wall-chargers" class="ez-mega-shop__subcat-seeall">All power →</a>
      </div>

    </div>

    <hr class="ez-mega-shop__divider" aria-hidden="true">

    {% comment %} ── Featured product strip ─────────────────── {% endcomment %}
    <div class="ez-mega-shop__feature{% unless fp != blank %} ez-mega-shop__feature--fallback{% endunless %}">
      {%- if fp != blank -%}
        <div class="ez-mega-shop__feature-thumb">
          {%- if fp.featured_image -%}
            <img src="{{ fp.featured_image | image_url: width: 112 }}"
                 alt="{{ fp.title | escape }}"
                 width="56" height="56" loading="lazy">
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__feature-info">
          <span class="ez-mega-shop__feature-badge">{{ fp_label }}</span>
          <p class="ez-mega-shop__feature-title">
            <a href="{{ fp.url }}" class="ez-mega-shop__feature-link">{{ fp.title }}</a>
          </p>
          <p class="ez-mega-shop__feature-meta">
            {%- assign spec_line = fp.metafields.custom.spec_line.value -%}
            {%- if spec_line != blank -%}
              {{ spec_line }}
            {%- elsif fp.type != blank -%}
              {{ fp.type }}{%- if fp.vendor != blank %} · {{ fp.vendor }}{%- endif -%}
            {%- endif -%}
          </p>
        </div>
      {%- else -%}
        <div class="ez-mega-shop__feature-info">
          <p class="ez-mega-shop__feature-title">Not sure which product fits your setup?</p>
        </div>
      {%- endif -%}
      <a href="/pages/help-me-choose" class="ez-mega-shop__feature-cta">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M7 4.5c-.83 0-1.5.67-1.5 1.5 0 .8.6 1.3 1.5 1.3V9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <circle cx="7" cy="10.5" r=".6" fill="currentColor"/>
        </svg>
        Help me choose
      </a>
    </div>

  </div>
</div>
