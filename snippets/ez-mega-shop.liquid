{%- liquid
  assign col_hubs   = collections['hubs-adapters']
  assign col_power  = collections['chargers-power']
  assign col_access = collections['accessories']
  assign fp         = section.settings.mega_menu_featured_product
  assign fp_label   = section.settings.mega_menu_featured_label | default: 'NEW'
-%}
<div class="ez-mega ez-mega--shop nav-panel" id="nav-panel-shop"
     role="region" aria-label="Shop menu" hidden>
  <div class="ez-mega__spotlight" aria-hidden="true"></div>

  <div class="ez-mega__shell ez-mega__shell--shop">

    {% comment %} ── Header row ───────────────────────────── {% endcomment %}
    <div class="ez-mega-shop__header">
      <span class="ez-mega-shop__header-label">EZQuest Products</span>
      <a href="{{ routes.all_products_collection_url }}" class="ez-mega-shop__header-pill">View all →</a>
    </div>

    <hr class="ez-mega-shop__divider" aria-hidden="true">

    {% comment %} ── Category tiles — 3 gradient cards ─────── {% endcomment %}
    <div class="ez-mega-shop__tiles">

      <a href="{{ col_hubs.url | default: '/collections/hubs-adapters' }}"
         class="ez-mega-shop__tile ez-mega-shop__tile--hubs"
         aria-label="{{ col_hubs.title | default: 'Hubs & Adapters' }}">
        <div class="ez-mega-shop__tile-media" aria-hidden="true">
          {%- if col_hubs.image -%}
            <img src="{{ col_hubs.image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <rect x="4" y="10" width="28" height="16" rx="3" stroke="currentColor" stroke-width="2"/>
              <path d="M10 10V8M16 10V8M22 10V8M28 10V8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 18h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__tile-body">
          <p class="ez-mega-shop__tile-name">Hubs &amp; Adapters</p>
          <p class="ez-mega-shop__tile-meta">Multi-port · Travel · Desk</p>
        </div>
      </a>

      <a href="{{ col_power.url | default: '/collections/chargers-power' }}"
         class="ez-mega-shop__tile ez-mega-shop__tile--chargers"
         aria-label="{{ col_power.title | default: 'Chargers & Power' }}">
        <div class="ez-mega-shop__tile-media" aria-hidden="true">
          {%- if col_power.image -%}
            <img src="{{ col_power.image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <path d="M18 4v10l6 2L18 32V22l-6-2 6-16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__tile-body">
          <p class="ez-mega-shop__tile-name">Chargers &amp; Power</p>
          <p class="ez-mega-shop__tile-meta">GaN · Wall · Car</p>
        </div>
      </a>

      <a href="{{ col_access.url | default: '/collections/accessories' }}"
         class="ez-mega-shop__tile ez-mega-shop__tile--cables"
         aria-label="{{ col_access.title | default: 'Cables & Accessories' }}">
        <div class="ez-mega-shop__tile-media" aria-hidden="true">
          {%- if col_access.image -%}
            <img src="{{ col_access.image | image_url: width: 320 }}" alt="" width="320" height="150" loading="lazy" class="ez-mega-shop__tile-img">
          {%- else -%}
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <path d="M6 18h24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <circle cx="18" cy="18" r="3.5" fill="currentColor"/>
              <path d="M6 18a5 5 0 01-5-5v-5M30 18a5 5 0 005-5v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__tile-body">
          <p class="ez-mega-shop__tile-name">Cables &amp; Accessories</p>
          <p class="ez-mega-shop__tile-meta">USB-C · HDMI · Audio</p>
        </div>
      </a>

    </div>

    {% comment %} ── Subcategory columns — 3 columns with icons ── {% endcomment %}
    <div class="ez-mega-shop__subcats">

      <div class="ez-mega-shop__subcat-col">
        <p class="ez-mega-shop__subcat-head">Hubs</p>
        <a href="{{ col_hubs.url }}?filter.p.tag=hub" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="5" width="12" height="7" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M5 5V4a1 1 0 012 0v1M9 5V4a1 1 0 012 0v1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          USB-C Hubs
        </a>
        <a href="{{ col_hubs.url }}?filter.p.tag=display-dual-hdmi" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1" y="3" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M6 12v2M10 12v2M4 14h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Dual Display
        </a>
        <a href="{{ col_hubs.url }}?filter.p.tag=storage-nvme" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="5" width="12" height="7" rx="2" stroke="currentColor" stroke-width="1.3"/><circle cx="12" cy="8.5" r="1" fill="currentColor"/></svg>
          NVMe Enclosures
        </a>
        <a href="{{ col_hubs.url }}?filter.p.tag=feature-magnetic" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M5 8a3 3 0 006 0V4H5v4z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 4h2M11 4h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Magnetic Series
        </a>
        <a href="{{ col_hubs.url }}" class="ez-mega-shop__subcat-seeall">All hubs →</a>
      </div>

      <div class="ez-mega-shop__subcat-col">
        <p class="ez-mega-shop__subcat-head">Chargers</p>
        <a href="{{ col_power.url }}?filter.p.tag=charger-type-wall" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="5" y="1" width="6" height="9" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M8 10v4M6 14h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Wall Chargers
        </a>
        <a href="{{ col_power.url }}?filter.p.tag=charger-type-car" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 10h12v2H2v-2zM4 10l1.5-5h5L12 10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><circle cx="4.5" cy="12.5" r="1" fill="currentColor"/><circle cx="11.5" cy="12.5" r="1" fill="currentColor"/></svg>
          Car Chargers
        </a>
        <a href="{{ col_power.url }}?filter.p.tag=gan-technology" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2v5l3 1L8 14V9L5 8l3-6z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          GaN Technology
        </a>
        <a href="{{ col_power.url }}?filter.p.tag=connection-usb-c" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M3 8a2 2 0 01-2-2V4M13 8a2 2 0 002-2V4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/></svg>
          USB-C Charging
        </a>
        <a href="{{ col_power.url }}" class="ez-mega-shop__subcat-seeall">All chargers →</a>
      </div>

      <div class="ez-mega-shop__subcat-col">
        <p class="ez-mega-shop__subcat-head">Cables</p>
        <a href="{{ col_access.url }}?filter.p.tag=connection-usb-c" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M3 8a2 2 0 01-2-2V4M13 8a2 2 0 002-2V4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/></svg>
          USB-C Cables
        </a>
        <a href="{{ col_access.url }}?filter.p.tag=connection-usb4" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M3 8L6 5M3 8l3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          USB4 Cables
        </a>
        <a href="{{ col_access.url }}?filter.p.tag=display-4k-60hz" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1" y="3" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M6 12v2M10 12v2M4 14h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          4K Display
        </a>
        <a href="{{ col_access.url }}?filter.p.tag=cable-braided" class="ez-mega-shop__subcat-link">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M5 2c0 2 2 2 2 4s-2 2-2 4M9 2c0 2 2 2 2 4s-2 2-2 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M4 14h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          Braided Cables
        </a>
        <a href="{{ col_access.url }}" class="ez-mega-shop__subcat-seeall">All cables →</a>
      </div>

    </div>

    <hr class="ez-mega-shop__divider" aria-hidden="true">

    {% comment %} ── Featured product strip ─────────────────── {% endcomment %}
    <div class="ez-mega-shop__feature{% unless fp != blank %} ez-mega-shop__feature--fallback{% endunless %}">
      {%- if fp != blank -%}
        <div class="ez-mega-shop__feature-thumb">
          {%- if fp.featured_image -%}
            <img src="{{ fp.featured_image | image_url: width: 112 }}"
                 alt="{{ fp.title | escape }}"
                 width="56" height="56" loading="lazy">
          {%- endif -%}
        </div>
        <div class="ez-mega-shop__feature-info">
          <span class="ez-mega-shop__feature-badge">{{ fp_label }}</span>
          <p class="ez-mega-shop__feature-title">
            <a href="{{ fp.url }}" class="ez-mega-shop__feature-link">{{ fp.title }}</a>
          </p>
          <p class="ez-mega-shop__feature-meta">
            {%- assign spec_line = fp.metafields.custom.spec_line.value -%}
            {%- if spec_line != blank -%}
              {{ spec_line }}
            {%- elsif fp.type != blank -%}
              {{ fp.type }}{%- if fp.vendor != blank %} · {{ fp.vendor }}{%- endif -%}
            {%- endif -%}
          </p>
        </div>
      {%- else -%}
        <div class="ez-mega-shop__feature-info">
          <p class="ez-mega-shop__feature-title">Not sure which product fits your setup?</p>
        </div>
      {%- endif -%}
      <a href="/pages/help-me-choose" class="ez-mega-shop__feature-cta">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
          <path d="M7 4.5c-.83 0-1.5.67-1.5 1.5 0 .8.6 1.3 1.5 1.3V9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <circle cx="7" cy="10.5" r=".6" fill="currentColor"/>
        </svg>
        Help me choose
      </a>
    </div>

  </div>
</div>
