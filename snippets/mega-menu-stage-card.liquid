{%- liquid
  assign product = product | default: blank
  assign href = href | default: product.url
  assign title = title | default: product.title
  assign descriptor = descriptor | default: blank
  assign eyebrow = eyebrow | default: blank
  assign card_class = card_class | default: ''
  assign image_variant = image_variant | default: 'compare'
  assign media_context = media_context | default: 'mega-menu'
  assign show_descriptor = show_descriptor | default: false
  assign show_price = show_price | default: true
  assign card_layout = card_layout | default: 'compact'
  assign show_arrow = show_arrow | default: true

  if show_descriptor and descriptor == blank and product != blank and product.metafields.ezquest.feature_highlights != blank and product.metafields.ezquest.feature_highlights.value.count > 0
    assign descriptor = product.metafields.ezquest.feature_highlights.value.first | strip
  endif
-%}
<a href="{{ href }}" class="mega-menu-stage-card mega-menu-stage-card--{{ card_layout }} card-soft card-interactive group flex items-stretch gap-0 overflow-hidden text-slate-950 no-underline {{ card_class | strip }}">
  <div class="mega-menu-stage-card-media relative flex w-20 shrink-0 items-center justify-center overflow-hidden border-r border-slate-100 bg-slate-50 p-2.5 sm:w-24">
    {% render 'product-browse-media',
      product: product,
      context: media_context,
      variant: image_variant,
      width: 900,
      height: 675,
      class: 'mega-menu-stage-card-image h-full w-full object-contain transition-transform duration-300 group-hover:scale-105'
    %}
  </div>
  <div class="mega-menu-stage-card-copy flex min-w-0 flex-col justify-between gap-2 p-4">
    {% if eyebrow != blank %}
      <p class="mega-menu-stage-card-eyebrow type-caption">{{ eyebrow }}</p>
    {% endif %}
    <div class="mega-menu-stage-card-main flex min-w-0 flex-1 flex-col gap-1">
      <div class="mega-menu-stage-card-body min-w-0">
        <h3 class="card-title mega-menu-stage-card-title">{{ title }}</h3>
        {% if show_descriptor and descriptor != blank %}
          <p class="type-body mega-menu-stage-card-descriptor">{{ descriptor | truncatewords: 6 }}</p>
        {% endif %}
      </div>
      <div class="mega-menu-stage-card-meta mt-auto flex items-center justify-between gap-2 border-t border-slate-100 pt-2">
        {% if show_price and product != blank %}
          <div class="mega-menu-stage-card-price">
            {% render 'price', product: product %}
          </div>
        {% endif %}
        {% if show_arrow %}
          <span class="mega-product-view" aria-hidden="true">View →</span>
        {% endif %}
      </div>
    </div>
  </div>
</a>
