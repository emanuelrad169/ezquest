<div class="accordion-shell" data-accordion-item>
  <button class="flex w-full items-start justify-between gap-4 text-left" type="button" aria-expanded="false" data-accordion-trigger>
    <span class="pr-4 text-base font-semibold leading-7 text-slate-950">{{ title }}</span>
    <span class="mt-1 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-slate-700 transition duration-200">
      {% render 'icon', name: 'plus' %}
    </span>
  </button>
  <div class="mt-4 border-t border-slate-200 pt-4 text-sm leading-7 text-slate-600" hidden data-accordion-content>
    {{ content }}
  </div>
</div>
