{%- liquid
  assign resolved_visual = visual | default: 'support'
  assign resolved_class = class | default: ''
  assign resolved_loading = loading | default: 'lazy'
  assign resolved_fetchpriority = fetchpriority | default: 'auto'
  assign primary_handle = 'usb-c-multimedia-7-in-1-hub'
  assign secondary_handle = 'duraguard-usb-c-to-usb-a-charge-and-sync-cable'
  assign tertiary_handle = 'worldtravel-65w-gan-5-port-pd-wall-charger'
  assign label = 'Support'

  case resolved_visual
    when 'downloads'
      assign primary_handle = 'usb-c-multimedia-7-in-1-hub'
      assign secondary_handle = 'usb-c-slim-gen-2-hub-adapter-6-in-1'
      assign tertiary_handle = 'duraguard-usb-c-to-usb-a-charge-and-sync-cable'
      assign label = 'Downloads'
    when 'manuals'
      assign primary_handle = 'usb-c-multimedia-8-in-1-hub'
      assign secondary_handle = 'usb-c-multimedia-7-in-1-hub'
      assign tertiary_handle = 'usb-c-slim-gen-2-hub-adapter-6-in-1'
      assign label = 'Manuals'
    when 'compatibility'
      assign primary_handle = 'usb-c-pro-dock'
      assign secondary_handle = 'dual-hdmi-usb-c-multimedia-hub-adapter-12-ports'
      assign tertiary_handle = 'worldtravel-65w-gan-5-port-pd-wall-charger'
      assign label = 'Compatibility'
  endcase
-%}
<div class="owned-support-visual owned-support-visual--{{ resolved_visual }} {{ resolved_class }}">
  <div class="owned-support-visual-glow" aria-hidden="true"></div>
  <div class="owned-support-visual-stage">
    <div class="owned-support-visual-copy">
      <p class="owned-support-visual-label">{{ label }}</p>
      <p class="owned-support-visual-note">EZQuest help, tied to the right product.</p>
    </div>
    <div class="owned-support-visual-stack">
      <div class="owned-support-visual-card owned-support-visual-card--primary">
        {% render 'owned-product-visual',
          product_handle: primary_handle,
          variant: 'setup',
          width: 1000,
          height: 750,
          class: 'owned-support-visual-image',
          loading: resolved_loading,
          fetchpriority: resolved_fetchpriority
        %}
      </div>
      <div class="owned-support-visual-card owned-support-visual-card--secondary">
        {% render 'owned-product-visual',
          product_handle: secondary_handle,
          variant: 'detail',
          width: 720,
          height: 540,
          class: 'owned-support-visual-image',
          loading: resolved_loading,
          fetchpriority: resolved_fetchpriority
        %}
      </div>
      <div class="owned-support-visual-card owned-support-visual-card--tertiary">
        {% render 'owned-product-visual',
          product_handle: tertiary_handle,
          variant: 'hero',
          width: 720,
          height: 540,
          class: 'owned-support-visual-image',
          loading: resolved_loading,
          fetchpriority: resolved_fetchpriority
        %}
      </div>
    </div>
  </div>
</div>
