<div id="mobile-nav-drawer" class="fixed inset-0 z-50" hidden data-drawer>
  <div class="drawer-backdrop" data-drawer-close></div>
  <div class="drawer-panel mega-mobile-drawer" data-drawer-panel tabindex="-1">
    <div class="flex items-center justify-between">
      <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="133" height="28">
      <button class="accordion-icon-btn" type="button" aria-label="Close menu" data-drawer-close>
        {% render 'icon', name: 'close' %}
      </button>
    </div>

    <div class="mega-mobile-service">
      <a href="{{ support_href | default: '/pages/support' }}" class="mega-mobile-service-link">
        <span class="mega-mobile-service-kicker">
          {% if support_has_phone %}
            {{ support_phone_label | default: 'Support' }}
          {% else %}
            Support center
          {% endif %}
        </span>
        <strong class="mega-mobile-service-value">
          {% if support_has_phone %}
            {{ support_phone }}
          {% else %}
            Contact support
          {% endif %}
        </strong>
      </a>
      <div class="mega-mobile-service-meta">
        <a href="/pages/shipping-returns">Shipping &amp; returns</a>
        <a href="/pages/compatibility">Compatibility</a>
      </div>
    </div>

    <nav aria-label="Mobile" class="mega-mobile-nav">
      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="shop" aria-controls="mega-mobile-panel-shop">
          <span>Shop</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-shop" data-mega-mobile-panel="shop" hidden>
          <div class="mega-mobile-stack-links">
            <a href="{{ routes.all_products_collection_url }}">All products</a>
            <a href="{{ routes.all_products_collection_url }}?filter.v.availability=1&amp;sort_by=best-selling">Featured picks</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="collections" aria-controls="mega-mobile-panel-collections">
          <span>Product families</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-collections" data-mega-mobile-panel="collections" hidden>
          <div class="mega-mobile-stack-links">
            <a href="{{ routes.collections_url }}/hubs-adapters">Hubs & adapters</a>
            <a href="{{ routes.collections_url }}/docking-stations">Docking stations</a>
            <a href="{{ routes.collections_url }}/chargers-power">Chargers & power</a>
            <a href="{{ routes.collections_url }}/accessories">Accessories</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="compare" aria-controls="mega-mobile-panel-compare">
          <span>Compare</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-compare" data-mega-mobile-panel="compare" hidden>
          <div class="mega-mobile-stack-links">
            <a href="/pages/compare">Choose the right setup</a>
            <a href="/pages/compatibility">Check compatibility</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="explore" aria-controls="mega-mobile-panel-explore">
          <span>Support</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-explore" data-mega-mobile-panel="explore" hidden>
          <div class="mega-mobile-stack-links">
            <a href="/pages/downloads">Downloads</a>
            <a href="/pages/manuals">Manuals</a>
            <a href="/pages/compatibility">Compatibility</a>
            <a href="/pages/troubleshooting">Troubleshooting</a>
            <a href="/pages/contact">Contact support</a>
            <a href="/pages/faq">FAQ</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="resources" aria-controls="mega-mobile-panel-resources">
          <span>Resources</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-resources" data-mega-mobile-panel="resources" hidden>
          <div class="mega-mobile-stack-links">
            <a href="/blogs/resources">Blog &amp; resources</a>
            <a href="/pages/help-me-choose">Help me choose</a>
            <a href="/pages/where-to-buy">Where to buy</a>
            <a href="/pages/warranty">Warranty</a>
            <a href="/pages/shipping-returns">Shipping &amp; returns</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <a href="/pages/about" class="mega-mobile-trigger mega-mobile-trigger--link">
          <span>About</span>
        </a>
      </div>
    </nav>

    <div class="support-crosslink-list">
      <a href="{{ routes.search_url }}" class="support-crosslink">
        <span>{{ 'header.search' | t }}</span>
        <span class="text-slate-400">Browse</span>
      </a>
      <a href="/pages/support" class="support-crosslink">
        <span>Support center</span>
        <span class="text-slate-400">Start here</span>
      </a>
      <a href="{{ routes.cart_url }}" class="support-crosslink">
        <span>{{ 'header.cart' | t }}</span>
        <span class="text-slate-400">Checkout</span>
      </a>
    </div>
  </div>
</div>
