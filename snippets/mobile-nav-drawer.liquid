{%- liquid
  assign hubs_collection = collections['hubs-adapters']
  assign docks_collection = collections['docking-stations']
  assign power_collection = collections['chargers-power']
  assign sorted_use_case_keys = '' | split: ''

  if metaobjects.ezquest_use_case != blank
    capture sorted_use_cases_raw
      for use_case in metaobjects.ezquest_use_case.values
        capture order_token_raw
          echo '000000'
          echo use_case.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo use_case.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_use_case_keys = sorted_use_cases_raw | split: '||' | sort_natural
  endif
-%}
<div id="mobile-nav-drawer" class="fixed inset-0 z-50" hidden data-drawer>
  <div class="drawer-backdrop" data-drawer-close></div>
  <div class="drawer-panel mega-mobile-drawer" data-drawer-panel tabindex="-1">
    <div class="flex items-center justify-between">
      <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="133" height="28">
      <button class="accordion-icon-btn" type="button" aria-label="Close menu" data-drawer-close>
        {% render 'icon', name: 'close' %}
      </button>
    </div>

    <div class="mega-mobile-service">
      <a href="{{ support_href | default: '/pages/support' }}" class="mega-mobile-service-link">
        <span class="mega-mobile-service-kicker">
          {% if support_has_phone %}
            {{ support_phone_label | default: 'Support' }}
          {% else %}
            Support center
          {% endif %}
        </span>
        <strong class="mega-mobile-service-value">
          {% if support_has_phone %}
            {{ support_phone }}
          {% else %}
            Contact support
          {% endif %}
        </strong>
      </a>
      <div class="mega-mobile-service-meta">
        <a href="/pages/shipping-returns">Shipping &amp; returns</a>
        <a href="/pages/compatibility">Compatibility</a>
      </div>
    </div>

    <div class="mega-mobile-primary-actions">
      <a href="/pages/help-me-choose" class="mega-mobile-primary-link" data-drawer-close>Shop by setup</a>
      <a href="{{ routes.collections_url }}" class="mega-mobile-primary-link mega-mobile-primary-link--secondary" data-drawer-close>Browse products</a>
    </div>

    <nav aria-label="Mobile" class="mega-mobile-nav">
      <div class="mega-mobile-section">
        <a href="/pages/compare" class="mega-mobile-trigger mega-mobile-trigger--link" data-drawer-close>
          <span>Compare</span>
        </a>
      </div>

      <div class="mega-mobile-section">
        <a href="/pages/support" class="mega-mobile-trigger mega-mobile-trigger--link" data-drawer-close>
          <span>Support</span>
        </a>
      </div>

      <div class="mega-mobile-section">
        <a href="/blogs/resources" class="mega-mobile-trigger mega-mobile-trigger--link" data-drawer-close>
          <span>Resources</span>
        </a>
      </div>

      <div class="mega-mobile-section">
        <a href="/pages/about" class="mega-mobile-trigger mega-mobile-trigger--link" data-drawer-close>
          <span>About</span>
        </a>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="more" aria-controls="mega-mobile-panel-more">
          <span>More destinations</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-more" data-mega-mobile-panel="more" hidden>
          <div class="mega-mobile-stack-links mega-mobile-stack-links--detailed">
            {% if sorted_use_case_keys.size > 0 %}
              {% for use_case_key in sorted_use_case_keys %}
                {% if use_case_key == blank %}
                  {% continue %}
                {% endif %}
                {%- liquid
                  assign use_case_handle = use_case_key | split: '::' | last
                  assign use_case = metaobjects.ezquest_use_case[use_case_handle]
                  if use_case == blank or use_case.title == blank or use_case.products == blank or use_case.products.value.count == 0
                    continue
                  endif
                  assign use_case_slug = use_case.slug.value | default: use_case.system.handle
                  assign use_case_description = use_case.description.value | default: blank
                  assign use_case_destination_url = use_case.products.value.first.url
                  case use_case_slug
                    when 'balanced-everyday'
                      assign use_case_destination_url = hubs_collection.url
                    when 'portable'
                      assign use_case_destination_url = hubs_collection.url
                    when 'desk-ready'
                      assign use_case_destination_url = docks_collection.url
                    when 'chargers-power'
                      assign use_case_destination_url = power_collection.url
                  endcase
                  if use_case_description == blank
                    assign use_case_description = 'Products for ' | append: use_case.title.value | downcase | append: '.'
                  endif
                -%}
                <a href="{{ use_case_destination_url | default: '/pages/help-me-choose' }}" data-drawer-close>
                  <span>{{ use_case.title.value }}</span>
                  <span class="mega-mobile-link-detail">{{ use_case_description }}</span>
                </a>
              {% endfor %}
            {% endif %}
            <a href="{{ routes.collections_url }}/hubs-adapters" data-drawer-close>
              <span>Hubs & adapters</span>
              <span class="mega-mobile-link-detail">USB-C expansion for desks, travel, and everyday carry.</span>
            </a>
            <a href="{{ routes.collections_url }}/docking-stations" data-drawer-close>
              <span>Docking stations</span>
              <span class="mega-mobile-link-detail">Display, Ethernet, charging, and desk-ready connectivity.</span>
            </a>
            <a href="{{ routes.collections_url }}/chargers-power" data-drawer-close>
              <span>Chargers & power</span>
              <span class="mega-mobile-link-detail">Wall chargers, car chargers, and power for daily devices.</span>
            </a>
            <a href="{{ routes.collections_url }}/accessories" data-drawer-close>
              <span>Cables & accessories</span>
              <span class="mega-mobile-link-detail">Cables, adapters, and finishing pieces for the setup.</span>
            </a>
            <a href="/pages/downloads" data-drawer-close>
              <span>Downloads</span>
              <span class="mega-mobile-link-detail">Drivers, utilities, and supporting files.</span>
            </a>
            <a href="/pages/manuals" data-drawer-close>
              <span>Manuals</span>
              <span class="mega-mobile-link-detail">Product guides and setup instructions.</span>
            </a>
            <a href="/pages/compatibility" data-drawer-close>
              <span>Compatibility</span>
              <span class="mega-mobile-link-detail">Check displays, systems, and connection support.</span>
            </a>
            <a href="/pages/faq" data-drawer-close>
              <span>FAQ</span>
              <span class="mega-mobile-link-detail">Common answers without leaving the flow.</span>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="support-crosslink-list">
      <a href="{{ routes.search_url }}" class="support-crosslink" data-drawer-close>
        <span>{{ 'header.search' | t }}</span>
        <span class="text-slate-400">Browse</span>
      </a>
      <a href="/pages/support" class="support-crosslink" data-drawer-close>
        <span>Support center</span>
        <span class="text-slate-400">Direct help</span>
      </a>
      <a href="{{ routes.cart_url }}" class="support-crosslink" data-drawer-close>
        <span>{{ 'header.cart' | t }}</span>
        <span class="text-slate-400">Checkout</span>
      </a>
    </div>
  </div>
</div>
