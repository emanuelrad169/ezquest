{%- liquid
  assign hubs_collection = collections['hubs-adapters']
  assign docks_collection = collections['docking-stations']
  assign power_collection = collections['chargers-power']
  assign sorted_use_case_keys = '' | split: ''

  if metaobjects.ezquest_use_case != blank
    capture sorted_use_cases_raw
      for use_case in metaobjects.ezquest_use_case.values
        capture order_token_raw
          echo '000000'
          echo use_case.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo use_case.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_use_case_keys = sorted_use_cases_raw | split: '||' | sort_natural
  endif
-%}
<div id="mobile-nav-drawer" class="fixed inset-0 z-50" hidden data-drawer>
  <div class="drawer-backdrop" data-drawer-close></div>
  <div class="drawer-panel mega-mobile-drawer" data-drawer-panel tabindex="-1">
    <div class="flex items-center justify-between">
      <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="133" height="28">
      <button class="accordion-icon-btn" type="button" aria-label="Close menu" data-drawer-close>
        {% render 'icon', name: 'close' %}
      </button>
    </div>

    <div class="mega-mobile-service">
      <a href="{{ support_href | default: '/pages/support' }}" class="mega-mobile-service-link">
        <span class="mega-mobile-service-kicker">
          {% if support_has_phone %}
            {{ support_phone_label | default: 'Support' }}
          {% else %}
            Support center
          {% endif %}
        </span>
        <strong class="mega-mobile-service-value">
          {% if support_has_phone %}
            {{ support_phone }}
          {% else %}
            Contact support
          {% endif %}
        </strong>
      </a>
      <div class="mega-mobile-service-meta">
        <a href="/pages/shipping-returns">Shipping &amp; returns</a>
        <a href="/pages/compatibility">Compatibility</a>
      </div>
    </div>

    <div class="mega-mobile-primary-actions">
      <a href="/pages/help-me-choose" class="mega-mobile-primary-link">Shop by setup</a>
      <a href="{{ routes.collections_url }}" class="mega-mobile-primary-link mega-mobile-primary-link--secondary">Browse products</a>
    </div>

    <nav aria-label="Mobile" class="mega-mobile-nav">
      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="shop" aria-controls="mega-mobile-panel-shop">
          <span>Shop by setup</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-shop" data-mega-mobile-panel="shop" hidden>
          <div class="mega-mobile-stack-links mega-mobile-stack-links--detailed">
            {% if sorted_use_case_keys.size > 0 %}
              {% for use_case_key in sorted_use_case_keys %}
                {% if use_case_key == blank %}
                  {% continue %}
                {% endif %}
                {%- liquid
                  assign use_case_handle = use_case_key | split: '::' | last
                  assign use_case = metaobjects.ezquest_use_case[use_case_handle]
                  if use_case == blank or use_case.title == blank or use_case.products == blank or use_case.products.value.count == 0
                    continue
                  endif
                  assign use_case_slug = use_case.slug.value | default: use_case.system.handle
                  assign use_case_description = use_case.description.value | default: blank
                  assign use_case_destination_url = use_case.products.value.first.url
                  case use_case_slug
                    when 'balanced-everyday'
                      assign use_case_destination_url = hubs_collection.url
                    when 'portable'
                      assign use_case_destination_url = hubs_collection.url
                    when 'desk-ready'
                      assign use_case_destination_url = docks_collection.url
                    when 'chargers-power'
                      assign use_case_destination_url = power_collection.url
                  endcase
                  if use_case_description == blank
                    assign use_case_description = 'Start with the products built for ' | append: use_case.title.value | downcase | append: '.'
                  endif
                -%}
                <a href="{{ use_case_destination_url | default: '/pages/help-me-choose' }}">
                  <span>{{ use_case.title.value }}</span>
                  <span class="mega-mobile-link-detail">{{ use_case_description }}</span>
                </a>
              {% endfor %}
            {% endif %}
            <a href="/pages/help-me-choose">
              <span>Open full setup guide</span>
              <span class="mega-mobile-link-detail">Compare the setup roles before you move into a family.</span>
            </a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="collections" aria-controls="mega-mobile-panel-collections">
          <span>Browse product families</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-collections" data-mega-mobile-panel="collections" hidden>
          <div class="mega-mobile-stack-links mega-mobile-stack-links--detailed">
            <a href="{{ routes.collections_url }}/hubs-adapters">
              <span>Hubs & adapters</span>
              <span class="mega-mobile-link-detail">Best for daily carry, hybrid desks, and flexible USB-C expansion.</span>
            </a>
            <a href="{{ routes.collections_url }}/docking-stations">
              <span>Docking stations</span>
              <span class="mega-mobile-link-detail">Best for permanent desks with displays, Ethernet, and charging.</span>
            </a>
            <a href="{{ routes.collections_url }}/chargers-power">
              <span>Chargers & power</span>
              <span class="mega-mobile-link-detail">Best for keeping phones, tablets, and laptops ready across the day.</span>
            </a>
            <a href="{{ routes.collections_url }}/accessories">
              <span>Accessories</span>
              <span class="mega-mobile-link-detail">Best for cables and finishing pieces that complete the setup.</span>
            </a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="compare" aria-controls="mega-mobile-panel-compare">
          <span>Compare</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-compare" data-mega-mobile-panel="compare" hidden>
          <div class="mega-mobile-stack-links">
            <a href="/pages/compare">Choose the right setup</a>
            <a href="/pages/compatibility">Check compatibility</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="explore" aria-controls="mega-mobile-panel-explore">
          <span>Support</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-explore" data-mega-mobile-panel="explore" hidden>
          <div class="mega-mobile-stack-links">
            <a href="/pages/downloads">Downloads</a>
            <a href="/pages/manuals">Manuals</a>
            <a href="/pages/compatibility">Compatibility</a>
            <a href="/pages/troubleshooting">Troubleshooting</a>
            <a href="/pages/contact">Contact support</a>
            <a href="/pages/faq">FAQ</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <button class="mega-mobile-trigger" type="button" aria-expanded="false" data-mega-mobile-trigger="resources" aria-controls="mega-mobile-panel-resources">
          <span>Resources</span>
          <span aria-hidden="true">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel" id="mega-mobile-panel-resources" data-mega-mobile-panel="resources" hidden>
          <div class="mega-mobile-stack-links">
            <a href="/blogs/resources">Blog &amp; resources</a>
            <a href="/pages/help-me-choose">Help me choose</a>
            <a href="/pages/where-to-buy">Where to buy</a>
            <a href="/pages/warranty">Warranty</a>
            <a href="/pages/shipping-returns">Shipping &amp; returns</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section">
        <a href="/pages/about" class="mega-mobile-trigger mega-mobile-trigger--link">
          <span>About</span>
        </a>
      </div>
    </nav>

    <div class="support-crosslink-list">
      <a href="{{ routes.search_url }}" class="support-crosslink">
        <span>{{ 'header.search' | t }}</span>
        <span class="text-slate-400">Browse</span>
      </a>
      <a href="/pages/support" class="support-crosslink">
        <span>Support center</span>
        <span class="text-slate-400">Start here</span>
      </a>
      <a href="{{ routes.cart_url }}" class="support-crosslink">
        <span>{{ 'header.cart' | t }}</span>
        <span class="text-slate-400">Checkout</span>
      </a>
    </div>
  </div>
</div>
