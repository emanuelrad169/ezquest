{% style %}
  /* Sit above the sticky site header (z-index 51) and sticky ATC bar (80),
     consistent with the cart drawer (z-index 200). Fixes header bleeding
     over the open mobile menu. */
  #mobile-nav-drawer { z-index: 200; }

  /* Brand-yellow support block */
  #mobile-nav-drawer .mega-mobile-service {
    background: var(--ez-amber, #FED300);
    border-color: rgba(10, 10, 10, 0.08);
  }
  #mobile-nav-drawer .mega-mobile-service-kicker {
    color: rgba(10, 10, 10, 0.62);
  }
  #mobile-nav-drawer .mega-mobile-service-value {
    color: #0a0a0a;
  }
{% endstyle %}
<div id="mobile-nav-drawer" class="fixed inset-0 z-50" hidden data-drawer>
  <div class="drawer-backdrop" data-drawer-close></div>
  <div class="drawer-panel mega-mobile-drawer absolute top-0 right-0 h-full w-full max-w-96 overflow-y-auto bg-white px-5 py-5 shadow-2xl outline-none" data-drawer-panel tabindex="-1">
    <div class="flex items-center justify-between">
      <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="h-7 w-auto" width="133" height="28">
      <button class="accordion-icon-btn" type="button" aria-label="Close menu" data-drawer-close>
        {% render 'icon', name: 'close' %}
      </button>
    </div>

    <div class="mega-mobile-service mt-5 rounded-2xl border border-slate-200/80 bg-slate-50/80 p-4 shadow-soft">
      <a href="{{ support_href | default: '/pages/support' }}" class="mega-mobile-service-link block no-underline">
        <span class="mega-mobile-service-kicker block text-xs font-medium uppercase tracking-widest text-slate-400">
          {% if support_has_phone %}
            {{ support_phone_label | default: 'Support' }}
          {% else %}
            Support center
          {% endif %}
        </span>
        <strong class="mega-mobile-service-value mt-1 block text-base font-medium tracking-tight text-slate-950">
          {% if support_has_phone %}
            {{ support_phone }}
          {% else %}
            Contact support
          {% endif %}
        </strong>
      </a>
      <div class="mega-mobile-service-meta mt-4 flex flex-wrap gap-2">
        <a href="/pages/shipping-returns" class="inline-flex min-h-9 items-center rounded-full border border-slate-200/80 bg-white px-3 py-2 text-xs font-medium uppercase tracking-widest text-slate-600 no-underline">Shipping &amp; returns</a>
        <a href="/pages/compatibility" class="inline-flex min-h-9 items-center rounded-full border border-slate-200/80 bg-white px-3 py-2 text-xs font-medium uppercase tracking-widest text-slate-600 no-underline">Compatibility</a>
      </div>
    </div>

    <div class="mega-mobile-primary-actions mt-4 grid grid-cols-2 gap-2">
      <a href="/pages/help-me-choose" class="mega-mobile-primary-link inline-flex min-h-12 items-center justify-center rounded-2xl bg-slate-950 px-4 py-3 text-sm font-medium text-white no-underline transition hover:bg-slate-800" data-drawer-close>Shop by setup</a>
      <a href="{{ routes.collections_url }}" class="mega-mobile-primary-link mega-mobile-primary-link--secondary inline-flex min-h-12 items-center justify-center rounded-2xl border border-slate-200/80 bg-white px-4 py-3 text-sm font-medium text-slate-900 no-underline transition hover:bg-slate-50" data-drawer-close>Browse products</a>
    </div>

    {% comment %} Mirrors the desktop mega-menu: Shop / Support / Resources / Compare / About (same items + order). {% endcomment %}
    <nav aria-label="Mobile" class="mega-mobile-nav mt-4 grid gap-2">
      <div class="mega-mobile-section rounded-2xl border border-slate-200/80 bg-slate-50/60 px-4 py-0.5">
        <button class="mega-mobile-trigger flex min-h-11 w-full items-center justify-between gap-4 py-2 text-left text-base font-medium text-slate-900 no-underline" type="button" aria-expanded="false" data-mega-mobile-trigger="shop" aria-controls="mega-mobile-panel-shop">
          <span>Shop</span>
          <span aria-hidden="true" class="text-slate-400">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel overflow-hidden px-4" id="mega-mobile-panel-shop" data-mega-mobile-panel="shop" hidden>
          <div class="mega-mobile-stack-links space-y-0.5 pb-1">
            <a href="{{ routes.collections_url }}/hubs-adapters" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Hubs &amp; adapters</a>
            <a href="{{ routes.collections_url }}/docking-stations" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Docking stations</a>
            <a href="{{ routes.collections_url }}/chargers-power" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Chargers &amp; power</a>
            <a href="{{ routes.collections_url }}/accessories" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Cables &amp; accessories</a>
            <a href="{{ routes.collections_url }}" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-900 no-underline" data-drawer-close>Shop all products</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section rounded-2xl border border-slate-200/80 bg-slate-50/60 px-4 py-0.5">
        <button class="mega-mobile-trigger flex min-h-11 w-full items-center justify-between gap-4 py-2 text-left text-base font-medium text-slate-900 no-underline" type="button" aria-expanded="false" data-mega-mobile-trigger="support" aria-controls="mega-mobile-panel-support">
          <span>Support</span>
          <span aria-hidden="true" class="text-slate-400">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel overflow-hidden px-4" id="mega-mobile-panel-support" data-mega-mobile-panel="support" hidden>
          <div class="mega-mobile-stack-links space-y-0.5 pb-1">
            <a href="/pages/support" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Support center</a>
            <a href="/pages/faq" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>FAQ</a>
            <a href="/pages/downloads" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Downloads</a>
            <a href="/pages/manuals" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Manuals</a>
            <a href="/pages/warranty" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Warranty</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section rounded-2xl border border-slate-200/80 bg-slate-50/60 px-4 py-0.5">
        <button class="mega-mobile-trigger flex min-h-11 w-full items-center justify-between gap-4 py-2 text-left text-base font-medium text-slate-900 no-underline" type="button" aria-expanded="false" data-mega-mobile-trigger="resources" aria-controls="mega-mobile-panel-resources">
          <span>Resources</span>
          <span aria-hidden="true" class="text-slate-400">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel overflow-hidden px-4" id="mega-mobile-panel-resources" data-mega-mobile-panel="resources" hidden>
          <div class="mega-mobile-stack-links space-y-0.5 pb-1">
            <a href="/blogs/resources" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>All articles</a>
            <a href="/pages/compatibility" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Compatibility</a>
            <a href="/pages/help-me-choose" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Help me choose</a>
          </div>
        </div>
      </div>

      <div class="mega-mobile-section rounded-2xl border border-slate-200/80 bg-slate-50/60 px-4 py-0.5">
        <a href="/pages/compare" class="mega-mobile-trigger mega-mobile-trigger--link flex min-h-11 w-full items-center justify-between gap-4 py-2 text-left text-base font-medium text-slate-900 no-underline" data-drawer-close>
          <span>Compare</span>
        </a>
      </div>

      <div class="mega-mobile-section rounded-2xl border border-slate-200/80 bg-slate-50/60 px-4 py-0.5">
        <button class="mega-mobile-trigger flex min-h-11 w-full items-center justify-between gap-4 py-2 text-left text-base font-medium text-slate-900 no-underline" type="button" aria-expanded="false" data-mega-mobile-trigger="about" aria-controls="mega-mobile-panel-about">
          <span>About</span>
          <span aria-hidden="true" class="text-slate-400">{% render 'icon', name: 'chevron-down' %}</span>
        </button>
        <div class="mega-mobile-panel overflow-hidden px-4" id="mega-mobile-panel-about" data-mega-mobile-panel="about" hidden>
          <div class="mega-mobile-stack-links space-y-0.5 pb-1">
            <a href="/pages/our-story" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Our story</a>
            <a href="/pages/about" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>About EZQuest</a>
            <a href="/pages/where-to-buy" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Where to buy</a>
            <a href="/pages/shipping-returns" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Shipping &amp; returns</a>
            <a href="/pages/contact" class="block border-t border-slate-200/80 px-0 py-3 text-sm font-medium text-slate-700 no-underline" data-drawer-close>Contact us</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="support-crosslink-list">
      <a href="{{ routes.search_url }}" class="support-crosslink" data-drawer-close>
        <span>{{ 'header.search' | t }}</span>
        <span class="text-slate-400">Browse</span>
      </a>
      <a href="/pages/support" class="support-crosslink" data-drawer-close>
        <span>Support center</span>
        <span class="text-slate-400">Direct help</span>
      </a>
      <a href="{{ routes.cart_url }}" class="support-crosslink" data-drawer-close>
        <span>{{ 'header.cart' | t }}</span>
        <span class="text-slate-400">Checkout</span>
      </a>
    </div>
  </div>
</div>
