<div id="mobile-nav-drawer" class="fixed inset-0 z-50" hidden data-drawer>
  <div class="absolute inset-0 bg-slate-950/40" data-drawer-close></div>
  <div class="absolute right-0 top-0 h-full w-full max-w-sm overflow-y-auto bg-white p-6 shadow-2xl">
    <div class="flex items-center justify-between">
      <strong class="text-lg">{{ shop.name }}</strong>
      <button class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-full border border-slate-300 px-3 text-sm" type="button" aria-label="Close menu" data-drawer-close>Close</button>
    </div>
    {% if menu != blank %}
      <nav aria-label="Mobile">
        <ul class="mt-8 space-y-2">
          {% for link in menu.links %}
            <li class="rounded-2xl border border-slate-200 p-4">
              <a href="{{ link.url }}" class="block text-base font-medium text-slate-900">{{ link.title }}</a>
              {% if link.links.size > 0 %}
                <ul class="mt-3 space-y-2 border-t border-slate-200 pt-3">
                  {% for child_link in link.links %}
                    <li><a href="{{ child_link.url }}" class="text-sm text-slate-600">{{ child_link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}
  </div>
</div>
