<div id="mobile-nav-drawer" class="fixed inset-0 z-50" hidden data-drawer>
  <div class="absolute inset-0 bg-slate-950/45 backdrop-blur-sm" data-drawer-close></div>
  <div class="absolute right-0 top-0 h-full w-full max-w-sm overflow-y-auto border-l border-slate-200 bg-white p-6 shadow-[0_24px_80px_rgba(15,23,42,0.18)]">
    <div class="flex items-center justify-between">
      <strong class="text-lg font-semibold tracking-[-0.03em] text-slate-950">{{ shop.name }}</strong>
      <button class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-full border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-900" type="button" aria-label="Close menu" data-drawer-close>Close</button>
    </div>
    {% if menu != blank %}
      <nav aria-label="Mobile">
        <ul class="mt-8 space-y-3">
          {% for link in menu.links %}
            <li class="rounded-[1.5rem] border border-slate-200/80 bg-slate-50/90 p-4">
              <a href="{{ link.url }}" class="block text-base font-semibold tracking-[-0.02em] text-slate-950">{{ link.title }}</a>
              {% if link.links.size > 0 %}
                <ul class="mt-3 space-y-2 border-t border-slate-200 pt-3">
                  {% for child_link in link.links %}
                    <li><a href="{{ child_link.url }}" class="text-sm text-slate-600">{{ child_link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

    <div class="support-crosslink-list">
      <a href="{{ routes.search_url }}" class="support-crosslink">
        <span>{{ 'header.search' | t }}</span>
        <span class="text-slate-400">Browse</span>
      </a>
      {% if support_url != blank %}
        <a href="{{ support_url }}" class="support-crosslink">
          <span>Support center</span>
          <span class="text-slate-400">Help</span>
        </a>
      {% endif %}
      <a href="{{ routes.cart_url }}" class="support-crosslink">
        <span>{{ 'header.cart' | t }}</span>
        <span class="text-slate-400">Checkout</span>
      </a>
    </div>
  </div>
</div>
