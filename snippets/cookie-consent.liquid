{% comment %}
  Render before </body> in layout/theme.liquid:
    {% render 'cookie-consent' %}

  Load cookie-consent.js before </body>:
    {{ 'cookie-consent.js' | asset_url | script_tag }}
{% endcomment %}

<div
  class="cookie-banner"
  id="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  aria-describedby="cookie-banner-body"
  data-cookie-consent
  hidden
>
  <div class="cookie-banner__inner">
    <p class="cookie-banner__body" id="cookie-banner-body">
      We use cookies to enhance your browsing experience, serve personalised ads or content,
      and analyse our traffic. By clicking &ldquo;Accept&rdquo;, you consent to our use of cookies.
      <a href="/pages/cookie-policy" class="cookie-banner__link">Cookie Policy</a>
    </p>
    <div class="cookie-banner__actions">
      <button
        type="button"
        class="cookie-banner__btn cookie-banner__btn--decline"
        id="cookie-decline"
        aria-label="Decline non-essential cookies"
      >
        Decline
      </button>
      <button
        type="button"
        class="cookie-banner__btn cookie-banner__btn--accept"
        id="cookie-accept"
        aria-label="Accept all cookies"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    top: auto;
    z-index: 399; /* below Tidio (999999) so chat stays accessible */
    padding: 0;
    margin: 0;
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 0.5px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.06);
  }

  .cookie-banner.is-visible {
    transform: translateY(0);
  }

  .cookie-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    max-width: 1280px;
    margin: 0 auto;
    padding: 1rem clamp(1.25rem, 5vw, 5rem);
  }

  .cookie-banner__body {
    flex: 1;
    min-width: 200px;
    margin: 0;
    font-size: 13px;
    color: #6e6e73;
    line-height: 1.5;
  }

  .cookie-banner__link {
    color: #1d1d1f;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cookie-banner__actions {
    display: flex;
    flex-shrink: 0;
    gap: 0.5rem;
    align-items: center;
  }

  .cookie-banner__btn {
    height: 36px;
    padding: 0 1.125rem;
    border-radius: 100px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .cookie-banner__btn--decline {
    border: 1.5px solid rgba(0, 0, 0, 0.12);
    background: transparent;
    color: #6e6e73;
  }

  .cookie-banner__btn--decline:hover {
    border-color: rgba(0, 0, 0, 0.25);
    color: #1d1d1f;
  }

  .cookie-banner__btn--accept {
    border: none;
    background: #1d1d1f;
    color: #f5f5f7;
  }

  .cookie-banner__btn--accept:hover {
    background: #FBCE2A;
    color: #1d1d1f;
  }

  /* Push body content up so nothing hides behind the bar */
  body.cookie-visible {
    padding-bottom: 68px;
  }

  @media (max-width: 480px) {
    .cookie-banner__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .cookie-banner__actions {
      width: 100%;
    }

    .cookie-banner__btn {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    body.cookie-visible {
      padding-bottom: 136px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner {
      transition: none;
    }
  }
</style>
