{% comment %}
  Render before </body> in layout/theme.liquid:
    {% render 'cookie-consent' %}

  Load cookie-consent.js before </body>:
    {{ 'cookie-consent.js' | asset_url | script_tag }}
{% endcomment %}

{% liquid
  assign cookie_heading = cookie_heading | default: 'We use cookies'
%}

<div
  class="cookie-banner"
  id="cookie-banner"
  role="dialog"
  aria-labelledby="cookie-banner-heading"
  aria-describedby="cookie-banner-body"
  hidden
>
  <div class="cookie-banner__inner">
    <div class="cookie-banner__text">
      <p class="cookie-banner__heading" id="cookie-banner-heading">
        {{ cookie_heading | escape }}
      </p>
      <p class="cookie-banner__body" id="cookie-banner-body">
        We use cookies to enhance your browsing experience, serve personalised ads or content,
        and analyse our traffic. By clicking "Accept", you consent to our use of cookies.
        <a href="/pages/cookie-policy" class="cookie-banner__link">
          Cookie Policy
        </a>
      </p>
    </div>

    <div class="cookie-banner__actions">
      <button
        type="button"
        class="cookie-banner__btn cookie-banner__btn--decline"
        id="cookie-decline"
        aria-label="Decline non-essential cookies"
      >
        Decline
      </button>
      <button
        type="button"
        class="cookie-banner__btn cookie-banner__btn--accept"
        id="cookie-accept"
        aria-label="Accept all cookies"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 500;
    padding: 0;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .cookie-banner.is-visible {
    transform: translateY(0);
  }

  .cookie-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 100%;
    padding: 1.25rem clamp(1.25rem, 5vw, 5rem);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: #1d1d1f;
  }

  .cookie-banner__text {
    flex: 1;
    min-width: 240px;
  }

  .cookie-banner__heading {
    margin: 0 0 0.25rem;
    color: #f5f5f7;
    font-size: 14px;
    font-weight: 600;
  }

  .cookie-banner__body {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 13px;
    line-height: 1.55;
  }

  .cookie-banner__link {
    color: #F59E0B;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cookie-banner__actions {
    display: flex;
    flex-shrink: 0;
    gap: 0.75rem;
  }

  .cookie-banner__btn {
    height: 38px;
    padding: 0 1.25rem;
    border: 1.5px solid transparent;
    border-radius: 100px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }

  .cookie-banner__btn--decline {
    border-color: rgba(255, 255, 255, 0.2);
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
  }

  .cookie-banner__btn--decline:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #f5f5f7;
  }

  .cookie-banner__btn--accept {
    border-color: #F59E0B;
    background: #F59E0B;
    color: #fff;
  }

  .cookie-banner__btn--accept:hover {
    background: #d97706;
  }

  @media (max-width: 480px) {
    .cookie-banner__inner {
      flex-direction: column;
      align-items: stretch;
    }

    .cookie-banner__actions {
      width: 100%;
    }

    .cookie-banner__btn {
      flex: 1;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner {
      transition: none;
    }
  }
</style>
