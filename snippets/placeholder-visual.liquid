{%- liquid
  assign placeholder_text = text | default: 'EZQuest'
  assign placeholder_width = width | default: 1600
  assign placeholder_height = height | default: 1200
  assign placeholder_alt = alt | default: placeholder_text
  assign placeholder_class = class | default: ''
  assign placeholder_kind = kind | default: ''
  assign placeholder_asset = 'placeholder-product.svg'

  if placeholder_kind == blank
    if placeholder_class contains 'home-hero'
      assign placeholder_kind = 'hero'
    elsif placeholder_class contains 'editorial' or placeholder_class contains 'explore'
      assign placeholder_kind = 'editorial'
    elsif placeholder_class contains 'support'
      assign placeholder_kind = 'support'
    elsif placeholder_class contains 'home-story' or placeholder_class contains 'mega-menu-compare'
      assign placeholder_kind = 'story'
    elsif placeholder_class contains 'collection'
      assign placeholder_kind = 'collection'
    else
      assign placeholder_kind = 'product'
    endif
  endif

  if placeholder_kind == 'hero'
    assign placeholder_asset = 'placeholder-hero.svg'
  elsif placeholder_kind == 'collection_hubs'
    assign placeholder_asset = 'placeholder-collection.svg'
  elsif placeholder_kind == 'collection_docks'
    assign placeholder_asset = 'placeholder-collection.svg'
  elsif placeholder_kind == 'collection_power'
    assign placeholder_asset = 'placeholder-collection.svg'
  elsif placeholder_kind == 'collection_accessories'
    assign placeholder_asset = 'placeholder-collection.svg'
  elsif placeholder_kind == 'collection'
    assign placeholder_asset = 'placeholder-collection.svg'
  elsif placeholder_kind == 'support'
    assign placeholder_asset = 'placeholder-support.svg'
  elsif placeholder_kind == 'editorial'
    assign placeholder_asset = 'placeholder-editorial.svg'
  elsif placeholder_kind == 'story'
    assign placeholder_asset = 'placeholder-editorial.svg'
  elsif placeholder_kind == 'compare'
    assign placeholder_asset = 'placeholder-compare.svg'
  elsif placeholder_kind == 'explore'
    assign placeholder_asset = 'placeholder-support.svg'
  endif
-%}
{% if placeholder_kind == 'product' %}
  <div class="product-visual-placeholder {{ placeholder_class }}"
       role="img"
       aria-label="{{ placeholder_alt | escape }} — image coming soon">
    <img
      src="{{ 'ezquest-logo.svg' | asset_url }}"
      alt="EZQuest"
      class="product-visual-placeholder__logo"
      width="80"
      height="24"
      loading="lazy"
    >
  </div>
{% else %}
  <img
    src="{{ placeholder_asset | asset_url }}"
    alt="{{ placeholder_alt | escape }}"
    class="home-placeholder-image {{ placeholder_class }}"
    width="{{ placeholder_width }}"
    height="{{ placeholder_height }}"
    loading="lazy"
    decoding="async"
  >
{% endif %}
