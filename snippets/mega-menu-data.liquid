{%- liquid
  assign hub_product = all_products['usb-c-multimedia-hub']
  assign dock_product = all_products['usb-c-pro-dock']
  assign travel_product = all_products['usb-c-travel-hub']

  assign hubs_url = routes.collections_url | append: '/hubs-adapters'
  assign docks_url = routes.collections_url | append: '/docking-stations'
  assign power_url = routes.collections_url | append: '/chargers-power'
  assign accessories_url = routes.collections_url | append: '/accessories'
  assign compare_url = '/pages/compare'
  assign compatibility_url = '/pages/compatibility'
  assign support_url = '/pages/support'
  assign downloads_url = '/pages/downloads'
  assign manuals_url = '/pages/manuals'
  assign faq_url = '/pages/faq'
  assign troubleshooting_url = '/pages/support#troubleshooting'
  assign contact_url = '/pages/contact'
  assign about_url = '/pages/about'
  assign story_url = '/pages/our-story'
  assign where_to_buy_url = '/pages/where-to-buy'
  assign resources_url = '/blogs/resources'

  assign hub_image = ''
  assign dock_image = ''
  assign travel_image = ''

  if hub_product != blank and hub_product.featured_image != blank
    assign hub_image = hub_product.featured_image | image_url: width: 900
  endif

  if dock_product != blank and dock_product.featured_image != blank
    assign dock_image = dock_product.featured_image | image_url: width: 900
  endif

  if travel_product != blank and travel_product.featured_image != blank
    assign travel_image = travel_product.featured_image | image_url: width: 900
  endif
-%}
{
  "shop": {
    "label": {{ 'Shop' | json }},
    "href": {{ routes.all_products_collection_url | json }},
    "behaviorType": {{ 'preview-grid' | json }},
    "groups": [
      {
        "id": {{ 'hubs' | json }},
        "label": {{ 'Hubs' | json }},
        "href": {{ hubs_url | json }},
        "eyebrow": {{ 'Compact expansion' | json }},
        "copy": {{ 'Display, charge, data.' | json }},
        "preview": {
          "eyebrow": {{ 'Everyday expansion' | json }},
          "title": {{ 'Hubs that keep the setup moving' | json }},
          "copy": {{ 'Compact expansion without the clutter.' | json }},
          "href": {{ hubs_url | json }},
          "cta": {{ 'Browse hubs' | json }},
          "image": {{ hub_image | json }}
        }
      },
      {
        "id": {{ 'docking' | json }},
        "label": {{ 'Docking Stations' | json }},
        "href": {{ docks_url | json }},
        "eyebrow": {{ 'Desktop power' | json }},
        "copy": {{ 'Desk-ready expansion.' | json }},
        "preview": {
          "eyebrow": {{ 'For serious desks' | json }},
          "title": {{ 'Docking built for cleaner workstations' | json }},
          "copy": {{ 'More ports, more power, cleaner desks.' | json }},
          "href": {{ docks_url | json }},
          "cta": {{ 'Explore docks' | json }},
          "image": {{ dock_image | json }}
        }
      },
      {
        "id": {{ 'power' | json }},
        "label": {{ 'Power' | json }},
        "href": {{ power_url | json }},
        "eyebrow": {{ 'Fast charging' | json }},
        "copy": {{ 'Fast, reliable charging.' | json }},
        "preview": {
          "eyebrow": {{ 'Charge with confidence' | json }},
          "title": {{ 'Power that fits modern devices' | json }},
          "copy": {{ 'Reliable charging across the setup.' | json }},
          "href": {{ power_url | json }},
          "cta": {{ 'See power products' | json }},
          "image": {{ dock_image | json }}
        }
      },
      {
        "id": {{ 'accessories' | json }},
        "label": {{ 'Accessories' | json }},
        "href": {{ accessories_url | json }},
        "eyebrow": {{ 'Finish the setup' | json }},
        "copy": {{ 'Finish the setup.' | json }},
        "preview": {
          "eyebrow": {{ 'The final layer' | json }},
          "title": {{ 'Accessories that remove friction' | json }},
          "copy": {{ 'Cables and add-ons that keep things simple.' | json }},
          "href": {{ accessories_url | json }},
          "cta": {{ 'View accessories' | json }},
          "image": {{ travel_image | json }}
        }
      }
    ],
    "previewContent": { "defaultId": {{ 'hubs' | json }} },
    "featuredContent": {
      "eyebrow": {{ 'Featured' | json }},
      "title": {{ dock_product.title | default: 'USB-C Pro Dock' | json }},
      "copy": {{ 'A stronger anchor for larger desk setups.' | json }},
      "href": {{ dock_product.url | default: docks_url | json }},
      "cta": {{ 'View featured dock' | json }},
      "image": {{ dock_image | json }},
      "badge": {{ 'Desk setup' | json }},
      "price": {{ dock_product.price | money | json }}
    },
    "quickLinks": [
      { "label": {{ 'Travel setup' | json }}, "href": {{ travel_product.url | default: hubs_url | json }} },
      { "label": {{ 'Dual-display desk' | json }}, "href": {{ compare_url | json }} },
      { "label": {{ 'iPad workflow' | json }}, "href": {{ hubs_url | json }} },
      { "label": {{ 'MacBook power users' | json }}, "href": {{ docks_url | json }} }
    ]
  },
