{%- liquid
  assign resolved_handle = promo_handle | default: blank
  assign resolved_eyebrow = promo_eyebrow | default: 'Next step'
  assign resolved_title = promo_title | default: 'Explore the next part of the lineup'
  assign resolved_copy = promo_copy | default: 'See the adjacent EZQuest category that keeps the setup moving cleanly.'
  assign resolved_link_label = promo_link_label | default: 'Explore now'
  assign target_collection = collections[resolved_handle]
  assign target_url = routes.collections_url
  assign target_product_count = 0

  if target_collection != blank
    assign target_url = target_collection.url
    assign target_product_count = target_collection.products_count
  endif
-%}
<a href="{{ target_url }}" class="collection-promo-tile collection-promo-tile--{{ resolved_handle | handleize }} md:col-span-2 xl:col-span-2" aria-label="{{ resolved_eyebrow }}: {{ resolved_title }}">
  <div class="collection-promo-tile-media">
    {% render 'owned-collection-visual',
      collection_handle: resolved_handle,
      collection_title: resolved_title,
      width: 1200,
      height: 900,
      class: 'collection-promo-tile-image',
      loading: 'lazy'
    %}
  </div>
  <div class="collection-promo-tile-scrim" aria-hidden="true"></div>
  <div class="collection-promo-tile-copy">
    <div class="collection-promo-tile-meta">
      <p class="collection-promo-tile-eyebrow">{{ resolved_eyebrow }}</p>
      {% if target_product_count > 0 %}
        <span class="collection-promo-tile-count">{{ target_product_count }} products</span>
      {% endif %}
    </div>
    <div class="collection-promo-tile-body">
      <h3 class="collection-promo-tile-title">{{ resolved_title }}</h3>
      <p class="collection-promo-tile-text">{{ resolved_copy }}</p>
    </div>
    <span class="collection-promo-tile-link">{{ resolved_link_label }}</span>
  </div>
</a>
