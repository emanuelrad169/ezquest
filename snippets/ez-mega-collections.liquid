<div class="ez-mega" id="ez-mega-collections"
     role="dialog" aria-label="Shop by Collections" hidden>
  <div class="ez-mega__spotlight" aria-hidden="true"></div>

  <div class="ez-mega__shell">

    <div class="ez-mega__rail">
      <p class="ez-mega__rail-label">By Category</p>

      <div class="ez-mega__tabs" role="tablist">

        <button class="ez-mega__tab is-active"
                role="tab" aria-selected="true"
                data-target="col-usbc" aria-controls="col-usbc">
          <div class="ez-mega__tab-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="2" y="5" width="12" height="8" rx="2" stroke="currentColor" stroke-width="1.25"/>
              <path d="M5 5V3.5M8 5V3.5M11 5V3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </div>
          <span>USB-C</span>
          <svg class="ez-mega__tab-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 3.5l3.5 3.5L5 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button class="ez-mega__tab"
                role="tab" aria-selected="false"
                data-target="col-cables" aria-controls="col-cables">
          <div class="ez-mega__tab-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M2 8h5M9 8h5M7 5v6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              <circle cx="8" cy="8" r="1.5" fill="currentColor"/>
            </svg>
          </div>
          <span>Cables &amp; Adapters</span>
          <svg class="ez-mega__tab-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 3.5l3.5 3.5L5 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button class="ez-mega__tab"
                role="tab" aria-selected="false"
                data-target="col-power" aria-controls="col-power">
          <div class="ez-mega__tab-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 2v4l2.5 1L8 14v-4L5.5 9 8 2z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span>Power</span>
          <svg class="ez-mega__tab-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 3.5l3.5 3.5L5 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button class="ez-mega__tab"
                role="tab" aria-selected="false"
                data-target="col-docking" aria-controls="col-docking">
          <div class="ez-mega__tab-icon">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="1" y="4" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M4 13v2M12 13v2M1 7.5h14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
            </svg>
          </div>
          <span>Docking Stations</span>
          <svg class="ez-mega__tab-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 3.5l3.5 3.5L5 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

      </div>
    </div>

    <div class="ez-mega__panels">

      <div class="ez-mega__panel is-active" id="col-usbc" role="tabpanel">
        {% for product in collections['hubs-adapters'].products limit: 8 %}
          {%- assign card_img = product.featured_image | default: product.images.first -%}
          {% if card_img == blank %}{% continue %}{% endif %}
          <a href="{{ product.url }}" class="ez-mega__card">
            <div class="ez-mega__card-img">
              <img src="{{ card_img | image_url: width: 200 }}"
                   alt="{{ product.title | escape }}"
                   width="200" height="200" loading="lazy">
            </div>
            <div class="ez-mega__card-body">
              <p class="ez-mega__card-name">{{ product.title | truncate: 50 }}</p>
              <p class="ez-mega__card-link">View product →</p>
            </div>
          </a>
        {% endfor %}
      </div>

      <div class="ez-mega__panel" id="col-cables" role="tabpanel" hidden>
        {% for product in collections['accessories'].products limit: 8 %}
          {%- assign card_img = product.featured_image | default: product.images.first -%}
          {% if card_img == blank %}{% continue %}{% endif %}
          <a href="{{ product.url }}" class="ez-mega__card">
            <div class="ez-mega__card-img">
              <img src="{{ card_img | image_url: width: 200 }}"
                   alt="{{ product.title | escape }}"
                   width="200" height="200" loading="lazy">
            </div>
            <div class="ez-mega__card-body">
              <p class="ez-mega__card-name">{{ product.title | truncate: 50 }}</p>
              <p class="ez-mega__card-link">View product →</p>
            </div>
          </a>
        {% endfor %}
      </div>

      <div class="ez-mega__panel" id="col-power" role="tabpanel" hidden>
        {% for product in collections['chargers-power'].products limit: 8 %}
          {%- assign card_img = product.featured_image | default: product.images.first -%}
          {% if card_img == blank %}{% continue %}{% endif %}
          <a href="{{ product.url }}" class="ez-mega__card">
            <div class="ez-mega__card-img">
              <img src="{{ card_img | image_url: width: 200 }}"
                   alt="{{ product.title | escape }}"
                   width="200" height="200" loading="lazy">
            </div>
            <div class="ez-mega__card-body">
              <p class="ez-mega__card-name">{{ product.title | truncate: 50 }}</p>
              <p class="ez-mega__card-link">View product →</p>
            </div>
          </a>
        {% endfor %}
      </div>

      <div class="ez-mega__panel" id="col-docking" role="tabpanel" hidden>
        {% for product in collections['docking-stations'].products limit: 8 %}
          {%- assign card_img = product.featured_image | default: product.images.first -%}
          {% if card_img == blank %}{% continue %}{% endif %}
          <a href="{{ product.url }}" class="ez-mega__card">
            <div class="ez-mega__card-img">
              <img src="{{ card_img | image_url: width: 200 }}"
                   alt="{{ product.title | escape }}"
                   width="200" height="200" loading="lazy">
            </div>
            <div class="ez-mega__card-body">
              <p class="ez-mega__card-name">{{ product.title | truncate: 50 }}</p>
              <p class="ez-mega__card-link">View product →</p>
            </div>
          </a>
        {% endfor %}
      </div>

    </div>
  </div>

  <div class="ez-mega__footer">
    <a href="{{ routes.collections_url }}" class="ez-mega__footer-link">
      View all collections →
    </a>
  </div>
</div>
