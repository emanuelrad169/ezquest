{%- liquid
  assign account_url = routes.account_url | default: '/account'
  assign account_login_url = routes.account_login_url | default: '/account/login'
-%}
<header class="site-header site-header--hero-overlay" role="banner" data-header-scroll-threshold="28">
  <div class="site-header-inner container-shell">
    <div class="site-header-shell grid w-full grid-cols-1 py-0">
      <div class="site-header-main-row flex w-full items-center gap-3 lg:gap-6">
        <a href="{{ routes.root_url }}" class="site-brandmark inline-flex shrink-0 items-center">
          <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="block h-auto w-32 lg:w-60" width="240" height="56" loading="eager" fetchpriority="high">
        </a>

        <nav aria-label="Primary" class="site-header-nav hidden min-w-0 flex-1 justify-center lg:flex">
          {% render 'mega-menu', section: section %}
        </nav>

        <div class="site-header-utility-cluster ml-auto flex items-center gap-1 lg:gap-1.5">
          <div class="site-header-actions flex items-center gap-1">
            <button
              type="button"
              class="site-header-icon-button hidden lg:inline-flex"
              aria-label="{{ 'header.search' | t }}"
              aria-expanded="false"
              aria-controls="site-header-search-panel"
              data-search-mega-trigger
            >
              {% render 'icon', name: 'search' %}
            </button>
            <button type="button"
                    class="site-header-icon-button lg:hidden"
                    aria-label="{{ 'header.search' | t }}"
                    data-mobile-search-open>
              {% render 'icon', name: 'search' %}
            </button>
            {% if customer %}
              <div class="site-header-account-wrap">
                <a href="{{ account_url }}"
                   class="site-header-icon-button"
                   aria-label="{{ 'header.my_account' | t }}"
                   aria-haspopup="true">
                  <svg width="20" height="20" viewBox="0 0 20 20"
                       fill="none" aria-hidden="true">
                    <circle cx="10" cy="7" r="3"
                            stroke="currentColor" stroke-width="1.25"/>
                    <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6"
                          stroke="currentColor" stroke-width="1.25"
                          stroke-linecap="round"/>
                  </svg>
                </a>
                <div class="site-header-account-menu" role="menu">
                  <a href="{{ account_url }}" class="site-header-account-menu__item" role="menuitem">My account</a>
                  <a href="{{ account_url }}/orders" class="site-header-account-menu__item" role="menuitem">My orders</a>
                  <a href="{{ routes.account_logout_url }}" class="site-header-account-menu__item site-header-account-menu__item--signout" role="menuitem">Sign out</a>
                </div>
              </div>
            {% else %}
              <a href="{{ account_login_url }}"
                 class="site-header-icon-button"
                 aria-label="{{ 'header.sign_in' | t }}">
                <svg width="20" height="20" viewBox="0 0 20 20"
                     fill="none" aria-hidden="true">
                  <circle cx="10" cy="7" r="3"
                          stroke="currentColor" stroke-width="1.25"/>
                  <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6"
                        stroke="currentColor" stroke-width="1.25"
                        stroke-linecap="round"/>
                </svg>
              </a>
            {% endif %}
            <a href="/pages/wishlist" class="site-header-icon-button" aria-label="{{ 'header.wishlist' | t }}">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
                <path d="M10 16.5S2.5 12 2.5 6.5a4 4 0 017.5-2A4 4 0 0117.5 6.5c0 5.5-7.5 10-7.5 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
              <span class="site-header-wishlist-count" data-wishlist-count hidden>0</span>
            </a>

            {%- if localization.available_languages and localization.available_languages.size > 1 -%}
              {%- assign lang_code = localization.language.iso_code | downcase -%}
              {%- case lang_code -%}
                {%- when 'en' -%}{%- assign flag_cc = 'us' -%}
                {%- when 'es' -%}{%- assign flag_cc = 'es' -%}
                {%- when 'ar' -%}{%- assign flag_cc = 'iq' -%}
                {%- when 'fr' -%}{%- assign flag_cc = 'fr' -%}
                {%- when 'de' -%}{%- assign flag_cc = 'de' -%}
                {%- when 'it' -%}{%- assign flag_cc = 'it' -%}
                {%- when 'pt' -%}{%- assign flag_cc = 'pt' -%}
                {%- when 'nl' -%}{%- assign flag_cc = 'nl' -%}
                {%- when 'zh' -%}{%- assign flag_cc = 'cn' -%}
                {%- when 'ja' -%}{%- assign flag_cc = 'jp' -%}
                {%- when 'ko' -%}{%- assign flag_cc = 'kr' -%}
                {%- when 'ru' -%}{%- assign flag_cc = 'ru' -%}
                {%- else -%}{%- assign flag_cc = localization.country.iso_code | downcase -%}
              {%- endcase -%}
              <div class="site-header-locale">
                {%- form 'localization', class: 'site-header-locale__form' -%}
                  <label class="sr-only" for="header-locale-select">Language</label>
                  <span class="site-header-locale__flag" aria-hidden="true">
                    <img src="https://flagcdn.com/h20/{{ flag_cc }}.png"
                         srcset="https://flagcdn.com/h40/{{ flag_cc }}.png 2x"
                         width="20" height="15" alt="" loading="lazy" decoding="async">
                  </span>
                  <span class="site-header-locale__code" aria-hidden="true">{{ localization.language.iso_code | upcase }}</span>
                  <span class="site-header-locale__caret" aria-hidden="true">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4.5l3 3 3-3"/></svg>
                  </span>
                  <select id="header-locale-select" name="locale_code" class="site-header-locale__select" onchange="this.form.submit()" aria-label="Language">
                    {%- for lang in localization.available_languages -%}
                      <option value="{{ lang.iso_code }}" lang="{{ lang.iso_code }}" {% if lang.iso_code == localization.language.iso_code %}selected{% endif %}>{{ lang.endonym_name | capitalize }}</option>
                    {%- endfor -%}
                  </select>
                {%- endform -%}
              </div>
            {%- endif -%}

            <button
              class="site-header-icon-button site-header-cart-button header-icon-btn"
              type="button"
              aria-label="Open cart"
              aria-expanded="false"
              aria-controls="cart-drawer"
              id="header-cart-btn"
              data-cart-drawer-trigger
              data-cart-count="{{ cart.item_count }}"
            >
              {% render 'icon', name: 'cart' %}
              <span
                class="site-header-cart-count header-icon-btn__count"
                data-cart-count-badge
                aria-label="{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %} in cart"
                {% if cart.item_count == 0 %}hidden{% endif %}
              >
                {{ cart.item_count }}
              </span>
            </button>
            <button
              class="site-header-icon-button lg:hidden"
              type="button"
              aria-label="{{ 'header.open_menu' | t }}"
              aria-controls="mobile-nav-drawer"
              aria-expanded="false"
              data-drawer-open="mobile-nav-drawer"
            >
              <span class="sr-only">{{ 'header.open_menu' | t }}</span>
              {% render 'icon', name: 'menu' %}
            </button>
          </div>
        </div>
      </div>
    </div>

    {% render 'search-mega-panel' %}
  </div>

<div class="mobile-search-overlay lg:hidden" id="mobile-search-overlay" aria-hidden="true" role="search" data-search-panel>
  <form action="{{ routes.search_url }}" method="get" class="mobile-search-overlay__form">
    <input type="hidden" name="type" value="product,article,page">
    <input type="search"
           name="q"
           id="mobile-search-input"
           class="mobile-search-overlay__input"
           placeholder="{{ 'general.search_placeholder' | t }}"
           aria-label="{{ 'general.search' | t }}"
           aria-autocomplete="list"
           aria-expanded="false"
           aria-controls="mobile-search-results"
           autocomplete="off"
           data-search-input>
    <button type="button" class="mobile-search-overlay__close" data-mobile-search-close aria-label="Close search">
      {% render 'icon', name: 'close' %}
    </button>
  </form>
  <div
    class="mobile-search-results"
    id="mobile-search-results"
    data-search-results
    role="listbox"
    aria-label="Search suggestions"
    hidden
  ></div>
</div>

<script>
(function() {
  var overlay = document.getElementById('mobile-search-overlay');
  if (!overlay) return;

  function openSearch() {
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    var input = overlay.querySelector('input[type="search"]');
    if (input) setTimeout(function() { input.focus(); }, 50);
  }

  function closeSearch() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-mobile-search-open]')) { openSearch(); return; }
    if (e.target.closest('[data-mobile-search-close]')) { closeSearch(); return; }
    if (overlay.classList.contains('is-open') && !overlay.contains(e.target)) closeSearch();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeSearch();
  });
})();
</script>

</header>
