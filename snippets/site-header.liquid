{%- liquid
  assign account_url = routes.account_url | default: '/account'
  assign support_url = section.settings.support_url | default: '/pages/support'
  assign support_label = section.settings.support_label | default: 'Support'
  assign support_phone_label = section.settings.support_phone_label | default: support_label
  assign support_phone = section.settings.support_phone | strip

  assign support_href = support_url
  assign support_aria_label = 'Support center'
  assign support_has_phone = false

  if support_phone != blank
    assign support_href = support_phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: '.', ''
    assign support_href = 'tel:' | append: support_href
    assign support_aria_label = support_phone_label | append: ' ' | append: support_phone
    assign support_has_phone = true
  endif
-%}
<header class="site-header" role="banner">
  <div class="site-header-inner">
    <div class="site-header-shell">
      <div class="site-header-main-row">
        <a href="{{ routes.root_url }}" class="site-brandmark">
          <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="h-12 w-auto lg:h-14" width="240" height="56">
        </a>

        <a href="{{ routes.search_url }}" class="site-header-search-surface hidden lg:flex" aria-label="{{ 'header.search' | t }}">
          <span class="site-header-search-label">Search</span>
          <span class="site-header-search-icon">
            {% render 'icon', name: 'search' %}
          </span>
        </a>

        <a href="{{ support_href }}" class="site-header-support-surface hidden lg:flex" aria-label="{{ support_aria_label }}">
          <span class="site-header-support-icon">
            {% render 'icon', name: 'support' %}
          </span>
          <span class="site-header-support-copy">
            <span class="site-header-support-label">
              {% if support_has_phone %}
                {{ support_phone_label }}
              {% else %}
                {{ support_label }}
              {% endif %}
            </span>
            <strong class="site-header-support-value">
              {% if support_has_phone %}
                {{ support_phone }}
              {% else %}
                Contact support
              {% endif %}
            </strong>
          </span>
          {% unless support_has_phone %}
            <span class="site-header-support-caret">
              {% render 'icon', name: 'chevron-down' %}
            </span>
          {% endunless %}
        </a>

        <div class="site-header-actions">
          <a href="{{ routes.search_url }}" class="site-header-icon-button lg:hidden" aria-label="{{ 'header.search' | t }}">
            {% render 'icon', name: 'search' %}
          </a>
          <a href="{{ account_url }}" class="site-header-icon-button" aria-label="Account">
            {% render 'icon', name: 'user' %}
          </a>
          <a href="/pages/compare" class="site-header-icon-button" aria-label="Compare">
            {% render 'icon', name: 'layers' %}
          </a>
          <a href="{{ routes.cart_url }}" class="site-header-icon-button site-header-cart-button" aria-label="{{ 'header.cart' | t }}">
            {% render 'icon', name: 'cart' %}
            {% if cart.item_count > 0 %}
              <span class="site-header-cart-count">{{ cart.item_count }}</span>
            {% endif %}
          </a>
          <a href="{{ routes.cart_url }}" class="site-header-cart-summary hidden lg:block">
            <span class="site-header-cart-summary-label">Subtotal</span>
            <strong>{{ cart.total_price | money }}</strong>
          </a>
          <button
            class="site-header-icon-button lg:hidden"
            type="button"
            aria-controls="mobile-nav-drawer"
            aria-expanded="false"
            data-drawer-open="mobile-nav-drawer"
          >
            <span class="sr-only">{{ 'header.open_menu' | t }}</span>
            {% render 'icon', name: 'menu' %}
          </button>
        </div>
      </div>

      <div class="site-header-nav-row hidden lg:flex">
        <nav aria-label="Primary" class="site-header-nav">
          {% render 'mega-menu', section: section %}
        </nav>

        <div class="site-header-meta-links">
          <a href="{{ routes.all_products_collection_url }}" class="site-header-meta-link">
            {% render 'icon', name: 'tag' %}
            <span>All sales</span>
          </a>
          <a href="/pages/shipping-returns" class="site-header-meta-link">
            {% render 'icon', name: 'truck' %}
            <span>Shipping &amp; Delivery</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  {% render 'mobile-nav-drawer' %}
</header>
