{%- liquid
  assign account_url = routes.account_url | default: '/account'
  assign account_login_url = routes.account_login_url | default: '/account/login'
  assign is_home_template = false
  if request.page_type == 'index'
    assign is_home_template = true
  endif
-%}
<header class="site-header{% if is_home_template %} site-header--hero-overlay{% endif %}" role="banner"{% if is_home_template %} data-header-scroll-threshold="28"{% else %} data-header-scroll-threshold="8"{% endif %}>
  <div class="site-header-inner container-shell">
    <div class="site-header-shell grid w-full grid-cols-1 py-0">
      <div class="site-header-main-row flex w-full items-center gap-3 lg:gap-6">
        <a href="{{ routes.root_url }}" class="site-brandmark inline-flex shrink-0 items-center">
          <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="block h-auto w-32 lg:w-60" width="240" height="56">
        </a>

        <nav aria-label="Primary" class="site-header-nav hidden min-w-0 flex-1 justify-center lg:flex">
          {% render 'mega-menu', section: section %}
        </nav>

        <div class="site-header-utility-cluster ml-auto flex items-center gap-1 lg:gap-1.5">
          <div class="site-header-actions flex items-center gap-1">
            <button
              type="button"
              class="site-header-icon-button hidden lg:inline-flex"
              aria-label="{{ 'header.search' | t }}"
              aria-expanded="false"
              aria-controls="site-header-search-panel"
              data-search-mega-trigger
            >
              {% render 'icon', name: 'search' %}
            </button>
            <a href="{{ routes.search_url }}" class="site-header-icon-button lg:hidden" aria-label="{{ 'header.search' | t }}">
              {% render 'icon', name: 'search' %}
            </a>
            {% if customer %}
              <div class="site-header-account-wrap">
                <a href="{{ account_url }}"
                   class="site-header-icon-button"
                   aria-label="{{ 'header.my_account' | t }}"
                   aria-haspopup="true">
                  <svg width="20" height="20" viewBox="0 0 20 20"
                       fill="none" aria-hidden="true">
                    <circle cx="10" cy="7" r="3"
                            stroke="currentColor" stroke-width="1.25"/>
                    <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6"
                          stroke="currentColor" stroke-width="1.25"
                          stroke-linecap="round"/>
                  </svg>
                </a>
                <div class="site-header-account-menu" role="menu">
                  <a href="{{ account_url }}" class="site-header-account-menu__item" role="menuitem">My account</a>
                  <a href="{{ account_url }}/orders" class="site-header-account-menu__item" role="menuitem">My orders</a>
                  <a href="{{ routes.account_logout_url }}" class="site-header-account-menu__item site-header-account-menu__item--signout" role="menuitem">Sign out</a>
                </div>
              </div>
            {% else %}
              <a href="{{ account_login_url }}"
                 class="site-header-icon-button"
                 aria-label="{{ 'header.sign_in' | t }}">
                <svg width="20" height="20" viewBox="0 0 20 20"
                     fill="none" aria-hidden="true">
                  <circle cx="10" cy="7" r="3"
                          stroke="currentColor" stroke-width="1.25"/>
                  <path d="M3 17c0-3.314 3.134-6 7-6s7 2.686 7 6"
                        stroke="currentColor" stroke-width="1.25"
                        stroke-linecap="round"/>
                </svg>
              </a>
            {% endif %}
            <a href="/pages/wishlist" class="site-header-icon-button" aria-label="{{ 'header.wishlist' | t }}">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
                <path d="M10 16.5S2.5 12 2.5 6.5a4 4 0 017.5-2A4 4 0 0117.5 6.5c0 5.5-7.5 10-7.5 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
              <span class="site-header-wishlist-count" data-wishlist-count hidden>0</span>
            </a>

            {% if localization.available_languages.size > 1 %}
            <div class="lang-picker hidden lg:block" id="lang-picker">

              <button class="lang-picker__trigger"
                      type="button"
                      aria-expanded="false"
                      aria-controls="lang-picker-dropdown"
                      aria-label="{{ 'header.select_language' | t }}">
                <span class="lang-picker__flag-wrap">
                  {% case localization.language.iso_code %}
                    {% when 'en' %}
                      <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg" aria-label="English">
                        <rect width="28" height="20" rx="2" fill="#012169"/>
                        <path d="M0 0l28 20M28 0L0 20" stroke="#fff" stroke-width="4"/>
                        <path d="M0 0l28 20M28 0L0 20" stroke="#C8102E" stroke-width="2.5"/>
                        <path d="M14 0v20M0 10h28" stroke="#fff" stroke-width="7"/>
                        <path d="M14 0v20M0 10h28" stroke="#C8102E" stroke-width="4"/>
                      </svg>
                    {% when 'es' %}
                      <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg" aria-label="Español">
                        <rect width="28" height="20" rx="2" fill="#AA151B"/>
                        <rect y="5" width="28" height="10" fill="#F1BF00"/>
                      </svg>
                    {% when 'fr' %}
                      <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg" aria-label="Français">
                        <rect width="28" height="20" rx="2" fill="#ED2939"/>
                        <rect width="19" height="20" fill="#fff"/>
                        <rect width="10" height="20" fill="#002395"/>
                        <rect width="28" height="20" rx="2" fill="none" stroke="rgba(0,0,0,0.1)" stroke-width="0.5"/>
                      </svg>
                    {% when 'de' %}
                      <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg" aria-label="Deutsch">
                        <rect width="28" height="20" rx="2" fill="#FFCE00"/>
                        <rect width="28" height="14" fill="#DD0000"/>
                        <rect width="28" height="7" rx="2" fill="#000"/>
                        <rect x="0" y="6" width="28" height="1" fill="#000"/>
                      </svg>
                    {% when 'ar' %}
                      <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg" aria-label="العربية">
                        <rect width="28" height="20" rx="2" fill="#006C35"/>
                        <text x="14" y="13" text-anchor="middle" font-size="7" fill="#fff" font-weight="500">&#x644;&#x627; &#x625;&#x644;&#x647;</text>
                        <rect x="3" y="14" width="22" height="1.5" fill="#fff"/>
                      </svg>
                    {% else %}
                      <svg width="22" height="16" viewBox="0 0 28 20" xmlns="http://www.w3.org/2000/svg">
                        <rect width="28" height="20" rx="2" fill="var(--ez-light)"/>
                        <text x="14" y="14" text-anchor="middle" font-size="9" font-weight="700" fill="var(--ez-black)">{{ localization.language.iso_code | upcase | slice: 0, 2 }}</text>
                      </svg>
                  {% endcase %}
                </span>
                <span class="lang-picker__code">{{ localization.language.iso_code | upcase }}</span>
                <svg class="lang-picker__chevron" width="10" height="6"
                     viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor"
                        stroke-width="1.5" stroke-linecap="round"
                        stroke-linejoin="round"/>
                </svg>
              </button>

              <div class="lang-picker__dropdown"
                   id="lang-picker-dropdown"
                   role="listbox"
                   hidden>
                {% form 'localization', class: 'lang-picker__form' %}
                  {%- comment -%} Pass 1: EN always first {%- endcomment -%}
                  {% for lang in localization.available_languages %}
                    {% unless lang.iso_code == 'en' %}{% continue %}{% endunless %}
                    <button
                      class="lang-picker__option{% if lang.iso_code == localization.language.iso_code %} is-active{% endif %}"
                      type="submit" name="locale_code" value="{{ lang.iso_code }}"
                      role="option"
                      aria-selected="{% if lang.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
                    >
                      <span class="lang-picker__option-flag">
                        <svg width="22" height="16" viewBox="0 0 28 20" aria-label="English">
                          <rect width="28" height="20" rx="2" fill="#012169"/>
                          <path d="M0 0l28 20M28 0L0 20" stroke="#fff" stroke-width="4"/>
                          <path d="M0 0l28 20M28 0L0 20" stroke="#C8102E" stroke-width="2.5"/>
                          <path d="M14 0v20M0 10h28" stroke="#fff" stroke-width="7"/>
                          <path d="M14 0v20M0 10h28" stroke="#C8102E" stroke-width="4"/>
                        </svg>
                      </span>
                      <span class="lang-picker__option-code">EN</span>
                      {% if lang.iso_code == localization.language.iso_code %}
                        <svg class="lang-picker__option-check" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M2.5 7l3 3 6-6" stroke="var(--ez-amber)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% endif %}
                    </button>
                  {% endfor %}

                  {%- comment -%} Pass 2: all other languages in Shopify order {%- endcomment -%}
                  {% for lang in localization.available_languages %}
                    {% if lang.iso_code == 'en' %}{% continue %}{% endif %}
                    <button
                      class="lang-picker__option{% if lang.iso_code == localization.language.iso_code %} is-active{% endif %}"
                      type="submit" name="locale_code" value="{{ lang.iso_code }}"
                      role="option"
                      aria-selected="{% if lang.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
                    >
                      <span class="lang-picker__option-flag">
                        {% case lang.iso_code %}
                          {% when 'es' %}
                            <svg width="22" height="16" viewBox="0 0 28 20" aria-label="Español">
                              <rect width="28" height="20" rx="2" fill="#AA151B"/>
                              <rect y="5" width="28" height="10" fill="#F1BF00"/>
                            </svg>
                          {% when 'fr' %}
                            <svg width="22" height="16" viewBox="0 0 28 20" aria-label="Français">
                              <rect width="28" height="20" rx="2" fill="#ED2939"/>
                              <rect width="19" height="20" fill="#fff"/>
                              <rect width="10" height="20" fill="#002395"/>
                              <rect width="28" height="20" rx="2" fill="none" stroke="rgba(0,0,0,0.1)" stroke-width="0.5"/>
                            </svg>
                          {% when 'de' %}
                            <svg width="22" height="16" viewBox="0 0 28 20" aria-label="Deutsch">
                              <rect width="28" height="20" rx="2" fill="#FFCE00"/>
                              <rect width="28" height="14" fill="#DD0000"/>
                              <rect width="28" height="7" rx="2" fill="#000"/>
                              <rect x="0" y="6" width="28" height="1" fill="#000"/>
                            </svg>
                          {% when 'ar' %}
                            <svg width="22" height="16" viewBox="0 0 28 20" aria-label="العربية">
                              <rect width="28" height="20" rx="2" fill="#006C35"/>
                              <text x="14" y="13" text-anchor="middle" font-size="7" fill="#fff" font-weight="500">&#x644;&#x627; &#x625;&#x644;&#x647;</text>
                              <rect x="3" y="14" width="22" height="1.5" fill="#fff"/>
                            </svg>
                          {% else %}
                            <svg width="22" height="16" viewBox="0 0 28 20">
                              <rect width="28" height="20" rx="2" fill="var(--ez-light)"/>
                            </svg>
                        {% endcase %}
                      </span>
                      <span class="lang-picker__option-code">{{ lang.iso_code | upcase }}</span>
                      {% if lang.iso_code == localization.language.iso_code %}
                        <svg class="lang-picker__option-check" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M2.5 7l3 3 6-6" stroke="var(--ez-amber)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {% endif %}
                    </button>
                  {% endfor %}
                {% endform %}
              </div>

            </div>
            {% endif %}

            <button
              class="site-header-icon-button site-header-cart-button header-icon-btn"
              type="button"
              aria-label="Open cart"
              aria-expanded="false"
              aria-controls="cart-drawer"
              id="header-cart-btn"
              data-cart-drawer-trigger
              data-cart-count="{{ cart.item_count }}"
            >
              {% render 'icon', name: 'cart' %}
              <span
                class="site-header-cart-count header-icon-btn__count"
                data-cart-count-badge
                aria-label="{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %} in cart"
                {% if cart.item_count == 0 %}hidden{% endif %}
              >
                {{ cart.item_count }}
              </span>
            </button>
            <button
              class="site-header-icon-button lg:hidden"
              type="button"
              aria-label="{{ 'header.open_menu' | t }}"
              aria-controls="mobile-nav-drawer"
              aria-expanded="false"
              data-drawer-open="mobile-nav-drawer"
            >
              <span class="sr-only">{{ 'header.open_menu' | t }}</span>
              {% render 'icon', name: 'menu' %}
            </button>
          </div>
        </div>
      </div>
    </div>

    {% render 'search-mega-panel' %}
  </div>

  {% render 'mobile-nav-drawer',
    support_href: '/pages/support',
    support_has_phone: false,
    support_phone: section.settings.support_phone,
    support_phone_label: section.settings.support_phone_label
  %}

{% if localization.available_languages.size > 1 %}
<script>
(function() {
  var picker   = document.getElementById('lang-picker');
  if (!picker) return;
  var trigger  = picker.querySelector('.lang-picker__trigger');
  var dropdown = document.getElementById('lang-picker-dropdown');

  function open()  { trigger.setAttribute('aria-expanded', 'true');  dropdown.hidden = false; }
  function close() { trigger.setAttribute('aria-expanded', 'false'); dropdown.hidden = true;  }

  trigger.addEventListener('click', function() {
    trigger.getAttribute('aria-expanded') === 'true' ? close() : open();
  });
  document.addEventListener('click', function(e) {
    if (!picker.contains(e.target)) close();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { close(); trigger.focus(); }
  });
})();
</script>
{% endif %}
</header>
