{%- liquid
  assign account_url = routes.account_url | default: '/account'
  assign account_login_url = routes.account_login_url | default: '/account/login'
  assign account_register_url = routes.account_register_url | default: '/account/register'
  assign account_logout_url = routes.account_logout_url | default: '/account/logout'
  assign is_home_template = false
  if request.page_type == 'index'
    assign is_home_template = true
  endif
-%}
<header class="site-header{% if is_home_template %} site-header--hero-overlay{% endif %}" role="banner"{% if is_home_template %} data-header-scroll-threshold="28"{% else %} data-header-scroll-threshold="8"{% endif %}>
  <div class="site-header-inner container-shell">
    <div class="site-header-shell grid w-full grid-cols-1 py-0">
      <div class="site-header-main-row flex w-full items-center gap-3 lg:gap-6">
        <a href="{{ routes.root_url }}" class="site-brandmark inline-flex shrink-0 items-center">
          <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="block h-auto w-48 max-w-full lg:w-60" width="240" height="56">
        </a>

        <nav aria-label="Primary" class="site-header-nav hidden min-w-0 flex-1 justify-center lg:flex">
          {% render 'mega-menu', section: section %}
        </nav>

        <div class="site-header-utility-cluster ml-auto flex shrink-0 items-center gap-1 lg:gap-1.5">
          <div class="site-header-actions flex items-center gap-1">
            <button
              type="button"
              class="site-header-icon-button hidden lg:inline-flex"
              aria-label="{{ 'header.search' | t }}"
              aria-expanded="false"
              aria-controls="site-header-search-panel"
              data-search-mega-trigger
            >
              {% render 'icon', name: 'search' %}
            </button>
            <a href="{{ routes.search_url }}" class="site-header-icon-button lg:hidden" aria-label="{{ 'header.search' | t }}">
              {% render 'icon', name: 'search' %}
            </a>
            <div class="site-header-action-menu mega-menu-nav-item--submenu relative hidden lg:block" data-nav-submenu>
              <button
                type="button"
                class="site-header-icon-button"
                aria-label="Account"
                aria-expanded="false"
                aria-controls="header-account-menu"
                data-nav-submenu-trigger
              >
                {% render 'icon', name: 'user' %}
              </button>
              <div id="header-account-menu" class="nav-submenu-panel nav-submenu-panel--icon" hidden data-nav-submenu-panel>
                {% if customer %}
                  <a href="{{ account_url }}" class="nav-submenu-link">My account</a>
                  <a href="{{ account_url }}#orders" class="nav-submenu-link">Orders</a>
                  <a href="{{ account_logout_url }}" class="nav-submenu-link">Log out</a>
                {% else %}
                  <a href="{{ account_login_url }}" class="nav-submenu-link">Sign in</a>
                  <a href="{{ account_register_url }}" class="nav-submenu-link">Create account</a>
                {% endif %}
              </div>
            </div>
            <a href="{{ account_url }}" class="site-header-icon-button lg:hidden" aria-label="Account">
              {% render 'icon', name: 'user' %}
            </a>
            <a href="/pages/wishlist" class="site-header-icon-button" aria-label="Wishlist">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
                <path d="M10 16.5S2.5 12 2.5 6.5a4 4 0 017.5-2A4 4 0 0117.5 6.5c0 5.5-7.5 10-7.5 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
              <span class="site-header-wishlist-count" data-wishlist-count hidden>0</span>
            </a>
            <div class="site-header-action-menu mega-menu-nav-item--submenu relative hidden lg:block" data-nav-submenu>
              <button
                type="button"
                class="site-header-icon-button site-header-cart-button"
                aria-label="{{ 'header.cart' | t }}"
                aria-expanded="false"
                aria-controls="header-cart-menu"
                data-nav-submenu-trigger
              >
                {% render 'icon', name: 'cart' %}
                {% if cart.item_count > 0 %}
                  <span class="site-header-cart-count">{{ cart.item_count }}</span>
                {% endif %}
              </button>
              <div id="header-cart-menu" class="nav-submenu-panel nav-submenu-panel--icon nav-submenu-panel--cart" hidden data-nav-submenu-panel>
                <div class="nav-submenu-summary">
                  <strong>
                    {% if cart.item_count > 0 %}
                      {{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}
                    {% else %}
                      Your cart is empty
                    {% endif %}
                  </strong>
                  <span>
                    {% if cart.item_count > 0 %}
                      {{ cart.total_price | money }}
                    {% else %}
                      Add a product to get started.
                    {% endif %}
                  </span>
                </div>
                <a href="{{ routes.cart_url }}" class="nav-submenu-link">View cart</a>
                {% if cart.item_count > 0 %}
                  <a href="/checkout" class="nav-submenu-link">Checkout</a>
                {% else %}
                  <a href="{{ routes.all_products_collection_url }}" class="nav-submenu-link">Browse products</a>
                {% endif %}
              </div>
            </div>
            <a href="{{ routes.cart_url }}" class="site-header-icon-button site-header-cart-button lg:hidden" aria-label="{{ 'header.cart' | t }}">
              {% render 'icon', name: 'cart' %}
              {% if cart.item_count > 0 %}
                <span class="site-header-cart-count">{{ cart.item_count }}</span>
              {% endif %}
            </a>
            <button
              class="site-header-icon-button lg:hidden"
              type="button"
              aria-controls="mobile-nav-drawer"
              aria-expanded="false"
              data-drawer-open="mobile-nav-drawer"
            >
              <span class="sr-only">{{ 'header.open_menu' | t }}</span>
              {% render 'icon', name: 'menu' %}
            </button>
          </div>
        </div>
      </div>
    </div>

    {% render 'search-mega-panel' %}
  </div>

  {% render 'mobile-nav-drawer',
    support_href: '/pages/support',
    support_has_phone: false,
    support_phone: section.settings.support_phone,
    support_phone_label: section.settings.support_phone_label
  %}
</header>
