{%- liquid
  assign current_variant = variant | default: product.selected_or_first_available_variant
  assign current_price = current_variant.price | default: product.price
  assign compare_price = current_variant.compare_at_price
-%}
<div class="space-y-1">
  <div class="flex flex-wrap items-end gap-3">
    {% if product != blank and product.price_varies %}
      <span class="text-xs font-medium uppercase tracking-[0.18em] text-slate-500">From</span>
    {% endif %}
    <span class="text-2xl font-semibold text-slate-900">
      {{ current_price | money }}
    </span>
    {% if compare_price > current_price %}
      <span class="text-sm text-slate-400 line-through">{{ compare_price | money }}</span>
    {% endif %}
  </div>
  {% if compare_price > current_price %}
    <p class="text-xs text-slate-500">Structured pricing and promotional messaging can be expanded in later implementation passes.</p>
  {% endif %}
</div>
