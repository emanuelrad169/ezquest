{%- liquid
  assign hub_product = all_products['usb-c-multimedia-hub']
  assign dock_product = all_products['usb-c-pro-dock']
-%}
<section
  id="site-header-search-panel"
  class="search-mega-panel"
  hidden
  data-search-mega-panel
  aria-label="Search the EZQuest storefront"
>
  <div class="search-mega-surface card-elevated rounded-panel bg-white p-5 shadow-lift lg:p-6">
    <div class="grid gap-5 xl:gap-6">
      <div class="grid gap-4 xl:grid-cols-12 xl:items-start">
        <div class="grid gap-3 xl:col-span-11">
          <div class="space-y-2">
            <p class="search-mega-label">Search EZQuest</p>
            <h2 class="type-heading text-heading-lg">Search products or support</h2>
          </div>

          <form action="{{ routes.search_url }}" method="get" class="search-mega-form grid min-h-14 flex-1 items-center gap-3 rounded-2xl border border-slate-200/90 bg-slate-50/70 px-4" role="search">
            <label class="sr-only" for="site-header-search-input">Search EZQuest</label>
            <span class="search-mega-form-icon inline-flex h-10 w-10 items-center justify-center text-slate-700">{% render 'icon', name: 'search' %}</span>
            <input
              id="site-header-search-input"
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="Search products, manuals, compatibility, or setup help"
              class="search-mega-input min-w-0 flex-1 bg-transparent text-body-lg text-slate-950 outline-none"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              enterkeyhint="search"
            >
            <input type="hidden" name="type" value="product,page,article">
            {% render 'button', label: 'Search', tag: 'button', type: 'submit', style: 'primary', size: 'sm', class: 'search-mega-submit' %}
          </form>
        </div>

        <button type="button" class="button-icon search-mega-close xl:col-span-1 xl:justify-self-end" data-search-mega-close aria-label="Close search">
          {% render 'icon', name: 'close' %}
        </button>
      </div>

      <div class="grid gap-5 border-t border-slate-200/70 pt-5 xl:grid-cols-12 xl:gap-6 xl:pt-6">
        <aside class="grid content-start gap-4 xl:col-span-4 2xl:col-span-3">
          <div class="search-mega-block card-soft grid gap-2.5 p-4">
            <div class="space-y-2">
              <p class="search-mega-label">Suggested searches</p>
            </div>
            <div class="search-mega-chip-list flex flex-wrap gap-2">
              <a href="{{ routes.search_url }}?q=pro+dock" class="search-mega-chip inline-flex min-h-8 items-center rounded-full border border-slate-200/90 bg-slate-50/70 px-3 text-xs font-medium text-slate-700 no-underline transition duration-200 hover:-translate-y-px hover:border-slate-300 hover:bg-white hover:text-slate-950">Pro dock</a>
              <a href="{{ routes.search_url }}?q=usb-c+hub" class="search-mega-chip inline-flex min-h-8 items-center rounded-full border border-slate-200/90 bg-slate-50/70 px-3 text-xs font-medium text-slate-700 no-underline transition duration-200 hover:-translate-y-px hover:border-slate-300 hover:bg-white hover:text-slate-950">USB-C hub</a>
              <a href="{{ routes.search_url }}?q=compatibility" class="search-mega-chip inline-flex min-h-8 items-center rounded-full border border-slate-200/90 bg-slate-50/70 px-3 text-xs font-medium text-slate-700 no-underline transition duration-200 hover:-translate-y-px hover:border-slate-300 hover:bg-white hover:text-slate-950">Compatibility</a>
              <a href="{{ routes.search_url }}?q=manual" class="search-mega-chip inline-flex min-h-8 items-center rounded-full border border-slate-200/90 bg-slate-50/70 px-3 text-xs font-medium text-slate-700 no-underline transition duration-200 hover:-translate-y-px hover:border-slate-300 hover:bg-white hover:text-slate-950">Manuals</a>
            </div>
          </div>

          <div class="search-mega-block card-soft grid gap-2.5 p-4">
            <div class="space-y-2">
              <p class="search-mega-label">Quick links</p>
            </div>
            <div class="search-mega-link-stack grid gap-2">
              <a href="/pages/compatibility" class="text-sm font-medium text-slate-900 no-underline transition duration-200 hover:text-blue-600">Check compatibility</a>
              <a href="/pages/support" class="text-sm font-medium text-slate-900 no-underline transition duration-200 hover:text-blue-600">Open support center</a>
            </div>
          </div>
        </aside>

        <div class="grid gap-4 xl:col-span-8 2xl:col-span-9">
          <div class="space-y-2">
            <p class="search-mega-label">Suggested products</p>
            <h2 class="text-heading-base font-medium tracking-title text-slate-950">Quick starts</h2>
          </div>

          <div class="search-mega-results" aria-live="polite" aria-busy="false" data-search-results>
            <div class="search-mega-products grid gap-4 xl:grid-cols-2" data-search-products>
              {% if hub_product != blank %}
                {% render 'mega-menu-stage-card',
                  product: hub_product,
                  media_context: 'search',
                  eyebrow: 'Popular',
                  show_descriptor: true,
                  card_class: 'search-mega-stage-card'
                %}
              {% endif %}
              {% if dock_product != blank %}
                {% render 'mega-menu-stage-card',
                  product: dock_product,
                  media_context: 'search',
                  eyebrow: 'Desk',
                  show_descriptor: true,
                  card_class: 'search-mega-stage-card'
                %}
              {% endif %}
            </div>

            <div class="search-mega-skeleton grid gap-4 xl:grid-cols-2" aria-hidden="true" hidden data-search-skeleton>
              {% for i in (1..2) %}
                <div class="search-skeleton-card card-base overflow-hidden">
                  <div class="search-skeleton-media"></div>
                  <div class="search-skeleton-body">
                    <div class="search-skeleton-line"></div>
                    <div class="search-skeleton-line search-skeleton-line--short"></div>
                    <div class="search-skeleton-line search-skeleton-line--price"></div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
