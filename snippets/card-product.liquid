{%- liquid
  assign card_style = card_style | default: 'default'
  assign image_variant = image_variant | default: 'hero'
  assign featured_card = false
  if card_style == 'featured-strip'
    assign featured_card = true
  endif

  assign value_line = blank
  assign trust_cue = 'Setup help stays close'
  assign product_badge = blank
  assign fit_cue = blank
  assign support_text = blank

  if product != blank and product.metafields.ezquest.feature_highlights != blank and product.metafields.ezquest.feature_highlights.value.count > 0
    assign value_line = product.metafields.ezquest.feature_highlights.value.first
  elsif product != blank and product.type != blank
    assign normalized_type = product.type | downcase
    if normalized_type contains 'dock'
      assign value_line = 'Desk-ready power, ports, and display expansion'
      assign fit_cue = 'Best for desk setups'
    elsif normalized_type contains 'hub'
      assign value_line = 'Compact expansion for charging, display, and data'
      assign fit_cue = 'Best for everyday carry'
    elsif normalized_type contains 'charg' or normalized_type contains 'power'
      assign value_line = 'Reliable charging for notebooks, tablets, and mobile devices'
      assign fit_cue = 'Best for charging workflows'
    elsif normalized_type contains 'cable' or normalized_type contains 'accessor'
      assign value_line = 'Everyday cables and add-ons that keep the setup moving'
      assign fit_cue = 'Best for finishing the setup'
    else
      assign value_line = 'Premium connectivity for Apple, PC, and mobile workflows'
    endif
  else
    assign value_line = 'Premium connectivity for Apple, PC, and mobile workflows'
  endif

  if product != blank
    if product.metafields.ezquest.compatibility_summary != blank
      assign support_text = product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | strip
    elsif product.metafields.ezquest.support_summary != blank
      assign support_text = product.metafields.ezquest.support_summary | metafield_tag | strip_html | strip
    elsif product.description != blank
      assign support_text = product.description | strip_html | strip
    endif

    if support_text != blank
      assign trust_cue = support_text | truncatewords: 6
    elsif product.metafields.ezquest.feature_highlights != blank and product.metafields.ezquest.feature_highlights.value.count > 1
      assign trust_cue = product.metafields.ezquest.feature_highlights.value[1]
    endif

    assign product_tags_downcase = product.tags | join: ',' | downcase
    if product.compare_at_price_max > product.price
      assign product_badge = 'Sale'
    elsif product_tags_downcase contains 'best seller' or product_tags_downcase contains 'best-seller' or product_tags_downcase contains 'bestseller'
      assign product_badge = 'Best seller'
    elsif product_tags_downcase contains 'new'
      assign product_badge = 'New'
    endif
  endif
-%}

{% if featured_card %}
  <a
    href="{{ product.url | default: '#' }}"
    class="product-card-tile product-card-tile--featured-strip motion-fade-up{% if featured %} is-featured{% endif %}"
    {% if card_index != blank %}data-card-index="{{ card_index }}"{% endif %}
  >
    <div class="product-card-featured-media">
      {% if product != blank and product.featured_image != blank %}
        {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'product-card-image product-card-featured-image aspect-card w-full object-contain' }}
      {% else %}
        {% render 'owned-product-visual',
          product_handle: product.handle,
          product_title: product.title | default: 'EZQuest Product',
          variant: image_variant,
          kind: 'product',
          width: 1200,
          height: 900,
          class: 'product-card-image product-card-featured-image aspect-card w-full object-contain'
        %}
      {% endif %}

      {% if product_badge != blank %}
        <span class="product-card-featured-badge">{{ product_badge }}</span>
      {% endif %}
    </div>

    <div class="product-card-featured-body">
      <div class="product-card-featured-meta">
        <span class="product-card-featured-brand">{{ product.vendor | default: shop.name }}</span>
        {% if product.type != blank %}
          <span class="product-card-featured-category">{{ product.type }}</span>
        {% endif %}
      </div>

      {% if fit_cue != blank %}
        <div class="product-card-featured-fit">{{ fit_cue }}</div>
      {% endif %}

      <h3 class="card-title product-card-featured-title">{{ product.title | default: 'EZQuest connectivity essential' }}</h3>
      <p class="product-card-featured-value">{{ value_line }}</p>

      <div class="product-card-featured-rating" aria-label="Buying confidence">
        <span class="product-card-featured-rating-copy">{{ trust_cue }}</span>
      </div>

      <div class="product-card-featured-footer">
        <div class="product-card-featured-price">
          {% render 'price', product: product, show_promo_note: false %}
        </div>
        <span class="product-card-featured-cta">View product</span>
      </div>
    </div>
  </a>
{% else %}
<article class="product-card-tile motion-lift flex h-full flex-col">
  {% if product != blank and product.featured_image != blank %}
    <div class="product-thumb-card product-card-media relative">
      {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'product-card-image aspect-card w-full object-cover' }}
      {% if product.available == false %}
        <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-caption font-semibold uppercase tracking-wide text-slate-900">Sold out</span>
      {% elsif product.compare_at_price_max > product.price %}
        <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-caption font-semibold uppercase tracking-wide text-slate-900">On sale</span>
      {% endif %}
    </div>
  {% else %}
    <div class="product-thumb-card product-card-media">
      {% render 'owned-product-visual',
        product_handle: product.handle,
        product_title: product.title | default: value_line,
        variant: image_variant,
        kind: 'product',
        width: 900,
        height: 675,
        class: 'product-card-image aspect-card w-full object-cover'
      %}
    </div>
  {% endif %}

  <div class="product-card-body mt-4 flex flex-1 flex-col">
  <div class="flex items-center justify-between gap-3">
    {% if product != blank and product.vendor != blank %}
      <p class="section-kicker">{{ product.vendor }}</p>
    {% else %}
      <p class="section-kicker text-slate-400">Product</p>
    {% endif %}
    {% if product != blank and product.type != blank %}
      <span class="text-xs font-medium uppercase tracking-wide text-slate-400">{{ product.type }}</span>
    {% endif %}
  </div>

  <h3 class="card-title mt-3">
    {% if product != blank %}
      <a href="{{ product.url }}" class="transition hover:text-slate-700">{{ product.title }}</a>
    {% else %}
      EZQuest connectivity essential
    {% endif %}
  </h3>

  <p class="product-card-value-line mt-3">{{ value_line }}</p>

  <div class="product-card-trust mt-3">{{ trust_cue }}</div>

  <div class="product-card-footer mt-5">
    {% render 'price', product: product %}
    <div class="flex items-center gap-3">
      {% if product != blank %}
        {% render 'button', label: 'View product', url: product.url, style: 'secondary' %}
      {% endif %}
    </div>
  </div>
</div>
</article>
{% endif %}
