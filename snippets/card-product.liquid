{%- liquid
  assign card_style = card_style | default: 'default'
  assign card_context = card_context | default: 'default'
  assign image_variant = image_variant | default: blank
  assign featured_card = false
  if card_style == 'featured-strip'
    assign featured_card = true
  endif

  if image_variant == blank
    case card_context
      when 'homepage', 'collection', 'search', 'compare'
        assign image_variant = 'compare'
      else
        assign image_variant = 'hero'
    endcase
  endif

  assign value_line = blank
  assign product_badge = blank
  assign product_badge_modifier = blank
  assign rating_value = blank
  assign rating_count = blank
  assign swatch_values = blank
  assign swatch_limit = 4
  assign swatch_overflow = 0
  assign structured_spec_rows = blank
  assign has_structured_spec_rows = false
  assign show_spec_strip = true
  assign spec_limit = 3
  assign show_media_dots = false
  assign media_dot_count = 0
  assign fallback_weight_value = blank
  assign highlight_spec_value = blank
  assign show_swatches = true
  assign show_quick_add = false
  assign show_media_quick_add = true
  assign show_footer_quick_add = true
  assign selected_variant = blank
  assign quick_add_label = 'Add to cart'
  assign quick_add_attributes = 'name="add"'
  assign product_eyebrow = blank
  assign show_product_eyebrow = true
  assign product_card_url = product.url | default: '#'

  if product != blank and collection != blank and card_context == 'collection'
    assign product_card_url = product.url | within: collection
  endif

  case card_context
    when 'homepage'
      assign show_spec_strip = false
      assign show_swatches = false
      assign spec_limit = 0
      assign show_media_quick_add = false
    when 'collection'
      assign show_spec_strip = true
      assign show_swatches = true
      assign spec_limit = 3
      assign show_media_quick_add = false
    when 'search'
      assign show_spec_strip = false
      assign show_swatches = false
      assign spec_limit = 0
      assign show_media_quick_add = false
    when 'compare'
      assign show_swatches = false
      assign show_spec_strip = false
      assign show_product_eyebrow = false
      assign show_media_quick_add = false
      assign show_footer_quick_add = false
    when 'featured'
      assign show_spec_strip = true
      assign show_swatches = true
      assign spec_limit = 3
      assign show_footer_quick_add = false
      assign show_media_quick_add = true
  endcase

  if product != blank and product.metafields.ezquest.feature_highlights != blank and product.metafields.ezquest.feature_highlights.value.count > 0
    assign value_line = product.metafields.ezquest.feature_highlights.value.first
    assign highlight_spec_value = product.metafields.ezquest.feature_highlights.value.first
  elsif product != blank and product.type != blank
    assign normalized_type = product.type | downcase
    if normalized_type contains 'dock'
      assign value_line = 'Desk-ready connectivity'
    elsif normalized_type contains 'hub'
      assign value_line = 'Compact everyday connectivity'
    elsif normalized_type contains 'charg' or normalized_type contains 'power'
      assign value_line = 'Fast, reliable charging'
    elsif normalized_type contains 'cable' or normalized_type contains 'accessor'
      assign value_line = 'Refined everyday accessories'
    else
      assign value_line = 'Premium connectivity'
    endif
  else
    assign value_line = 'Premium connectivity'
  endif

  if product != blank
    assign product_tags_downcase = product.tags | join: ',' | downcase
    if product.compare_at_price_max > product.price
      assign product_badge = 'Sale'
      assign product_badge_modifier = 'sale'
    elsif product_tags_downcase contains 'new'
      assign product_badge = 'New'
      assign product_badge_modifier = 'new'
    endif

    if product.metafields.reviews.rating != blank and product.metafields.reviews.rating.value != blank
      assign rating_value = product.metafields.reviews.rating.value.rating
      assign rating_count = product.metafields.reviews.rating_count.value | default: blank
    endif

    for option in product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'color' or option_name contains 'finish'
        assign swatch_values = option.values
        break
      endif
    endfor

    if swatch_values != blank and swatch_values.size > swatch_limit
      assign swatch_overflow = swatch_values.size | minus: swatch_limit
    endif

    if product.metafields.ezquest.spec_rows != blank
      assign structured_spec_rows = product.metafields.ezquest.spec_rows.value
      if structured_spec_rows.count > 0
        assign has_structured_spec_rows = true
      endif
    endif

    assign selected_variant = product.selected_or_first_available_variant
    if selected_variant != blank and card_context != 'compare'
      assign show_quick_add = true
      if selected_variant.weight > 0
        assign fallback_weight_value = selected_variant.weight | weight_with_unit
      endif
    endif

    if product.type != blank
      assign product_eyebrow = product.type
    elsif product.vendor != blank
      assign product_eyebrow = product.vendor
    endif

    if product.media.size > 1 and card_context == 'homepage'
      assign show_media_dots = true
      assign media_dot_count = product.media.size
      if media_dot_count > 3
        assign media_dot_count = 3
      endif
    endif

    unless product.available
      assign quick_add_label = 'Sold out'
      assign quick_add_attributes = 'name="add" disabled="disabled"'
    endunless
  endif
-%}

{% if featured_card %}
  <article
    class="product-card-tile product-card-tile--featured-strip product-card-tile--{{ card_context | handleize }} card-elevated card-interactive motion-fade-up relative flex h-full flex-col overflow-hidden text-slate-950 no-underline{% if featured %} is-featured{% endif %}"
    {% if card_index != blank %}data-card-index="{{ card_index }}"{% endif %}
  >
    <div class="product-card-featured-media-shell relative">
      <a href="{{ product_card_url }}" class="product-card-featured-media product-card-featured-media-link relative flex min-h-56 items-center justify-center overflow-hidden border-b border-slate-200/70 bg-white no-underline" aria-label="View {{ product.title | default: 'product' }}">
        {% render 'product-browse-media',
          product: product,
          context: card_context,
          variant: image_variant,
          width: 1200,
          height: 900,
          class: 'product-card-image product-card-featured-image aspect-card w-full object-contain'
        %}
        {% if product_badge != blank %}
          <span class="product-card-featured-badge{% if product_badge_modifier != blank %} product-card-featured-badge--{{ product_badge_modifier }}{% endif %}">{{ product_badge }}</span>
        {% endif %}
        {% if rating_value != blank %}
          <span class="product-card-featured-rating-badge" aria-label="Rated {{ rating_value }} out of 5{% if rating_count != blank %} from {{ rating_count }} reviews{% endif %}">
            <span class="rating-star" aria-hidden="true">★</span>
            {{ rating_value }}
            {% if rating_count != blank %}<span class="rating-count">({{ rating_count }})</span>{% endif %}
          </span>
        {% elsif settings.reviews_app == 'judgeme' %}
          {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', concierge_install: true, product: product %}
        {% endif %}
      </a>

      <div class="product-card__wishlist">
        {% render 'wishlist-button',
          product_id: product.id,
          product_title: product.title,
          product_url: product.url,
          product_image: product.featured_image,
          product_price: product.price
        %}
      </div>

      {% if show_media_quick_add and show_quick_add %}
        {% form 'product', product, class: 'product-card-featured-add-form product-card-featured-add-form--media' %}
          <input type="hidden" name="id" value="{{ selected_variant.id }}">
          {% render 'button', label: quick_add_label, tag: 'button', type: 'submit', style: 'primary', size: 'sm', class: 'product-card-featured-media-cta', attributes: quick_add_attributes %}
        {% endform %}
      {% endif %}

      {% if show_media_dots %}
        <div class="product-card-featured-indicators" aria-hidden="true">
          {% for i in (1..media_dot_count) %}
            <span class="product-card-featured-indicator{% if forloop.first %} is-active{% endif %}"></span>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-card-featured-body flex flex-1 flex-col gap-3 px-4 pb-4 pt-3 lg:px-5">
      <div class="product-card-featured-copy grid gap-1.5">
        {% if show_product_eyebrow and product_eyebrow != blank %}
          <p class="product-card-featured-vendor">{{ product_eyebrow }}</p>
        {% endif %}

        <div class="product-card-featured-title-price-row flex items-start justify-between gap-3">
          <h3 class="card-title product-card-featured-title">
            <a href="{{ product_card_url }}" class="product-card-featured-title-link">{{ product.title | default: 'EZQuest connectivity essential' }}</a>
          </h3>
          <div class="product-card-featured-price">
            {% render 'price', product: product, show_promo_note: false %}
          </div>
        </div>

        {% if show_swatches and swatch_values != blank and swatch_values.size > 0 %}
          <div class="product-card-featured-swatches flex flex-wrap items-center gap-1.5" aria-label="Available finishes">
            {% for swatch_value in swatch_values limit: swatch_limit %}
              <span
                class="product-card-featured-swatch product-card-featured-swatch--{{ swatch_value | handleize }}"
                title="{{ swatch_value }}"
                aria-hidden="true"
              ></span>
            {% endfor %}
            {% if swatch_overflow > 0 %}
              <span class="product-card-featured-swatch-count">+{{ swatch_overflow }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if show_footer_quick_add and show_quick_add %}
        <div class="product-card-featured-footer mt-auto pt-3">
          {% form 'product', product, class: 'product-card-featured-add-form product-card-featured-add-form--footer' %}
            <input type="hidden" name="id" value="{{ selected_variant.id }}">
            {% render 'button', label: quick_add_label, tag: 'button', type: 'submit', style: 'primary', class: 'product-card-featured-footer-cta', attributes: quick_add_attributes %}
          {% endform %}
        </div>
      {% endif %}
    </div>

    {% if show_spec_strip %}
      {%- assign rendered_spec_cells = 0 -%}
      {%- capture spec_cells_html -%}
        {% if has_structured_spec_rows %}
          {% for spec_row in structured_spec_rows %}
            {% if rendered_spec_cells >= spec_limit %}{% break %}{% endif %}
            {%- assign spec_label = spec_row.label.value | strip -%}
            {%- assign spec_value = spec_row.spec_value.value | strip_html | strip -%}
            {% if spec_label != blank and spec_value != blank %}
              {%- assign spec_lower = spec_label | downcase -%}
              {%- if spec_lower contains 'sku' or spec_lower contains 'barcode' or spec_lower contains 'upc' or spec_lower contains 'ean' or spec_lower contains 'part number' or spec_lower contains 'item number' or spec_lower contains 'asin' or spec_lower contains 'model number' -%}{%- continue -%}{%- endif -%}
              {%- assign spec_icon_name = 'spark' -%}
              {%- if spec_lower contains 'speed' or spec_lower contains 'transfer' -%}{%- assign spec_icon_name = 'bolt' -%}{%- endif -%}
              {%- if spec_lower contains 'port' or spec_lower contains 'hub' -%}{%- assign spec_icon_name = 'layers' -%}{%- endif -%}
              {%- if spec_lower contains 'type' or spec_lower contains 'connector' -%}{%- assign spec_icon_name = 'tag' -%}{%- endif -%}
              {%- if spec_lower contains 'power' or spec_lower contains 'watt' or spec_lower contains 'charg' or spec_lower contains 'battery' -%}{%- assign spec_icon_name = 'bolt' -%}{%- endif -%}
              {%- if spec_lower contains 'display' or spec_lower contains 'resolution' or spec_lower contains 'video' -%}{%- assign spec_icon_name = 'monitor' -%}{%- endif -%}
              {%- if spec_lower contains 'weight' -%}{%- assign spec_icon_name = 'layers' -%}{%- endif -%}
              {%- if spec_lower contains 'length' -%}{%- assign spec_icon_name = 'map' -%}{%- endif -%}
              {%- if spec_lower contains 'driver' -%}{%- assign spec_icon_name = 'headphones' -%}{%- endif -%}
              <div class="product-card-featured-spec">
                <span class="product-card-featured-spec-icon" aria-hidden="true">{% render 'icon', name: spec_icon_name %}</span>
                <span class="product-card-featured-spec-content">
                  <span class="product-card-featured-spec-value">{{ spec_value | truncatewords: 5 }}</span>
                  <span class="product-card-featured-spec-label">{{ spec_label }}</span>
                </span>
              </div>
              {%- assign rendered_spec_cells = rendered_spec_cells | plus: 1 -%}
            {% endif %}
          {% endfor %}
        {% endif %}


        {% if rendered_spec_cells < spec_limit and fallback_weight_value != blank %}
          <div class="product-card-featured-spec">
            <span class="product-card-featured-spec-icon" aria-hidden="true">{% render 'icon', name: 'layers' %}</span>
            <span class="product-card-featured-spec-content">
              <span class="product-card-featured-spec-value">{{ fallback_weight_value }}</span>
              <span class="product-card-featured-spec-label">Weight</span>
            </span>
          </div>
          {%- assign rendered_spec_cells = rendered_spec_cells | plus: 1 -%}
        {% endif %}

        {% if rendered_spec_cells < spec_limit and highlight_spec_value != blank and has_structured_spec_rows == false %}
          <div class="product-card-featured-spec">
            <span class="product-card-featured-spec-icon" aria-hidden="true">{% render 'icon', name: 'spark' %}</span>
            <span class="product-card-featured-spec-content">
              <span class="product-card-featured-spec-value">{{ highlight_spec_value | truncatewords: 5 }}</span>
              <span class="product-card-featured-spec-label">Highlight</span>
            </span>
          </div>
        {% endif %}
      {%- endcapture -%}
      {%- assign spec_cells_html = spec_cells_html | strip -%}
      {% if spec_cells_html != blank %}
        <div class="product-card-featured-spec-strip grid grid-cols-1" aria-label="Key details">
          {{ spec_cells_html }}
        </div>
      {% endif %}
    {% endif %}
  </article>
{% else %}
<article class="product-card-tile product-card-tile--{{ card_context | handleize }} flex h-full flex-col">

  {%- comment -%} ── Image wrapper ── {%- endcomment -%}
  {% if product != blank %}
    <div class="product-thumb-card product-card-image-wrapper relative overflow-hidden">
      <a href="{{ product_card_url }}" class="product-card-image-link" aria-label="{{ product.title }}">
        {% render 'product-browse-media',
          product: product,
          context: card_context,
          variant: image_variant,
          width: 900,
          height: 675,
          class: 'product-card-image aspect-card w-full object-contain'
        %}
      </a>
      {% if product.available == false %}
        <span class="product-card-badge">Sold out</span>
      {% elsif product.compare_at_price_max > product.price %}
        <span class="product-card-badge product-card-badge--sale">Sale</span>
      {% endif %}
      <div class="product-card-quick-action" aria-hidden="true">
        <span class="product-card-quick-action-cta">View product</span>
      </div>
    </div>
  {% else %}
    <div class="product-thumb-card product-card-image-wrapper">
      {% render 'owned-product-visual',
        product_handle: product.handle,
        product_title: product.title | default: value_line,
        variant: image_variant,
        kind: 'product',
        width: 900,
        height: 675,
        class: 'product-card-image aspect-card w-full object-cover'
      %}
    </div>
  {% endif %}

  {%- comment -%} ── Info row: title left, price right ── {%- endcomment -%}
  <div class="product-card-info mt-3 flex items-start justify-between gap-3">
    <h3 class="product-card-title">
      {% if product != blank %}
        <a href="{{ product_card_url }}" class="product-card-title-link">{{ product.title }}</a>
      {% else %}
        EZQuest connectivity essential
      {% endif %}
    </h3>
    <div class="product-card-price">
      {% render 'price', product: product %}
    </div>
  </div>

  {% if value_line != blank %}
    <p class="product-card-proof">{{ value_line | truncatewords: 7 }}</p>
  {% endif %}

  {% if product != blank %}
    <a href="{{ product_card_url }}" class="product-card-mobile-cta button-secondary">View product</a>
  {% endif %}

</article>
{% endif %}
