<article class="feature-card h-full bg-gradient-to-br from-white to-slate-50">
  {% if product != blank and product.featured_image != blank %}
    <div class="relative overflow-hidden rounded-[1.5rem] border border-slate-200/80 bg-white">
      {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'aspect-[4/3] w-full object-cover transition duration-300 hover:scale-[1.02]' }}
      {% if product.available == false %}
        <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-slate-900">Sold out</span>
      {% elsif product.compare_at_price_max > product.price %}
        <span class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-slate-900">On sale</span>
      {% endif %}
    </div>
  {% else %}
    <div class="aspect-[4/3] rounded-[1.5rem] border border-slate-200/80 bg-slate-100"></div>
  {% endif %}

  <div class="mt-5 flex items-center justify-between gap-3">
    {% if product != blank and product.vendor != blank %}
      <p class="section-kicker">{{ product.vendor }}</p>
    {% else %}
      <p class="section-kicker text-slate-400">Product</p>
    {% endif %}
    {% if product != blank and product.type != blank %}
      <span class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">{{ product.type }}</span>
    {% endif %}
  </div>

  <h3 class="mt-3 text-xl font-semibold tracking-[-0.03em] text-slate-950">
    {% if product != blank %}
      <a href="{{ product.url }}">{{ product.title }}</a>
    {% else %}
      Product card
    {% endif %}
  </h3>

  <p class="mt-3 text-sm leading-7 text-slate-600">
    {% if description != blank %}
      {{ description }}
    {% elsif product != blank and product.metafields.ezquest.support_summary != blank %}
      {{ product.metafields.ezquest.support_summary | metafield_tag | strip_html | truncatewords: 20 }}
    {% elsif product != blank and product.description != blank %}
      {{ product.description | strip_html | truncatewords: 20 }}
    {% else %}
      Reserved for product summary content and merchandising hierarchy.
    {% endif %}
  </p>

  <div class="mt-5">
    {% render 'price', product: product %}
  </div>

  <div class="product-link-row">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Compare options, review support, or view details</p>
    <div class="flex flex-wrap gap-3">
      {% if product != blank %}
        {% render 'button', label: 'View details', url: product.url, style: 'secondary' %}
      {% endif %}
      <a href="/pages/compare" class="site-meta-link">Compare</a>
    </div>
  </div>
</article>
