{%- liquid
  assign card_style = card_style | default: 'default'
  assign card_context = card_context | default: 'default'
  assign image_variant = image_variant | default: blank
  assign featured_card = false
  if card_style == 'featured-strip'
    assign featured_card = true
  endif

  if image_variant == blank
    case card_context
      when 'homepage', 'collection', 'search', 'compare'
        assign image_variant = 'compare'
      else
        assign image_variant = 'hero'
    endcase
  endif

  assign product_badge_codes = ''
  assign swatch_values = blank
  assign swatch_limit = 4
  assign swatch_overflow = 0
  assign show_media_dots = false
  assign media_dot_count = 0
  assign show_swatches = true
  assign show_quick_add = false
  assign show_footer_quick_add = true
  assign selected_variant = blank
  assign quick_add_label = 'Add to cart'
  assign quick_add_attributes = 'name="add"'
  assign product_eyebrow = blank
  assign show_product_eyebrow = true
  assign product_card_url = product.url | default: '#'
  assign card_image_loading = 'lazy'
  assign card_image_fetchpriority = 'auto'

  if product != blank and collection != blank and card_context == 'collection'
    assign product_card_url = product.url | within: collection
  endif

  if card_index != blank and card_index < 4
    assign card_image_loading = 'eager'
    assign card_image_fetchpriority = 'high'
  endif

  case card_context
    when 'homepage'
      assign show_swatches = false
    when 'collection'
      assign show_swatches = true
    when 'search'
      assign show_swatches = false
    when 'compare'
      assign show_swatches = false
      assign show_product_eyebrow = false
      assign show_footer_quick_add = false
    when 'featured'
      assign show_swatches = true
      assign show_footer_quick_add = false
  endcase

  if product != blank
    assign product_tags_downcase = product.tags | join: ',' | downcase
    assign product_tags_normalized = product_tags_downcase | replace: ' ', '-' | replace: '_', '-'
    assign product_title_downcase = product.title | downcase
    assign now_seconds = 'now' | date: '%s' | plus: 0
    assign published_seconds = product.published_at | date: '%s' | plus: 0
    assign product_age_seconds = now_seconds | minus: published_seconds
    assign product_days_old = product_age_seconds | divided_by: 86400

    unless product.available
      assign product_badge_codes = product_badge_codes | append: 'soldout,'
    endunless

    if product.compare_at_price_max > product.price
      assign product_badge_codes = product_badge_codes | append: 'sale,'
    endif

    if product_tags_normalized contains 'best-seller' or product_tags_normalized contains 'bestseller'
      assign product_badge_codes = product_badge_codes | append: 'bestseller,'
    endif

    if product_days_old < 60 or product_tags_normalized contains 'new'
      assign product_badge_codes = product_badge_codes | append: 'new,'
    endif

    if product_tags_normalized contains 'usb4' or product_tags_normalized contains 'usb-4' or product_title_downcase contains 'usb4' or product_title_downcase contains 'usb 4'
      assign product_badge_codes = product_badge_codes | append: 'usb4,'
    endif

    if product_tags_normalized contains 'thunderbolt' or product_title_downcase contains 'thunderbolt'
      assign product_badge_codes = product_badge_codes | append: 'thunderbolt,'
    endif

    if product_tags_normalized contains 'gan' or product_title_downcase contains 'gan'
      assign product_badge_codes = product_badge_codes | append: 'gan,'
    endif

    if product_tags_normalized contains 'duraguard' or product_title_downcase contains 'duraguard'
      assign product_badge_codes = product_badge_codes | append: 'duraguard,'
    endif

    if product_tags_normalized contains 'dual-display' or product_title_downcase contains 'dual display' or product_title_downcase contains 'dual-display'
      assign product_badge_codes = product_badge_codes | append: 'dual-display,'
    endif

    if product_tags_normalized contains '100w' or product_tags_normalized contains '120w' or product_title_downcase contains '100w' or product_title_downcase contains '120w'
      assign product_badge_codes = product_badge_codes | append: 'highwatt,'
    endif

    for option in product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'color' or option_name contains 'finish'
        assign swatch_values = option.values
        break
      endif
    endfor

    if swatch_values != blank and swatch_values.size > swatch_limit
      assign swatch_overflow = swatch_values.size | minus: swatch_limit
    endif

    assign selected_variant = product.selected_or_first_available_variant
    if selected_variant != blank and card_context != 'compare'
      assign show_quick_add = true
    endif

    if product.type != blank
      assign product_eyebrow = product.type
    elsif product.vendor != blank
      assign product_eyebrow = product.vendor
    endif

    if product.media.size > 1 and card_context == 'homepage'
      assign show_media_dots = true
      assign media_dot_count = product.media.size
      if media_dot_count > 3
        assign media_dot_count = 3
      endif
    endif

    unless product.available
      assign quick_add_label = 'Sold out'
      assign quick_add_attributes = 'name="add" disabled="disabled"'
    endunless
  endif
-%}

{% if featured_card %}
  <article
    class="product-card product-card-tile product-card-tile--featured-strip product-card-tile--{{ card_context | handleize }} card-elevated card-interactive motion-fade-up relative flex h-full flex-col overflow-hidden text-slate-950 no-underline{% if featured %} is-featured{% endif %}"
    {% if card_index != blank %}data-card-index="{{ card_index }}"{% endif %}
  >
    <div class="product-card-featured-media-shell relative">
      <a href="{{ product_card_url }}" class="product-card-featured-media product-card-featured-media-link relative flex min-h-56 items-center justify-center overflow-hidden border-b border-slate-200/70 bg-white no-underline" aria-label="View {{ product.title | default: 'product' }}">
        {% assign second_image = product.images[1] %}
        <div class="card-img-wrap aspect-card w-full{% if second_image != blank %} has-rollover{% endif %}">
          {% render 'product-browse-media',
            product: product,
            context: card_context,
            variant: image_variant,
            width: 1200,
            height: 900,
            loading: card_image_loading,
            fetchpriority: card_image_fetchpriority,
            class: 'card-img card-img--primary product-card-image product-card-featured-image aspect-card w-full object-contain'
          %}
          {% if second_image != blank %}
            <img
              class="card-img card-img--secondary product-card-image product-card-featured-image"
              src="{{ second_image | image_url: width: 600, format: 'pjpg' }}"
              srcset="
                {{ second_image | image_url: width: 400, format: 'pjpg' }} 400w,
                {{ second_image | image_url: width: 600, format: 'pjpg' }} 600w,
                {{ second_image | image_url: width: 800, format: 'pjpg' }} 800w
              "
              sizes="(max-width: 639px) calc(50vw - 1.5rem), (max-width: 1023px) calc(33vw - 1.5rem), calc(25vw - 1.5rem)"
              alt="{{ second_image.alt | default: product.title | escape }} — alternate view"
              width="{{ second_image.width }}"
              height="{{ second_image.height }}"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            >
          {% endif %}
        </div>
        {% if product_badge_codes != blank %}
          {% assign product_badge_list = product_badge_codes | split: ',' %}
          <div class="product-badges" aria-label="Product features">
            {% for badge in product_badge_list limit: 3 %}
              {% unless badge == blank %}
                {% case badge %}
                  {% when 'soldout' %}
                    <span class="product-badge product-badge--soldout">Sold out</span>
                  {% when 'sale' %}
                    {% assign discount_pct = product.compare_at_price_max | minus: product.price | times: 100 | divided_by: product.compare_at_price_max %}
                    <span class="product-badge product-badge--sale">-{{ discount_pct }}%</span>
                  {% when 'bestseller' %}
                    <span class="product-badge product-badge--best">Best seller</span>
                  {% when 'new' %}
                    <span class="product-badge product-badge--new">New</span>
                  {% when 'usb4' %}
                    <span class="product-badge product-badge--tech">USB4</span>
                  {% when 'thunderbolt' %}
                    <span class="product-badge product-badge--tech">Thunderbolt</span>
                  {% when 'gan' %}
                    <span class="product-badge product-badge--tech">GaN</span>
                  {% when 'duraguard' %}
                    <span class="product-badge product-badge--tech">DuraGuard</span>
                  {% when 'dual-display' %}
                    <span class="product-badge product-badge--tech">Dual 4K</span>
                  {% when 'highwatt' %}
                    <span class="product-badge product-badge--tech">100W+</span>
                {% endcase %}
              {% endunless %}
            {% endfor %}
          </div>
        {% endif %}
      </a>

      {% if product != blank %}
        {% unless product.has_only_default_variant %}
          <a href="{{ product_card_url }}"
             class="quick-add-btn quick-add-btn--options"
             aria-label="View options for {{ product.title | escape }}">
            View options
          </a>
        {% else %}
          <button
            type="button"
            class="quick-add-btn quick-add-btn--atc"
            data-quick-add-id="{{ product.selected_or_first_available_variant.id }}"
            data-quick-add-title="{{ product.title | escape }}"
            aria-label="Add {{ product.title | escape }} to cart">
            <svg width="16" height="16" viewBox="0 0 16 16"
                 fill="none" aria-hidden="true">
              <path d="M8 2v12M2 8h12"
                    stroke="currentColor" stroke-width="1.5"
                    stroke-linecap="round"/>
            </svg>
            <span>Add to cart</span>
          </button>
        {% endunless %}
      {% endif %}

      <div class="product-card__wishlist">
        {% render 'wishlist-button',
          product_id: product.id,
          product_title: product.title,
          product_url: product.url,
          product_image: product.featured_image,
          product_price: product.price
        %}
      </div>

      <button type="button" class="cmp-toggle" data-compare-toggle data-compare-handle="{{ product.handle }}" aria-pressed="false" aria-label="Add {{ product.title | escape }} to comparison">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
        <span data-compare-label>Compare</span>
      </button>

      {% if show_media_dots %}
        <div class="product-card-featured-indicators" aria-hidden="true">
          {% for i in (1..media_dot_count) %}
            <span class="product-card-featured-indicator{% if forloop.first %} is-active{% endif %}"></span>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-card-featured-body flex flex-1 flex-col gap-3 px-4 pb-4 pt-3 lg:px-5">
      <div class="product-card-featured-copy grid gap-1.5">
        {% if show_product_eyebrow and product_eyebrow != blank %}
          <p class="product-card-featured-vendor">{{ product_eyebrow }}</p>
        {% endif %}

        <div class="product-card-featured-title-price-row flex items-start justify-between gap-3">
          <h3 class="card-title product-card-featured-title">
            <a href="{{ product_card_url }}" class="product-card-featured-title-link">{{ product.title | default: 'EZQuest connectivity essential' }}</a>
          </h3>
          <div class="product-card-featured-price">
            {% render 'price', product: product, show_promo_note: false %}
          </div>
        </div>

        {%- comment -%} Key stat pill — first highlight only {%- endcomment -%}
        {%- assign first_highlight = product.metafields.ezquest.highlights.value | first -%}
        {% if first_highlight != blank %}
          <span class="product-card__stat-pill">{{ first_highlight }}</span>
        {% endif %}

        {% if show_swatches and swatch_values != blank and swatch_values.size > 0 %}
          <div class="product-card-featured-swatches flex flex-wrap items-center gap-1.5" role="img" aria-label="Available finishes">
            {% for swatch_value in swatch_values limit: swatch_limit %}
              <span
                class="product-card-featured-swatch product-card-featured-swatch--{{ swatch_value | handleize }}"
                title="{{ swatch_value }}"
                aria-hidden="true"
              ></span>
            {% endfor %}
            {% if swatch_overflow > 0 %}
              <span class="product-card-featured-swatch-count">+{{ swatch_overflow }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if show_footer_quick_add and show_quick_add %}
        <div class="product-card-featured-footer mt-auto pt-3">
          {% form 'product', product, class: 'product-card-featured-add-form product-card-featured-add-form--footer' %}
            <input type="hidden" name="id" value="{{ selected_variant.id }}">
            {% render 'button', label: quick_add_label, tag: 'button', type: 'submit', style: 'primary', class: 'product-card-featured-footer-cta', attributes: quick_add_attributes %}
          {% endform %}
        </div>
      {% endif %}
    </div>
  </article>
{% else %}
<article class="product-card product-card-tile product-card-tile--{{ card_context | handleize }} flex h-full flex-col">

  {%- comment -%} ── Image wrapper ── {%- endcomment -%}
  {% if product != blank %}
    <div class="product-thumb-card product-card-image-wrapper relative overflow-hidden">
      <a href="{{ product_card_url }}" class="product-card-image-link" aria-label="{{ product.title }}">
        {% assign second_image = product.images[1] %}
        <div class="card-img-wrap aspect-card w-full{% if second_image != blank %} has-rollover{% endif %}">
          {% render 'product-browse-media',
            product: product,
            context: card_context,
            variant: image_variant,
            width: 900,
            height: 675,
            loading: card_image_loading,
            fetchpriority: card_image_fetchpriority,
            class: 'card-img card-img--primary product-card-image aspect-card w-full object-contain'
          %}
          {% if second_image != blank %}
            <img
              class="card-img card-img--secondary product-card-image"
              src="{{ second_image | image_url: width: 600, format: 'pjpg' }}"
              srcset="
                {{ second_image | image_url: width: 400, format: 'pjpg' }} 400w,
                {{ second_image | image_url: width: 600, format: 'pjpg' }} 600w,
                {{ second_image | image_url: width: 800, format: 'pjpg' }} 800w
              "
              sizes="(max-width: 639px) calc(50vw - 1.5rem), (max-width: 1023px) calc(33vw - 1.5rem), calc(25vw - 1.5rem)"
              alt="{{ second_image.alt | default: product.title | escape }} — alternate view"
              width="{{ second_image.width }}"
              height="{{ second_image.height }}"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            >
          {% endif %}
        </div>
      </a>
      {% if product_badge_codes != blank %}
        {% assign product_badge_list = product_badge_codes | split: ',' %}
        <div class="product-badges" aria-label="Product features">
          {% for badge in product_badge_list limit: 3 %}
            {% unless badge == blank %}
              {% case badge %}
                {% when 'soldout' %}
                  <span class="product-badge product-badge--soldout">Sold out</span>
                {% when 'sale' %}
                  {% assign discount_pct = product.compare_at_price_max | minus: product.price | times: 100 | divided_by: product.compare_at_price_max %}
                  <span class="product-badge product-badge--sale">-{{ discount_pct }}%</span>
                {% when 'bestseller' %}
                  <span class="product-badge product-badge--best">Best seller</span>
                {% when 'new' %}
                  <span class="product-badge product-badge--new">New</span>
                {% when 'usb4' %}
                  <span class="product-badge product-badge--tech">USB4</span>
                {% when 'thunderbolt' %}
                  <span class="product-badge product-badge--tech">Thunderbolt</span>
                {% when 'gan' %}
                  <span class="product-badge product-badge--tech">GaN</span>
                {% when 'duraguard' %}
                  <span class="product-badge product-badge--tech">DuraGuard</span>
                {% when 'dual-display' %}
                  <span class="product-badge product-badge--tech">Dual 4K</span>
                {% when 'highwatt' %}
                  <span class="product-badge product-badge--tech">100W+</span>
              {% endcase %}
            {% endunless %}
          {% endfor %}
        </div>
      {% endif %}
      <button type="button"
              class="qv-trigger"
              data-quick-view="{{ product.handle }}"
              aria-label="Quick view {{ product.title | escape }}">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="2.5" stroke="currentColor" stroke-width="1.25"/>
          <path d="M1 6s2-4 5-4 5 4 5 4-2 4-5 4-5-4-5-4z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
        </svg>
        Quick view
      </button>
      {% unless product.has_only_default_variant %}
        <a href="{{ product_card_url }}"
           class="quick-add-btn quick-add-btn--options"
           aria-label="View options for {{ product.title | escape }}">
          View options
        </a>
      {% else %}
        <button
          type="button"
          class="quick-add-btn quick-add-btn--atc"
          data-quick-add-id="{{ product.selected_or_first_available_variant.id }}"
          data-quick-add-title="{{ product.title | escape }}"
          aria-label="Add {{ product.title | escape }} to cart">
          <svg width="16" height="16" viewBox="0 0 16 16"
               fill="none" aria-hidden="true">
            <path d="M8 2v12M2 8h12"
                  stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round"/>
          </svg>
          <span>Add to cart</span>
        </button>
      {% endunless %}
    </div>
  {% else %}
    <div class="product-thumb-card product-card-image-wrapper">
      {% render 'owned-product-visual',
        product_handle: product.handle,
        product_title: product.title | default: 'EZQuest connectivity essential',
        variant: image_variant,
        kind: 'product',
        width: 900,
        height: 675,
        class: 'product-card-image aspect-card w-full object-cover'
      %}
    </div>
  {% endif %}

  {%- comment -%} ── Info row: title left, price right ── {%- endcomment -%}
  <div class="product-card-info mt-3 flex items-start justify-between gap-3">
    <h3 class="product-card-title">
      {% if product != blank %}
        <a href="{{ product_card_url }}" class="product-card-title-link">{{ product.title }}</a>
      {% else %}
        EZQuest connectivity essential
      {% endif %}
    </h3>
    <div class="product-card-price">
      {% render 'price', product: product %}
    </div>
  </div>

  {%- comment -%} Key stat pill — first highlight only {%- endcomment -%}
  {%- assign first_highlight = product.metafields.ezquest.highlights.value | first -%}
  {% if first_highlight != blank %}
    <span class="product-card__stat-pill">{{ first_highlight }}</span>
  {% endif %}

  {% if product != blank %}
    <a href="{{ product_card_url }}" class="product-card-mobile-cta button-secondary">View product</a>
  {% endif %}

</article>
{% endif %}
