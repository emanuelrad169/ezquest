<article class="feature-card h-full">
  {% if product != blank and product.featured_image != blank %}
    <div class="relative">
      {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'aspect-[4/3] w-full rounded-2xl object-cover' }}
      {% if product.available == false %}
        <span class="absolute left-4 top-4 rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-900">Sold out</span>
      {% elsif product.compare_at_price_max > product.price %}
        <span class="absolute left-4 top-4 rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-900">On sale</span>
      {% endif %}
    </div>
  {% else %}
    <div class="aspect-[4/3] rounded-2xl bg-slate-100"></div>
  {% endif %}
  <div class="mt-5 flex items-center justify-between gap-3">
    {% if product != blank and product.vendor != blank %}
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-500">{{ product.vendor }}</p>
    {% else %}
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Product</p>
    {% endif %}
    {% if product != blank and product.type != blank %}
      <span class="text-xs text-slate-400">{{ product.type }}</span>
    {% endif %}
  </div>
  <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">
    {% if product != blank %}
      <a href="{{ product.url }}">{{ product.title }}</a>
    {% else %}
      Product card
    {% endif %}
  </h3>
  <p class="mt-2 text-sm text-slate-600">
    {% if description != blank %}
      {{ description }}
    {% elsif product != blank and product.description != blank %}
      {{ product.description | strip_html | truncatewords: 18 }}
    {% else %}
      Reserved for product summary content and merchandising hierarchy.
    {% endif %}
  </p>
  <div class="mt-4">
    {% render 'price', product: product %}
  </div>
  {% if product != blank %}
    <div class="mt-5">
      {% render 'button', label: 'View details', url: product.url, style: 'secondary' %}
    </div>
  {% endif %}
</article>
