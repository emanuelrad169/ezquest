{% comment %} snippets/cart-drawer-footer.liquid {% endcomment %}
{% assign free_shipping_threshold = 100 %}
{% assign cart_dollars = cart.total_price | divided_by: 100.0 %}
{% assign remaining = free_shipping_threshold | minus: cart_dollars %}

{% if remaining > 0 %}
  {%- assign shipping_amount = remaining | round: 2 | prepend: '$' -%}
  <div class="cart-shipping-bar">
    <p class="cart-shipping-bar__label">
      {{ 'cart.free_shipping_threshold' | t: amount: shipping_amount }}
    </p>
    <div class="cart-shipping-bar__track"
         role="progressbar"
         aria-valuenow="{{ cart_dollars | divided_by: free_shipping_threshold | times: 100 | round }}"
         aria-valuemin="0"
         aria-valuemax="100"
         aria-label="Free shipping progress">
      <div
        class="cart-shipping-bar__fill"
        style="width: {{ cart_dollars | divided_by: free_shipping_threshold | times: 100 | at_most: 100 }}%"
      ></div>
    </div>
  </div>
{% else %}
  <div class="cart-shipping-bar cart-shipping-bar--unlocked">
    <p class="cart-shipping-bar__label">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" style="display:inline;vertical-align:-2px;margin-right:4px">
        <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.25"/>
        <path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {{ 'cart.free_shipping_unlocked' | t }}
    </p>
  </div>
{% endif %}

<div class="cart-drawer__subtotal">
  <span class="cart-drawer__subtotal-label">{{ 'cart.subtotal' | t }}</span>
  <span class="cart-drawer__subtotal-amount" id="cart-drawer-subtotal">{{ cart.total_price | money }}</span>
</div>

<p class="cart-drawer__tax-note">{{ 'cart.tax_note' | t }}</p>

{% render 'cart-gift-message', id: 'cart-drawer-gift-message' %}

{% render 'cart-trust-strip' %}

<a
  href="/checkout"
  class="btn btn--primary cart-drawer__checkout"
>
  {{ 'cart.checkout' | t }}
</a>

<button class="cart-drawer__continue" data-cart-continue type="button">
  {{ 'cart.continue_shopping' | t }}
</button>
