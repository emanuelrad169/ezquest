<div class="resource-card" {% if attributes != blank %}{{ attributes }}{% endif %}>
  <div class="resource-card-layout">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-center gap-3">
        {% if meta != blank %}
          <p class="section-kicker">{{ meta }}</p>
        {% endif %}
        {% if context != blank %}
          <span class="text-xs uppercase tracking-wide text-slate-400">{{ context }}</span>
        {% endif %}
      </div>
      <h3 class="card-title mt-4">{{ title }}</h3>
      {% if copy != blank %}
        <p class="mt-3 text-sm leading-7 text-slate-600">{{ copy }}</p>
      {% endif %}
      {% if secondary_context != blank %}
        <div class="resource-card-context">{{ secondary_context }}</div>
      {% endif %}
    </div>
    <div class="shrink-0 lg:pl-4">
      {% if url != blank %}
        {% render 'button', label: label, url: url, style: 'secondary' %}
      {% endif %}
      <p class="mt-3 max-w-copy-sm text-xs font-medium uppercase tracking-wide text-slate-400">Open the resource, then move on only if you still need help</p>
    </div>
  </div>
</div>
