<div class="resource-card" {% if attributes != blank %}{{ attributes }}{% endif %}>
  <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-center gap-3">
        {% if meta != blank %}
          <p class="section-kicker">{{ meta }}</p>
        {% endif %}
        {% if context != blank %}
          <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{{ context }}</span>
        {% endif %}
      </div>
      <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">{{ title }}</h3>
      {% if copy != blank %}
        <p class="mt-3 text-sm leading-7 text-slate-600">{{ copy }}</p>
      {% endif %}
      {% if secondary_context != blank %}
        <div class="mt-4 inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{{ secondary_context }}</div>
      {% endif %}
    </div>
    {% if url != blank %}
      <div class="shrink-0">
        {% render 'button', label: label, url: url, style: 'secondary' %}
      </div>
    {% endif %}
  </div>
</div>
