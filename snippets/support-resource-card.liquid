<div class="resource-card" {% if attributes != blank %}{{ attributes }}{% endif %}>
  <div class="resource-card-layout">
    <div class="max-w-3xl">
      <div class="resource-card-meta-row">
        {% if meta != blank %}
          <p class="section-kicker">{{ meta }}</p>
        {% endif %}
        {% if context != blank %}
          <span class="text-xs uppercase tracking-wide text-slate-400">{{ context }}</span>
        {% endif %}
      </div>
      <h3 class="card-title resource-card-title mt-4">{{ title }}</h3>
      {% if copy != blank %}
        <p class="resource-card-copy mt-3 text-sm leading-7 text-slate-600">{{ copy }}</p>
      {% endif %}
      {% if secondary_context != blank %}
        <div class="resource-card-context-stack">
          <span class="resource-card-context-label">Best for</span>
          <div class="resource-card-context">{{ secondary_context }}</div>
        </div>
      {% endif %}
    </div>
    <div class="resource-card-action">
      {% if url != blank %}
        {% render 'button', label: label, url: url, style: 'secondary' %}
      {% endif %}
      <p class="resource-card-note">Start here, then contact support only if the setup still needs a clearer answer.</p>
    </div>
  </div>
</div>
