{{ 'pages.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign cta_variant = variant | default: 'light'
-%}
<section class="page-cta page-cta--{{ cta_variant }}"{% if aria_label != blank %} aria-label="{{ aria_label | escape }}"{% endif %}>
  <div class="page-cta__inner container-shell">
    <div class="page-cta__copy">
      {%- if kicker != blank -%}
        <p class="page-cta__kicker">{{ kicker }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
        <p class="page-cta__heading">{{ heading }}</p>
      {%- endif -%}
      {%- if subhead != blank -%}
        <p class="page-cta__sub">{{ subhead }}</p>
      {%- endif -%}
    </div>
    {%- if primary_label != blank or secondary_label != blank -%}
      <div class="page-cta__actions">
        {%- if primary_label != blank -%}
          <a href="{{ primary_url | default: '#' }}" class="btn btn--primary">
            {{ primary_label }}
            {%- render 'icon', name: 'arrow-right', size: 16 -%}
          </a>
        {%- endif -%}
        {%- if secondary_label != blank -%}
          <a href="{{ secondary_url | default: '#' }}" class="btn btn--secondary">
            {{ secondary_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>
