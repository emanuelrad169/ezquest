<div class="site-mega-panel grid gap-6 py-6 lg:grid-cols-[1.1fr_0.9fr]">
  <div class="rounded-3xl border border-slate-200 bg-white p-6">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Browse</p>
    {% if menu != blank %}
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {% for link in menu.links %}
          <a href="{{ link.url }}" class="rounded-2xl border border-slate-200 p-4 transition hover:border-slate-400">
            <div class="text-base font-semibold text-slate-900">{{ link.title }}</div>
            {% if link.links.size > 0 %}
              <div class="mt-2 text-sm text-slate-500">
                {% for child_link in link.links limit: 3 %}
                  <span>{{ child_link.title }}{% unless forloop.last %} · {% endunless %}</span>
                {% endfor %}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="rounded-3xl border border-slate-200 bg-slate-50 p-5 transition hover:border-slate-400" {{ block.shopify_attributes }}>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{{ block.settings.eyebrow }}</p>
        <h3 class="mt-3 text-lg font-semibold text-slate-900">{{ block.settings.title }}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-600">{{ block.settings.copy }}</p>
      </a>
    {% endfor %}
  </div>
</div>
