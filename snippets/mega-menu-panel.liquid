{%- liquid
  assign group_handle = group_handle | default: 'shop'

  assign hub_product = all_products['usb-c-multimedia-hub']
  assign dock_product = all_products['usb-c-pro-dock']
  assign travel_product = all_products['usb-c-travel-hub']

  assign hubs_collection = collections['hubs-adapters']
  assign docks_collection = collections['docking-stations']
  assign power_collection = collections['chargers-power']

  assign sorted_use_case_keys = '' | split: ''

  if metaobjects.ezquest_use_case != blank
    capture sorted_use_cases_raw
      for use_case in metaobjects.ezquest_use_case.values
        capture order_token_raw
          echo '000000'
          echo use_case.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo use_case.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_use_case_keys = sorted_use_cases_raw | split: '||' | sort_natural
  endif
-%}
<section
  id="mega-menu-panel-{{ group_handle }}"
  class="mega-menu-panel mega-menu-panel--{{ group_handle }}"
  data-mega-panel="{{ group_handle }}"
  hidden
>
  {% case group_handle %}
    {% when 'shop' %}
      <div class="mega-menu-panel-surface rounded-shell bg-white p-4 shadow-lift lg:p-5">
        <div class="grid gap-5 lg:grid-cols-12" data-mega-stage-root>
          <aside class="mega-menu-panel-aside flex flex-col gap-3 rounded-card-sm border border-slate-200 bg-slate-50 p-3 lg:col-span-3">
            <p class="mega-menu-side-label">Shop by setup</p>

            <div class="grid gap-1" role="tablist" aria-label="Shop by setup">
              {% if sorted_use_case_keys.size > 0 %}
                {% for use_case_key in sorted_use_case_keys %}
                  {% if use_case_key == blank %}
                    {% continue %}
                  {% endif %}
                  {% assign use_case_handle = use_case_key | split: '::' | last %}
                  {% assign use_case = metaobjects.ezquest_use_case[use_case_handle] %}
                  {% if use_case == blank or use_case.title == blank or use_case.products == blank or use_case.products.value.count == 0 %}
                    {% continue %}
                  {% endif %}
                  <button
                    type="button"
                    class="mega-menu-editorial-rail-item setup-tab{% if forloop.first %} is-active{% endif %}"
                    data-mega-stage-target="shop-{{ use_case.system.handle }}"
                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  >
                    <div class="setup-tab__icon">
                      {% case use_case.system.handle %}
                        {% when 'balanced-everyday' %}
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="1" y="3" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                            <path d="M4 12v1.5M8 12v1.5M12 12v1.5M1 7h14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                          </svg>
                        {% when 'portable' %}
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="3" y="5" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                            <path d="M6 5V4a2 2 0 014 0v1" stroke="currentColor" stroke-width="1.25"/>
                          </svg>
                        {% when 'desk-ready' %}
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="2" y="4" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                            <path d="M5 12v2M11 12v2M2 7h12" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                          </svg>
                        {% when 'chargers-power' %}
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <path d="M8 2v4l2.5 1L8 14v-4L5.5 9 8 2z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        {% else %}
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                            <rect x="2" y="4" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                          </svg>
                      {% endcase %}
                    </div>
                    <span class="setup-tab__label">{{ use_case.title.value }}</span>
                  </button>
                {% endfor %}
              {% endif %}
            </div>

            <a href="/pages/help-me-choose" class="mega-menu-rail-link">Open setup guide</a>
          </aside>

          <div class="grid lg:col-span-9">
            {% if sorted_use_case_keys.size > 0 %}
              {% for use_case_key in sorted_use_case_keys %}
                {% if use_case_key == blank %}
                  {% continue %}
                {% endif %}
                {% assign use_case_handle = use_case_key | split: '::' | last %}
                {% assign use_case = metaobjects.ezquest_use_case[use_case_handle] %}
                {% if use_case == blank or use_case.title == blank or use_case.products == blank or use_case.products.value.count == 0 %}
                  {% continue %}
                {% endif %}
                {%- liquid
                  assign use_case_slug = use_case.slug.value | default: use_case.system.handle
                  assign use_case_description = use_case.description.value | default: blank
                  assign use_case_destination_url = blank
                  assign use_case_destination_label = 'Start with the recommended pick'
                  assign use_case_best_for = 'Everyday'
                  if use_case.products.value.first != blank
                    assign use_case_destination_url = use_case.products.value.first.url
                  endif
                  case use_case_slug
                    when 'balanced-everyday'
                      assign use_case_destination_url = hubs_collection.url
                      assign use_case_destination_label = 'Shop balanced setups'
                      assign use_case_best_for = 'Balanced desks'
                    when 'portable'
                      assign use_case_destination_url = hubs_collection.url
                      assign use_case_destination_label = 'Shop travel setups'
                      assign use_case_best_for = 'Travel kits'
                    when 'desk-ready'
                      assign use_case_destination_url = docks_collection.url
                      assign use_case_destination_label = 'See desk-ready docks'
                      assign use_case_best_for = 'Desk setups'
                    when 'chargers-power'
                      assign use_case_destination_url = power_collection.url
                      assign use_case_destination_label = 'Shop charging setups'
                      assign use_case_best_for = 'Charging'
                  endcase
                  if use_case_description == blank
                    assign use_case_description = 'Start with the setup path built for ' | append: use_case.title.value | downcase | append: '.'
                  endif
                -%}
                <section class="mega-menu-stage-panel{% if forloop.first %} is-active{% endif %} grid content-start gap-4 rounded-card-sm border border-slate-200 bg-white p-4 lg:p-5" data-mega-stage-panel="shop-{{ use_case.system.handle }}"{% unless forloop.first %} hidden{% endunless %}>
                  <div class="mega-menu-stage-head">
                    <div class="grid gap-1">
                      <p class="section-kicker text-slate-500">Start here</p>
                      <h2 class="mega-menu-stage-title">{{ use_case.title.value }}</h2>
                      <p class="type-body max-w-2xl">{{ use_case_description }}</p>
                    </div>
                  </div>

                  <div class="grid gap-3 lg:grid-cols-2">
                    {% for product in use_case.products.value limit: 2 %}
                      {%- liquid
                        assign stage_card_class = ''
                        assign stage_card_eyebrow = blank
                        if forloop.first
                          assign stage_card_class = 'mega-menu-stage-card--priority'
                          assign stage_card_eyebrow = use_case_best_for
                        endif
                      -%}
                      {% render 'mega-menu-stage-card',
                        product: product,
                        card_layout: 'showcase',
                        card_class: stage_card_class,
                        eyebrow: stage_card_eyebrow,
                        show_descriptor: false,
                        show_price: false
                      %}
                    {% endfor %}
                  </div>

                  <div class="flex flex-wrap items-center gap-3 pt-0.5">
                    <a href="{{ use_case_destination_url | default: '/pages/help-me-choose' }}" class="button-tertiary mega-menu-stage-view-all">{{ use_case_destination_label }}</a>
                    <a href="/pages/help-me-choose" class="site-meta-link">Need a second opinion?</a>
                  </div>
                </section>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>

    {% when 'collections' %}
      <div class="mega-menu-panel-surface rounded-shell bg-white p-4 shadow-lift lg:p-5">
        <div class="mega-menu-inner">

          <p class="mega-menu-kicker">Shop by Collections</p>

          <div class="mega-menu-grid">

            {% comment %} ── Column 1: USB-C ── {% endcomment %}
            <div class="mega-col">
              <div class="mega-col__header">
                <div class="mega-col__icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <rect x="2" y="5" width="14" height="9" rx="2.5" stroke="currentColor" stroke-width="1.25"/>
                    <path d="M5.5 5V3.5M9 5V3.5M12.5 5V3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                    <path d="M5.5 10h7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                  </svg>
                </div>
                <span class="mega-col__title">USB-C</span>
              </div>
              <nav class="mega-col__links">
                <a href="{{ collections['hubs-adapters'].url }}" class="mega-col__link">
                  <span>Hubs</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=Cable" class="mega-col__link">
                  <span>Cables</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=Adapter" class="mega-col__link">
                  <span>Adapters</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=Card+Reader" class="mega-col__link">
                  <span>Card Readers</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=Enclosure" class="mega-col__link">
                  <span>Enclosure</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </nav>
            </div>

            {% comment %} ── Column 2: Cables & Adapters ── {% endcomment %}
            <div class="mega-col">
              <div class="mega-col__header">
                <div class="mega-col__icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M3 9h12M3 9l3-3M3 9l3 3M15 9l-3-3M15 9l-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="mega-col__title">Cables &amp; Adapters</span>
              </div>
              <nav class="mega-col__links">
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=HDMI" class="mega-col__link">
                  <span>HDMI</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=DisplayPort" class="mega-col__link">
                  <span>DisplayPort</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=Mini+DisplayPort" class="mega-col__link">
                  <span>Mini DisplayPort</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['accessories'].url }}?filter.p.product_type=Audio" class="mega-col__link">
                  <span>Audio</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </nav>
            </div>

            {% comment %} ── Column 3: Power ── {% endcomment %}
            <div class="mega-col">
              <div class="mega-col__header">
                <div class="mega-col__icon">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M9 2v5l3 1-3 8v-5L6 10l3-8z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="mega-col__title">Power</span>
              </div>
              <nav class="mega-col__links">
                <a href="{{ collections['chargers-power'].url }}?filter.p.product_type=Wall+Charger" class="mega-col__link">
                  <span>Wall Charger</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="{{ collections['chargers-power'].url }}?filter.p.product_type=Car+Charger" class="mega-col__link">
                  <span>Car Charger</span>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M4.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </nav>
            </div>

          </div>

          {% comment %} ── Footer strip ── {% endcomment %}
          <div class="mega-menu-footer">
            <span class="mega-menu-footer__text">Browse all product families</span>
            <a href="{{ routes.collections_url }}" class="mega-menu-footer__link">View all →</a>
          </div>

        </div>
      </div>

    {% when 'compare' %}
      <div class="mega-menu-panel-surface mega-menu-panel-surface--editorial">
        <div class="mega-menu-editorial-shell" data-mega-stage-root>
          <aside class="mega-menu-editorial-rail">
            <p class="mega-menu-side-label">Compare</p>

            <div class="mega-menu-editorial-rail-list" role="tablist" aria-label="Compare by role">
              <button type="button" class="mega-menu-editorial-rail-item is-active" data-mega-stage-target="compare-balanced" aria-selected="true">
                <span>Balanced</span>
              </button>
              <button type="button" class="mega-menu-editorial-rail-item" data-mega-stage-target="compare-portable" aria-selected="false">
                <span>Portable</span>
              </button>
              <button type="button" class="mega-menu-editorial-rail-item" data-mega-stage-target="compare-desk" aria-selected="false">
                <span>Desk</span>
              </button>
            </div>
          </aside>

          <div class="mega-menu-editorial-stage">
            <section class="mega-menu-stage-panel is-active" data-mega-stage-panel="compare-balanced">
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Balanced</h2>
                </div>
              </div>
              <div class="mega-menu-stage-grid mega-menu-stage-grid--products">
                {% if hub_product != blank %}
                  {% render 'mega-menu-stage-card',
                    product: hub_product,
                    card_class: 'mega-menu-stage-card--priority',
                    eyebrow: 'Balanced desks',
                    show_descriptor: true
                  %}
                {% endif %}
                {% if travel_product != blank %}
                  {% render 'mega-menu-stage-card',
                    product: travel_product,
                    show_descriptor: false
                  %}
                {% endif %}
              </div>
              <div class="mega-menu-stage-footer">
                <a href="/pages/compare" class="button-tertiary mega-menu-stage-view-all">Compare lineup</a>
              </div>
            </section>

            <section class="mega-menu-stage-panel" data-mega-stage-panel="compare-portable" hidden>
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Portable</h2>
                </div>
              </div>
              <div class="mega-menu-stage-grid mega-menu-stage-grid--products">
                {% if travel_product != blank %}
                  {% render 'mega-menu-stage-card',
                    product: travel_product,
                    card_class: 'mega-menu-stage-card--priority',
                    eyebrow: 'Travel kits',
                    show_descriptor: true
                  %}
                {% endif %}
                {% if hub_product != blank %}
                  {% render 'mega-menu-stage-card',
                    product: hub_product,
                    show_descriptor: false
                  %}
                {% endif %}
              </div>
              <div class="mega-menu-stage-footer">
                <a href="/pages/compare" class="button-tertiary mega-menu-stage-view-all">Compare options</a>
              </div>
            </section>

            <section class="mega-menu-stage-panel" data-mega-stage-panel="compare-desk" hidden>
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Desk</h2>
                </div>
              </div>
              <div class="mega-menu-stage-grid mega-menu-stage-grid--products">
                {% if dock_product != blank %}
                  {% render 'mega-menu-stage-card',
                    product: dock_product,
                    card_class: 'mega-menu-stage-card--priority',
                    eyebrow: 'Desk setups',
                    show_descriptor: true
                  %}
                {% endif %}
                {% if hub_product != blank %}
                  {% render 'mega-menu-stage-card',
                    product: hub_product,
                    show_descriptor: false
                  %}
                {% endif %}
              </div>
              <div class="mega-menu-stage-footer">
                <a href="/pages/compare" class="button-tertiary mega-menu-stage-view-all">Compare desk setups</a>
              </div>
            </section>
          </div>
        </div>
      </div>

    {% when 'explore' %}
      <div class="mega-menu-panel-surface mega-menu-panel-surface--editorial">
        <div class="mega-menu-editorial-shell" data-mega-stage-root>
          <aside class="mega-menu-editorial-rail">
            <p class="mega-menu-side-label">Support</p>

            <div class="mega-menu-editorial-rail-list" role="tablist" aria-label="Support center">
              <button type="button" class="mega-menu-editorial-rail-item is-active" data-mega-stage-target="support-self-serve" aria-selected="true">
                <span>Downloads</span>
              </button>
              <button type="button" class="mega-menu-editorial-rail-item" data-mega-stage-target="support-troubleshooting" aria-selected="false">
                <span>Troubleshooting</span>
              </button>
              <button type="button" class="mega-menu-editorial-rail-item" data-mega-stage-target="support-contact" aria-selected="false">
                <span>Direct help</span>
              </button>
            </div>
          </aside>

          <div class="mega-menu-editorial-stage">
            <section class="mega-menu-stage-panel is-active" data-mega-stage-panel="support-self-serve">
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Downloads</h2>
                </div>
              </div>
              <div class="mega-menu-stage-grid mega-menu-stage-grid--links">
                <a href="/pages/downloads" class="mega-menu-link-card mega-menu-link-card--priority card-base card-interactive"><strong>Downloads</strong><span>Drivers and utilities.</span></a>
                <a href="/pages/manuals" class="mega-menu-link-card card-base card-interactive"><strong>Manuals</strong><span>Quick starts and guides.</span></a>
                <a href="/pages/firmware" class="mega-menu-link-card card-base card-interactive"><strong>Firmware</strong><span>Product updates.</span></a>
              </div>
              <div class="mega-menu-stage-footer">
                <a href="/pages/support" class="button-tertiary mega-menu-stage-view-all">All support</a>
              </div>
            </section>

            <section class="mega-menu-stage-panel" data-mega-stage-panel="support-troubleshooting" hidden>
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Troubleshooting</h2>
                </div>
              </div>
              <div class="mega-menu-stage-grid mega-menu-stage-grid--links">
                <a href="/pages/troubleshooting" class="mega-menu-link-card mega-menu-link-card--priority card-base card-interactive"><strong>Troubleshooting</strong><span>Common fixes.</span></a>
                <a href="/pages/faq" class="mega-menu-link-card card-base card-interactive"><strong>FAQ</strong><span>Fast answers.</span></a>
                <a href="/pages/contact" class="mega-menu-link-card card-base card-interactive"><strong>Contact support</strong><span>Reach the team.</span></a>
              </div>
              <div class="mega-menu-stage-footer">
                <a href="/pages/troubleshooting" class="button-tertiary mega-menu-stage-view-all">Open troubleshooting</a>
              </div>
            </section>

            <section class="mega-menu-stage-panel" data-mega-stage-panel="support-contact" hidden>
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Direct help</h2>
                </div>
              </div>
              <div class="mega-menu-stage-grid mega-menu-stage-grid--links">
                <a href="/pages/contact" class="mega-menu-link-card mega-menu-link-card--priority card-base card-interactive"><strong>Start support</strong><span>Setup-specific help.</span></a>
                <a href="/pages/shipping-returns" class="mega-menu-link-card card-base card-interactive"><strong>Order help</strong><span>Shipping and returns.</span></a>
                <a href="/pages/warranty" class="mega-menu-link-card card-base card-interactive"><strong>Warranty</strong><span>Coverage and claims.</span></a>
              </div>
              <div class="mega-menu-stage-footer">
                <a href="/pages/contact" class="button-tertiary mega-menu-stage-view-all">Start support request</a>
              </div>
            </section>
          </div>
        </div>
      </div>

    {% when 'resources' %}
      <div class="mega-menu-panel-surface mega-menu-panel-surface--editorial">
        <div class="mega-menu-editorial-shell" data-mega-stage-root>
          <aside class="mega-menu-editorial-rail">
            <p class="mega-menu-side-label">Resources</p>

            <div class="mega-menu-editorial-rail-list" role="tablist" aria-label="Resources">
              <button type="button" class="mega-menu-editorial-rail-item is-active" data-mega-stage-target="resources-guidance" aria-selected="true">
                <span>Guidance</span>
              </button>
              <button type="button" class="mega-menu-editorial-rail-item" data-mega-stage-target="resources-policies" aria-selected="false">
                <span>Policies</span>
              </button>
              <button type="button" class="mega-menu-editorial-rail-item" data-mega-stage-target="resources-brand" aria-selected="false">
                <span>About</span>
              </button>
            </div>
          </aside>

          <div class="mega-menu-editorial-stage">
            <section class="mega-menu-stage-panel is-active" data-mega-stage-panel="resources-guidance">
              <div class="mega-menu-stage-head">
                <div>
                  <h2 class="mega-menu-stage-title">Guidance</h2>
                </div>
