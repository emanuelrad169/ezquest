<div class="site-mega-panel grid gap-6 py-6 lg:grid-cols-[1.1fr_0.9fr]">
  <div class="section-frame">
    <div class="flex items-center justify-between gap-4">
      <p class="section-kicker">Browse</p>
      <span class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Shop and support</span>
    </div>
    {% if menu != blank %}
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {% for link in menu.links %}
          <a href="{{ link.url }}" class="rounded-[1.4rem] border border-slate-200/80 bg-slate-50/90 p-5 transition hover:border-slate-300 hover:bg-white">
            <div class="text-base font-semibold tracking-[-0.02em] text-slate-950">{{ link.title }}</div>
            {% if link.links.size > 0 %}
              <div class="mt-3 text-sm leading-6 text-slate-500">
                {% for child_link in link.links limit: 3 %}
                  <span>{{ child_link.title }}{% unless forloop.last %} · {% endunless %}</span>
                {% endfor %}
              </div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="feature-card bg-gradient-to-br from-white to-slate-50" {{ block.shopify_attributes }}>
        <div class="flex items-center justify-between gap-4">
          <p class="section-kicker">{{ block.settings.eyebrow }}</p>
          <span class="text-xs uppercase tracking-[0.18em] text-slate-300">{{ forloop.index | prepend: '0' }}</span>
        </div>
        <h3 class="mt-4 text-lg font-semibold tracking-[-0.03em] text-slate-950">{{ block.settings.title }}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-600">{{ block.settings.copy }}</p>
      </a>
    {% endfor %}
  </div>
</div>
