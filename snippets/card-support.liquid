<div class="flex h-full flex-col bg-gradient-to-br from-white to-slate-50">
  <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">{{ title }}</h3>
  <p class="mt-3 grow text-sm leading-7 text-slate-600">{{ copy }}</p>
  <div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200/80 pt-5">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-slate-400">Use this route for the next best support step</p>
    {% if link_label != blank and link_url != blank %}
      {% render 'button', label: link_label, url: link_url, style: 'secondary' %}
    {% endif %}
  </div>
</div>
