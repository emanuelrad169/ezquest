{% comment %} snippets/cart-drawer.liquid {% endcomment %}
<div
  id="cart-drawer"
  class="cart-drawer"
  data-drawer
  hidden
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
>
  <div class="cart-drawer__overlay" data-drawer-close aria-hidden="true"></div>

  <div class="cart-drawer__panel" data-drawer-panel tabindex="-1">

    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        Your cart
        <span class="cart-drawer__count" id="cart-drawer-count">({{ cart.item_count }})</span>
      </h2>
      <button
        class="cart-drawer__close"
        data-drawer-close
        aria-label="Close cart"
        type="button"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__body" id="cart-drawer-body">
      {% if cart.item_count > 0 %}
        {% render 'cart-drawer-items' %}
      {% else %}
        {% render 'cart-drawer-empty' %}
      {% endif %}
    </div>

    <div class="cart-drawer__footer" id="cart-drawer-footer">
      {% if cart.item_count > 0 %}
        {% render 'cart-drawer-footer' %}
      {% endif %}
    </div>

  </div>
</div>
