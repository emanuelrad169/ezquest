{% comment %} snippets/cart-drawer-empty.liquid {% endcomment %}
<div class="cart-drawer__empty">
  <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="cart-drawer__empty-icon">
    <rect x="4" y="12" width="40" height="32" rx="4" stroke="currentColor" stroke-width="1.5"/>
    <path d="M16 12V10a8 8 0 0116 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
  <p class="cart-drawer__empty-heading">Your cart is empty</p>
  <p class="cart-drawer__empty-body">Add products to your cart to see them here.</p>
  <button class="btn btn--primary cart-drawer__empty-cta" data-cart-continue type="button">
    Continue shopping
  </button>
</div>
