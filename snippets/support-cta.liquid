{% comment %} snippets/support-cta.liquid — dark CTA banner, render at bottom of every support section {% endcomment %}
<section class="support-cta-strip" style="border-radius:0;margin:0">
  <div>
    <p class="support-cta-strip__heading">Still need help?</p>
    <p class="support-cta-strip__body">Our team responds within 1 business day.</p>
  </div>
  <div class="support-cta-strip__actions">
    <a href="/pages/contact" class="btn btn--primary" style="background:var(--ez-amber);color:var(--ez-black);">Contact support</a>
    <a href="tel:18008819305" class="btn btn--secondary" style="color:var(--ez-light);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,0.2);">1-800-881-9305</a>
  </div>
</section>
