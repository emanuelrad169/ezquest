{%- liquid
  assign sorted_setup_keys = '' | split: ''
  if metaobjects.ezquest_use_case != blank
    capture sorted_raw
      for uc in metaobjects.ezquest_use_case.values
        capture order_token_raw
          echo '000000'
          echo uc.sort_order.value | default: 999999 | plus: 0
        endcapture
        assign order_token = order_token_raw | strip | slice: -6, 6
        echo order_token
        echo '::'
        echo uc.system.handle
        echo '||'
      endfor
    endcapture
    assign sorted_setup_keys = sorted_raw | split: '||' | sort_natural
  endif
-%}
<div class="ez-mega" id="mega-setup"
     role="dialog" aria-label="Shop by Setup" hidden>
  <div class="ez-mega__spotlight" aria-hidden="true"></div>

  <div class="ez-mega__shell">

    <div class="ez-mega__rail">
      <p class="ez-mega__rail-label">By Setup</p>

      <div class="ez-mega__tabs" role="tablist">
        {% assign ez_tab_first = true %}
        {% for uc_key in sorted_setup_keys %}
          {% if uc_key == blank %}{% continue %}{% endif %}
          {% assign uc_handle = uc_key | split: '::' | last %}
          {% assign uc = metaobjects.ezquest_use_case[uc_handle] %}
          {% if uc == blank or uc.title == blank or uc.products == blank or uc.products.value.count == 0 %}{% continue %}{% endif %}
          <button
            class="ez-mega__tab{% if ez_tab_first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if ez_tab_first %}true{% else %}false{% endif %}"
            data-target="setup-{{ uc.system.handle }}"
            aria-controls="setup-{{ uc.system.handle }}"
          >
            <div class="ez-mega__tab-icon">
              {% case uc.system.handle %}
                {% when 'balanced-everyday' %}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="1" y="3" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                    <path d="M4 12v1.5M8 12v1.5M12 12v1.5M1 7h14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                  </svg>
                {% when 'portable' %}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="3" y="5" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                    <path d="M6 5V4a2 2 0 014 0v1" stroke="currentColor" stroke-width="1.25"/>
                  </svg>
                {% when 'desk-ready' %}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="4" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                    <path d="M5 12v2M11 12v2M2 7h12" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                  </svg>
                {% when 'chargers-power' %}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 2v4l2.5 1L8 14v-4L5.5 9 8 2z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% else %}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="4" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
                  </svg>
              {% endcase %}
            </div>
            <span>{{ uc.title.value }}</span>
            <svg class="ez-mega__tab-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M5 3.5l3.5 3.5L5 10.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          {% assign ez_tab_first = false %}
        {% endfor %}
      </div>
    </div>

    <div class="ez-mega__panels">
      {% assign ez_panel_first = true %}
      {% for uc_key in sorted_setup_keys %}
        {% if uc_key == blank %}{% continue %}{% endif %}
        {% assign uc_handle = uc_key | split: '::' | last %}
        {% assign uc = metaobjects.ezquest_use_case[uc_handle] %}
        {% if uc == blank or uc.title == blank or uc.products == blank or uc.products.value.count == 0 %}{% continue %}{% endif %}
        <div class="ez-mega__panel{% if ez_panel_first %} is-active{% endif %}"
             id="setup-{{ uc.system.handle }}"
             role="tabpanel"
             {% unless ez_panel_first %}hidden{% endunless %}>
          {% for product in uc.products.value limit: 8 %}
            {%- assign card_img = product.featured_image | default: product.images.first -%}
            {% if card_img == blank %}{% continue %}{% endif %}
            <a href="{{ product.url }}" class="ez-mega__card">
              <div class="ez-mega__card-img">
                <img src="{{ card_img | image_url: width: 200 }}"
                     alt="{{ product.title | escape }}"
                     width="200" height="200" loading="lazy">
              </div>
              <div class="ez-mega__card-body">
                <p class="ez-mega__card-name">{{ product.title | truncate: 50 }}</p>
                <p class="ez-mega__card-link">View product →</p>
              </div>
            </a>
          {% endfor %}
        </div>
        {% assign ez_panel_first = false %}
      {% endfor %}
    </div>
  </div>

  <div class="ez-mega__footer">
    <a href="/pages/help-me-choose" class="ez-mega__footer-link">
      Explore all setups →
    </a>
  </div>
</div>
