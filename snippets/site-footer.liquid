<footer class="site-footer" role="contentinfo">
  <div class="container-shell">

    {% comment %} TOP: 4-col link grid {% endcomment %}
    <div class="site-footer__grid">

    <div class="footer-col">
      <p class="footer-col__heading">Products</p>
      <ul class="footer-col__links">
        <li><a href="{{ routes.collections_url }}/hubs-adapters">Hubs &amp; adapters</a></li>
        <li><a href="{{ routes.collections_url }}/chargers-power">Chargers &amp; power</a></li>
        <li><a href="{{ routes.collections_url }}/accessories">Cables &amp; accessories</a></li>
        <li><a href="{{ routes.collections_url }}">View all products</a></li>
        <li><a href="/pages/help-me-choose">Setup guide</a></li>
        <li><a href="/pages/compare">Compare products</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Support</p>
      <ul class="footer-col__links">
        <li><a href="/pages/support">Support center</a></li>
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/pages/downloads">Downloads</a></li>
        <li><a href="/pages/warranty">Warranty</a></li>
        <li><a href="/pages/contact">Contact us</a></li>
        <li><a href="/pages/ticket-submission">Submit a ticket</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Company</p>
      <ul class="footer-col__links">
        <li><a href="/pages/about">About EZQuest</a></li>
        <li><a href="/pages/our-story">Our story</a></li>
        <li><a href="/pages/where-to-buy">Where to buy</a></li>
        <li><a href="/blogs/resources">Guides &amp; resources</a></li>
        <li><a href="/pages/compatibility">Compatibility</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <p class="footer-col__heading">Legal</p>
      <ul class="footer-col__links">
        <li><a href="/policies/privacy-policy">Privacy policy</a></li>
        <li><a href="/policies/terms-of-service">Terms of service</a></li>
        <li><a href="/policies/refund-policy">Refund policy</a></li>
        <li><a href="/pages/shipping-returns">Shipping &amp; returns</a></li>
        <li><a href="/pages/cookie-policy">Cookie policy</a></li>
      </ul>
    </div>

    </div>

    <div class="site-footer__divider"></div>

    {% comment %} BOTTOM: logo + social + copyright {% endcomment %}
    <div class="site-footer__bottom">

    <div class="site-footer__brand">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
        {% if settings.brand_logo != blank %}
          {{ settings.brand_logo | image_url: width: 200 | image_tag: alt: shop.name, width: 100, height: 28, loading: 'lazy' }}
        {% else %}
          <img src="{{ 'ezquest-logo.svg' | asset_url }}" alt="{{ shop.name }}" width="100" height="28" loading="lazy">
        {% endif %}
      </a>
      <p class="site-footer__tagline">Premium Digital Life Accessories</p>
    </div>

    <div class="site-footer__social">
      <a href="https://www.facebook.com/EZQuestInc/" aria-label="EZQuest on Facebook" class="footer-social-link" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/ezquestinc/" aria-label="EZQuest on Instagram" class="footer-social-link" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
