{%- liquid
  assign support_menu = section.settings.support_menu | default: settings.footer_menu_support
  assign company_menu = section.settings.company_menu | default: settings.footer_menu_company
  assign newsletter_heading = section.settings.newsletter_heading | default: settings.footer_newsletter_heading
-%}
<footer class="site-footer border-t border-slate-200 bg-slate-50" role="contentinfo">
  <div class="container-shell grid gap-10 py-12 lg:grid-cols-[1.2fr_0.9fr_0.9fr_1.2fr]">
    <div>
      <h2 class="text-xl font-semibold">{{ shop.name }}</h2>
      <p class="mt-3 max-w-md text-sm text-slate-600">{{ settings.brand_tagline }}</p>
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">{{ section.settings.support_heading }}</h3>
      {% if support_menu != blank %}
        <ul class="mt-4 space-y-3 text-sm text-slate-700">
          {% for link in support_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">{{ section.settings.company_heading }}</h3>
      {% if company_menu != blank %}
        <ul class="mt-4 space-y-3 text-sm text-slate-700">
          {% for link in company_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">{{ newsletter_heading }}</h3>
      <p class="mt-4 text-sm text-slate-600">Newsletter signup and lifecycle integrations can be connected in a later implementation pass.</p>
    </div>
  </div>
  <div class="border-t border-slate-200">
    <div class="container-shell py-5 text-sm text-slate-500">
      {{ section.settings.bottom_text }}
    </div>
  </div>
</footer>
