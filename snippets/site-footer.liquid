{%- liquid
  assign support_menu = section.settings.support_menu | default: settings.footer_menu_support
  assign company_menu = section.settings.company_menu | default: settings.footer_menu_company
  assign newsletter_heading = section.settings.newsletter_heading | default: settings.footer_newsletter_heading
-%}
<footer class="site-footer" role="contentinfo">
  <div class="container-shell">
    <div class="site-footer-shell">
      <div class="max-w-md">
        <p class="section-kicker text-slate-400">Connectivity platform</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-[-0.04em] text-white">{{ shop.name }}</h2>
        <p class="mt-4 text-sm leading-7 text-slate-400">{{ settings.brand_tagline }}</p>
        {% if settings.support_contact_url != blank %}
          <div class="mt-6">
            <a href="{{ settings.support_contact_url }}" class="inline-flex min-h-11 items-center justify-center rounded-full border border-slate-700 bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:border-slate-600 hover:bg-slate-800">
              Contact support
            </a>
          </div>
        {% endif %}
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">{{ section.settings.support_heading }}</h3>
        {% if support_menu != blank %}
          <ul class="mt-5 space-y-3 text-sm text-slate-300">
            {% for link in support_menu.links %}
              <li><a href="{{ link.url }}" class="transition hover:text-white">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">{{ section.settings.company_heading }}</h3>
        {% if company_menu != blank %}
          <ul class="mt-5 space-y-3 text-sm text-slate-300">
            {% for link in company_menu.links %}
              <li><a href="{{ link.url }}" class="transition hover:text-white">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div class="rounded-[1.8rem] border border-slate-800 bg-slate-900/80 p-6">
        <h3 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">{{ newsletter_heading }}</h3>
        <p class="mt-4 text-sm leading-7 text-slate-300">Use this space for newsletter capture, channel updates, or launch-readiness messaging once lifecycle tooling is connected.</p>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="container-shell flex flex-col gap-3 py-5 text-sm text-slate-500 lg:flex-row lg:items-center lg:justify-between">
      <div>{{ section.settings.bottom_text }}</div>
      <div class="text-slate-600">Built for product discovery, support continuity, and cleaner electronics merchandising.</div>
    </div>
  </div>
</footer>
