{%- liquid
  assign row_classes = 'grid grid-cols-1 gap-3 py-5 md:grid-cols-spec-row md:items-start'
  unless first
    assign row_classes = row_classes | append: ' border-t border-slate-200/80'
  endunless
-%}
<div class="{{ row_classes }}">
  <div class="spec-label">{{ label }}</div>
  <div class="spec-value">{{ value }}</div>
</div>
