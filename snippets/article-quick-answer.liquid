{% comment %} snippets/article-quick-answer.liquid {% endcomment %}
{% assign resolved_answer = answer.value | default: answer %}
{% if resolved_answer != blank %}
  <div class="article-quick-answer" role="note" aria-label="Quick answer">
    <div class="article-quick-answer__icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M8 1.5v9M5 7.5l3 3 3-3M2.5 13.5h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="article-quick-answer__body">
      <p class="article-quick-answer__label">Quick answer</p>
      <p class="article-quick-answer__text">{{ resolved_answer }}</p>
    </div>
  </div>
{% endif %}
