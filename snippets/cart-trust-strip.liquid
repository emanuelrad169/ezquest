{% comment %} snippets/cart-trust-strip.liquid {% endcomment %}
<div class="cart-trust-strip" aria-label="Trust badges">
  <div class="cart-trust-strip__item">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
      <rect x="1" y="5" width="12" height="8" rx="2" stroke="currentColor" stroke-width="1.25"/>
      <path d="M4 5V4a3 3 0 016 0v1" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
    </svg>
    <span>SSL secured</span>
  </div>
  <div class="cart-trust-strip__item">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
      <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Free returns</span>
  </div>
  <div class="cart-trust-strip__item">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="shrink-0">
      <path d="M7 1l1.5 4H13l-3.5 2.5 1.5 4L7 9l-4 2.5 1.5-4L1 5h4.5L7 1z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
    </svg>
    <span>2-year warranty</span>
  </div>
</div>
