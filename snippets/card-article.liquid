<article class="card-shell">
  <h3 class="text-lg font-semibold text-slate-900">
    {% if article != blank %}
      <a href="{{ article.url }}">{{ article.title }}</a>
    {% else %}
      Article title
    {% endif %}
  </h3>
  <p class="mt-3 text-sm text-slate-600">{{ excerpt | default: 'Reserved for article summary structure.' }}</p>
</article>
