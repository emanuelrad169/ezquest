<article class="feature-card h-full bg-gradient-to-br from-white to-slate-50">
  <div class="flex items-center justify-between gap-4">
    <p class="section-kicker">
      {% if article != blank and article.blog != blank %}
        {{ article.blog.title }}
      {% else %}
        Resource article
      {% endif %}
    </p>
    {% if article != blank %}
      <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{{ article.published_at | date: '%b %d, %Y' }}</span>
    {% endif %}
  </div>
  <h3 class="mt-4 text-xl font-semibold tracking-[-0.03em] text-slate-950">
    {% if article != blank %}
      <a href="{{ article.url }}">{{ article.title }}</a>
    {% else %}
      Article title
    {% endif %}
  </h3>
  <p class="mt-4 text-sm leading-7 text-slate-600">{{ excerpt | default: 'Reserved for article summary structure.' }}</p>
</article>
