{%- liquid
  assign compare_product = block.settings.product
  assign compare_title = block.settings.title
  assign compare_copy = block.settings.copy
  assign compare_vendor = blank
  assign compare_type = blank
  assign compare_handoff_label = 'See product'
  assign compare_support_label = 'Confirm fit'

  if compare_product != blank
    assign compare_title = compare_product.title
    assign compare_vendor = compare_product.vendor
    assign compare_type = compare_product.type
  endif
-%}

<article class="compare-card" {{ block.shopify_attributes }}>
  <div class="compare-card-label-row">
    {% if block.settings.eyebrow != blank %}
      <p class="section-kicker">{{ block.settings.eyebrow }}</p>
    {% elsif compare_vendor != blank %}
      <p class="section-kicker">{{ compare_vendor }}</p>
    {% endif %}

    {% if compare_type != blank %}
      <span class="compare-card-type">{{ compare_type }}</span>
    {% endif %}
  </div>

  {% if compare_product != blank %}
    {% render 'card-product', product: compare_product, card_style: 'featured-strip', image_variant: 'compare' %}
  {% else %}
    <article class="product-card-tile product-card-tile--featured-strip">
      <div class="product-card-featured-media">
        {% render 'placeholder-visual', kind: 'compare', text: compare_title, width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
      </div>
      <div class="product-card-featured-body">
        <h3 class="card-title product-card-featured-title">{{ compare_title }}</h3>
        {% if compare_copy != blank %}
          <p class="product-card-featured-value">{{ compare_copy | truncatewords: 12 }}</p>
        {% endif %}
      </div>
    </article>
  {% endif %}

  <p class="compare-context-note">
    {% if compare_product != blank and compare_product.metafields.ezquest.support_summary != blank %}
      {{ compare_product.metafields.ezquest.support_summary | metafield_tag | strip_html | truncatewords: 14 }}
    {% elsif compare_product != blank and compare_product.metafields.ezquest.compatibility_summary != blank %}
      {{ compare_product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | truncatewords: 14 }}
    {% elsif compare_copy != blank %}
      {{ compare_copy | truncatewords: 14 }}
    {% else %}
      See how this option differs by fit, support, and everyday use.
    {% endif %}
  </p>
  {% if compare_product != blank %}
    <div class="compare-card-links">
      <a href="{{ compare_product.url }}" class="site-meta-link">{{ compare_handoff_label }}</a>
      <a href="/pages/compatibility" class="site-meta-link">{{ compare_support_label }}</a>
    </div>
  {% endif %}
</article>
