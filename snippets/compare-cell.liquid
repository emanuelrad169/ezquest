{%- liquid
  assign compare_product = product | default: compare_product | default: block.settings.product
  assign compare_title = compare_product.title | default: title | default: block.settings.title | default: 'EZQuest product'
  assign compare_group_handle = group_handle | default: ''
  assign compare_source = source_context | default: 'compare'
  assign compare_role = ''
  assign compare_best_for = ''
  assign compare_reason = ''
  assign compare_price = ''
  assign compare_compare_at_price = ''
  assign compare_manual_count = 0
  assign compare_download_count = 0
  assign is_recommended = false

  if compare_product != blank
    assign compare_role = compare_product.metafields.ezquest.compare_role.value | default: compare_product.metafields.ezquest.compare_role
    assign compare_best_for = compare_product.metafields.ezquest.best_for.value | default: compare_product.metafields.ezquest.best_for
    assign compare_reason = compare_product.metafields.ezquest.compare_short_reason.value | default: compare_product.metafields.ezquest.compare_short_reason
    assign compare_price = compare_product.price | money
    assign compare_compare_at_price = compare_product.compare_at_price_max
    assign compare_manual_count = compare_product.metafields.ezquest.manuals.value.count | default: 0
    assign compare_download_count = compare_product.metafields.ezquest.downloads.value.count | default: 0

    if recommended_handle != blank and compare_product.handle == recommended_handle
      assign is_recommended = true
    endif
  endif

  if compare_reason == blank and compare_product != blank and compare_product.metafields.ezquest.compatibility_summary != blank
    assign compare_reason = compare_product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html
  endif

  if compare_reason == blank and compare_product != blank and compare_product.metafields.ezquest.support_summary != blank
    assign compare_reason = compare_product.metafields.ezquest.support_summary | metafield_tag | strip_html
  endif

  assign compare_role_label = compare_role | replace: '-', ' ' | strip
  if compare_role_label != blank
    assign compare_role_label = compare_role_label | capitalize
  endif

  capture compare_query
    echo '?source='
    echo compare_source
    if compare_group_handle != blank
      echo '&group='
      echo compare_group_handle
    endif
    if compare_product != blank
      echo '&product='
      echo compare_product.handle
    endif
  endcapture

  assign compare_pdp_url = '#'
  assign compare_compatibility_url = '/pages/compatibility'
  assign compare_support_url = '/pages/support'

  if compare_product != blank
    assign compare_pdp_url = compare_product.url | append: compare_query
  endif

  assign compare_compatibility_url = compare_compatibility_url | append: compare_query
  assign compare_support_url = compare_support_url | append: compare_query
-%}

<article class="compare-choice-card card-base card-interactive flex min-h-full flex-col p-6{% if is_recommended %} is-recommended{% endif %}">
  <div class="compare-choice-card-top grid gap-2.5">
    <div class="compare-choice-card-flags flex flex-wrap gap-2">
      {% if is_recommended %}
        <span class="compare-choice-badge compare-choice-badge--recommended">Recommended</span>
      {% endif %}
      {% if compare_role_label != blank %}
        <span class="compare-choice-badge">{{ compare_role_label }}</span>
      {% endif %}
    </div>
    {% if compare_best_for != blank %}
      <p class="compare-choice-best-for">{{ compare_best_for }}</p>
    {% endif %}
  </div>

  <div class="compare-choice-media-wrap mt-4 flex min-h-52 items-center justify-center rounded-2xl border border-slate-100 bg-gradient-to-b from-white to-slate-50 p-4">
    {% if compare_product != blank %}
      {% render 'product-browse-media',
        product: compare_product,
        context: 'compare',
        variant: 'compare',
        width: 560,
        height: 560,
        class: 'compare-choice-media'
      %}
    {% endif %}
  </div>

  <div class="compare-choice-body mt-4 grid gap-3">
    <h2 class="card-title compare-choice-title">{{ compare_title }}</h2>

    {% if compare_price != blank %}
      <div class="compare-choice-price-row flex items-baseline gap-2">
        <span class="compare-choice-price">{{ compare_price }}</span>
        {% if compare_compare_at_price > compare_product.price %}
          <span class="compare-choice-compare-price">{{ compare_compare_at_price | money }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if compare_reason != blank %}
      <p class="type-body compare-choice-reason">{{ compare_reason | truncatewords: 20 }}</p>
    {% endif %}

    <p class="type-body compare-choice-resource-note">
      {% if compare_manual_count > 0 or compare_download_count > 0 %}
        {% if compare_manual_count > 0 %}{{ compare_manual_count }} manual{% if compare_manual_count != 1 %}s{% endif %}{% endif %}
        {% if compare_manual_count > 0 and compare_download_count > 0 %} and {% endif %}
        {% if compare_download_count > 0 %}{{ compare_download_count }} download{% if compare_download_count != 1 %}s{% endif %}{% endif %}
        stay linked after purchase.
      {% else %}
        Compatibility and support stay linked to this product.
      {% endif %}
    </p>
  </div>

  <div class="compare-choice-actions mt-auto grid gap-3 pt-4">
    {% if compare_product != blank %}
      {% if is_recommended %}
        {% render 'button', label: 'Choose this setup', url: compare_pdp_url, style: 'primary' %}
      {% else %}
        {% render 'button', label: 'View details', url: compare_pdp_url, style: 'secondary' %}
      {% endif %}
      <div class="compare-choice-links flex flex-wrap gap-x-4 gap-y-3">
        <a href="{{ compare_compatibility_url }}" class="compare-choice-link">Compatibility</a>
        <a href="{{ compare_support_url }}" class="compare-choice-link">Support</a>
      </div>
    {% endif %}
  </div>
</article>
