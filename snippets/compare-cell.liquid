{%- liquid
  assign compare_product = block.settings.product
  assign compare_title = block.settings.title
  assign compare_copy = block.settings.copy
  assign compare_vendor = blank
  assign compare_type = blank
  assign compare_handoff_label = 'See product details'
  assign compare_visual_handle = blank

  if compare_product != blank
    assign compare_title = compare_product.title
    assign compare_vendor = compare_product.vendor
    assign compare_type = compare_product.type
    assign compare_visual_handle = compare_product.handle
  elsif compare_title != blank
    assign normalized_compare_title = compare_title | downcase
    if normalized_compare_title contains 'travel'
      assign compare_visual_handle = 'usb-c-travel-hub'
    elsif normalized_compare_title contains 'dock'
      assign compare_visual_handle = 'usb-c-pro-dock'
    elsif normalized_compare_title contains 'multimedia' or normalized_compare_title contains 'everyday'
      assign compare_visual_handle = 'usb-c-multimedia-hub'
    endif
  endif
-%}

<article class="compare-card card-soft flex h-full flex-col p-4 lg:p-5" {{ block.shopify_attributes }}>
  <div class="compare-card-label-row mb-2 flex items-center justify-between gap-3">
    {% if block.settings.eyebrow != blank %}
      <p class="section-kicker">{{ block.settings.eyebrow }}</p>
    {% elsif compare_vendor != blank %}
      <p class="section-kicker">{{ compare_vendor }}</p>
    {% endif %}

    {% if compare_type != blank %}
      <span class="compare-card-type">{{ compare_type }}</span>
    {% endif %}
  </div>

  {% if compare_product != blank %}
    {% render 'card-product', product: compare_product, card_style: 'featured-strip', card_context: 'compare', image_variant: 'compare' %}
  {% else %}
    <article class="product-card-tile product-card-tile--featured-strip product-card-tile--compare card-elevated flex h-full flex-col">
      <div class="product-card-featured-media-shell relative px-3 pt-3">
        <div class="product-card-featured-media">
          {% if compare_visual_handle != blank %}
            {% render 'owned-product-visual',
              product_handle: compare_visual_handle,
              product_title: compare_title,
              variant: 'compare',
              kind: 'compare',
              width: 1200,
              height: 900,
              class: 'hero-media-frame aspect-card w-full object-cover'
            %}
          {% else %}
            {% render 'placeholder-visual', kind: 'compare', text: compare_title, width: 1200, height: 900, class: 'hero-media-frame aspect-card w-full object-cover' %}
          {% endif %}
        </div>
      </div>
      <div class="product-card-featured-body flex flex-1 flex-col gap-3 px-4 pb-5 pt-4">
        <div class="product-card-featured-copy product-card-featured-copy--compare-fallback grid gap-2">
          <h3 class="card-title product-card-featured-title">{{ compare_title }}</h3>
          {% if compare_copy != blank %}
            <p class="product-card-featured-value">{{ compare_copy | truncatewords: 12 }}</p>
          {% endif %}
        </div>
      </div>
    </article>
  {% endif %}

  <p class="compare-context-note">
    {% if compare_product != blank and compare_product.metafields.ezquest.support_summary != blank %}
      {{ compare_product.metafields.ezquest.support_summary | metafield_tag | strip_html | truncatewords: 14 }}
    {% elsif compare_product != blank and compare_product.metafields.ezquest.compatibility_summary != blank %}
      {{ compare_product.metafields.ezquest.compatibility_summary | metafield_tag | strip_html | truncatewords: 14 }}
    {% elsif compare_copy != blank %}
      {{ compare_copy | truncatewords: 14 }}
    {% else %}
      See how this option differs by role, compatibility, and everyday use.
    {% endif %}
  </p>
  {% if compare_product != blank %}
    <div class="compare-card-links mt-3.5 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-slate-200/75 pt-3.5">
      {% render 'button', label: compare_handoff_label, url: compare_product.url, style: 'tertiary' %}
      {% render 'button', label: compare_support_label, url: '/pages/compatibility?product=' | append: compare_product.handle, style: 'tertiary' %}
    </div>
  {% endif %}
</article>
