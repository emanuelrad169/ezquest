{%- liquid
  assign compare_product = block.settings.product
  assign compare_title = block.settings.title
  assign compare_copy = block.settings.copy
  assign compare_link = block.settings.link
  assign compare_vendor = blank
  if compare_product != blank
    assign compare_title = compare_product.title
    assign compare_link = compare_product.url
    assign compare_vendor = compare_product.vendor
  endif
-%}
<article class="feature-card text-sm text-slate-600" {{ block.shopify_attributes }}>
  {% if compare_product.featured_image != blank %}
    {{ compare_product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'aspect-[4/3] w-full rounded-2xl object-cover' }}
  {% else %}
    <div class="aspect-[4/3] w-full rounded-2xl bg-slate-100"></div>
  {% endif %}
  <div class="mt-5 flex items-center justify-between gap-4">
    {% if block.settings.eyebrow != blank %}
      <p class="section-kicker">{{ block.settings.eyebrow }}</p>
    {% endif %}
    {% if compare_vendor != blank %}
      <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{{ compare_vendor }}</span>
    {% endif %}
  </div>
  <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900">{{ compare_title }}</h3>
  {% if compare_copy != blank %}
    <p class="mt-3 leading-6">{{ compare_copy }}</p>
  {% endif %}
  {% if compare_product != blank %}
    <div class="mt-4">
      {% render 'price', product: compare_product %}
    </div>
  {% endif %}
  {% if compare_link != blank %}
    <div class="mt-6">
      {% render 'button', label: block.settings.link_label, url: compare_link, style: 'secondary' %}
    </div>
  {% endif %}
</article>
