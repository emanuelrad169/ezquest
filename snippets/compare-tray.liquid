{%- comment -%} Floating compare tray — shown by compare.js when products are selected. {%- endcomment -%}
<div class="cmp-tray" data-compare-tray hidden role="region" aria-label="Product comparison">
  <span class="cmp-tray__note" data-compare-tray-note aria-live="polite"></span>
  <div class="cmp-tray__inner">
    <span class="cmp-tray__label">
      <span class="cmp-tray__badge" data-compare-tray-count>0</span>
      to compare
    </span>
    <button type="button" class="cmp-tray__clear" data-compare-tray-clear>Clear</button>
    <a href="/pages/compare" class="cmp-tray__cta">Compare now</a>
  </div>
</div>
