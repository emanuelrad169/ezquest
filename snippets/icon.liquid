{%- liquid
  assign icon_name  = name | default: 'chevron-right'
  assign icon_size  = size | default: 18
  assign icon_class = class | default: ''
  if icon_class != ''
    assign icon_class_attr = ' class="' | append: icon_class | append: '"'
  else
    assign icon_class_attr = ''
  endif
-%}
